{
  "name": "opl-framework-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./automation-companions": "./dist/modules/console/automation-companions.js",
    "./advisory-knowledge-boundary": "./dist/modules/charter/advisory-knowledge-boundary.js",
    "./agent-lab": "./dist/modules/foundry-lab/agent-lab.js",
    "./agent-lab-complete": "./dist/modules/foundry-lab/agent-lab-complete.js",
    "./family-action-catalog": "./dist/modules/console/family-action-catalog.js",
    "./family-domain-agent-descriptor": "./dist/modules/atlas/family-domain-agent-descriptor.js",
    "./domain-pack-compiler": "./dist/modules/pack/domain-pack-compiler.js",
    "./functional-agent-runtime-harness": "./dist/modules/runway/functional-agent-runtime-harness.js",
    "./family-runtime-lifecycle-index": "./dist/modules/runway/family-runtime-lifecycle-index.js",
    "./generic-substrate-projection": "./dist/modules/runway/generic-substrate-projection.js",
    "./family-transition-runner": "./dist/modules/stagecraft/family-transition-runner.js",
    "./stage-transition-authority": "./dist/modules/stagecraft/stage-transition-authority.js",
    "./family-shared-release": "./dist/modules/atlas/family-shared-release.js",
    "./family-domain-catalog": "./dist/modules/atlas/family-domain-catalog.js",
    "./family-entry-contracts": "./dist/modules/atlas/family-entry-contracts.js",
    "./family-orchestration": "./dist/modules/runway/family-orchestration.js",
    "./managed-runtime-contract": "./dist/modules/runway/managed-runtime-contract.js",
    "./product-entry-companions": "./dist/modules/console/product-entry-companions.js",
    "./product-entry-program-companions": "./dist/modules/console/product-entry-program-companions.js",
    "./runtime-task-companions": "./dist/modules/runway/runtime-task-companions.js",
    "./skill-catalog": "./dist/modules/pack/skill-catalog.js"
  },
  "bin": {
    "opl": "./bin/opl"
  },
  "files": [
    "bin/opl",
    "dist",
    "contracts/opl-framework",
    "Cargo.toml",
    "Cargo.lock",
    "native/opl-native-helper/Cargo.toml",
    "native/opl-native-helper/src",
    "native-helper-prebuilds",
    "scripts/native-helper-cache.mjs",
    "scripts/native-helper-doctor.mjs",
    "scripts/native-helper-family-smoke.mjs",
    "scripts/native-helper-pack-check.mjs",
    "scripts/native-helper-prebuild.mjs",
    "scripts/native-helper-repair.mjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "native:build": "cargo build --workspace",
    "native:cache": "node ./scripts/native-helper-cache.mjs",
    "native:doctor": "node ./scripts/native-helper-doctor.mjs",
    "native:prebuild": "node ./scripts/native-helper-prebuild.mjs install",
    "native:prebuild-pack": "node ./scripts/native-helper-prebuild.mjs pack",
    "native:prebuild-archive": "node ./scripts/native-helper-prebuild.mjs archive",
    "native:prebuild-check": "node ./scripts/native-helper-prebuild.mjs check",
    "native:pack-check": "node ./scripts/native-helper-pack-check.mjs",
    "native:repair": "node ./scripts/native-helper-repair.mjs",
    "native:test": "RUSTC=\"$(rustup which --toolchain stable rustc)\" RUSTDOC=\"$(rustup which --toolchain stable rustdoc)\" \"$(rustup which --toolchain stable cargo)\" test --workspace",
    "native:family-smoke": "node ./scripts/native-helper-family-smoke.mjs",
    "family:structure-advisory": "node ./scripts/family-structure-advisory.mjs",
    "family:shared-release": "node ./scripts/family-shared-release.mjs",
    "packages:manifest": "node --experimental-strip-types ./scripts/package-module-archives.mjs",
    "packages:release-discipline": "node ./scripts/package-release-discipline.mjs",
    "packages:daily-check": "node ./scripts/package-channel-daily-check.mjs",
    "packages:cleanup-ghcr": "node --experimental-strip-types ./scripts/cleanup-ghcr-package-versions.mjs",
    "codex:export-default-profile": "node --experimental-strip-types ./scripts/export-codex-default-profile.mjs",
    "capability-map:audit": "node ./scripts/capability-map-audit.mjs",
    "docs:whitepaper": "node --experimental-strip-types ./scripts/build-opl-whitepaper.ts",
    "docs:whitepapers:family": "bash ./scripts/build-opl-family-whitepapers.sh",
    "docs:latest": "npm run docs:whitepaper",
    "docs:publish": "bash scripts/publish-docs-latest.sh",
    "repo:hygiene": "scripts/repo-hygiene.sh",
    "repo:hygiene:fix": "scripts/repo-hygiene.sh --fix",
    "lint": "node ./scripts/lint.mjs",
    "hygiene:fallow": "npx --yes fallow@latest --root . --no-cache --production",
    "test:smoke": "node ./scripts/test-lanes.mjs run smoke",
    "test:fast": "node ./scripts/test-lanes.mjs run fast",
    "test:meta": "node ./scripts/test-lanes.mjs run meta",
    "test:read-model-gates": "node ./scripts/test-lanes.mjs run read-model-gates",
    "test:regression": "node ./scripts/test-lanes.mjs run regression",
    "test:integration": "node ./scripts/test-lanes.mjs run integration",
    "test:artifact": "node ./scripts/test-lanes.mjs run artifact",
    "test:fresh-install": "node ./scripts/test-lanes.mjs run fresh-install",
    "test:native": "./scripts/verify.sh native",
    "test:structure": "./scripts/verify.sh structure",
    "test:full": "node ./scripts/test-lanes.mjs run full",
    "test": "npm run test:smoke",
    "line-budget": "node ./scripts/line-budget.mjs",
    "line-budget:strict": "node ./scripts/line-budget.mjs --strict",
    "reuse-first:scan:diff": "node ./scripts/reuse-first-scan.mjs --diff-ref origin/main",
    "fresh-install:smoke": "node ./scripts/fresh-install-smoke.mjs",
    "new-machine:codex-bootstrap:docker-smoke": "node ./scripts/new-machine-codex-bootstrap-docker-smoke.mjs",
    "source:modules": "node ./scripts/source-module-boundary.mjs",
    "source:modules:public-imports": "node ./scripts/source-module-public-imports.mjs"
  },
  "dependencies": {
    "@temporalio/activity": "^1.18.1",
    "@temporalio/client": "^1.18.1",
    "@temporalio/common": "^1.18.1",
    "@temporalio/worker": "^1.18.1",
    "@temporalio/workflow": "^1.18.1",
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@temporalio/testing": "^1.18.1",
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "protobufjs": "7.6.4"
  },
  "license": "Apache-2.0",
  "optionalDependencies": {
    "e2b": "^2.31.0"
  }
}
