{
  "name": "opl-readonly-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "opl": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "node ./scripts/lint.mjs",
    "test:src": "NODE_NO_WARNINGS=1 node --experimental-strip-types --test tests/src/**/*.test.ts",
    "test:dist": "NODE_NO_WARNINGS=1 node --test tests/built/**/*.test.mjs",
    "test": "npm run test:src && npm run build && npm run test:dist"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3"
  }
}
