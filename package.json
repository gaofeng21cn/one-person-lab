{
  "name": "opl-gateway-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./automation-companions": "./dist/automation-companions.js",
    "./family-shared-release": "./dist/family-shared-release.js",
    "./family-domain-catalog": "./dist/family-domain-catalog.js",
    "./family-entry-contracts": "./dist/family-entry-contracts.js",
    "./family-orchestration": "./dist/family-orchestration.js",
    "./managed-runtime-contract": "./dist/managed-runtime-contract.js",
    "./product-entry-companions": "./dist/product-entry-companions.js",
    "./product-entry-program-companions": "./dist/product-entry-program-companions.js",
    "./runtime-task-companions": "./dist/runtime-task-companions.js",
    "./skill-catalog": "./dist/skill-catalog.js"
  },
  "bin": {
    "opl": "./bin/opl"
  },
  "files": [
    "bin/opl",
    "dist",
    "contracts/opl-gateway",
    "Cargo.toml",
    "Cargo.lock",
    "native/opl-native-helper/Cargo.toml",
    "native/opl-native-helper/src",
    "native-helper-prebuilds",
    "scripts/native-helper-cache.mjs",
    "scripts/native-helper-doctor.mjs",
    "scripts/native-helper-family-smoke.mjs",
    "scripts/native-helper-pack-check.mjs",
    "scripts/native-helper-prebuild.mjs",
    "scripts/native-helper-repair.mjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "native:build": "cargo build --workspace",
    "native:cache": "node ./scripts/native-helper-cache.mjs",
    "native:doctor": "node ./scripts/native-helper-doctor.mjs",
    "native:prebuild": "node ./scripts/native-helper-prebuild.mjs install",
    "native:prebuild-pack": "node ./scripts/native-helper-prebuild.mjs pack",
    "native:prebuild-archive": "node ./scripts/native-helper-prebuild.mjs archive",
    "native:prebuild-check": "node ./scripts/native-helper-prebuild.mjs check",
    "native:pack-check": "node ./scripts/native-helper-pack-check.mjs",
    "native:repair": "node ./scripts/native-helper-repair.mjs",
    "native:test": "cargo test --workspace",
    "native:family-smoke": "node ./scripts/native-helper-family-smoke.mjs",
    "family:shared-release": "node ./scripts/family-shared-release.mjs",
    "packages:manifest": "node --experimental-strip-types ./scripts/package-module-archives.mjs",
    "packages:full-internal": "node --experimental-strip-types ./scripts/build-full-internal-package.mjs",
    "packages:release-discipline": "node ./scripts/package-release-discipline.mjs",
    "codex:export-default-profile": "node --experimental-strip-types ./scripts/export-codex-default-profile.mjs",
    "lint": "node ./scripts/lint.mjs && node ./scripts/line-budget.mjs",
    "test:fast": "NODE_NO_WARNINGS=1 node --experimental-strip-types --test tests/src/cli.test.ts tests/src/cli-codex-default-shell.test.ts tests/src/runtime-state-paths.test.ts tests/src/family-domain-catalog.test.ts tests/src/family-entry-contracts.test.ts tests/src/family-executor-adapter-contract.test.ts tests/src/product-entry-companions.test.ts tests/src/product-entry-runtime.test.ts tests/src/product-entry-program-companions.test.ts tests/src/family-orchestration.test.ts tests/src/runtime-task-companions.test.ts tests/src/skill-catalog.test.ts tests/src/automation-companions.test.ts tests/src/full-internal-package.test.ts",
    "test:meta": "NODE_NO_WARNINGS=1 node --experimental-strip-types --test tests/src/verification-command-surfaces.test.ts tests/src/family-shared-release-discipline.test.ts tests/src/family-shared-release.test.ts tests/src/native-helper-family-smoke.test.ts tests/src/native-helper-prebuild.test.ts tests/src/family-external-orchestration-learning-board.test.ts tests/src/family-runtime-attempt-contract.test.ts tests/src/family-domain-quality-projection-contract.test.ts tests/src/family-incident-learning-loop.test.ts tests/src/family-product-operator-projection.test.ts",
    "test:artifact": "npm run build && NODE_NO_WARNINGS=1 node --test tests/built/**/*.test.mjs",
    "test:fresh-install": "NODE_NO_WARNINGS=1 node --experimental-strip-types --test tests/src/fresh-install-smoke.test.ts",
    "test:full": "./scripts/run-parallel-test-lanes.sh full",
    "test": "npm run test:fast",
    "line-budget": "node ./scripts/line-budget.mjs",
    "fresh-install:smoke": "node ./scripts/fresh-install-smoke.mjs",
    "gui:release": "node ./scripts/publish-gui-release.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3"
  }
}
