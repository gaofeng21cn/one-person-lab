{
  "name": "opl-framework-static-contracts",
  "version": "0.1.0",
  "description": "Lightweight OPL contract and build primitives for Foundry Agent consumers.",
  "type": "module",
  "exports": {
    "./foundry-agent-series-policy": "./build/dist/modules/foundry-lab/public/foundry-agent-series-policy.js",
    "./json-schema-registry": "./build/dist/kernel/schema-registry.js",
    "./reference-build-proof": "./build/dist/modules/foundry-lab/reference-build-proof.js",
    "./reference-design-pattern-packet": "./build/dist/modules/workspace/reference-design-pattern-packet.js",
    "./standard-agent-action-stage-run": "./build/dist/modules/stagecraft/standard-agent-action-stage-run.js",
