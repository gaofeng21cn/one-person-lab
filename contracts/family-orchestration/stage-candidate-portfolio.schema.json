{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/stage-candidate-portfolio.schema.json",
  "title": "OPL Stage Candidate Portfolio",
  "description": "Refs-only stage candidate portfolio companion for OPL indexing, projection, review routing, and stage readiness drilldown. It carries candidate, assumption, provenance, negative-path, ranking/proximity/advisory metric, and human-review refs/status only. Domain agents retain candidate body, domain truth, quality verdict, artifact authority, and owner receipt authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "portfolio_id",
    "target_domain_id",
    "portfolio_status",
    "stage_context_refs",
    "related_evidence_pack_refs",
    "stage_candidates",
    "assumption_decomposition",
    "provenance_checks",
    "negative_path_ledger",
    "advisory_metrics",
    "human_review_refs",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "stage_candidate_portfolio" },
    "version": { "const": "stage_candidate_portfolio.v1" },
    "portfolio_id": { "type": "string", "minLength": 1 },
    "target_domain_id": { "type": "string", "minLength": 1 },
    "portfolio_status": {
      "type": "string",
      "enum": ["draft", "active", "under_domain_review", "blocked", "closed", "superseded"]
    },
    "stage_context_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_ref" }
    },
    "related_evidence_pack_refs": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface_ref" }
    },
    "stage_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage_candidate" }
    },
    "assumption_decomposition": { "$ref": "#/$defs/assumption_decomposition" },
    "provenance_checks": { "$ref": "#/$defs/provenance_checks" },
    "negative_path_ledger": { "$ref": "#/$defs/stage_candidate_negative_path_ledger" },
    "advisory_metrics": { "$ref": "#/$defs/advisory_metrics" },
    "human_review_refs": { "$ref": "#/$defs/human_review_refs" },
    "authority_boundary": { "$ref": "#/$defs/authority_boundary" }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "role",
        "ref_kind",
        "ref",
        "status",
        "required",
        "body_included"
      ],
      "properties": {
        "ref_id": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "ref_kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/ref_status" },
        "required": { "type": "boolean" },
        "body_included": { "const": false }
      }
    },
    "ref_status": {
      "type": "string",
      "enum": ["present", "missing", "blocked", "stale", "superseded", "not_required"]
    },
    "candidate_status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "selected_for_domain_review",
        "deferred",
        "blocked",
        "superseded",
        "rejected_by_domain_owner",
        "accepted_by_domain_owner"
      ]
    },
    "stage_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "status",
        "candidate_ref",
        "rationale_ref",
        "origin_ref",
        "owner_ref",
        "assumption_ref_ids",
        "provenance_check_ref_ids",
        "negative_path_ref_ids",
        "advisory_metric_ref_ids",
        "human_review_ref_ids",
        "evidence_refs",
        "body_included"
      ],
      "properties": {
        "candidate_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/candidate_status" },
        "candidate_ref": { "type": "string", "minLength": 1 },
        "rationale_ref": { "type": ["string", "null"], "minLength": 1 },
        "origin_ref": { "type": "string", "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "assumption_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "provenance_check_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "negative_path_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "advisory_metric_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "human_review_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/surface_ref" }
        },
        "body_included": { "const": false }
      }
    },
    "assumption_decomposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "assumptions"
      ],
      "properties": {
        "surface_kind": { "const": "stage_candidate_assumption_refs" },
        "version": { "const": "stage_candidate_assumption_refs.v1" },
        "assumptions": {
          "type": "array",
          "items": { "$ref": "#/$defs/assumption_ref" }
        }
      }
    },
    "assumption_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "candidate_id",
        "role",
        "status",
        "assumption_ref",
        "support_ref_ids",
        "contradiction_ref_ids",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "assumption_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "role": {
          "type": "string",
          "enum": [
            "goal",
            "input",
            "output",
            "constraint",
            "feasibility",
            "dependency",
            "risk",
            "ownership",
            "timing",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["unreviewed", "supported_by_ref", "contested_by_ref", "blocked", "superseded"]
        },
        "assumption_ref": { "type": "string", "minLength": 1 },
        "support_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "contradiction_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "provenance_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "checks"
      ],
      "properties": {
        "surface_kind": { "const": "stage_candidate_provenance_checks" },
        "version": { "const": "stage_candidate_provenance_checks.v1" },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/provenance_check" }
        }
      }
    },
    "provenance_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "candidate_id",
        "check_type",
        "status",
        "check_ref",
        "source_ref_ids",
        "result_ref",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "check_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "check_type": {
          "type": "string",
          "enum": [
            "provenance_search",
            "prior_art",
            "citation_provenance",
            "source_lineage",
            "contamination",
            "duplicate_detection",
            "domain_owner_prior"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["unchecked", "passed_by_ref", "concern_by_ref", "inconclusive", "blocked", "superseded"]
        },
        "check_ref": { "type": "string", "minLength": 1 },
        "source_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "result_ref": { "type": ["string", "null"], "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "stage_candidate_negative_path_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "failed_paths",
        "negative_results"
      ],
      "properties": {
        "surface_kind": { "const": "stage_candidate_negative_path_ledger" },
        "version": { "const": "stage_candidate_negative_path_ledger.v1" },
        "failed_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/failed_path_ref" }
        },
        "negative_results": {
          "type": "array",
          "items": { "$ref": "#/$defs/negative_result_ref" }
        }
      }
    },
    "failed_path_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "candidate_id",
        "stage_id",
        "status",
        "failed_path_ref",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "path_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "stage_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["failed", "blocked", "retested", "superseded", "accepted_as_negative"]
        },
        "failed_path_ref": { "type": "string", "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "negative_result_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id",
        "candidate_id",
        "stage_id",
        "status",
        "result_ref",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "result_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "stage_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["negative_result", "accepted_as_negative", "blocked", "superseded"]
        },
        "result_ref": { "type": "string", "minLength": 1 },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "advisory_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "metrics",
        "rankings",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "stage_candidate_advisory_metrics" },
        "version": { "const": "stage_candidate_advisory_metrics.v1" },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/advisory_metric_ref" }
        },
        "rankings": {
          "type": "array",
          "items": { "$ref": "#/$defs/advisory_ranking_ref" }
        },
        "authority_boundary": { "$ref": "#/$defs/advisory_metrics_authority_boundary" }
      }
    },
    "advisory_metric_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "candidate_id",
        "metric_kind",
        "status",
        "metric_ref",
        "source_ref_ids",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "metric_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "metric_kind": {
          "type": "string",
          "enum": [
            "advisory_rank",
            "proximity_to_goal",
            "provenance_signal",
            "evidence_support_signal",
            "feasibility_signal",
            "risk_signal",
            "review_priority",
            "uncertainty_signal"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["available_by_ref", "missing", "blocked", "stale", "superseded"]
        },
        "metric_ref": { "type": "string", "minLength": 1 },
        "source_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "advisory_ranking_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ranking_id",
        "scope",
        "status",
        "ranking_ref",
        "candidate_ref_ids",
        "owner_ref",
        "body_included"
      ],
      "properties": {
        "ranking_id": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "string",
          "enum": ["portfolio", "stage", "review_queue", "domain_owner_review"]
        },
        "status": {
          "type": "string",
          "enum": ["available_by_ref", "missing", "blocked", "stale", "superseded"]
        },
        "ranking_ref": { "type": "string", "minLength": 1 },
        "candidate_ref_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_ref": { "type": "string", "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "advisory_metrics_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "metrics_scope",
        "metrics_are_domain_verdict",
        "can_authorize_candidate_acceptance",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_rank_as_domain_truth"
      ],
      "properties": {
        "opl_role": { "const": "advisory_metric_ref_projection_only" },
        "metrics_scope": { "const": "refs_status_advisory_only" },
        "metrics_are_domain_verdict": { "const": false },
        "can_authorize_candidate_acceptance": { "const": false },
        "can_authorize_domain_ready": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "can_rank_as_domain_truth": { "const": false }
      }
    },
    "human_review_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "reviews"
      ],
      "properties": {
        "surface_kind": { "const": "stage_candidate_human_review_refs" },
        "version": { "const": "stage_candidate_human_review_refs.v1" },
        "reviews": {
          "type": "array",
          "items": { "$ref": "#/$defs/human_review_ref" }
        }
      }
    },
    "human_review_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "candidate_id",
        "review_type",
        "status",
        "reviewer_owner_ref",
        "request_ref",
        "decision_ref",
        "route_back_ref",
        "body_included"
      ],
      "properties": {
        "review_id": { "type": "string", "minLength": 1 },
        "candidate_id": { "type": "string", "minLength": 1 },
        "review_type": {
          "type": "string",
          "enum": [
            "domain_owner_review",
            "independent_expert_review",
            "human_gate",
            "ethics_or_safety_review",
            "operator_triage"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["requested", "ready", "blocked", "completed", "route_back", "superseded"]
        },
        "reviewer_owner_ref": { "type": "string", "minLength": 1 },
        "request_ref": { "type": "string", "minLength": 1 },
        "decision_ref": { "type": ["string", "null"], "minLength": 1 },
        "route_back_ref": { "type": ["string", "null"], "minLength": 1 },
        "body_included": { "const": false }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "domain_role",
        "portfolio_scope",
        "holds_domain_truth",
        "can_read_domain_body",
        "can_write_domain_truth",
        "can_authorize_candidate_acceptance",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body",
        "can_accept_or_reject_owner_receipt",
        "advisory_metrics_are_domain_verdict"
      ],
      "properties": {
        "opl_role": { "const": "stage_candidate_portfolio_refs_projection_owner" },
        "domain_role": { "const": "domain_truth_quality_receipt_and_artifact_authority" },
        "portfolio_scope": { "const": "refs_status_advisory_projection_only" },
        "holds_domain_truth": { "const": false },
        "can_read_domain_body": { "const": false },
        "can_write_domain_truth": { "const": false },
        "can_authorize_candidate_acceptance": { "const": false },
        "can_authorize_domain_ready": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "can_mutate_artifact_body": { "const": false },
        "can_accept_or_reject_owner_receipt": { "const": false },
        "advisory_metrics_are_domain_verdict": { "const": false }
      }
    }
  },
  "examples": [
    {
      "surface_kind": "stage_candidate_portfolio",
      "version": "stage_candidate_portfolio.v1",
      "portfolio_id": "stage-candidate-portfolio:example-domain",
      "target_domain_id": "example-domain",
      "portfolio_status": "active",
      "stage_context_refs": [
        {
          "ref_id": "context:example-domain",
          "role": "stage_context",
          "ref_kind": "workspace_relative_path",
          "ref": "studies/example/context/index.json",
          "status": "present",
          "required": true,
          "body_included": false
        }
      ],
      "related_evidence_pack_refs": [
        {
          "ref_id": "evidence-pack:example-domain",
          "role": "evidence_pack",
          "ref_kind": "contract_ref",
          "ref": "contracts/family-orchestration/stage-run-evidence-pack.schema.json#examples/0",
          "status": "present",
          "required": false,
          "body_included": false
        }
      ],
      "stage_candidates": [
        {
          "candidate_id": "candidate:c1",
          "status": "selected_for_domain_review",
          "candidate_ref": "domain://example-domain/stage-candidates/c1",
          "rationale_ref": "domain://example-domain/stage-candidates/c1/rationale",
          "origin_ref": "stage-attempt:example-domain/idea/1",
          "owner_ref": "owner:example-domain",
          "assumption_ref_ids": ["assumption:c1:dependency"],
          "provenance_check_ref_ids": ["provenance:c1:prior-art"],
          "negative_path_ref_ids": ["failed-path:c1:model-a"],
          "advisory_metric_ref_ids": ["metric:c1:review-priority"],
          "human_review_ref_ids": ["review:c1:domain-owner"],
          "evidence_refs": [
            {
              "ref_id": "evidence:c1:source-link",
              "role": "supporting_evidence_ref",
              "ref_kind": "domain_owned_ref",
              "ref": "domain://example-domain/evidence/c1/source-link",
              "status": "present",
              "required": true,
              "body_included": false
            }
          ],
          "body_included": false
        }
      ],
      "assumption_decomposition": {
        "surface_kind": "stage_candidate_assumption_refs",
        "version": "stage_candidate_assumption_refs.v1",
        "assumptions": [
          {
            "assumption_id": "assumption:c1:dependency",
            "candidate_id": "candidate:c1",
            "role": "dependency",
            "status": "supported_by_ref",
            "assumption_ref": "domain://example-domain/stage-candidates/c1/assumptions/dependency",
            "support_ref_ids": ["evidence:c1:source-link"],
            "contradiction_ref_ids": [],
            "owner_ref": "owner:example-domain",
            "body_included": false
          }
        ]
      },
      "provenance_checks": {
        "surface_kind": "stage_candidate_provenance_checks",
        "version": "stage_candidate_provenance_checks.v1",
        "checks": [
          {
            "check_id": "provenance:c1:prior-art",
            "candidate_id": "candidate:c1",
            "check_type": "prior_art",
            "status": "concern_by_ref",
            "check_ref": "domain://example-domain/stage-candidates/c1/provenance/source-lineage",
            "source_ref_ids": ["context:example-domain"],
            "result_ref": "domain://example-domain/stage-candidates/c1/provenance/source-lineage/result",
            "owner_ref": "owner:example-domain",
            "body_included": false
          }
        ]
      },
      "negative_path_ledger": {
        "surface_kind": "stage_candidate_negative_path_ledger",
        "version": "stage_candidate_negative_path_ledger.v1",
        "failed_paths": [
          {
            "path_id": "failed-path:c1:model-a",
            "candidate_id": "candidate:c1",
            "stage_id": "idea",
            "status": "accepted_as_negative",
            "failed_path_ref": "domain://example-domain/stage-candidates/c1/negative-paths/model-a",
            "owner_ref": "owner:example-domain",
            "body_included": false
          }
        ],
        "negative_results": []
      },
      "advisory_metrics": {
        "surface_kind": "stage_candidate_advisory_metrics",
        "version": "stage_candidate_advisory_metrics.v1",
        "metrics": [
          {
            "metric_id": "metric:c1:review-priority",
            "candidate_id": "candidate:c1",
            "metric_kind": "review_priority",
            "status": "available_by_ref",
            "metric_ref": "domain://example-domain/stage-candidates/c1/metrics/review-priority",
            "source_ref_ids": ["evidence:c1:source-link", "provenance:c1:prior-art"],
            "owner_ref": "owner:example-domain",
            "body_included": false
          }
        ],
        "rankings": [
          {
            "ranking_id": "ranking:portfolio:review-queue",
            "scope": "review_queue",
            "status": "available_by_ref",
            "ranking_ref": "domain://example-domain/stage-candidates/rankings/review-queue",
            "candidate_ref_ids": ["candidate:c1"],
            "owner_ref": "owner:example-domain",
            "body_included": false
          }
        ],
        "authority_boundary": {
          "opl_role": "advisory_metric_ref_projection_only",
          "metrics_scope": "refs_status_advisory_only",
          "metrics_are_domain_verdict": false,
          "can_authorize_candidate_acceptance": false,
          "can_authorize_domain_ready": false,
          "can_authorize_quality_verdict": false,
          "can_rank_as_domain_truth": false
        }
      },
      "human_review_refs": {
        "surface_kind": "stage_candidate_human_review_refs",
        "version": "stage_candidate_human_review_refs.v1",
        "reviews": [
          {
            "review_id": "review:c1:domain-owner",
            "candidate_id": "candidate:c1",
            "review_type": "domain_owner_review",
