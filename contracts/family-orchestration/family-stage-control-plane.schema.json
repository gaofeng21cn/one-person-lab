{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-control-plane.schema.json",
  "title": "OPL Family Stage Control Plane",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "stages"
  ],
  "properties": {
    "surface_kind": {
      "const": "family_stage_control_plane"
    },
    "version": {
      "const": "family-stage-control-plane.v1"
    },
    "plane_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true
    },
    "replay_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_ref"
      },
      "description": "Refs-only replay evidence declared at plane level for readiness/replay projection. Classification is explicit via each ref role/ref_kind and grants no OPL execution, domain truth, domain-ready, or quality-verdict authority."
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "required": [
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "stage_kind",
        "title",
        "goal",
        "owner",
        "authority_boundary"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_kind": {
          "type": "string",
          "enum": [
            "intake",
            "planning",
            "source_preparation",
            "creation",
            "review",
            "revision",
            "packaging",
            "publish",
            "operator_gate",
            "domain_specific"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "domain_stage_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain-owned memory or knowledge locators that OPL may index and inject as references only; this does not grant OPL memory-store, domain-truth, quality-verdict, or artifact authority."
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "prompt_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "allowed_action_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "evaluation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": true
        },
        "stage_contract": {
          "$ref": "#/$defs/stage_contract"
        },
        "trust_boundary": {
          "$ref": "#/$defs/trust_boundary"
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "stage_contract": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ensures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to runtime boundary events recorded by the domain/runtime owner for effect-boundary or runtime-guarded stages; OPL checks declaration completeness only and does not emit these events."
        },
        "replay_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs-only replay evidence declared for this stage contract. Classification is explicit via each ref role/ref_kind, such as append_only_event_log_ref, attempt_ledger_ref, recorded_runtime_event_ref, or closeout_receipt_ref."
        },
        "runtime_assumptions": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/runtime_assumption"
              }
            ]
          },
          "description": "Operational assumptions that must be monitored at runtime, such as source freshness, provider SLO, boundary failure rate, or artifact locator freshness. String entries keep the legacy lightweight form; object entries can carry owner, monitor, freshness, invalidation, and repair refs. OPL projects and gates these assumptions but does not turn them into domain verdicts."
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to domain-owned or OPL-owned monitor projections that make runtime assumptions visible to App/operator surfaces."
        },
        "source_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the source cohort or source set used by this stage before launch. OPL projects these refs but does not own source truth."
        },
        "cohort_query_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to auditable cohort/source queries that bind stage launch scope to execution and monitoring. OPL projects refs only and does not evaluate source truth."
        },
        "trigger_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to launch, schedule, or queue trigger surfaces that bind the cohort query to a stage attempt."
        },
        "metric_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to metrics computed over the same cohort or source scope after launch."
        },
        "dashboard_metric_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to dashboard/operator metrics for the same cohort or source scope. These are observability refs, not readiness verdicts."
        },
        "artifact_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the artifact set this stage may read, produce, or reconcile. OPL projects these refs but does not own artifact authority."
        },
        "workspace_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the workspace or runtime scope for this stage. OPL projects these refs but does not own workspace truth."
        }
      }
    },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "lane"
      ],
      "properties": {
        "lane": {
          "type": "string",
          "enum": [
            "opl_framework",
            "domain_agent",
            "codex_executor",
            "ai_decision",
            "human_gate",
            "external_system",
            "app_projection"
          ]
        },
        "static_check_eligible": {
          "type": "boolean"
        },
        "effect_boundary": {
          "type": "boolean"
        },
        "records_runtime_events": {
          "type": "boolean"
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to replayable/auditable runtime events for effect-boundary or runtime-guarded stages; this is a declaration surface, not an OPL event emitter."
        },
        "owner_receipt_required": {
          "type": "boolean"
        },
        "human_gate_required": {
          "type": "boolean"
        },
        "runtime_guard_required": {
          "type": "boolean"
        }
      }
    },
    "runtime_assumption": {
      "type": "object",
      "additionalProperties": true,
      "anyOf": [
        {
          "required": [
            "assumption_id"
          ]
        },
        {
          "required": [
            "id"
          ]
        },
        {
          "required": [
            "ref"
          ]
        },
        {
          "required": [
            "name"
          ]
        }
      ],
      "properties": {
        "assumption_id": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "freshness_window_ref": {
          "type": "string",
          "minLength": 1
        },
        "observed_at_ref": {
          "type": "string",
          "minLength": 1
        },
        "invalidated_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repair_action": {
          "type": "string",
          "minLength": 1
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
