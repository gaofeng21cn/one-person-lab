{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-control-plane.schema.json",
  "title": "OPL Family Stage Control Plane",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "stages"
  ],
  "properties": {
    "surface_kind": {
      "const": "family_stage_control_plane"
    },
    "version": {
      "const": "family-stage-control-plane.v1"
    },
    "plane_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true
    },
    "quality_governance_profile_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Optional registry-bound quality governance profile. Its absence is valid for generic OPL Agents."
    },
    "meta_review_policy_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Optional domain-owned cross-stage Meta Review policy ref."
    },
    "replay_evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface_ref"
      },
      "description": "Refs-only replay evidence declared at plane level for readiness/replay projection. Classification is explicit via each ref role/ref_kind and grants no OPL execution, domain truth, domain-ready, or quality-verdict authority."
    },
    "stage_pack_conformance_version": {
      "type": "string",
      "description": "Standard stage pack conformance marker. New OPL-generated domain-agent scaffolds use standard-stage-pack.v2 so selected executor, requires/ensures, expected receipts, and independent gate policy are visible without turning those refs into domain verdict authority."
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "required": [
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "stage_kind",
        "title",
        "goal",
        "owner",
        "authority_boundary"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_kind": {
          "type": "string",
          "enum": [
            "intake",
            "planning",
            "source_preparation",
            "creation",
            "review",
            "revision",
            "packaging",
            "release_gate",
            "operator_gate",
            "domain_specific"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "display_names": {
          "description": "Optional for legacy family planes. When present, en-US is required and must exactly match title; the canonical normalizer enforces that cross-field equality.",
          "type": "object",
          "minProperties": 1,
          "required": [
            "en-US"
          ],
          "propertyNames": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S+$"
          },
          "properties": {
            "en-US": {
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            }
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          }
        },
        "summary": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "stage_role": {
          "type": "string",
          "enum": [
            "producer",
            "cross_stage_meta_review",
            "operator_gate",
            "domain_specific"
          ]
        },
        "stage_quality_cycle_policy_ref": {
          "type": "string",
          "minLength": 1
        },
        "stage_pack_conformance_version": {
          "type": "string",
          "description": "Stage-level conformance marker. For standard-stage-pack.v2, the stage declares prompt/tool/knowledge/evaluation refs, selected executor, stage contract obligations, expected receipts, and independent gate policy."
        },
        "selected_executor": {
          "$ref": "#/$defs/selected_executor"
        },
        "domain_stage_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain-owned memory or knowledge locators that OPL may index and inject as references only; this does not grant OPL memory-store, domain-truth, quality-verdict, or artifact authority."
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "prompt_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "tool_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Available tool affordance catalog refs for this stage. These refs declare capabilities and authority boundaries only; they do not prescribe executor tool order, cognitive strategy, or mandatory workflow."
        },
        "tool_affordance_boundary": {
          "$ref": "#/$defs/tool_affordance_boundary"
        },
        "allowed_action_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "evaluation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "independent_gate_policy": {
          "$ref": "#/$defs/independent_gate_policy"
        },
        "handoff": {
          "type": "object",
          "additionalProperties": true
        },
        "stage_contract": {
          "$ref": "#/$defs/stage_contract"
        },
        "trust_boundary": {
          "$ref": "#/$defs/trust_boundary"
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "selected_executor": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executor_kind"
      ],
      "properties": {
        "executor_kind": {
          "type": "string",
          "minLength": 1,
          "description": "Concrete executor selected for this stage. codex_cli is the default first-class executor; non-default adapters require explicit executor_binding_ref when launch admission is enforced."
        },
        "default_executor": {
          "type": "boolean"
        },
        "executor_binding_ref": {
          "type": "string",
          "minLength": 1
        },
        "binding_policy": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning_effort": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "executor_labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "receipt_requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        }
      }
    },
    "tool_affordance_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "catalog_role",
        "capability_refs",
        "permission_scope_refs",
        "credential_boundary_refs",
        "write_scope_refs",
        "side_effect_risk_refs",
        "forbidden_authority_refs",
        "executor_autonomy"
      ],
      "properties": {
        "catalog_role": {
          "const": "available_affordance_catalog_not_workflow_script"
        },
        "standardized_boundary_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "capability_refs",
              "permission_scope_refs",
              "credential_boundary_refs",
              "write_scope_refs",
              "side_effect_risk_refs",
              "forbidden_authority_refs"
            ]
          }
        },
        "capability_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "permission_scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "credential_boundary_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "write_scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "side_effect_risk_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "forbidden_authority_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "executor_autonomy": {
          "$ref": "#/$defs/tool_executor_autonomy"
        }
      }
    },
    "tool_executor_autonomy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "executor_can_choose_tools",
        "executor_can_skip_tools",
        "executor_can_substitute_tools_within_boundary",
        "executor_can_choose_order_and_parallelism",
        "executor_can_request_missing_context_or_human_gate",
        "tool_catalog_can_prescribe_tool_sequence",
        "tool_catalog_can_define_cognitive_strategy",
        "tool_catalog_can_override_stage_goal",
        "tool_catalog_can_authorize_forbidden_write"
      ],
      "properties": {
        "executor_can_choose_tools": {
          "const": true
        },
        "executor_can_skip_tools": {
          "const": true
        },
        "executor_can_substitute_tools_within_boundary": {
          "const": true
        },
        "executor_can_choose_order_and_parallelism": {
          "const": true
        },
        "executor_can_request_missing_context_or_human_gate": {
          "const": true
        },
        "tool_catalog_can_prescribe_tool_sequence": {
          "const": false
        },
        "tool_catalog_can_define_cognitive_strategy": {
          "const": false
        },
        "tool_catalog_can_override_stage_goal": {
          "const": false
        },
        "tool_catalog_can_authorize_forbidden_write": {
          "const": false
        }
      }
    },
    "independent_gate_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "gate_ref": {
          "type": "string",
          "minLength": 1
        },
        "gate_owner": {
          "type": "string",
          "minLength": 1
        },
        "execution_review_separation_required": {
          "type": "boolean"
        },
        "mechanical_completion_can_close_stage": {
          "type": "boolean"
        },
        "provider_completion_can_claim_domain_ready": {
          "type": "boolean"
        },
        "generated_surface_readiness_can_claim_quality_or_export": {
          "type": "boolean"
        }
      }
    },
    "stage_contract": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "user_stage_log_contract": {
          "$ref": "#/$defs/user_stage_log_contract"
        },
        "progress_delta_policy": {
          "$ref": "#/$defs/progress_delta_policy"
        },
        "typed_blocker_lineage_policy": {
          "$ref": "#/$defs/typed_blocker_lineage_policy"
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ensures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to runtime boundary events recorded by the domain/runtime owner for effect-boundary or runtime-guarded stages; OPL checks declaration completeness only and does not emit these events."
        },
        "expected_receipt_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain-owned expected receipt or typed-blocker refs for this stage. OPL projects these refs into stage evidence workorders; if present they replace the generic owner_receipt:<stage> fallback. OPL cannot create or sign these receipts."
        },
        "monitor_freshness_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain/App/live freshness refs that can satisfy monitor freshness for this stage. OPL records refs-only evidence and cannot generate freshness evidence."
        },
        "replay_evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs-only replay evidence declared for this stage contract. Classification is explicit via each ref role/ref_kind, such as append_only_event_log_ref, attempt_ledger_ref, recorded_runtime_event_ref, or closeout_receipt_ref."
        },
        "runtime_assumptions": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/runtime_assumption"
              }
            ]
          },
          "description": "Operational assumptions that must be monitored at runtime, such as source freshness, provider SLO, boundary failure rate, or artifact locator freshness. String entries keep the legacy lightweight form; object entries can carry owner, monitor, freshness, invalidation, and repair refs. OPL projects and gates these assumptions but does not turn them into domain verdicts."
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to domain-owned or OPL-owned monitor projections that make runtime assumptions visible to App/operator surfaces."
        },
        "source_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the source cohort or source set used by this stage before launch. OPL projects these refs but does not own source truth."
        },
        "cohort_query_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to auditable cohort/source queries that bind stage launch scope to execution and monitoring. OPL projects refs only and does not evaluate source truth."
        },
        "trigger_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to launch, schedule, or queue trigger surfaces that bind the cohort query to a stage attempt."
        },
        "metric_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to metrics computed over the same cohort or source scope after launch."
        },
        "dashboard_metric_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to dashboard/operator metrics for the same cohort or source scope. These are observability refs, not readiness verdicts."
        },
        "artifact_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the artifact set this stage may read, produce, or reconcile. OPL projects these refs but does not own artifact authority."
        },
        "workspace_scope_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs that freeze the workspace or runtime scope for this stage. OPL projects these refs but does not own workspace truth."
        }
      }
    },
    "user_stage_log_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required_fields"
      ],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "contains": {
            "const": "progress_delta_classification"
          }
        },
        "no_domain_body_authority": {
          "type": "boolean"
        }
      }
    },
    "progress_delta_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required_fields"
      ],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "allOf": [
            {
              "contains": {
                "const": "progress_delta_classification"
              }
            },
            {
              "contains": {
                "const": "deliverable_progress_delta"
              }
            },
            {
              "contains": {
                "const": "platform_repair_delta"
              }
            },
            {
              "contains": {
                "const": "next_forced_delta"
              }
            }
          ]
        },
        "classification_values": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "deliverable_progress",
              "platform_repair",
              "mixed",
              "typed_blocker",
              "human_gate",
              "stop_loss"
            ]
          }
        },
        "platform_only_is_not_deliverable_progress": {
          "const": true
        }
      }
    },
    "typed_blocker_lineage_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "required_fields"
      ],
      "properties": {
        "surface_kind": {
          "const": "family-stall-lineage.v1"
        },
        "version": {
          "const": "family-stall-lineage.v1"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "allOf": [
            {
              "contains": {
                "const": "repeat_count"
              }
            },
            {
              "contains": {
                "const": "next_forced_delta"
              }
            },
            {
              "contains": {
                "const": "escalation_owner"
              }
            }
          ]
        }
      }
    },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "lane"
      ],
      "properties": {
        "lane": {
          "type": "string",
          "enum": [
            "opl_framework",
            "domain_agent",
            "codex_executor",
            "ai_decision",
            "human_gate",
            "external_system",
            "app_projection"
          ]
        },
        "static_check_eligible": {
          "type": "boolean"
        },
        "effect_boundary": {
          "type": "boolean"
        },
        "records_runtime_events": {
          "type": "boolean"
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to replayable/auditable runtime events for effect-boundary or runtime-guarded stages; this is a declaration surface, not an OPL event emitter."
        },
        "owner_receipt_required": {
          "type": "boolean"
        },
        "human_gate_required": {
          "type": "boolean"
        },
        "runtime_guard_required": {
          "type": "boolean"
        }
      }
    },
    "runtime_assumption": {
      "type": "object",
      "additionalProperties": true,
      "anyOf": [
        {
          "required": [
            "assumption_id"
          ]
        },
        {
          "required": [
            "id"
          ]
        },
        {
          "required": [
            "ref"
          ]
        },
        {
          "required": [
            "name"
          ]
        }
      ],
      "properties": {
        "assumption_id": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "freshness_window_ref": {
          "type": "string",
          "minLength": 1
        },
        "observed_at_ref": {
          "type": "string",
          "minLength": 1
        },
        "invalidated_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repair_action": {
          "type": "string",
          "minLength": 1
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
