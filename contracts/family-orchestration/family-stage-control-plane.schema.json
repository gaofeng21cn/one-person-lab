{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-control-plane.schema.json",
  "title": "OPL Family Stage Control Plane",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "stages"
  ],
  "properties": {
    "surface_kind": {
      "const": "family_stage_control_plane"
    },
    "version": {
      "const": "family-stage-control-plane.v1"
    },
    "plane_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "required": [
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "stage_kind",
        "title",
        "goal",
        "owner",
        "authority_boundary"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_kind": {
          "type": "string",
          "enum": [
            "intake",
            "planning",
            "source_preparation",
            "creation",
            "review",
            "revision",
            "packaging",
            "publish",
            "operator_gate",
            "domain_specific"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "domain_stage_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain-owned memory or knowledge locators that OPL may index and inject as references only; this does not grant OPL memory-store, domain-truth, quality-verdict, or artifact authority."
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "prompt_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "allowed_action_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "evaluation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": true
        },
        "stage_contract": {
          "$ref": "#/$defs/stage_contract"
        },
        "trust_boundary": {
          "$ref": "#/$defs/trust_boundary"
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "stage_contract": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "ensures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to runtime boundary events recorded by the domain/runtime owner; OPL checks declaration completeness only and does not emit these events."
        },
        "runtime_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Operational assumptions that must be monitored at runtime, such as source freshness, provider SLO, boundary failure rate, or artifact locator freshness. OPL projects these assumptions but does not turn them into domain verdicts."
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Refs to domain-owned or OPL-owned monitor projections that make runtime assumptions visible to App/operator surfaces."
        }
      }
    },
    "trust_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "lane"
      ],
      "properties": {
        "lane": {
          "type": "string",
          "enum": [
            "opl_framework",
            "domain_agent",
            "codex_executor",
            "ai_decision",
            "human_gate",
            "external_system",
            "app_projection"
          ]
        },
        "static_check_eligible": {
          "type": "boolean"
        },
        "effect_boundary": {
          "type": "boolean"
        },
        "records_runtime_events": {
          "type": "boolean"
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable refs to replayable/auditable runtime events for effect-boundary stages; this is a declaration surface, not an OPL event emitter."
        },
        "owner_receipt_required": {
          "type": "boolean"
        },
        "human_gate_required": {
          "type": "boolean"
        },
        "runtime_guard_required": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": true
}
