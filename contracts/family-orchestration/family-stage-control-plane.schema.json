{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-control-plane.schema.json",
  "title": "OPL Family Stage Control Plane",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "stages"
  ],
  "properties": {
    "surface_kind": {
      "const": "family_stage_control_plane"
    },
    "version": {
      "const": "family-stage-control-plane.v1"
    },
    "plane_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stage"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "required": [
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "stage": {
      "type": "object",
      "required": [
        "stage_id",
        "stage_kind",
        "title",
        "goal",
        "owner",
        "authority_boundary"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_kind": {
          "type": "string",
          "enum": [
            "intake",
            "planning",
            "source_preparation",
            "creation",
            "review",
            "revision",
            "packaging",
            "publish",
            "operator_gate",
            "domain_specific"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "domain_stage_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "knowledge_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          },
          "description": "Domain-owned memory or knowledge locators that OPL may index and inject as references only; this does not grant OPL memory-store, domain-truth, quality-verdict, or artifact authority."
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "prompt_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "allowed_action_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "evaluation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "handoff": {
          "type": "object",
          "additionalProperties": true
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
