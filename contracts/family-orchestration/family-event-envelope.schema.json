{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-event-envelope.schema.json",
  "title": "OPL Family Event Envelope",
  "description": "Shared runtime-oriented event envelope for cross-repository orchestration correlation. This schema freezes the interoperability surface, not the runtime host implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "envelope_id",
    "event_name",
    "event_time",
    "target_domain_id",
    "producer",
    "session",
    "correlation",
    "payload"
  ],
  "properties": {
    "version": {
      "const": "family-event-envelope.v1"
    },
    "envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "event_name": {
      "type": "string",
      "minLength": 1
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "$ref": "#/$defs/surfaceRef"
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "source_surface"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "source_surface": {
          "type": "string",
          "minLength": 1
        },
        "active_run_id": {
          "type": "string",
          "minLength": 1
        },
        "program_id": {
          "type": "string",
          "minLength": 1
        },
        "study_id": {
          "type": "string",
          "minLength": 1
        },
        "quest_id": {
          "type": "string",
          "minLength": 1
        },
        "topic_id": {
          "type": "string",
          "minLength": 1
        },
        "deliverable_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "correlation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correlation_id"
      ],
      "properties": {
        "correlation_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_envelope_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_session_id": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_lineage_id": {
          "type": "string",
          "minLength": 1
        },
        "action_graph_id": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "gate_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "Domain-owned event body. This schema intentionally leaves the inner payload open."
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/referenceRef"
      }
    },
    "human_gate_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "status"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "requested",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "review_surface": {
          "$ref": "#/$defs/surfaceRef"
        }
      }
    }
  },
  "$defs": {
    "surfaceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "surface_id"
      ],
      "properties": {
        "surface_kind": {
          "type": "string",
          "minLength": 1
        },
        "surface_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "referenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "enum": [
            "repo_path",
            "json_pointer",
            "workspace_locator",
            "external_url"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "examples": [
    {
      "version": "family-event-envelope.v1",
      "envelope_id": "evt-mas-2026-04-13-01",
      "event_name": "study_runtime.stage_completed",
      "event_time": "2026-04-13T08:30:00Z",
      "target_domain_id": "med-autoscience",
      "producer": {
        "surface_kind": "study_runtime_status",
        "surface_id": "study_runtime"
      },
      "session": {
        "session_id": "sess_mas_001",
        "source_surface": "codex_cli_autonomous",
        "active_run_id": "run_mas_001",
        "program_id": "mas_runtime_program",
        "study_id": "study_heart_failure_01"
      },
      "correlation": {
        "correlation_id": "corr_mas_001",
        "action_graph_id": "mas_study_runtime_graph",
        "node_id": "source_intake"
      },
      "payload": {
        "status": "completed",
        "summary": "Source intake finished and checkpoint materialized."
      },
      "audit_refs": [
        {
          "ref_kind": "repo_path",
          "ref": "runtime_watch/latest.json",
          "label": "runtime watch"
        }
      ]
    }
  ]
}
