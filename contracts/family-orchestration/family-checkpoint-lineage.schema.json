{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-checkpoint-lineage.schema.json",
  "title": "OPL Family Checkpoint Lineage",
  "description": "Shared checkpoint-lineage contract for resume, ancestry, and state-reference continuity across the OPL family.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "lineage_id",
    "checkpoint_id",
    "target_domain_id",
    "session",
    "producer",
    "state_refs",
    "resume_contract",
    "integrity"
  ],
  "properties": {
    "version": {
      "const": "family-checkpoint-lineage.v1"
    },
    "lineage_id": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "active_run_id": {
          "type": "string",
          "minLength": 1
        },
        "program_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_envelope_id"
      ],
      "properties": {
        "event_envelope_id": {
          "type": "string",
          "minLength": 1
        },
        "action_graph_id": {
          "type": "string",
          "minLength": 1
        },
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "gate_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "parent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "parent_lineage_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_checkpoint_id": {
          "type": "string",
          "minLength": 1
        },
        "resume_from_lineage_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "state_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/stateRef"
      }
    },
    "restoration_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stateRef"
      }
    },
    "resume_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resume_mode",
        "resume_handle"
      ],
      "properties": {
        "resume_mode": {
          "type": "string",
          "enum": [
            "resume_from_checkpoint",
            "replay_node",
            "reenter_human_gate"
          ]
        },
        "resume_handle": {
          "type": "string",
          "minLength": 1
        },
        "human_gate_required": {
          "type": "boolean"
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "recorded_at"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "incomplete",
            "superseded"
          ]
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "stateRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "ref_kind",
        "ref"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "status",
            "audit",
            "controller",
            "artifact",
            "workspace",
            "publication"
          ]
        },
        "ref_kind": {
          "type": "string",
          "enum": [
            "repo_path",
            "json_pointer",
            "workspace_locator",
            "external_url"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "examples": [
    {
      "version": "family-checkpoint-lineage.v1",
      "lineage_id": "lineage-mas-2026-04-13-01",
      "checkpoint_id": "checkpoint_source_intake_01",
      "target_domain_id": "med-autoscience",
      "session": {
        "session_id": "sess_mas_001",
        "active_run_id": "run_mas_001",
        "program_id": "mas_runtime_program"
      },
      "producer": {
        "event_envelope_id": "evt-mas-2026-04-13-01",
        "action_graph_id": "mas_study_runtime_graph",
        "node_id": "source_intake"
      },
      "state_refs": [
        {
          "role": "status",
          "ref_kind": "repo_path",
          "ref": "study_runtime_status/latest.json",
          "label": "study runtime status"
        },
        {
          "role": "audit",
          "ref_kind": "repo_path",
          "ref": "runtime_watch/latest.json",
          "label": "runtime watch"
        }
      ],
      "resume_contract": {
        "resume_mode": "resume_from_checkpoint",
        "resume_handle": "study_runtime:checkpoint_source_intake_01",
        "human_gate_required": false
      },
      "integrity": {
        "status": "complete",
        "recorded_at": "2026-04-13T08:31:00Z"
      }
    }
  ]
}
