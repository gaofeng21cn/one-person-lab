{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-replay-certification.schema.json",
  "title": "OPL Family Stage Replay Certification",
  "description": "Refs-only replay certification for a proof-carrying family stage pack. It proves replay can use append-only event log, attempt ledger, runtime event, and closeout receipt refs instead of re-querying AI, human, or external outcomes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "stage_pack_id",
    "target_domain_id",
    "stage_pack_hash",
    "replay_status",
    "summary",
    "stage_results",
    "blockers",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_family_stage_replay_certification"
    },
    "version": {
      "const": "family-stage-replay-certification.v1"
    },
    "stage_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_pack_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "replay_status": {
      "type": "string",
      "enum": [
        "replay_ready",
        "blocked"
      ]
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "stage_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_result"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_count",
        "replay_ready_stage_count",
        "blocked_stage_count",
        "missing_runtime_event_ref_count",
        "missing_receipt_ref_count",
        "append_only_event_log_ref_count",
        "attempt_ledger_ref_count",
        "codex_attempt_trace_ref_count",
        "stage_manifest_ref_count",
        "current_pointer_ref_count",
        "owner_answer_binding_ref_count",
        "blocker_count"
      ],
      "properties": {
        "stage_count": { "type": "integer", "minimum": 0 },
        "replay_ready_stage_count": { "type": "integer", "minimum": 0 },
        "blocked_stage_count": { "type": "integer", "minimum": 0 },
        "missing_runtime_event_ref_count": { "type": "integer", "minimum": 0 },
        "missing_receipt_ref_count": { "type": "integer", "minimum": 0 },
        "append_only_event_log_ref_count": { "type": "integer", "minimum": 0 },
        "attempt_ledger_ref_count": { "type": "integer", "minimum": 0 },
        "codex_attempt_trace_ref_count": { "type": "integer", "minimum": 0 },
        "stage_manifest_ref_count": { "type": "integer", "minimum": 0 },
        "current_pointer_ref_count": { "type": "integer", "minimum": 0 },
        "owner_answer_binding_ref_count": { "type": "integer", "minimum": 0 },
        "blocker_count": { "type": "integer", "minimum": 0 }
      }
    },
    "stage_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "replay_status",
        "required_runtime_event_refs",
        "recorded_runtime_event_refs",
        "missing_runtime_event_refs",
        "expected_receipt_refs",
        "recorded_receipt_refs",
        "missing_receipt_refs",
        "missing_receipt_workorders"
      ],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "replay_status": {
          "type": "string",
          "enum": ["replay_ready", "blocked"]
        },
        "required_runtime_event_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recorded_runtime_event_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_runtime_event_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_receipt_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recorded_receipt_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_receipt_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_receipt_workorders": {
          "type": "array",
          "items": { "$ref": "#/$defs/missing_receipt_workorder" }
        }
      }
    },
    "missing_receipt_workorder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "stage_id",
        "missing_ref",
        "missing_ref_kind",
        "payload_owner",
        "payload_path_policy",
        "required_success_ref",
        "required_return_shapes",
        "payload_template",
        "accepted_payload_paths",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "opl_stage_replay_missing_receipt_workorder" },
        "stage_id": { "type": "string", "minLength": 1 },
        "missing_ref": { "type": "string", "minLength": 1 },
        "missing_ref_kind": {
          "type": "string",
          "enum": ["human_gate_ref", "owner_receipt_ref", "domain_receipt_ref"]
        },
        "payload_owner": { "const": "domain_or_human_gate_owner" },
        "payload_path_policy": { "const": "success_receipt_ref_or_domain_owned_typed_blocker_ref" },
        "required_success_ref": { "type": "string", "minLength": 1 },
        "required_return_shapes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "payload_template": {
          "type": "object",
          "additionalProperties": false,
          "required": ["receipt_refs", "typed_blocker_refs"],
          "properties": {
            "receipt_refs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "typed_blocker_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "accepted_payload_paths": {
          "type": "object",
          "additionalProperties": false,
          "required": ["success_refs_path", "typed_blocker_path"],
          "properties": {
            "success_refs_path": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "required_receipt_ref",
                "typed_blocker_refs_must_be_absent",
                "closes_replay_receipt_ref",
                "closes_domain_ready",
                "closes_production_ready"
              ],
              "properties": {
                "required_receipt_ref": { "type": "string", "minLength": 1 },
                "typed_blocker_refs_must_be_absent": { "const": true },
                "closes_replay_receipt_ref": { "const": true },
                "closes_domain_ready": { "const": false },
                "closes_production_ready": { "const": false }
              }
            },
            "typed_blocker_path": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "required_typed_blocker_refs",
                "success_claimed",
                "closes_replay_receipt_ref",
                "closes_domain_ready",
                "closes_production_ready"
              ],
              "properties": {
                "required_typed_blocker_refs": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "minItems": 1
                },
                "success_claimed": { "const": false },
                "closes_replay_receipt_ref": { "const": false },
                "closes_domain_ready": { "const": false },
                "closes_production_ready": { "const": false }
              }
            }
          }
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "refs_only",
            "can_execute_domain_action",
            "can_requery_human",
            "can_write_domain_truth",
            "can_create_owner_receipt",
            "can_write_owner_receipt",
            "can_authorize_quality_or_export",
            "can_close_domain_ready",
            "can_claim_production_ready"
          ],
          "properties": {
            "refs_only": { "const": true },
            "can_execute_domain_action": { "const": false },
            "can_requery_human": { "const": false },
            "can_write_domain_truth": { "const": false },
            "can_create_owner_receipt": { "const": false },
            "can_write_owner_receipt": { "const": false },
            "can_authorize_quality_or_export": { "const": false },
            "can_close_domain_ready": { "const": false },
            "can_claim_production_ready": { "const": false }
          }
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocker_kind",
        "blocker_id",
        "stage_id",
        "minimal_counterexample",
        "repair_action"
      ],
      "properties": {
        "blocker_kind": {
          "const": "replay_certification_blocker"
        },
        "blocker_id": {
          "type": "string",
          "enum": [
            "stage_pack_not_conformant",
            "append_only_event_log_ref_missing",
            "attempt_ledger_ref_missing",
            "stage_manifest_ref_missing",
            "current_pointer_ref_missing",
            "owner_answer_binding_ref_missing",
            "runtime_event_ref_missing",
            "expected_receipt_ref_missing"
          ]
        },
        "stage_id": {
          "type": ["string", "null"]
        },
        "minimal_counterexample": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason"],
          "properties": {
            "stage_id": { "type": "string" },
            "expected_ref": { "type": "string" },
            "missing_ref": { "type": "string" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "repair_action": {
          "type": "string",
          "enum": [
            "repair_stage_pack_conformance",
            "record_append_only_event_log_ref",
            "record_attempt_ledger_ref",
            "record_stage_manifest_ref",
            "record_current_pointer_ref",
            "record_owner_answer_binding_ref",
            "record_runtime_event_ref",
            "record_expected_receipt_ref"
          ]
        },
        "payload_workorder": {
          "$ref": "#/$defs/missing_receipt_workorder"
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "replay_reads_append_only_log_refs_only",
        "can_requery_ai",
        "can_requery_human",
        "can_requery_external_system",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body",
        "can_accept_or_reject_owner_receipt"
      ],
      "properties": {
        "opl_role": { "const": "replay_certification_projection_only" },
        "replay_reads_append_only_log_refs_only": { "const": true },
        "can_requery_ai": { "const": false },
        "can_requery_human": { "const": false },
        "can_requery_external_system": { "const": false },
        "can_write_domain_truth": { "const": false },
        "can_authorize_domain_ready": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "can_mutate_artifact_body": { "const": false },
        "can_accept_or_reject_owner_receipt": { "const": false }
      }
    }
  },
  "examples": [
    {
      "surface_kind": "opl_family_stage_replay_certification",
      "version": "family-stage-replay-certification.v1",
      "stage_pack_id": "example-domain:example_stage_control_plane",
      "target_domain_id": "example-domain",
      "stage_pack_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "replay_status": "replay_ready",
      "summary": {
        "stage_count": 1,
        "replay_ready_stage_count": 1,
        "blocked_stage_count": 0,
        "missing_runtime_event_ref_count": 0,
        "missing_receipt_ref_count": 0,
        "append_only_event_log_ref_count": 1,
        "attempt_ledger_ref_count": 1,
        "codex_attempt_trace_ref_count": 0,
        "stage_manifest_ref_count": 1,
        "current_pointer_ref_count": 1,
        "owner_answer_binding_ref_count": 1,
        "blocker_count": 0
      },
      "stage_results": [
        {
          "stage_id": "owner_review",
          "replay_status": "replay_ready",
          "required_runtime_event_refs": ["runtime_event:owner_review.gate_recorded"],
          "recorded_runtime_event_refs": ["runtime_event:owner_review.gate_recorded"],
          "missing_runtime_event_refs": [],
          "expected_receipt_refs": ["human_gate:owner_review_gate"],
          "recorded_receipt_refs": ["human_gate:owner_review_gate"],
          "missing_receipt_refs": [],
          "missing_receipt_workorders": []
        }
      ],
      "blockers": [],
      "authority_boundary": {
        "opl_role": "replay_certification_projection_only",
        "replay_reads_append_only_log_refs_only": true,
        "can_requery_ai": false,
        "can_requery_human": false,
        "can_requery_external_system": false,
        "can_write_domain_truth": false,
        "can_authorize_domain_ready": false,
        "can_authorize_quality_verdict": false,
        "can_mutate_artifact_body": false,
        "can_accept_or_reject_owner_receipt": false
      }
    }
  ]
}
