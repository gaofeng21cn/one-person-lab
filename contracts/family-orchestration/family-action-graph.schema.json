{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-action-graph.schema.json",
  "title": "OPL Family Action Graph",
  "description": "Shared action-graph topology contract across the OPL family. This schema freezes graph semantics without requiring one orchestration framework implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "graph_id",
    "target_domain_id",
    "graph_kind",
    "nodes",
    "edges",
    "entry_nodes"
  ],
  "properties": {
    "version": {
      "const": "family-action-graph.v1"
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_kind": {
      "type": "string",
      "minLength": 1
    },
    "graph_version": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "entry_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exit_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "human_gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/humanGateBinding"
      }
    },
    "checkpoint_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "none",
            "node_boundary",
            "explicit_nodes"
          ]
        },
        "checkpoint_nodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_kind",
        "title"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "node_kind": {
          "type": "string",
          "enum": [
            "intake",
            "discovery",
            "authoring",
            "audit",
            "review",
            "release_gate",
            "operator_step",
            "controller",
            "tool_call"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "executor_hint": {
          "type": "string",
          "minLength": 1
        },
        "produces_checkpoint": {
          "type": "boolean"
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "on": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "decision",
            "manual_resume"
          ]
        },
        "condition": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "humanGateBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "trigger_nodes"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "trigger_nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocking": {
          "type": "boolean"
        }
      }
    }
  },
  "examples": [
    {
      "version": "family-action-graph.v1",
      "graph_id": "sample_domain_delivery_graph",
      "target_domain_id": "example-domain",
      "graph_kind": "domain_delivery_entry",
      "graph_version": "2026-04-13",
      "nodes": [
        {
          "node_id": "source_intake",
          "node_kind": "intake",
          "title": "Source intake",
          "executor_hint": "codex_cli",
          "produces_checkpoint": true
        },
        {
          "node_id": "draft_loop",
          "node_kind": "authoring",
          "title": "Draft loop"
        },
        {
          "node_id": "delivery_release_gate",
          "node_kind": "release_gate",
          "title": "Delivery release gate"
        }
      ],
      "edges": [
        {
          "from": "source_intake",
          "to": "draft_loop",
          "on": "success"
        },
        {
          "from": "draft_loop",
          "to": "delivery_release_gate",
          "on": "decision"
        }
      ],
      "entry_nodes": [
        "source_intake"
      ],
      "human_gates": [
        {
          "gate_id": "delivery_release_gate",
          "trigger_nodes": [
            "draft_loop"
          ],
          "blocking": true
        }
      ],
      "checkpoint_policy": {
        "mode": "node_boundary",
        "checkpoint_nodes": [
          "source_intake",
          "draft_loop"
        ]
      }
    }
  ]
}
