{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-assumption-lifecycle.schema.json",
  "title": "OPL Family Stage Assumption Lifecycle",
  "description": "OPL-owned projection for runtime assumption freshness and monitor completeness. It can block launch readiness, but it does not grant domain truth or quality authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "summary",
    "assumptions",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_family_stage_assumption_lifecycle"
    },
    "version": {
      "const": "family-stage-assumption-lifecycle.v1"
    },
    "plane_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_count",
        "current_count",
        "stale_count",
        "missing_monitor_count",
        "missing_owner_count",
        "blocker_count",
        "warning_count"
      ],
      "properties": {
        "assumption_count": {
          "type": "integer",
          "minimum": 0
        },
        "current_count": {
          "type": "integer",
          "minimum": 0
        },
        "stale_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_monitor_count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_owner_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assumption"
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "can_execute_stage",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body"
      ],
      "properties": {
        "opl_role": {
          "const": "assumption_lifecycle_projection_only"
        },
        "can_execute_stage": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_authorize_domain_ready": {
          "const": false
        },
        "can_authorize_quality_verdict": {
          "const": false
        },
        "can_mutate_artifact_body": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "counterexample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "stage_id",
        "reason"
      ],
      "properties": {
        "assumption_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "missing_field": {
          "type": "string",
          "enum": [
            "owner",
            "monitor_refs",
            "freshness_window_ref",
            "observed_at_ref"
          ]
        },
        "invalidated_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assumption_id",
        "stage_id",
        "owner",
        "status",
        "severity",
        "freshness_window_ref",
        "observed_at_ref",
        "invalidated_by",
        "repair_action",
        "monitor_refs",
        "minimal_counterexample"
      ],
      "properties": {
        "assumption_id": {
          "type": "string",
          "minLength": 1
        },
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "current",
            "stale",
            "missing_monitor",
            "missing_owner"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "blocker"
          ]
        },
        "freshness_window_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "observed_at_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "invalidated_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repair_action": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "monitor_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/surface_ref"
          }
        },
        "minimal_counterexample": {
          "anyOf": [
            {
              "$ref": "#/$defs/counterexample"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
