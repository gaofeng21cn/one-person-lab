{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-action-catalog.schema.json",
  "title": "OPL Family Action Catalog",
  "description": "Shared callable-action catalog used to derive CLI, MCP, Skill, OpenAI, AI SDK, and product-entry descriptors without moving domain truth into OPL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "catalog_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "actions"
  ],
  "properties": {
    "surface_kind": {
      "const": "family_action_catalog"
    },
    "version": {
      "const": "family-action-catalog.v1"
    },
    "catalog_id": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "domain_truth_owner",
        "opl_role",
        "write_policy"
      ],
      "properties": {
        "domain_truth_owner": {
          "type": "string",
          "minLength": 1
        },
        "opl_role": {
          "const": "projection_consumer_only"
        },
        "write_policy": {
          "const": "no_domain_truth_writes"
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "title",
        "summary",
        "owner",
        "effect",
        "source_command",
        "input_schema_ref",
        "output_schema_ref",
        "supported_surfaces"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "enum": [
            "read_only",
            "mutating"
          ]
        },
        "source_command": {
          "$ref": "#/$defs/sourceCommand"
        },
        "input_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "output_schema_ref": {
          "type": "string",
          "minLength": 1
        },
        "workspace_locator_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "human_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_surfaces": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 6,
          "required": [
            "cli",
            "mcp",
            "skill",
            "product_entry",
            "openai",
            "ai_sdk"
          ],
          "properties": {
            "cli": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            },
            "mcp": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            },
            "skill": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            },
            "product_entry": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            },
            "openai": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            },
            "ai_sdk": {
              "$ref": "#/$defs/nullableSurfaceDescriptor"
            }
          }
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "sourceCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "surface_kind"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "surfaceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "command_contract_id": {
          "type": "string",
          "minLength": 1
        },
        "action_key": {
          "type": "string",
          "minLength": 1
        },
        "public_runtime": {
          "type": "boolean"
        },
        "descriptor_only": {
          "type": "boolean"
        }
      }
    },
    "nullableSurfaceDescriptor": {
      "anyOf": [
        {
          "$ref": "#/$defs/surfaceDescriptor"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
