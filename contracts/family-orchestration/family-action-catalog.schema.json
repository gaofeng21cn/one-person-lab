{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-action-catalog.schema.json",
  "title": "OPL Family Action Catalog",
  "description": "Canonical Standard Agent action contract. OPL owns executable command generation and FoundryRun execution; domain packs declare handler, stage, or Foundry provider bindings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "catalog_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "actions"
  ],
  "properties": {
    "surface_kind": { "const": "family_action_catalog" },
    "version": { "const": "family-action-catalog.v2" },
    "catalog_id": { "type": "string", "minLength": 1 },
    "target_domain_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "authority_boundary": {
      "allOf": [
        { "$ref": "#/$defs/nonOplAuthorityBoundary" },
        {
          "required": ["domain_truth_owner", "opl_role", "write_policy"],
          "properties": {
            "domain_truth_owner": { "type": "string", "minLength": 1 },
            "opl_role": { "enum": ["projection_consumer_only", "foundry_runtime_owner"] },
            "write_policy": { "const": "no_domain_truth_writes" }
          }
        }
      ]
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/action" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "actions": {
            "contains": {
              "properties": {
                "execution_binding": {
                  "properties": { "kind": { "const": "foundry_binding" } },
                  "required": ["kind"]
                }
              },
              "required": ["execution_binding"]
            }
          }
        },
        "required": ["actions"]
      },
      "then": {
        "properties": {
          "authority_boundary": {
            "properties": { "opl_role": { "const": "foundry_runtime_owner" } }
          },
          "actions": {
            "items": {
              "properties": {
                "execution_binding": {
                  "properties": { "kind": { "const": "foundry_binding" } },
                  "required": ["kind"]
                }
              },
              "required": ["execution_binding"]
            }
          }
        }
      },
      "else": {
        "properties": {
          "authority_boundary": {
            "properties": { "opl_role": { "const": "projection_consumer_only" } }
          }
        }
      }
    }
  ],
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "title",
        "summary",
        "owner",
        "effect",
        "execution_binding",
        "input_schema_ref",
        "output_schema_ref",
        "required_fields",
        "optional_fields",
        "workspace_locator_fields",
        "human_gate_ids",
        "supported_surfaces"
      ],
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "effect": { "enum": ["read_only", "mutating"] },
        "execution_binding": { "$ref": "#/$defs/executionBinding" },
        "source_of_work": { "$ref": "#/$defs/sourceOfWork" },
        "input_schema_ref": { "type": "string", "minLength": 1 },
        "output_schema_ref": { "type": "string", "minLength": 1 },
        "required_fields": { "$ref": "#/$defs/stringList" },
        "optional_fields": { "$ref": "#/$defs/stringList" },
        "workspace_locator_fields": { "$ref": "#/$defs/stringList" },
        "human_gate_ids": { "$ref": "#/$defs/stringList" },
        "execution_scope": { "$ref": "#/$defs/executionScope" },
        "stage_route": { "$ref": "#/$defs/stageRoute" },
        "supported_surfaces": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cli", "mcp", "skill", "product_entry", "openai", "ai_sdk"],
          "properties": {
            "cli": { "$ref": "#/$defs/nullableSurfaceDescriptor" },
            "mcp": { "$ref": "#/$defs/nullableSurfaceDescriptor" },
            "skill": { "$ref": "#/$defs/nullableSurfaceDescriptor" },
            "product_entry": { "$ref": "#/$defs/nullableSurfaceDescriptor" },
            "openai": { "$ref": "#/$defs/nullableSurfaceDescriptor" },
            "ai_sdk": { "$ref": "#/$defs/nullableSurfaceDescriptor" }
          }
        },
        "authority_boundary": { "$ref": "#/$defs/nonOplAuthorityBoundary" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "execution_binding": {
                "properties": { "kind": { "const": "stage_binding" } },
                "required": ["kind"]
              }
            }
          },
          "then": { "required": ["stage_route"] },
          "else": { "not": { "required": ["stage_route"] } }
        }
      ]
    },
    "executionBinding": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "handler_ref"],
          "properties": {
            "kind": { "const": "handler_ref" },
            "handler_ref": {
              "type": "string",
              "pattern": "^handler:[A-Za-z0-9](?:[A-Za-z0-9._-]*[A-Za-z0-9])?$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "stage_manifest_ref"],
          "properties": {
            "kind": { "const": "stage_binding" },
            "stage_manifest_ref": { "const": "agent/stages/manifest.json" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "provider_manifest_ref"],
          "properties": {
            "kind": { "const": "foundry_binding" },
            "provider_manifest_ref": { "const": "contracts/foundry_provider.json" }
          }
        }
      ]
    },
    "executionScope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "alias_fields"],
          "properties": {
            "kind": { "const": "work_item" },
            "alias_fields": {
              "allOf": [{ "$ref": "#/$defs/stringList" }, { "minItems": 1 }]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "const": "none" }
          }
        }
      ]
    },
    "stageRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_stage_ref",
        "required_stage_refs",
        "optional_stage_refs",
        "terminal_stage_refs",
        "route_policy"
      ],
      "properties": {
        "entry_stage_ref": { "type": "string", "minLength": 1 },
        "required_stage_refs": {
          "allOf": [{ "$ref": "#/$defs/stringList" }, { "minItems": 1 }]
        },
        "optional_stage_refs": { "$ref": "#/$defs/stringList" },
        "terminal_stage_refs": {
          "allOf": [{ "$ref": "#/$defs/stringList" }, { "minItems": 1 }]
        },
        "route_policy": { "const": "ai_selected_progress_route" }
      }
    },
    "sourceOfWork": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_catalog",
        "source_catalog_ref",
        "source_action_id",
        "stage_catalog_ref",
        "derived_surface_policy"
      ],
      "properties": {
        "source_catalog": { "const": "family_action_catalog" },
        "source_catalog_ref": { "type": "string", "minLength": 1 },
        "source_action_id": { "type": "string", "minLength": 1 },
        "stage_catalog_ref": { "type": "string", "minLength": 1 },
        "derived_surface_policy": {
          "const": "derive_cli_mcp_openai_ai_sdk_skill_app_status_workbench_from_single_catalog"
        },
        "domain_repo_wrapper_policy": {
          "const": "handler_target_refs_only_adapter_or_tombstone_candidate"
        }
      }
    },
    "surfaceDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "surface_kind": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "command_contract_id": { "type": "string", "minLength": 1 },
        "action_key": { "type": "string", "minLength": 1 },
        "public_runtime": { "type": "boolean" },
        "descriptor_only": { "type": "boolean" }
      }
    },
    "nonOplAuthorityBoundary": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^opl_can_": { "const": false }
      },
      "properties": {
        "provider_completion_is_domain_completion": { "const": false },
        "provider_completion_counts_as_domain_completion": { "const": false },
        "quality_verdict_owner": {
          "type": "string",
          "minLength": 1,
          "not": { "const": "one-person-lab" }
        },
        "artifact_authority_owner": {
          "type": "string",
          "minLength": 1,
          "not": { "const": "one-person-lab" }
        }
      }
    },
    "nullableSurfaceDescriptor": {
      "anyOf": [
        { "$ref": "#/$defs/surfaceDescriptor" },
        { "type": "null" }
      ]
    },
    "stringList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
