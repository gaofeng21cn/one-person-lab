{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/family-orchestration/family-product-entry-manifest-v2.schema.json",
  "title": "OPL Family Product Entry Manifest v2",
  "description": "Shared family-level product-entry discovery manifest for direct-entry, operator-loop, gate, and orchestration discovery across domain repositories.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "manifest_version",
    "manifest_kind",
    "target_domain_id",
    "formal_entry",
    "workspace_locator",
    "skill_catalog",
    "runtime_control",
    "runtime_loop_closure",
    "session_continuity",
    "progress_projection",
    "artifact_inventory",
    "product_entry_shell",
    "shared_handoff",
    "product_entry_start",
    "family_orchestration"
  ],
  "properties": {
    "surface_kind": {
      "const": "product_entry_manifest"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "manifest_version": {
      "const": 2
    },
    "manifest_kind": {
      "type": "string",
      "minLength": 1
    },
    "target_domain_id": {
      "type": "string",
      "minLength": 1
    },
    "formal_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default",
        "supported_protocols"
      ],
      "properties": {
        "default": {
          "type": "string",
          "minLength": 1
        },
        "supported_protocols": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "internal_surface": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workspace_locator": {
      "type": "object"
    },
    "managed_runtime_contract": {
      "type": "object"
    },
    "runtime": {
      "type": "object"
    },
    "executor_defaults": {
      "type": "object"
    },
    "repo_mainline": {
      "type": "object"
    },
    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    "product_entry_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "next_focus": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remaining_gaps_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "product_entry_surface": {
      "$ref": "#/$defs/shellSurface"
    },
    "operator_loop_surface": {
      "$ref": "#/$defs/shellSurface"
    },
    "operator_loop_actions": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "recommended_shell": {
      "type": "string",
      "minLength": 1
    },
    "recommended_command": {
      "type": "string",
      "minLength": 1
    },
    "runtime_inventory": {
      "$ref": "#/$defs/runtimeInventorySurface"
    },
    "task_lifecycle": {
      "$ref": "#/$defs/taskLifecycleSurface"
    },
    "family_runtime_supervision": {
      "$ref": "#/$defs/familyRuntimeSupervisionSurface"
    },
    "persistence_policy": {
      "$ref": "#/$defs/persistencePolicySurface"
    },
    "lifecycle_ledger": {
      "$ref": "#/$defs/lifecycleLedgerSurface"
    },
    "owner_route": {
      "$ref": "#/$defs/ownerRouteSurface"
    },
    "runtime_control": {
      "$ref": "#/$defs/runtimeControlSurface"
    },
    "runtime_loop_closure": {
      "$ref": "#/$defs/runtimeLoopClosureSurface"
    },
    "session_continuity": {
      "$ref": "#/$defs/sessionContinuitySurface"
    },
    "progress_projection": {
      "$ref": "#/$defs/progressProjectionSurface"
    },
    "artifact_inventory": {
      "$ref": "#/$defs/artifactInventorySurface"
    },
    "skill_catalog": {
      "$ref": "#/$defs/skillCatalogSurface"
    },
    "automation": {
      "$ref": "#/$defs/automationSurface"
    },
    "product_entry_overview": {
      "$ref": "#/$defs/productEntryOverviewSurface"
    },
    "product_entry_start": {
      "$ref": "#/$defs/productEntryStart"
    },
    "product_entry_preflight": {
      "$ref": "#/$defs/productEntryPreflight"
    },
    "product_entry_readiness": {
      "$ref": "#/$defs/productEntryReadiness"
    },
    "product_entry_domain_readiness": {
      "$ref": "#/$defs/domainReadinessProfile"
    },
    "product_entry_quickstart": {
      "$ref": "#/$defs/productEntryQuickstartSurface"
    },
    "grant_authoring_readiness": {
      "$ref": "#/$defs/grantAuthoringReadiness",
      "deprecated": true,
      "description": "Deprecated MAG compatibility alias. New generic manifests should use product_entry_domain_readiness."
    },
    "product_entry_guardrails": {
      "$ref": "#/$defs/productEntryGuardrails"
    },
    "phase3_clearance_lane": {
      "$ref": "#/$defs/phase3ClearanceLane"
    },
    "source_provenance": {
      "$ref": "#/$defs/sourceProvenanceSurface"
    },
    "phase5_platform_target": {
      "$ref": "#/$defs/phase5PlatformTarget"
    },
    "product_entry_shell": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/shellCommand"
      }
    },
    "shared_handoff": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object"
      }
    },
    "schema_ref": {
      "type": "string",
      "minLength": 1
    },
    "domain_entry_contract": {
      "type": "object"
    },
    "user_interaction_contract": {
      "type": "object"
    },
    "family_orchestration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_gates"
      ],
      "properties": {
        "action_graph_ref": {
          "$ref": "#/$defs/referenceRef"
        },
        "human_gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gatePreview"
          }
        },
        "resume_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "surface_kind",
            "session_locator_field"
          ],
          "properties": {
            "surface_kind": {
              "type": "string",
              "minLength": 1
            },
            "session_locator_field": {
              "type": "string",
              "minLength": 1
            },
            "checkpoint_locator_field": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "event_envelope_surface": {
          "$ref": "#/$defs/referenceRef"
        },
        "checkpoint_lineage_surface": {
          "$ref": "#/$defs/referenceRef"
        }
      }
    },
    "family_action_catalog": {
      "$ref": "family-action-catalog.schema.json"
    },
    "family_action_catalog_ref": {
      "$ref": "#/$defs/actionCatalogContractRef"
    },
    "family_stage_control_plane": {
      "$ref": "family-stage-control-plane.schema.json"
    },
    "family_stage_control_plane_ref": {
      "$ref": "#/$defs/stageControlPlaneContractRef"
    },
    "family_stage_integrity_metadata": {
      "$ref": "family-stage-integrity-metadata.schema.json"
    },
    "domain_memory_descriptor": {
      "$ref": "family-domain-memory-ref.schema.json"
    },
    "remaining_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "not": {
        "required": [
          "family_action_catalog",
          "family_action_catalog_ref"
        ]
      }
    },
    {
      "not": {
        "required": [
          "family_stage_control_plane",
          "family_stage_control_plane_ref"
        ]
      }
    }
  ],
  "$defs": {
    "shellCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "shellSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell_key"
      ],
      "properties": {
        "shell_key": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "continuation_shell_key": {
          "type": "string",
          "minLength": 1
        },
        "continuation_command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "productEntryStartMode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode_id"
      ],
      "properties": {
        "mode_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "surface_kind": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "productEntryStart": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "recommended_mode_id",
        "modes",
        "human_gate_ids"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_start"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_mode_id": {
          "type": "string",
          "minLength": 1
        },
        "modes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/productEntryStartMode"
          }
        },
        "resume_surface": {
          "type": "object"
        },
        "human_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "referenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "type": "string",
          "enum": [
            "repo_path",
            "json_pointer",
            "workspace_locator",
            "external_url"
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actionCatalogContractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "const": "repo_path"
        },
        "ref": {
          "const": "contracts/action_catalog.json"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stageControlPlaneContractRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_kind",
        "ref"
      ],
      "properties": {
        "ref_kind": {
          "const": "repo_path"
        },
        "ref": {
          "const": "contracts/stage_control_plane.json"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtimeInventorySurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "runtime_inventory"
        }
      }
    },
    "taskLifecycleSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "task_lifecycle"
        }
      }
    },
    "familyRuntimeSupervisionSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "family_runtime_supervision"
        }
      }
    },
    "persistencePolicySurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "family_persistence_policy"
        }
      }
    },
    "lifecycleLedgerSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "family_lifecycle_ledger"
        }
      }
    },
    "ownerRouteSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "family_owner_route"
        }
      }
    },
    "runtimeControlSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "runtime_control"
        }
      }
    },
    "runtimeLoopClosureSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "runtime_loop_closure"
        }
      }
    },
    "sessionContinuitySurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "session_continuity"
        }
      }
    },
    "progressProjectionSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "progress_projection"
        }
      }
    },
    "artifactInventorySurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "artifact_inventory"
        }
      }
    },
    "skillCatalogSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "skill_catalog"
        }
      }
    },
    "automationSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "automation"
        }
      }
    },
    "productEntryOverviewSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_overview"
        }
      }
    },
    "productEntryQuickstartSurface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_quickstart"
        }
      }
    },
    "gatePreview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id"
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "requested",
            "approved",
            "rejected",
            "changes_requested"
          ]
        },
        "review_surface": {
          "$ref": "#/$defs/referenceRef"
        }
      }
    },
    "productEntryPreflightCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "blocking": {
          "type": "boolean"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "productEntryPreflight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "ready_to_try_now",
        "blocking_check_ids",
        "checks"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_preflight"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "ready_to_try_now": {
          "type": "boolean"
        },
        "recommended_check_command": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_command": {
          "type": "string",
          "minLength": 1
        },
        "runtime_loop_closure": {
          "$ref": "#/$defs/runtimeLoopClosureSurface"
        },
        "blocking_check_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/productEntryPreflightCheck"
          }
        }
      }
    },
    "workflowCoverageItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "minLength": 1
        },
        "manual_flow_label": {
          "type": "string",
          "minLength": 1
        },
        "coverage_status": {
          "type": "string",
          "minLength": 1
        },
        "current_surface": {
          "type": "string",
          "minLength": 1
        },
        "remaining_gap": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "productEntryReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "blocking_gaps",
        "workflow_coverage"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_readiness"
        },
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "usable_now": {
          "type": "boolean"
        },
        "good_to_use_now": {
          "type": "boolean"
        },
        "fully_automatic": {
          "type": "boolean"
        },
        "user_experience_level": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_command": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_command": {
          "type": "string",
          "minLength": 1
        },
        "workflow_coverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowCoverageItem"
          }
        },
        "blocking_gaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "domainReadinessProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "blocking_gaps",
        "workflow_coverage"
      ],
      "properties": {
        "surface_kind": {
          "const": "product_entry_domain_readiness"
        },
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "usable_now": {
          "type": "boolean"
        },
        "good_to_use_now": {
          "type": "boolean"
        },
        "fully_automatic": {
          "type": "boolean"
        },
        "user_experience_level": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_command": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_command": {
          "type": "string",
          "minLength": 1
        },
        "workflow_coverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowCoverageItem"
          }
        },
        "blocking_gaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "grantAuthoringReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "blocking_gaps",
        "workflow_coverage"
      ],
      "properties": {
        "surface_kind": {
          "const": "grant_authoring_readiness"
        },
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "usable_now": {
          "type": "boolean"
        },
        "good_to_use_now": {
          "type": "boolean"
        },
        "fully_automatic": {
          "type": "boolean"
        },
        "user_experience_level": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_start_command": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_surface": {
          "type": "string",
          "minLength": 1
        },
        "recommended_loop_command": {
          "type": "string",
          "minLength": 1
        },
        "workflow_coverage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowCoverageItem"
          }
        },
        "blocking_gaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "guardrailClass": {
      "type": "object",
      "additionalProperties": false,
