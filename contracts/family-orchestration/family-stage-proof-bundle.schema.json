{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-proof-bundle.schema.json",
  "title": "OPL Stage Pack Proof Bundle",
  "description": "Lightweight proof-carrying bundle projected from a family stage control plane, optional action catalog, and admission review. It exposes machine-readable obligations and blockers for OPL scheduling/admission without introducing a heavy prover or granting OPL domain truth authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "identity",
    "conformance_status",
    "conformance_summary",
    "stage_results",
    "conformance_findings",
    "failure_localization",
    "composition_obligations",
    "boundary_assumptions",
    "idempotency_assumptions",
    "expected_receipt_refs",
    "runtime_event_requirements",
    "test_proof_refs",
    "human_review_burden_budget",
    "proof_runtime_metrics",
    "integrity",
    "generated_artifact_manifest",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_stage_pack_proof_bundle"
    },
    "version": {
      "const": "opl-stage-pack-proof-bundle.v1"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_pack_id",
        "plane_id",
        "target_domain_id",
        "plane_owner",
        "stage_ids",
        "action_catalog_id"
      ],
      "properties": {
        "stage_pack_id": {
          "type": "string",
          "minLength": 1
        },
        "plane_id": {
          "type": "string",
          "minLength": 1
        },
        "target_domain_id": {
          "type": "string",
          "minLength": 1
        },
        "plane_owner": {
          "type": "string",
          "minLength": 1
        },
        "stage_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "action_catalog_id": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "conformance_status": {
      "$ref": "#/$defs/conformance_status"
    },
    "conformance_summary": {
      "$ref": "#/$defs/conformance_summary"
    },
    "stage_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_result"
      }
    },
    "conformance_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "failure_localization": {
      "type": "array",
      "description": "Projection-only failure/blocker localization by trust/source lane for scheduler and operator drilldown. It is not a domain verdict.",
      "items": {
        "$ref": "#/$defs/failure_localization"
      }
    },
    "composition_obligations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/composition_obligation"
      }
    },
    "boundary_assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_assumptions"
      }
    },
    "idempotency_assumptions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_assumptions"
      }
    },
    "expected_receipt_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expected_receipt_ref"
      }
    },
    "runtime_event_requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runtime_event_requirement"
      }
    },
    "test_proof_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stage_surface_ref"
      }
    },
    "human_review_burden_budget": {
      "$ref": "#/$defs/human_review_burden_budget"
    },
    "proof_runtime_metrics": {
      "description": "Scale-oriented counts derived from the proof bundle for OPL scheduling and operator observability only. These metrics do not authorize a domain ready, quality, receipt, or artifact verdict.",
      "$ref": "#/$defs/proof_runtime_metrics"
    },
    "integrity": {
      "description": "Deterministic digest metadata for the stage pack control-plane/action-catalog refs. OPL projects the digest and optional signature refs only; it does not verify external signatures or turn integrity metadata into domain readiness.",
      "$ref": "#/$defs/stage_pack_integrity"
    },
    "generated_artifact_manifest": {
      "description": "Refs-only manifest of generated/reviewable code, test, proof, schema, and artifact refs derived from the stage pack. It is bound to the stage_pack_hash and is a build/review input only.",
      "$ref": "#/$defs/generated_artifact_manifest"
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "domain_role",
        "can_execute_stage",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body",
        "can_accept_or_reject_owner_receipt",
        "proof_passed"
      ],
      "properties": {
        "opl_role": {
          "const": "proof_bundle_projection_owner"
        },
        "domain_role": {
          "const": "truth_quality_receipt_and_artifact_authority"
        },
        "can_execute_stage": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_authorize_domain_ready": {
          "const": false
        },
        "can_authorize_quality_verdict": {
          "const": false
        },
        "can_mutate_artifact_body": {
          "const": false
        },
        "can_accept_or_reject_owner_receipt": {
          "const": false
        },
        "proof_passed": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "conformance_status": {
      "type": "string",
      "enum": [
        "admitted",
        "needs_contracts",
        "blocked"
      ]
    },
    "trust_lane": {
      "type": "string",
      "enum": [
        "opl_framework",
        "domain_agent",
        "codex_executor",
        "ai_decision",
        "human_gate",
        "external_system",
        "app_projection"
      ]
    },
    "conformance_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stages_count",
        "admitted_stages_count",
        "blocked_stages_count",
        "needs_contracts_stages_count",
        "blockers_count",
        "warnings_count"
      ],
      "properties": {
        "stages_count": {
          "type": "integer",
          "minimum": 0
        },
        "admitted_stages_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_stages_count": {
          "type": "integer",
          "minimum": 0
        },
        "needs_contracts_stages_count": {
          "type": "integer",
          "minimum": 0
        },
        "blockers_count": {
          "type": "integer",
          "minimum": 0
        },
        "warnings_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "stage_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "status",
        "trust_lane",
        "static_check_eligible",
        "effect_boundary",
        "mode_tags",
        "runtime_event_refs",
        "finding_count",
        "blocker_count",
        "warning_count"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/conformance_status"
        },
        "trust_lane": {
          "anyOf": [
            {
              "$ref": "#/$defs/trust_lane"
            },
            {
              "type": "null"
            }
          ]
        },
        "static_check_eligible": {
          "type": "boolean"
        },
        "effect_boundary": {
          "type": "boolean"
        },
        "mode_tags": {
          "$ref": "#/$defs/mode_tags"
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "code",
        "message"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "blocker",
            "warning"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "stage_id": {
          "type": "string"
        },
        "target_stage_id": {
          "type": "string"
        },
        "action_id": {
          "type": "string"
        },
        "assumption_id": {
          "type": "string"
        },
        "failure_lane": {
          "$ref": "#/$defs/failure_lane"
        },
        "source_ref": {
          "type": "string"
        },
        "runtime_event_refs_missing_reason": {
          "type": "string"
        },
        "minimal_counterexample": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "mode_tags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verified_core_eligible",
        "durable_runtime_only",
        "runtime_boundary_required"
      ],
      "properties": {
        "verified_core_eligible": {
          "type": "boolean"
        },
        "durable_runtime_only": {
          "type": "boolean"
        },
        "runtime_boundary_required": {
          "type": "boolean"
        }
      }
    },
    "failure_lane": {
      "type": "string",
      "enum": [
        "ai",
        "human",
        "external",
        "provider",
        "runtime",
        "domain",
        "artifact",
        "source",
        "monitor",
        "executor"
      ]
    },
    "failure_localization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lane",
        "severity",
        "code",
        "stage_id",
        "target_stage_id",
        "action_id",
        "assumption_id",
        "source_ref",
        "minimal_counterexample"
      ],
      "properties": {
        "lane": {
          "$ref": "#/$defs/failure_lane"
        },
        "severity": {
          "type": "string",
          "enum": [
            "blocker",
            "warning"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "stage_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "target_stage_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "action_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "assumption_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "source_ref": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "minimal_counterexample": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "composition_obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "upstream_stage_id",
        "downstream_stage_id",
        "upstream_ensures",
        "downstream_requires",
        "satisfied_by",
        "missing",
        "status"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "upstream_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "downstream_stage_id": {
          "type": "string",
          "minLength": 1
        },
        "upstream_ensures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "downstream_requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "satisfied_by": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "missing"
          ]
        }
      }
    },
    "stage_assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "assumptions"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "expected_receipt_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "ref",
        "reason"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime_event_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "trust_lane",
        "required",
        "satisfied_by_records_runtime_events",
        "runtime_event_refs",
        "satisfied_by_runtime_event_refs",
        "reason"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "trust_lane": {
          "anyOf": [
            {
              "$ref": "#/$defs/trust_lane"
            },
            {
              "type": "null"
            }
          ]
        },
        "required": {
          "type": "boolean"
        },
        "satisfied_by_records_runtime_events": {
          "type": "boolean"
        },
        "runtime_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Machine-readable runtime event refs the stage declares for replay, retry, audit, and handoff. OPL checks declaration completeness only and does not emit these events."
        },
        "satisfied_by_runtime_event_refs": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "surface_ref_value": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "stage_surface_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "stage_id",
        "ref"
      ],
      "properties": {
        "stage_id": {
          "type": "string",
          "minLength": 1
        },
        "ref_kind": {
          "type": "string"
        },
        "ref": {
          "$ref": "#/$defs/surface_ref_value"
        },
        "role": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "proof_runtime_metrics": {
      "type": "object",
      "additionalProperties": false,
      "description": "Scale-oriented counts derived from the proof bundle for OPL scheduling and operator observability only. These metrics do not authorize a domain ready, quality, receipt, or artifact verdict.",
      "required": [
        "composition_obligation_count",
        "runtime_event_requirement_count",
        "satisfied_runtime_event_ref_count",
        "expected_receipt_ref_count",
        "human_review_gate_count",
        "blocked_human_review_gate_count",
        "test_proof_ref_count",
        "blocker_count",
        "warning_count",
        "authority_boundary"
      ],
      "properties": {
        "composition_obligation_count": {
          "type": "integer",
          "minimum": 0
        },
        "runtime_event_requirement_count": {
          "type": "integer",
          "minimum": 0
        },
        "satisfied_runtime_event_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_receipt_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "human_review_gate_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_human_review_gate_count": {
          "type": "integer",
          "minimum": 0
        },
        "test_proof_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "authority_boundary": {
          "$ref": "#/$defs/proof_runtime_metrics_authority_boundary"
        }
      }
    },
    "proof_runtime_metrics_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "domain_role",
        "can_execute_stage",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body",
        "can_accept_or_reject_owner_receipt",
        "metrics_are_domain_verdict"
      ],
      "properties": {
        "opl_role": {
          "const": "scheduling_operator_observability_only"
        },
        "domain_role": {
          "const": "truth_quality_receipt_and_artifact_authority"
        },
        "can_execute_stage": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_authorize_domain_ready": {
          "const": false
        },
        "can_authorize_quality_verdict": {
          "const": false
        },
        "can_mutate_artifact_body": {
          "const": false
        },
        "can_accept_or_reject_owner_receipt": {
          "const": false
        },
        "metrics_are_domain_verdict": {
          "const": false
        }
      }
    },
    "human_review_burden_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "projection_scope",
        "target_domain_id",
        "status",
        "gates",
        "summary",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "family_human_review_burden_budget" },
        "version": { "const": "family-human-review-burden-budget.v1" },
        "projection_scope": {
          "type": "string",
          "enum": ["stage_pack", "stage_attempt", "stage_attempt_workbench"]
        },
        "target_domain_id": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "status": {
          "type": "string",
          "enum": ["ready", "blocked", "no_human_review_required"]
        },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/human_review_budget_gate" }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "gate_count",
            "ready_gate_count",
            "blocked_gate_count",
            "required_ref_count",
            "missing_ref_count",
            "by_type",
            "by_owner"
          ],
          "properties": {
            "gate_count": { "type": "integer", "minimum": 0 },
            "ready_gate_count": { "type": "integer", "minimum": 0 },
            "blocked_gate_count": { "type": "integer", "minimum": 0 },
            "required_ref_count": { "type": "integer", "minimum": 0 },
            "missing_ref_count": { "type": "integer", "minimum": 0 },
            "by_type": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
            "by_owner": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
          }
        },
        "authority_boundary": { "$ref": "#/$defs/human_review_budget_authority_boundary" }
      }
    },
    "human_review_budget_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate_id",
        "gate_type",
        "owner",
        "stage_id",
        "required_refs",
        "missing_refs",
        "reason",
        "status",
        "source"
      ],
      "properties": {
        "gate_id": { "type": "string", "minLength": 1 },
        "gate_type": {
          "type": "string",
          "enum": [
            "intent_review",
            "scope_review",
            "boundary_exception_review",
            "quality_owner_review",
            "artifact_mutation_review"
          ]
        },
        "owner": { "type": "string", "minLength": 1 },
        "stage_id": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "required_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["ready", "blocked"] },
        "source": {
          "type": "string",
          "enum": ["stage_authority_boundary", "trust_boundary", "action_catalog", "signal_payload", "gate_ref"]
        }
      }
    },
    "human_review_budget_authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "domain_role",
        "can_ask_untyped_human_question",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body"
      ],
      "properties": {
        "opl_role": { "const": "human_review_budget_projection_only" },
        "domain_role": { "const": "truth_quality_receipt_and_artifact_authority" },
        "can_ask_untyped_human_question": { "const": false },
        "can_write_domain_truth": { "const": false },
        "can_authorize_domain_ready": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "can_mutate_artifact_body": { "const": false }
      }
    },
    "stage_pack_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "version",
        "hash_algorithm",
        "stage_pack_hash",
        "hash_scope",
        "signature_status",
        "signer_ref",
        "signature_ref",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_stage_pack_integrity_metadata"
        },
        "version": {
          "const": "opl-stage-pack-integrity-metadata.v1"
        },
        "hash_algorithm": {
          "const": "sha256"
        },
        "stage_pack_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "hash_scope": {
          "const": "family_stage_control_plane_and_action_catalog_contract_refs"
        },
        "signature_status": {
          "type": "string",
          "enum": [
            "unsigned_digest_only",
            "signature_ref_declared"
