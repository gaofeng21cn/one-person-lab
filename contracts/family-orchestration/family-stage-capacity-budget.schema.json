{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/family-orchestration/family-stage-capacity-budget.schema.json",
  "title": "OPL Family Stage Capacity Budget Projection",
  "description": "Refs-only stage capacity budget projection over a FamilyStageControlPlane. It records launch-capacity refs without scheduling providers, claiming probability truth, or issuing domain-ready verdicts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "plane_id",
    "target_domain_id",
    "summary",
    "stages",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_family_stage_capacity_budget_projection" },
    "version": { "const": "family-stage-capacity-budget.v1" },
    "plane_id": { "type": "string", "minLength": 1 },
    "target_domain_id": { "type": "string", "minLength": 1 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_count",
        "ready_count",
        "needs_capacity_budget_count",
        "blocker_count",
        "runtime_boundary_required_count",
        "provider_launch_eligible_count",
        "capacity_ref_count"
      ],
      "properties": {
        "stage_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "needs_capacity_budget_count": { "type": "integer", "minimum": 0 },
        "blocker_count": { "type": "integer", "minimum": 0 },
        "runtime_boundary_required_count": { "type": "integer", "minimum": 0 },
        "provider_launch_eligible_count": { "type": "integer", "minimum": 0 },
        "capacity_ref_count": { "type": "integer", "minimum": 0 }
      }
    },
    "stages": {
      "type": "array",
      "items": { "$ref": "#/$defs/stage" }
    },
    "authority_boundary": { "$ref": "#/$defs/authority_boundary" }
  },
  "$defs": {
    "surface_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ref"],
      "properties": {
        "ref_kind": { "type": "string", "minLength": 1 },
        "ref": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "array", "items": { "type": "string", "minLength": 1 } }
          ]
        },
        "role": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 }
      }
    },
    "capacity_status": {
      "type": "string",
      "enum": ["ready", "needs_capacity_budget", "blocker"]
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage_id",
        "owner",
        "capacity_status",
        "runtime_boundary_required",
        "provider_launch_eligible",
        "capacity_ref_count",
        "event_log_growth_ref",
        "replay_sla_ref",
        "concurrency_limit_ref",
        "provider_rate_limit_ref",
        "proof_check_cost_ref",
        "guard_eval_cost_ref",
        "minimal_counterexamples"
      ],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "capacity_status": { "$ref": "#/$defs/capacity_status" },
        "runtime_boundary_required": { "type": "boolean" },
        "provider_launch_eligible": { "type": "boolean" },
        "capacity_ref_count": { "type": "integer", "minimum": 0 },
        "event_log_growth_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "replay_sla_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "concurrency_limit_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "provider_rate_limit_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "proof_check_cost_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "guard_eval_cost_ref": { "$ref": "#/$defs/nullable_surface_ref" },
        "minimal_counterexamples": { "type": "array", "items": { "$ref": "#/$defs/counterexample" } }
      }
    },
    "nullable_surface_ref": {
      "oneOf": [
        { "$ref": "#/$defs/surface_ref" },
        { "type": "null" }
      ]
    },
    "counterexample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "missing_field", "reason"],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "missing_field": {
          "type": "string",
          "enum": [
            "event_log_growth_ref",
            "replay_sla_ref",
            "concurrency_limit_ref",
            "provider_rate_limit_ref",
            "proof_check_cost_ref",
            "guard_eval_cost_ref",
            "rate_or_concurrency_limit_ref"
          ]
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "refs_only",
        "probability_truth_claim",
        "can_execute_stage",
        "can_schedule_provider",
        "can_write_domain_truth",
        "can_authorize_domain_ready",
        "can_authorize_quality_verdict",
        "can_mutate_artifact_body"
      ],
      "properties": {
        "opl_role": { "const": "capacity_projection_only" },
        "refs_only": { "const": true },
        "probability_truth_claim": { "const": false },
        "can_execute_stage": { "const": false },
        "can_schedule_provider": { "const": false },
        "can_write_domain_truth": { "const": false },
        "can_authorize_domain_ready": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "can_mutate_artifact_body": { "const": false }
      }
    }
  }
}
