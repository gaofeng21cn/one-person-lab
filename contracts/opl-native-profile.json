{
  "active_truth_owner": "docs/active/current-state-vs-ideal-gap.md",
  "canonical_docs": [
    {
      "path": "README.md",
      "role": "root_entry"
    },
    {
      "path": "AGENTS.md",
      "role": "repo_agent_working_rules"
    },
    {
      "path": "docs/README.md",
      "role": "docs_entry"
    },
    {
      "path": "docs/project.md",
      "role": "project_positioning"
    },
    {
      "path": "docs/status.md",
      "role": "current_status"
    },
    {
      "path": "docs/architecture.md",
      "role": "architecture_boundary"
    },
    {
      "path": "docs/invariants.md",
      "role": "hard_constraints"
    },
    {
      "path": "docs/decisions.md",
      "role": "active_decision_record"
    }
  ],
  "doc_profile": "opl_framework",
  "flow_closeout_gates": [
    {
      "kind": "completion_audit",
      "path": "contracts/opl-framework/opl-flow-completion-audit-contract.json",
      "required_for_claim_scopes": [
        "thorough_landing",
        "complete_execution",
        "end_to_end_acceptance",
        "production_ready_claim",
        "release_ready_claim"
      ]
    }
  ],
  "flow_profile": "opl_framework",
  "machine_truth_surfaces": [
    "contracts",
    "src",
    "tests",
    "package.json"
  ],
  "managed_by_plugins": {
    "opl-doc": {
      "does_not_own": [
        "domain_truth",
        "runtime_truth",
        "artifact_authority",
        "owner_receipts",
        "quality_verdicts"
      ],
      "managed_surfaces": [
        "contracts/opl-native-profile.json"
      ],
      "management": "profile_check_and_sync"
    },
    "opl-flow": {
      "does_not_own": [
        "repo_specific_guidance",
        "contracts",
        "source",
        "tests",
        "runtime_outputs",
        "project_truth"
      ],
      "managed_surfaces": [],
      "management": "workflow_profile_pointer",
      "version": "0.1.23"
    }
  },
  "owned_by_repo": [
    "contracts/**",
    "src/**",
    "tests/**",
    "docs/status.md",
    "docs/active/current-state-vs-ideal-gap.md"
  ],
  "plugin_native_status": "profile_declared",
  "repo_id": "one-person-lab",
  "repo_profile": "opl_framework",
  "schema": "opl_native_profile.v1",
  "taxonomy_dirs": [
    "docs/active",
    "docs/public",
    "docs/product",
    "docs/runtime",
    "docs/delivery",
    "docs/source",
    "docs/policies",
    "docs/specs",
    "docs/references",
    "docs/history"
  ],
  "verification_commands": [
    "scripts/verify.sh",
    "package.json:scripts.test",
    "package.json:scripts.test:fast",
    "package.json:scripts.test:meta",
    "package.json:scripts.test:full",
    "package.json:scripts.build",
    "package.json:scripts.lint",
    "package.json:scripts.typecheck"
  ]
}
