{
  "version": "p18.m1",
  "scope": "opl_surface_review_matrix",
  "description": "Machine-readable derived review matrix for the frozen OPL public, contract, and supporting surfaces. It records human-review obligations, acceptance coverage, companion review surfaces, wording-check mode, and publishability stage without becoming an approval engine, publish controller, or second source of truth.",
  "non_goals": [
    "approval_engine",
    "publish_controller",
    "release_engine",
    "truth_registry"
  ],
  "matrix_rules": [
    "entries are derived from already frozen OPL public surfaces, contract docs, supporting reference surfaces, and the current acceptance/public-surface indices",
    "human_review_required records whether explicit human review is required before a surface is treated as current public gateway material; it does not automate approval",
    "required_acceptance_gates must resolve to existing gate ids in contracts/opl-gateway/acceptance-matrix.json and required_companion_surfaces must resolve to known surface ids in contracts/opl-gateway/public-surface-index.json",
    "cross_domain_wording_check records whether wording alignment is enforced through the shared cross-domain gate or through local review obligations only",
    "publishability_stage describes documentation-readiness stage only; it does not transfer domain review or publication authority into OPL",
    "task-map review entries may cover under-definition workstreams only as top-level semantic candidates; they do not admit domains or create routed readiness",
    "candidate-domain backlog review entries may cover under-definition workstreams only as admission blockers; they do not create onboarding readiness, discovery readiness, or routed readiness",
    "candidate-domain backlog review entries may expose blocked admission material only; they do not assign future domain identities or create G2/G3 readiness"
  ],
  "covered_surface_ids": [
    "opl_public_readme",
    "opl_roadmap",
    "opl_gateway_rollout",
    "opl_task_map",
    "opl_operating_model",
    "opl_federation_contract",
