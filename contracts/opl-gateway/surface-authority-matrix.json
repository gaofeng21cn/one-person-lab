{
  "version": "p18.m2",
  "scope": "opl_surface_authority_matrix",
  "description": "Machine-readable derived authority matrix for the frozen OPL gateway surfaces and linked domain gateway public-entry surfaces. It records routing, execution, truth, review, and publication ownership boundaries without becoming an authorization engine or runtime control plane.",
  "non_goals": [
    "authorization_engine",
    "runtime_control_plane",
    "workflow_executor",
    "truth_registry"
  ],
  "matrix_rules": [
    "entries are derived from already frozen gateway contracts, operating surfaces, supporting surfaces, and linked domain public-entry surfaces",
    "OPL-owned surfaces may expose routing, indexing, discoverability, or acceptance boundaries but do not own domain execution, canonical truth, review truth, or publication truth",
    "linked domain public-entry surfaces remain domain-owned and mark where domain-local routing and harness execution begin",
    "allowed_follow_on_surface may be null or domain_gateway only",
    "candidate backlog surfaces may expose blocked admission material, but they do not allocate future domain authority or routed readiness"
  ],
  "covered_surface_ids": [
    "opl_shared_foundation_ownership",
    "opl_shared_foundation",
    "opl_operating_model",
    "opl_gateway_contract_hub",
