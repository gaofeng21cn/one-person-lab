{
  "version": "p13.m1",
  "scope": "opl_operating_record_catalog",
  "description": "Machine-readable reference catalog of the frozen top-level OPL operating record kinds across P5.M1 and P5.M2. This catalog is derived from the governing schemas, docs, and examples, and does not implement runtime behavior.",
  "non_goals": [
    "runtime_manifest",
    "truth_registry",
    "execution_router",
    "publish_authority_surface"
  ],
  "catalog_rules": [
    "entries are reference-level only and do not restate full schema truth",
    "domain-owned truth remains outside OPL and is only pointed to through the governing records",
    "if any follow-on domain action exists, the only allowed route surface remains domain_gateway",
    "the catalog does not authorize direct publish, release, export, submission, or posting by OPL"
  ],
