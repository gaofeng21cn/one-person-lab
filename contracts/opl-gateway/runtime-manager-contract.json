{
  "version": "v1",
  "contract_id": "opl_runtime_manager_contract",
  "contract_ref": "contracts/opl-gateway/runtime-manager-contract.json",
  "scope": "opl_product_managed_adapter_over_external_runtime_kernel",
  "description": "Freezes the first OPL Runtime Manager boundary. OPL manages provisioning, profile wiring, diagnostics, task registration hydration, status projection, optional native helper catalog, and high-frequency state indexes while Hermes-Agent remains the external runtime kernel owner.",
  "owner_split": {
    "product_manager_owner": "one-person-lab",
    "runtime_kernel_owner": "upstream_hermes_agent",
    "domain_truth_owners": [
      "med-autoscience",
      "med-autogrant",
      "redcube-ai"
    ],
    "concrete_executor_owner": "route_selected_by_domain_contract"
  },
  "manager_responsibilities": [
    "provision_supported_hermes_runtime",
    "pin_runtime_version_and_profile",
    "hydrate_domain_task_registration_contracts",
    "project_runtime_status_into_opl_sessions_progress_artifacts",
    "provide_runtime_doctor_repair_resume_entrypoints",
    "catalog_optional_native_helpers",
    "catalog_high_frequency_state_indexes"
  ],
  "domain_registration_registry": {
    "surface_kind": "opl_runtime_manager_registration_registry",
    "version": "v1",
    "registration_status": "declared_projection_contracts",
    "source_of_truth_rule": "OPL indexes declared domain registration surfaces and must dereference domain-owned durable truth before acting.",
    "registered_domains": [
      "medautoscience",
      "medautogrant",
      "redcube"
    ],
    "required_domain_registration_fields": [
      "surface_kind",
      "registration_id",
      "domain_id",
      "domain_owner",
      "runtime_owner",
      "domain_entry_surface",
      "consumable_projection_refs",
      "state_index_inputs",
      "non_goals"
    ],
    "domain_surface_refs": [
      "/skill_catalog/skills/0/domain_projection/opl_runtime_manager_registration"
    ]
  },
  "non_goals": [
    "not_a_scheduler_kernel",
    "not_a_session_or_memory_store",
    "not_a_domain_truth_owner",
    "not_a_concrete_executor",
    "not_a_private_fork_of_hermes_agent"
  ],
  "native_helper_target": {
    "status": "contracted_optional_rust_helpers",
    "language": "rust",
    "protocol_ref": "contracts/opl-gateway/native-helper-contract.json",
    "allowed_shape": "small_json_stdio_or_cli_helpers_managed_by_opl",
    "lifecycle": {
      "status_surface": "native_helper_target.lifecycle",
      "build_command": "npm run native:build",
      "prebuild_install_command": "npm run native:prebuild",
      "prebuild_pack_command": "npm run native:prebuild-pack",
      "prebuild_check_command": "npm run native:prebuild-check",
      "doctor_command": "npm run native:doctor",
      "repair_command": "npm run native:repair",
      "test_command": "npm run native:test",
      "packaged_source_files": [
        "Cargo.toml",
        "Cargo.lock",
        "native/opl-native-helper/Cargo.toml",
        "native/opl-native-helper/src",
        "scripts/native-helper-doctor.mjs",
        "scripts/native-helper-prebuild.mjs",
        "scripts/native-helper-repair.mjs"
      ],
      "prebuild_cache_strategy": {
        "manifest": "native-helper-prebuilds/<target_triple>/<crate_version>/manifest.json",
        "restore_order": [
          "OPL_NATIVE_HELPER_PREBUILD_ROOT",
          "package native-helper-prebuilds",
          "local Cargo build fallback"
        ],
        "cache_destination": "${OPL_STATE_DIR}/native-helper/bin/<target_triple>/<crate_version>"
      }
    },
    "runtime_invocation": {
      "status_surface": "native_helper_target.runtime",
      "discovery_env": "OPL_NATIVE_HELPER_BIN_DIR",
      "repair_command": "npm run native:repair",
      "required_runtime_manager_invocations": [
        "opl-doctor-native",
        "opl-state-indexer",
        "opl-artifact-indexer",
        "opl-runtime-watch"
      ]
    },
    "candidate_helpers": [
      "opl-sysprobe",
      "opl-doctor-native",
      "opl-runtime-watch",
      "opl-artifact-indexer",
      "opl-state-indexer"
    ]
  },
  "state_index_target": {
    "status": "rust_helper_backed_contract_first",
    "source_of_truth_rule": "indexes project runtime surfaces but never replace domain-owned durable truth",
    "persistence": {
      "status_surface": "state_index_target.persistence",
      "default_index_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index.json",
      "persisted_surface_kind": "opl_runtime_manager_native_state_projection",
      "lifecycle_files": {
        "history_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-history.jsonl",
        "failure_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-failures.jsonl",
        "last_success_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-last-success.json"
      },
      "freshness_statuses": [
        "fresh",
        "stale_last_success_available",
        "expired_last_success",
        "unavailable_no_success"
      ],
      "diff_summary": {
        "compared_fields": [
          "index_key",
          "helper_id",
          "result_surface_kind",
          "status"
        ],
        "count_fields": [
          "previous_index_count",
          "current_index_count",
          "added_count",
          "removed_count",
          "changed_count",
          "unchanged_count",
          "helper_changed_count",
          "result_surface_changed_count",
          "status_changed_count"
        ]
      },
      "failure_record": {
        "required_fields": [
          "generated_at",
          "status",
          "category",
          "errors",
          "details"
        ],
        "categories": [
          "helper_unavailable",
          "helper_error",
          "write_failed"
        ]
      },
      "history_gc": {
        "max_history_entries": 50,
        "reporting_fields": [
          "retained_history_count",
          "preserved_count",
          "removed_count",
          "history_count_before_gc",
          "history_count_after_gc"
        ]
      }
    },
    "candidate_indexes": [
      "workspace_registry_index",
      "managed_session_ledger_index",
      "artifact_projection_index",
      "attention_queue_index",
      "runtime_health_snapshot_index"
    ]
  },
  "future_sidecar_promotion_gate": "Only promote beyond a thin manager if Hermes cannot express required task, wakeup, approval, audit, or product isolation contracts."
}
