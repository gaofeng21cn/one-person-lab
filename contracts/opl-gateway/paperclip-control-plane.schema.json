{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/opl-gateway/paperclip-control-plane.schema.json",
  "title": "OPL Paperclip Control-Plane Bridge Payload",
  "description": "Machine-readable OPL bridge surface for projecting routed work, family human gates, and dashboard state into a downstream external Paperclip control plane without transferring runtime ownership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "contracts_context",
    "paperclip_control_plane"
  ],
  "properties": {
    "version": {
      "const": "g2"
    },
    "contracts_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contracts_dir",
        "contracts_root_source"
      ],
      "properties": {
        "contracts_dir": {
          "type": "string",
          "minLength": 1
        },
        "contracts_root_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "paperclip_control_plane": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action",
        "surface_id",
        "readiness",
        "connection",
        "summary"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "config",
            "bind",
            "status",
            "open_task",
            "open_gate"
          ]
        },
        "surface_id": {
          "const": "opl_paperclip_control_plane_bridge"
        },
        "readiness": {
          "type": "string",
          "enum": [
            "not_configured",
            "partial",
            "configured"
          ]
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "base_url",
            "auth",
            "control_company_id"
          ],
          "properties": {
            "base_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "header_env",
                "cookie_env",
                "header_present",
                "cookie_present"
              ],
              "properties": {
                "header_env": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "cookie_env": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "header_present": {
                  "type": "boolean"
                },
                "cookie_present": {
                  "type": "boolean"
                }
              }
            },
            "control_company_id": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "available_projects",
            "project_bindings_count",
            "bound_projects"
          ],
          "properties": {
            "available_projects": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "project_bindings_count": {
              "type": "integer",
              "minimum": 0
            },
            "bound_projects": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "version": "g2",
      "contracts_context": {
        "contracts_dir": "contracts/opl-gateway",
        "contracts_root_source": "cwd"
      },
      "paperclip_control_plane": {
        "action": "status",
        "surface_id": "opl_paperclip_control_plane_bridge",
        "readiness": "configured",
        "connection": {
          "base_url": "https://paperclip.example.com",
          "auth": {
            "header_env": "OPL_PAPERCLIP_AUTH_HEADER",
            "cookie_env": null,
            "header_present": true,
            "cookie_present": false
          },
          "control_company_id": "company-opl-control"
        },
        "summary": {
          "available_projects": [
            "opl",
            "medautoscience",
            "redcube"
          ],
          "project_bindings_count": 1,
          "bound_projects": [
            "redcube"
          ]
        }
      }
    }
  ]
}
