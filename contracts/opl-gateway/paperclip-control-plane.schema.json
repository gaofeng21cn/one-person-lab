{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opl.onepersonlab/contracts/opl-gateway/paperclip-control-plane.schema.json",
  "title": "OPL Paperclip Control-Plane Bridge Payload",
  "description": "Machine-readable OPL bridge surface for projecting routed work, family human gates, and dashboard state into a downstream external Paperclip control plane without transferring runtime ownership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "contracts_context",
    "paperclip_control_plane"
  ],
  "properties": {
    "version": {
      "const": "g2"
    },
    "contracts_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contracts_dir",
        "contracts_root_source"
      ],
      "properties": {
        "contracts_dir": {
          "type": "string",
          "minLength": 1
        },
        "contracts_root_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "paperclip_control_plane": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action",
        "surface_id",
        "readiness",
        "connection",
        "summary"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "config",
            "bind",
            "status",
            "bootstrap",
            "open_task",
            "open_gate",
            "sync",
            "operator_loop"
          ]
        },
        "surface_id": {
          "const": "opl_paperclip_control_plane_bridge"
        },
        "readiness": {
          "type": "string",
          "enum": [
            "not_configured",
            "partial",
            "configured"
          ]
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "base_url",
            "auth",
            "control_company_id"
          ],
          "properties": {
            "base_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "header_env",
                "cookie_env",
                "header_present",
                "cookie_present"
              ],
              "properties": {
                "header_env": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "cookie_env": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "header_present": {
                  "type": "boolean"
                },
                "cookie_present": {
                  "type": "boolean"
                }
              }
            },
            "control_company_id": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "available_projects",
            "project_bindings_count",
            "bound_projects",
            "tracked_projections_count",
            "tracked_task_projections_count",
            "tracked_gate_projections_count",
            "tracked_pending_gate_count",
            "tracked_resolved_gate_count",
            "last_projection_at",
            "last_polled_at",
            "last_sync_at"
          ],
          "properties": {
            "available_projects": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "project_bindings_count": {
              "type": "integer",
              "minimum": 0
            },
            "bound_projects": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "tracked_projections_count": {
              "type": "integer",
              "minimum": 0
            },
            "tracked_task_projections_count": {
              "type": "integer",
              "minimum": 0
            },
            "tracked_gate_projections_count": {
              "type": "integer",
              "minimum": 0
            },
            "tracked_pending_gate_count": {
              "type": "integer",
              "minimum": 0
            },
            "tracked_resolved_gate_count": {
              "type": "integer",
              "minimum": 0
            },
            "last_projection_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "last_polled_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "last_sync_at": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "project_bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "project_id",
              "project",
              "company_id",
              "paperclip_project_id",
              "project_workspace_id",
              "execution_workspace_preference",
              "created_at",
              "updated_at"
            ],
            "properties": {
              "project_id": {
                "type": "string",
                "minLength": 1
              },
              "project": {
                "type": "string",
                "minLength": 1
              },
              "company_id": {
                "type": "string",
                "minLength": 1
              },
              "paperclip_project_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "project_workspace_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "execution_workspace_preference": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "created_at": {
                "type": "string",
                "minLength": 1
              },
              "updated_at": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "tracked_projections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "projection_id",
              "projection_kind",
              "target_project_id",
              "company_id",
              "issue_id",
              "approval_id",
              "workspace_path",
              "remote_issue_status",
              "approval_status",
              "gate_status",
              "gate_decision",
              "created_at",
              "last_polled_at",
              "last_sync_at",
              "sync_count"
            ],
            "properties": {
              "projection_id": {
                "type": "string",
                "minLength": 1
              },
              "projection_kind": {
                "type": "string",
                "enum": [
                  "task",
                  "gate"
                ]
              },
              "target_project_id": {
                "type": "string",
                "minLength": 1
              },
              "company_id": {
                "type": "string",
                "minLength": 1
              },
              "issue_id": {
                "type": "string",
                "minLength": 1
              },
              "approval_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "workspace_path": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "remote_issue_status": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "approval_status": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "gate_status": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "gate_decision": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "created_at": {
                "type": "string",
                "minLength": 1
              },
              "last_polled_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "last_sync_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "sync_count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "operator_loop": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "state_file",
            "state",
            "last_started_at",
            "last_completed_at",
            "last_error",
            "last_run_summary"
          ],
          "properties": {
            "state_file": {
              "type": "string",
              "minLength": 1
            },
            "state": {
              "type": "string",
              "enum": [
                "idle",
                "running"
              ]
            },
            "last_started_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "last_completed_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "last_error": {
              "type": [
                "string",
                "null"
              ]
            },
            "last_run_summary": {
              "type": [
                "object",
                "null"
              ],
              "additionalProperties": false,
              "required": [
                "cycles_completed",
                "matched_projection_count",
                "synced_count",
                "skipped_count",
                "approval_updates_count",
                "resolved_gate_count"
              ],
              "properties": {
                "cycles_completed": {
                  "type": "integer",
                  "minimum": 0
                },
                "matched_projection_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "synced_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "skipped_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "approval_updates_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "resolved_gate_count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "version": "g2",
      "contracts_context": {
        "contracts_dir": "contracts/opl-gateway",
        "contracts_root_source": "cwd"
      },
      "paperclip_control_plane": {
        "action": "status",
        "surface_id": "opl_paperclip_control_plane_bridge",
        "readiness": "configured",
        "connection": {
          "base_url": "https://paperclip.example.com",
          "auth": {
            "header_env": "OPL_PAPERCLIP_AUTH_HEADER",
