        },
        {
          "pattern_id": "directory_inline_product_entry",
          "regex": "(?:^|(?:&&|\\|\\||[;&|])\\s*)uv\\s+run\\s+--directory\\s+\\S+\\s+(?:python|python3)\\s+-c\\s+.*med_autogrant\\.product_entry"
