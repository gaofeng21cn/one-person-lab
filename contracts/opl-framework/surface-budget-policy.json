{
  "contract_kind": "opl_surface_budget_policy.v1",
  "owner": "one-person-lab",
  "state": "active_policy",
  "purpose": "Keep OPL AI-first and contract-light by limiting default surfaces to the Minimal Trust Kernel and attention entries.",
  "surface_model": {
    "minimal_trust_kernel": {
      "role": "contract_floor",
      "covers": [
        "launch_safety",
        "authority_boundary",
        "owner_boundary",
        "selected_executor_binding",
        "scope_refs",
        "runtime_event_refs",
        "receipt_refs",
        "replay_audit_refs",
        "route_back_refs"
      ],
      "does_not_cover": [
        "ai_reasoning_strategy",
        "stage_internal_planning",
        "domain_quality_verdict",
        "artifact_authority",
        "production_ready_verdict",
        "fixed_workflow_compilation"
      ]
    },
    "attention_entry": {
      "role": "default_operator_app_entry",
      "payload_style": "summary_first",
      "default_stage_command": "opl stages readiness --family-defaults",
      "default_operator_payload": "current_owner_delta",
      "default_read_contract": {
        "surface_kind": "opl_default_read_surface_contract",
        "normal_app_state_command": "opl app state --profile fast --json",
        "default_projection": "opl_current_owner_delta",
        "full_detail_policy": "explicit_full_detail_or_lazy_diagnostic_only",
        "raw_refs_policy": "raw_refs_require_explicit_full_detail",
        "first_screen_answer_policy": "owner_delta_action_artifact_or_blocker_only",
        "ordinary_progress_fields": [
          "ordinary_progress_spine",
          "progress_delta_receipt",
          "artifact_tier_policy",
          "audit_sidecar_policy"
        ],
        "diagnostic_only_answers": [
          "count_summary",
          "audit_next_safe_action_or_none",
          "full_detail_refs"
        ],
        "forbidden_fast_profile_fields": [
          "runtime_tray_snapshot",
          "raw_evidence_envelope",
          "raw_evidence_browser",
          "raw_ledger_browser",
          "ledger_browser",
          "stage_replay_packet_body",
          "private_residue_inventory_body",
          "provider_internal_ledger_body",
          "provider_internal_trace",
          "route_variant_menu"
        ]
      }
    },
    "diagnostic_lens": {
      "role": "explicit_drilldown_only",
      "author_required_by_default": false,
      "default_help_surface": false,
      "default_doc_entry": false,
      "can_block_launch_by_default": false,
      "folded_into_attention_entry": true
    },
    "history_reference": {
      "role": "provenance_only",
      "can_define_current_runtime": false,
      "can_define_default_surface": false
    }
  },
  "default_surface_allowed_reasons": [
    "launch_safety",
    "authority_boundary",
    "evidence_replay_audit_route_back",
    "repeated_app_runtime_consumption"
  ],
  "default_surface_denied_reasons": [
    "ai_reasoning_strategy",
    "stage_internal_planning",
    "domain_quality_claim",
    "artifact_authority_claim",
    "workflow_shape_preference",
    "paper_or_framework_learning_point_only",
    "single_consumer_diagnostic_only"
  ],
  "grip_big_release_small_review": {
    "review_id": "grip_big_release_small.v1",
    "purpose": "Prevent governance detail from becoming the ordinary owner-delta blocker unless it protects a hard boundary.",
    "required_questions": [
      "which_big_boundary_is_protected",
      "what_is_the_default_lane",
      "when_may_it_upgrade_to_hard_blocker",
      "when_must_it_demote_to_advisory_audit_diagnostic_cleanup_or_production_lane",
      "what_accepted_owner_answer_shape_closes_it"
    ],
    "big_boundaries_fail_closed": [
      "owner_boundary",
      "authority_boundary",
      "workspace_topology",
      "selected_executor_binding",
      "single_ordinary_route",
      "wrong_target_identity_conflict",
      "irreversible_action_authority",
      "explicit_human_decision",
      "app_release_verdict",
      "physical_delete_authority",
      "no_second_truth"
    ],
    "small_detail_default_lanes": [
      "advisory",
      "audit",
      "diagnostic",
      "cleanup",
      "production_evidence"
    ],
    "small_detail_examples": [
      "prompt_skill_tool_knowledge_rubric_ref_completeness",
      "path_alias",
      "generated_projection_mirror",
      "workspace_fleet_or_inventory_drift",
      "worklist_raw_counter",
      "diagnostic_proof",
      "route_variant",
      "receipt_accounting",
      "wrapper_lineage",
      "l5_evidence_matrix_item",
      "provider_ops_detail",
      "release_cohort_diagnostic"
    ],
    "hard_blocker_upgrade_conditions": [
      "wrong_launch",
      "authority_violation",
      "not_recoverable",
      "not_auditable",
      "cannot_closeout",
      "invalid_owner_answer_shape",
      "irreversible_mutation"
    ],
    "ordinary_path_root": "current_owner_delta",
    "ordinary_progress_spine": {
      "default_planning_root": "current_owner_delta",
      "default_next_action_derives_from": "current_owner_delta",
      "lightweight_receipt": "ProgressDeltaReceipt",
      "lightweight_receipt_tier": "T0_progress_delta",
      "audit_sidecar_role": "passive_evidence_ledger_and_drilldown"
    },
    "artifact_tiers": [
      "T0_progress_delta",
      "T1_stage_transition",
      "T2_delivery_artifact",
      "T3_production_evidence"
    ],
    "progress_delta_receipt_cannot_authorize": [
      "stage_complete",
      "publication_ready",
      "package_ready",
      "artifact_mutation",
      "memory_accept_reject",
      "production_ready"
    ],
    "audit_sidecar_must_not_generate_default_next_action": true,
    "surface_plane_binding_required": true,
    "default_surface_requires_plane_ref": true,
    "ordinary_surface_allowed_planes": [
      "ordinary_progress_plane",
      "durable_runway_plane",
      "authority_decision_plane",
      "reconciler_plane",
      "app_cockpit_plane"
    ],
    "non_authority_surface_forbidden_outputs": [
      "domain_owner_answer",
      "domain_typed_blocker",
      "quality_or_export_verdict",
      "artifact_body_mutation",
      "memory_body_mutation",
      "domain_ready_declaration",
      "production_ready_declaration"
    ],
    "ordinary_path_must_not_be_overridden_by": [
      "raw_worklist",
      "evidence_ledger",
      "provider_trace",
      "route_variant_menu",
      "private_residue_inventory",
      "cleanup_delete_gate",
      "l5_evidence_ledger",
      "release_diagnostics"
    ],
    "accepted_owner_answer_shapes": [
      "owner_receipt_ref",
      "domain_owner_receipt_ref",
      "quality_gate_receipt_ref",
      "human_gate_ref",
      "typed_blocker_ref",
      "no_regression_ref",
      "long_soak_ref",
      "route_back_ref",
      "route_back_evidence_ref",
      "physical_delete_authorization_ref",
      "keep_as_authority_adapter_ref"
    ]
  },
  "default_doc_entry_budget": {
    "stage_default_commands": [
      "opl stages readiness --family-defaults"
    ],
    "stage_diagnostic_commands": [
      "opl stages graph --domain <domain>",
      "opl stages proof-bundle --domain <domain>",
      "opl stages assumptions --domain <domain>",
      "opl stages cohort-loop --domain <domain>",
      "opl stages runtime-budget --domain <domain>",
      "opl stages registry --domain <domain>",
      "opl stages source-spec --domain <domain>",
      "opl stages replay-certification --domain <domain>"
    ],
    "forbidden_default_stage_commands": [
      "opl stages graph --domain <domain>",
      "opl stages proof-bundle --domain <domain>",
      "opl stages assumptions --domain <domain>",
      "opl stages cohort-loop --domain <domain>",
      "opl stages runtime-budget --domain <domain>",
      "opl stages registry --domain <domain>",
      "opl stages source-spec --domain <domain>",
      "opl stages replay-certification --domain <domain>",
      "opl stages capacity-budget --domain <domain>",
      "opl stages domain-validity --domain <domain>",
      "opl stages guarantee --domain <domain>",
      "opl stages property --domain <domain>",
      "opl stages isolation --domain <domain>"
    ]
  },
  "promotion_gate": {
    "new_surface_default_state": "diagnostic_lens_or_reference",
    "new_default_surface_requires_any_ref_from": [
      "replaced_or_folded_surface_ref",
      "retired_surface_ref",
      "folded_into_attention_entry_ref"
    ],
    "default_surface_requires_any_reason_from": [
      "launch_safety",
      "authority_boundary",
      "evidence_replay_audit_route_back",
      "repeated_app_runtime_consumption"
    ],
    "hard_gate_allowed_reasons": [
      "launch_safety",
      "authority_boundary",
      "runtime_boundary_event",
      "receipt_replay_audit_route_back"
    ],
    "hard_gate_requires_any_reason_from": [
      "launch_safety",
      "authority_boundary",
      "runtime_boundary_event",
      "receipt_replay_audit_route_back"
    ],
    "hard_gate_denied_reason_classes": [
      "advisory",
      "diagnostic",
      "graphflow_gfl_learning_point",
      "capacity_budget",
      "domain_validity",
      "guarantee",
      "property",
      "isolation"
    ],
    "repeated_app_runtime_consumption_requires": {
      "minimum_distinct_consumers": 2,
      "allowed_consumers": [
        "app",
        "operator_cli",
        "queue",
        "provider",
        "runtime_action_shell"
      ]
    }
  },
  "authority_boundary": {
    "can_claim_domain_ready": false,
    "can_claim_quality_verdict": false,
    "can_claim_artifact_authority": false,
    "can_claim_production_ready": false,
    "can_replace_ai_executor_planning": false,
    "can_replace_domain_owner": false
  }
}
