{
  "contract_kind": "opl_stage_route_scheduler_contract.v1",
  "owner": "one-person-lab",
  "scope": "framework-level stage graph scheduling, route hydration, reconciliation, and attempt ledger boundaries for complex domain agents",
  "model": "stage_graph_reconciliation_with_owner_route_hydration",
  "contract_laws": {
    "route_not_stage_strategy": true,
    "audit_tail_cannot_plan": true,
    "route_reconciler_role": "hydrate_reconcile_owner_routes_only",
    "default_planning_root": "current_owner_delta",
    "audit_tail_inputs": [
      "raw_evidence_envelope",
      "replay_packet",
      "receipt_ledger",
      "typed_blocker_group",
      "private_residue_inventory",
      "diagnostic_trace_or_metric"
    ],
    "audit_tail_default_planning_role": "passive_until_folded_to_current_owner_delta_owner_answer_typed_blocker_or_hard_gate"
  },
  "canonical_definitions": {
    "stage": {
      "owner": "one-person-lab",
      "meaning": "an executable, recoverable, auditable attempt unit launched from an admitted stage pack",
      "machine_surfaces": [
        "family-stage-control-plane.schema.json",
        "family-stage-admission.schema.json",
        "family-stage-graph-projection.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "required_runtime_proof": [
        "stage_attempt_id",
        "provider_receipt",
        "checkpoint_refs",
        "closeout_refs",
        "human_gate_refs",
        "typed_blocker_refs_or_owner_receipt_refs"
      ]
    },
    "route": {
      "owner": "domain-agent",
      "meaning": "a domain owner semantic that names the next owner, route-back target, typed blocker, safe action ref, or owner receipt ref",
      "machine_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "domain-owned owner receipt schema",
        "domain-owned typed blocker schema"
      ],
      "is_executable_stage": false,
      "is_small_stage": false,
      "can_complete_stage_attempt": false
    },
    "route_hydration": {
      "owner": "one-person-lab",
      "meaning": "OPL resolves domain owner route refs into Temporal-backed stage attempt requests, conflict envelopes, or operator projections without executing the route itself",
      "must_only": [
        "hydrate_domain_owner_route_refs",
        "reconcile_provider_attempt_ledger_and_projection_state",
        "emit_conflict_or_operator_projection_refs"
      ],
      "must_not": [
        "generate_stage_candidates",
        "evaluate_or_rank_stage_candidates",
        "complete_stage_attempts",
        "sign_owner_receipts",
        "create_typed_blockers",
        "write_domain_truth",
        "derive_default_plan_from_audit_tail"
      ],
      "machine_surfaces": [
        "opl family-runtime attempt create",
        "opl family-runtime provider-slo tick --provider temporal",
        "family-runtime-attempt-contract.json",
        "family-conflict-envelope.schema.json"
      ]
    },
    "attempt_ledger": {
      "owner": "one-person-lab",
      "meaning": "append-only control metadata for provider-backed stage attempts, checkpoints, human gates, retries, dead letters, closeout refs, and reconciliation status",
      "machine_surfaces": [
        "family-runtime-attempt-contract.json",
        "StageAttemptWorkflow",
        "stage_attempt_workbench"
      ]
    }
  },
  "mas_reference_flow": {
    "role": "complex_domain_agent_reference",
    "domain_owner_outputs": [
      "owner_route_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "source_refs",
      "source_fingerprint",
      "dispatch_ref",
      "recommended_task_kind"
    ],
    "opl_owned_hydration_outputs": [
      "stage_attempt_request",
      "stage_attempt_ledger_entry",
      "operator_projection",
      "conflict_or_blocker_envelope"
    ],
    "forbidden_interpretations": [
      "MAS route is a nested OPL stage",
      "MAS route completion is OPL stage completion",
      "OPL stage-attempt projection creates MAS owner receipt",
      "provider completion authorizes publication or artifact readiness"
    ]
  },
  "scheduler_layers": [
    {
      "layer": "stage_graph",
      "owner": "one-person-lab",
      "purpose": "project admitted stage packs, requires/ensures edges, launch blockers, route-back evidence, and integrity digests as a scheduler and App read model",
      "primary_surfaces": [
        "family-stage-graph-projection.schema.json",
        "family-stage-proof-bundle.schema.json",
        "family-stage-replay-certification.schema.json"
      ],
      "authority_boundary": "read_model_only_no_domain_verdict"
    },
    {
      "layer": "owner_route_hydration",
      "owner": "one-person-lab",
      "purpose": "consume domain owner route refs and produce Temporal stage-attempt or conflict/read-model projection records",
      "primary_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "authority_boundary": "transport_and_projection_only"
    },
    {
      "layer": "reconciliation_loop",
      "owner": "one-person-lab",
      "purpose": "compare desired route/stage refs with actual Temporal provider history, stage-attempt ledger, human gate, dead-letter, and receipt state",
      "primary_surfaces": [
        "opl family-runtime provider-slo tick --provider temporal",
        "opl runtime manager",
        "stage_attempt_workbench",
        "operator_conflicts"
      ],
      "authority_boundary": "reconcile_control_state_without_domain_truth"
    },
    {
      "layer": "attempt_ledger",
      "owner": "one-person-lab",
      "purpose": "record durable stage attempt lifecycle, event history refs, checkpoints, closeout refs, typed blockers, owner receipts, retries, and replay evidence",
      "primary_surfaces": [
        "family-runtime-attempt-contract.json",
        "Temporal workflow history",
        "sqlite projection/readback sidecar"
      ],
      "authority_boundary": "control_metadata_only"
    }
  ],
  "reconciliation_steps": [
    "discover_domain_owner_route_refs",
    "normalize_task_identity_and_idempotency_key",
    "resolve_admitted_stage_pack_or_return_typed_blocker",
    "check_stage_graph_requires_ensures_and_launch_boundary",
    "hydrate_route_ref_into_stage_attempt_request",
    "append_attempt_ledger_or_conflict_envelope",
    "dispatch_selected_executor_or_domain_callable_when_authorized",
    "observe_provider_history_checkpoint_closeout_and_receipts",
    "reconcile_actual_status_back_to_operator_read_model",
    "route_back_dead_letter_or_wait_for_human_gate_when_unclosed"
  ],
  "current_control_admission_currentness_policy": {
    "purpose": "Classify which provider-backed stage-attempt projection rows may represent the current MAS provider admission during supersession and provider cadence selection.",
    "current_admission_statuses": [
      "queued",
      "retry_waiting",
      "running",
      "waiting_approval"
    ],
    "retryable_blocked_dead_letter_reasons": [
      "temporal_stage_attempt_start_failed",
      "temporal_stage_attempt_not_completed",
      "temporal_stage_attempt_failed"
    ],
    "blocked_reasons_not_current_admission": [
      "mas_default_executor_superseded_by_current_source",
      "temporal_stage_attempt_canceled",
      "temporal_workflow_canceled"
    ],
    "terminal_or_canceled_residue_policy": "audit_or_stale_redrive_filter_only",
    "fresh_admission_precedence": "a fresh MAS current owner-route or current-control provider admission with matching study/action/work-unit identity must not be superseded by canceled, terminal, superseded, or otherwise non-retryable blocked residue",
    "authority_boundary": {
      "can_select_transport_task": true,
      "can_filter_stale_redrive": true,
      "can_write_domain_truth": false,
      "can_create_owner_receipt": false,
      "can_create_typed_blocker": false,
      "provider_completion_is_domain_ready": false
    }
  },
  "stage_route_arbiter_substrate_contract": {
    "surface_kind": "opl_stage_route_arbiter_substrate_contract",
    "schema_version": 1,
    "owner": "one-person-lab",
    "purpose": "Define the OPL-owned substrate guarantees that let domain agents run a single smooth stage-route loop without false running, repeated pending echo, or no-progress redrive loops.",
    "ordinary_path": [
      "fresh_current_owner_delta",
      "domain_provider_admission_identity",
      "stage_run_currentness_identity",
      "provider_attempt_or_owner_callable",
      "terminal_closeout_packet_ref",
      "domain_closeout_consumption_ref",
      "next_current_owner_delta_or_typed_blocker"
    ],
    "currentness_precedence": [
      "terminal_closeout_for_same_stage_attempt",
      "strict_live_attempt_for_same_identity",
      "accepted_closeout_or_executed_typed_blocker_for_same_identity",
      "fresh_provider_admission_identity",
      "stable_domain_typed_blocker",
      "diagnostic_or_stale_residue"
    ],
    "domain_progress_transition_runtime_first_slice": {
      "surface_kind": "opl_domain_progress_transition_runtime_first_slice",
      "schema_version": 1,
      "source_target_design": "human_doc:domain_progress_transition_runtime_target_design",
      "status": "runtime_slice_landed_non_ready",
      "purpose": "Land the minimal generic OPL substrate for domain progress transitions through existing Runway, Pack, Stagecraft, Console, and Ledger responsibilities without creating an eleventh brand module or a domain truth source.",
      "implementation_refs": {
        "runtime_source": "src/family-runtime-domain-progress-transition-runtime.ts",
        "current_control_consumer": "src/family-runtime-domain-intake-parts/current-control-provider-admission.ts",
        "focused_test": "tests/src/cli/cases/family-runtime-domain-progress-transition-runtime.test.ts",
        "provider_admission_regression_test": "tests/src/cli/cases/family-runtime-current-control-provider-admission.test.ts",
        "policy_adapter_source": "src/family-runtime-domain-progress-transition-runtime-parts/policy-adapter.ts",
        "policy_adapter_contract_export": "DOMAIN_PROGRESS_POLICY_ADAPTER_CONTRACT",
        "policy_adapter_focused_test": "tests/src/cli/cases/family-runtime-domain-progress-transition-runtime.test.ts"
      },
      "physical_persistence_refs": {
        "runtime_log_read_api": "readDomainProgressTransitionRuntimeLogJsonl",
        "runtime_log_append_api": "appendDomainProgressTransitionRuntimeResultJsonl",
        "idempotency_readback_api": "readDomainProgressTransitionIdempotencyJsonl",
        "runtime_live_readback_api": "readDomainProgressTransitionRuntimeReadbackJsonl",
        "replay_audit_api": "auditDomainProgressTransitionReplay",
        "storage_contract": "append_only_physical_jsonl",
        "runtime_live_readback_contract": {
          "complete_transaction_status": "complete_transaction",
          "incomplete_transaction_status": "incomplete_transaction",
          "complete_transaction_requires": [
            "command_event_outbox_entries_present",
            "event_and_outbox_entry_share_latest_transaction_id",
            "outbox_entry_item_id_matches_payload_item_id",
            "outbox_payload_item_id_matches_read_model_latest_outbox_item_id",
            "outbox_payload_transition_event_id_matches_latest_event_id"
          ],
          "incomplete_transaction_fail_closed_reason": "domain_progress_transition_readback_incomplete_transaction",
          "incomplete_transaction_outcome_kind": "blocked_incomplete_transaction",
          "projection_metadata_complete_role": "complete_runtime_readback",
          "projection_metadata_incomplete_role": "fail_closed_runtime_readback",
          "projection_metadata_consumable_only_when_transaction_complete": true,
          "replay_audit_surface_kind": "opl_domain_progress_transition_replay_audit",
          "replay_audit_ready_status": "replay_ready",
          "replay_audit_fail_closed_status": "fail_closed",
          "replay_audit_consumable_only_when_complete": true,
          "authority_boundary": "opl_runtime_primitive_readback_only_no_domain_truth_owner_receipt_or_typed_blocker"
        },
        "focused_test": "tests/src/cli/cases/family-runtime-domain-progress-transition-runtime.test.ts"
      },
      "brand_module_partition": {
        "module_count_policy": "no_new_brand_module",
        "Runway": "owns current-control intake, provider admission, exactly-one transition choice, NonAdvancingApply, and retry/replay guardrails",
        "Pack": "owns domain-declared transition request and normalized command/outbox/event shape, aggregate identity, expected version, postcondition/outcome, and authority ABI refs",
        "Stagecraft": "owns StageRun identity, stage packet refs, transition decision vocabulary, and runner/replay semantics",
        "Console": "owns operator read-model metadata including observed_generation, derived_generation, NonAdvancingApply, and typed blocked reason projection",
        "Ledger": "owns append-only outbox/event/replay refs and evidence retention without domain body authority"
      },
      "allowed_transition_decisions": [
        "execute_current_owner_delta",
        "consume_terminal_closeout",
        "materialize_recovery_action",
        "wait_for_owner_with_resume_token",
        "stop_with_stable_typed_blocker",
        "stop_with_owner_receipt"
      ],
      "decision_surface_policy": {
        "query_role": "read_only_current_obligation_and_evidence_refs",
        "update_role": "identity_bound_stage_route_or_recovery_obligation_transition",
        "signal_role": "owner_or_human_resume_token_only",
        "read_model_can_execute": false,
        "observability_can_close_owner_answer": false
      },
      "concepts": {
        "StageRunIdentityPacket": {
          "existing_surfaces": [
            "stage_run_currentness_identity",
            "stage-run-kernel-contract.json",
            "family-runtime-attempt-contract.json",
            "runtime stage-run-authorization ledger"
          ],
          "required_identity_refs": [
            "stage_run_id",
            "route_identity_key",
            "attempt_idempotency_key",
            "selected_dispatch_ref",
            "stage_packet_ref",
            "stage_packet_refs",
            "provider_attempt_ref",
            "attempt_lease_ref",
            "workflow_ref",
            "source_fingerprint",
            "truth_epoch",
            "runtime_health_epoch"
          ],
          "authority_boundary": "opl_identity_and_transport_only_no_domain_receipt_or_publication_verdict"
        },
        "HumanGateTransport": {
          "existing_surfaces": [
            "contracts/family-orchestration/family-human-gate.schema.json",
            "StageAttemptWorkflow resume signals",
            "stage_attempt_workbench resume ledger",
            "owner-answer.schema.json human_decision"
          ],
          "required_transport_refs": [
            "resume_token",
            "owner",
            "allowed_decisions",
            "timeout_policy",
            "default_safe_branch",
            "current_identity",
            "evidence_required"
          ],
          "authority_boundary": "opl_transports_resume_token_domain_or_human_owner_supplies_answer"
        },
        "TransitionObligationStore": {
          "existing_surfaces": [
            "current-owner-delta.schema.json",
            "state-index-kernel-contract.json"
          ],
          "required_obligation_refs": [
            "obligation_id",
            "desired_delta_ref",
            "current_identity",
            "status",
            "last_evidence_refs",
            "stale_read_model_lag",
            "transition_decision_ref"
          ],
          "landed_support": "current-control provider admission now consumes a domain transition request or OPL-native command record, preserves aggregate/study/work-unit identity, and carries OPL-generated transition apply metadata into stage-attempt request/projection locators without domain truth authority",
          "non_advancing_apply_current_transition_readback": {
            "landed_support": "authorized default-executor stage packets that require OPL execution authorization but lack a domain transition request or OPL-native command record are recorded as complete DomainProgressTransitionRuntime NonAdvancingApply transactions instead of being admitted as provider tasks",
            "runtime_log_ref": "runtime/artifacts/supervision/domain_progress_transition_runtime/command_event_log.jsonl",
            "current_control_refresh_source": "opl_transition_runtime_readback_non_advancing_apply",
            "current_control_action_status": "transition_non_advancing_apply_recorded",
            "provider_admission_allowed": false,
            "current_executable_owner_action_allowed": false,
            "deliverable_progress_delta": false,
            "stale_default_executor_pending_suppressed": true,
            "authority_boundary": {
              "opl_can_write_mas_truth": false,
              "opl_can_create_domain_owner_receipt": false,
              "opl_can_create_domain_typed_blocker": false,
              "provider_completion_is_domain_ready": false
            }
          },
          "durable_substrate_first_slice": {
            "obligation_store": "append_only_physical_jsonl_identity_bound",
            "command_event_log": "append_only_physical_jsonl_command_event_outbox_entries",
            "idempotency_readback": "command_event_outbox_transaction_readback_by_idempotency_key",
            "live_readback": "physical_jsonl_command_event_outbox_transaction_complete_or_fail_closed",
            "closeout_inbox": "append_only_physical_jsonl_pending_consumed_rejected_identity_bound",
            "same_identity_redrive_policy": "fail_closed_when_decision_is_not_current_latest_for_identity",
            "authority_boundary": {
              "opl_can_write_mas_truth": false,
              "opl_can_create_domain_owner_receipt": false,
              "opl_can_create_domain_typed_blocker": false,
              "provider_completion_is_domain_ready": false
            }
          },
          "remaining_gap": "dedicated provider-backed runtime soak and SQLite/index integration are not yet proven by end-to-end runtime soak"
        },
        "TransitionDecisionEngine": {
          "existing_surfaces": [
            "runway readiness",
            "runway reconcile",
            "runway handoff-gates",
            "runway recovery-repair",
            "runway control-loop status",
            "stage_route_arbiter_substrate_contract"
          ],
          "decision_inputs": [
            "current_owner_delta",
            "StageRunIdentityPacket",
            "terminal_closeout_packet_ref",
            "human_gate_ref",
            "owner_receipt_ref",
            "provider_liveness_or_repair_state",
            "observability_refs"
          ],
          "landed_support": "DomainProgressTransitionRuntime first slice uses current-control/provider admission as the generic transition consumer: domain transition request or OPL-native command identity is required, legacy supervisor apply alias is fail-closed, exactly-one advancing transition is selected per StageRun identity, NonAdvancingApply is projected as metadata rather than progress, and replay fixtures remain refs-only",
          "durable_substrate_first_slice": {
            "ledger": "append_only_physical_jsonl",
            "transactional_outbox": "event_and_outbox_item_share_one_runtime_transaction_result_with_dedupe_readback",
            "live_readback": "read_physical_jsonl_and_require_command_event_outbox_same_transaction_and_outbox_identity_before_consumption",
            "replay_audit": "latest_transaction_is_consumable_only_when_command_event_outbox_and_stage_run_identity_form_exactly_one_complete_transaction",
            "fixed_point_reconciler": "observations_and_command_produce_exactly_one_transition_or_non_advancing_apply",
            "replay_harness": "multi_step_trace_exposes_step_evidence_for_exactly_one_or_non_advancing_apply",
            "human_gate_resume_token": "transport_shape_landed_without_opl_supplying_human_or_domain_answer",
            "read_model_rebuild_metadata": "derived_from_event_id_observed_generation_derived_generation_authority_false",
            "current_latest_policy": "exactly_one_latest_current_decision_per_obligation_identity",
            "identity_mismatch_policy": "reject_without_current_latest_projection",
            "stage_attempt_projection_empty_terminal_evidence": false,
            "authority_boundary": {
              "opl_can_write_mas_truth": false,
              "opl_can_create_domain_owner_receipt": false,
              "opl_can_create_domain_typed_blocker": false,
              "provider_completion_is_domain_ready": false
            },
            "policy_adapter_abi": "domain_policy_request_only_normalized_before_command_materialization"
          },
          "remaining_gap": "real domain owner receipt consumption side effects, terminal closeout consumption, end-to-end runtime soak, and live domain progression evidence are not yet proven for all decision classes",
          "required_decision_refs": {
            "execute_current_owner_delta": [
              "current_owner_delta_ref",
              "provider_admission_identity_ref"
            ],
            "consume_terminal_closeout": [
              "terminal_closeout_ref"
            ],
            "materialize_recovery_action": [
              "recovery_action_ref_or_no_progress_or_inconsistency_ref"
            ],
            "wait_for_owner_with_resume_token": [
              "human_gate_ref",
              "resume_token"
            ],
            "stop_with_stable_typed_blocker": [
              "typed_blocker_ref",
              "budget_or_missing_evidence_ref"
            ],
            "stop_with_owner_receipt": [
              "owner_receipt_ref"
            ]
          },
          "runtime_apply_targets": {
            "execute_current_owner_delta": {
              "kind": "provider_attempt_or_owner_callable",
              "provider_admission_required": true,
              "owner_callable_required": true,
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            },
            "consume_terminal_closeout": {
              "kind": "terminal_closeout_consumption",
              "provider_admission_required": false,
              "owner_callable_required": false,
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            },
            "materialize_recovery_action": {
              "kind": "recovery_owner_action_materialization",
              "provider_admission_required": false,
              "owner_callable_required": true,
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            },
            "wait_for_owner_with_resume_token": {
              "kind": "human_gate_resume_token",
              "provider_admission_required": false,
              "owner_callable_required": false,
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            },
            "stop_with_stable_typed_blocker": {
              "kind": "stable_domain_typed_blocker",
              "provider_admission_required": false,
              "owner_callable_required": false,
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            },
            "stop_with_owner_receipt": {
              "kind": "owner_receipt_consumption",
              "provider_admission_required": false,
              "owner_callable_required": false,
              "required_ref": "owner_receipt_ref",
              "authority_boundary": {
                "opl_can_write_mas_truth": false,
                "opl_can_create_domain_owner_receipt": false,
                "opl_can_create_domain_typed_blocker": false,
                "provider_completion_is_domain_ready": false
              }
            }
          }
        },
        "ReadModelMetadataKernel": {
          "existing_surfaces": [
            "state-index-kernel-contract.json",
            "index doctor",
            "index rebuild",
            "operator read-model sqlite sidecar"
          ],
          "allowed_payload": [
            "refs",
            "fingerprint",
            "cursor",
            "checksum",
            "bounded_preview_hash",
            "obligation_id",
            "decision_id"
          ],
          "forbidden_payload": [
            "study_truth_body",
            "publication_verdict_body",
            "artifact_body",
            "memory_body",
            "paper_body"
          ]
        },
        "ConsoleReadModel": {
          "existing_surfaces": [
            "family-product-operator-projection.json",
            "app state --profile fast",
            "runtime app-operator-drilldown"
          ],
          "default_operator_answers": [
            "current_owner",
            "running_truth",
            "next_safe_action",
            "human_gate_token_state",
            "platform_repair_state",
            "domain_progress_transition_state"
          ],
          "drilldown_only": [
            "DHD",
            "retired_local_queue",
            "stage index",
            "trace",
            "lineage",
            "telemetry"
          ]
        },
        "LedgerReplayEvidence": {
          "existing_surfaces": [
            "evidence-ledger-event.schema.json",
            "family-product-operator-projection.runtime_observability_export",
            "trace_span_correlation_refs"
          ],
          "authority_boundary": "telemetry_lineage_and_trace_spans_are_observability_only"
        }
