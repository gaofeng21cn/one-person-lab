{
  "contract_kind": "opl_stage_route_scheduler_contract.v1",
  "owner": "one-person-lab",
  "scope": "framework-level stage graph scheduling, route hydration, reconciliation, and attempt ledger boundaries for complex domain agents",
  "model": "stage_graph_reconciliation_with_owner_route_hydration",
  "canonical_definitions": {
    "stage": {
      "owner": "one-person-lab",
      "meaning": "an executable, recoverable, auditable attempt unit launched from an admitted stage pack",
      "machine_surfaces": [
        "family-stage-control-plane.schema.json",
        "family-stage-admission.schema.json",
        "family-stage-graph-projection.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "required_runtime_proof": [
        "stage_attempt_id",
        "provider_receipt",
        "checkpoint_refs",
        "closeout_refs",
        "human_gate_refs",
        "typed_blocker_refs_or_owner_receipt_refs"
      ]
    },
    "route": {
      "owner": "domain-agent",
      "meaning": "a domain owner semantic that names the next owner, route-back target, typed blocker, safe action ref, or owner receipt ref",
      "machine_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "domain-owned owner receipt schema",
        "domain-owned typed blocker schema"
      ],
      "is_executable_stage": false,
      "is_small_stage": false,
      "can_complete_stage_attempt": false
    },
    "route_hydration": {
      "owner": "one-person-lab",
      "meaning": "OPL resolves domain owner route refs into typed queue tasks, stage attempt requests, conflict envelopes, or operator projections without executing the route itself",
      "machine_surfaces": [
        "opl family-runtime intake --hydrate",
        "opl family-runtime tick --hydrate",
        "family-runtime-attempt-contract.json",
        "family-conflict-envelope.schema.json"
      ]
    },
    "attempt_ledger": {
      "owner": "one-person-lab",
      "meaning": "append-only control metadata for provider-backed stage attempts, checkpoints, human gates, retries, dead letters, closeout refs, and reconciliation status",
      "machine_surfaces": [
        "family-runtime-attempt-contract.json",
        "StageAttemptWorkflow",
        "stage_attempt_workbench"
      ]
    }
  },
  "mas_reference_flow": {
    "role": "complex_domain_agent_reference",
    "domain_owner_outputs": [
      "owner_route_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "source_refs",
      "source_fingerprint",
      "dispatch_ref",
      "recommended_task_kind"
    ],
    "opl_owned_hydration_outputs": [
      "typed_queue_task",
      "stage_attempt_request",
      "stage_attempt_ledger_entry",
      "operator_projection",
      "conflict_or_blocker_envelope"
    ],
    "forbidden_interpretations": [
      "MAS route is a nested OPL stage",
      "MAS route completion is OPL stage completion",
      "OPL queue admission creates MAS owner receipt",
      "provider completion authorizes publication or artifact readiness"
    ]
  },
  "scheduler_layers": [
    {
      "layer": "stage_graph",
      "owner": "one-person-lab",
      "purpose": "project admitted stage packs, requires/ensures edges, launch blockers, route-back evidence, and integrity digests as a scheduler and App read model",
      "primary_surfaces": [
        "family-stage-graph-projection.schema.json",
        "family-stage-proof-bundle.schema.json",
        "family-stage-replay-certification.schema.json"
      ],
      "authority_boundary": "read_model_only_no_domain_verdict"
    },
    {
      "layer": "owner_route_hydration",
      "owner": "one-person-lab",
      "purpose": "consume domain owner route refs and produce queue, stage-attempt, or conflict/read-model records",
      "primary_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "authority_boundary": "transport_and_projection_only"
    },
    {
      "layer": "reconciliation_loop",
      "owner": "one-person-lab",
      "purpose": "compare desired route/stage refs with actual queue, provider, attempt ledger, human gate, dead-letter, and receipt state",
      "primary_surfaces": [
        "opl family-runtime scheduler tick",
        "opl runtime manager",
        "stage_attempt_workbench",
        "operator_conflicts"
      ],
      "authority_boundary": "reconcile_control_state_without_domain_truth"
    },
    {
      "layer": "attempt_ledger",
      "owner": "one-person-lab",
      "purpose": "record durable stage attempt lifecycle, event history refs, checkpoints, closeout refs, typed blockers, owner receipts, retries, and replay evidence",
      "primary_surfaces": [
        "family-runtime-attempt-contract.json",
        "Temporal workflow history",
        "local_sqlite development ledger"
      ],
      "authority_boundary": "control_metadata_only"
    }
  ],
  "reconciliation_steps": [
    "discover_domain_owner_route_refs",
    "normalize_task_identity_and_idempotency_key",
    "resolve_admitted_stage_pack_or_return_typed_blocker",
    "check_stage_graph_requires_ensures_and_launch_boundary",
    "hydrate_route_ref_into_typed_queue_or_stage_attempt_request",
    "append_attempt_ledger_or_conflict_envelope",
    "dispatch_selected_executor_or_domain_callable_when_authorized",
    "observe_provider_history_checkpoint_closeout_and_receipts",
    "reconcile_actual_status_back_to_operator_read_model",
    "route_back_dead_letter_or_wait_for_human_gate_when_unclosed"
  ],
  "external_patterns_absorbed": [
    {
      "source": "Temporal durable execution",
      "absorbed_as": [
        "event_history",
        "durable_stage_attempt",
        "activity_retry_timeout",
        "signal_query"
      ],
      "not_absorbed_as": [
        "domain_truth_owner",
        "quality_verdict_owner"
      ]
    },
    {
      "source": "LangGraph checkpoint and conditional edges",
      "absorbed_as": [
        "checkpoint_refs",
        "conditional_route_back_edges",
        "replayable_read_model"
      ],
      "not_absorbed_as": [
        "OPL core graph runtime dependency",
        "stage-internal planner"
      ]
    },
    {
      "source": "Kubernetes controller reconciliation and spec/status split",
      "absorbed_as": [
        "desired_owner_route_refs_vs_actual_attempt_status",
        "reconciliation_status",
        "operator_conflict_projection"
      ],
      "not_absorbed_as": [
        "domain scheduler in domain repos",
        "second truth source"
      ]
    },
    {
      "source": "Dagster asset graph and op boundary",
      "absorbed_as": [
        "graph_projection_for_dependencies",
        "operation_boundary_between_stage_and_callable_action"
      ],
      "not_absorbed_as": [
        "artifact_authority",
        "domain deliverable verdict"
      ]
    }
  ],
  "forbidden_semantics": [
    "route_is_small_stage",
    "route_executes_without_stage_attempt",
    "queue_task_admitted_equals_domain_work_done",
    "provider_completed_equals_owner_receipt",
    "attempt_ledger_entry_equals_quality_verdict",
    "OPL_hydration_writes_domain_truth",
    "domain_repo_owns_generic_scheduler_or_attempt_loop",
    "App_read_model_infers_domain_ready_from_route_refs"
  ],
  "required_hydration_inputs": [
    "domain_id",
    "route_ref_or_owner_route_refs",
    "source_fingerprint_or_idempotency_key",
    "recommended_task_kind_or_stage_ref",
    "authority_boundary"
  ],
  "required_hydration_outputs": [
    "typed_queue_task_or_stage_attempt_request",
    "attempt_ledger_ref_or_conflict_envelope_ref",
    "operator_projection_ref",
    "authority_boundary",
    "no_domain_truth_write"
  ],
  "authority_boundary": {
    "opl_can_hydrate_route_refs": true,
    "opl_can_schedule_stage_attempts": true,
    "opl_can_reconcile_attempt_ledger": true,
    "opl_can_project_operator_read_model": true,
    "opl_can_execute_route_as_stage": false,
    "opl_can_write_domain_truth": false,
    "opl_can_sign_domain_owner_receipt": false,
    "opl_can_authorize_quality_verdict": false,
    "opl_can_mutate_artifact_body": false
  }
}
