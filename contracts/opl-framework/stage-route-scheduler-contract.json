{
  "contract_kind": "opl_stage_route_scheduler_contract.v1",
  "owner": "one-person-lab",
  "scope": "framework-level stage graph scheduling, route hydration, reconciliation, and attempt ledger boundaries for complex domain agents",
  "model": "stage_graph_reconciliation_with_owner_route_hydration",
  "contract_laws": {
    "route_not_stage_strategy": true,
    "audit_tail_cannot_plan": true,
    "route_reconciler_role": "hydrate_reconcile_owner_routes_only",
    "default_planning_root": "current_owner_delta",
    "audit_tail_inputs": [
      "raw_evidence_envelope",
      "replay_packet",
      "receipt_ledger",
      "typed_blocker_group",
      "private_residue_inventory",
      "diagnostic_trace_or_metric"
    ],
    "audit_tail_default_planning_role": "passive_until_folded_to_current_owner_delta_owner_answer_typed_blocker_or_hard_gate"
  },
  "canonical_definitions": {
    "stage": {
      "owner": "one-person-lab",
      "meaning": "an executable, recoverable, auditable attempt unit launched from an admitted stage pack",
      "machine_surfaces": [
        "family-stage-control-plane.schema.json",
        "family-stage-admission.schema.json",
        "family-stage-graph-projection.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "required_runtime_proof": [
        "stage_attempt_id",
        "provider_receipt",
        "checkpoint_refs",
        "closeout_refs",
        "human_gate_refs",
        "typed_blocker_refs_or_owner_receipt_refs"
      ]
    },
    "route": {
      "owner": "domain-agent",
      "meaning": "a domain owner semantic that names the next owner, route-back target, typed blocker, safe action ref, or owner receipt ref",
      "machine_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "domain-owned owner receipt schema",
        "domain-owned typed blocker schema"
      ],
      "is_executable_stage": false,
      "is_small_stage": false,
      "can_complete_stage_attempt": false
    },
    "route_hydration": {
      "owner": "one-person-lab",
      "meaning": "OPL resolves domain owner route refs into typed queue tasks, stage attempt requests, conflict envelopes, or operator projections without executing the route itself",
      "must_only": [
        "hydrate_domain_owner_route_refs",
        "reconcile_queue_provider_attempt_ledger_and_projection_state",
        "emit_conflict_or_operator_projection_refs"
      ],
      "must_not": [
        "generate_stage_candidates",
        "evaluate_or_rank_stage_candidates",
        "complete_stage_attempts",
        "sign_owner_receipts",
        "create_typed_blockers",
        "write_domain_truth",
        "derive_default_plan_from_audit_tail"
      ],
      "machine_surfaces": [
        "opl family-runtime intake --hydrate",
        "opl family-runtime tick --hydrate",
        "family-runtime-attempt-contract.json",
        "family-conflict-envelope.schema.json"
      ]
    },
    "attempt_ledger": {
      "owner": "one-person-lab",
      "meaning": "append-only control metadata for provider-backed stage attempts, checkpoints, human gates, retries, dead letters, closeout refs, and reconciliation status",
      "machine_surfaces": [
        "family-runtime-attempt-contract.json",
        "StageAttemptWorkflow",
        "stage_attempt_workbench"
      ]
    }
  },
  "mas_reference_flow": {
    "role": "complex_domain_agent_reference",
    "domain_owner_outputs": [
      "owner_route_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "source_refs",
      "source_fingerprint",
      "dispatch_ref",
      "recommended_task_kind"
    ],
    "opl_owned_hydration_outputs": [
      "typed_queue_task",
      "stage_attempt_request",
      "stage_attempt_ledger_entry",
      "operator_projection",
      "conflict_or_blocker_envelope"
    ],
    "forbidden_interpretations": [
      "MAS route is a nested OPL stage",
      "MAS route completion is OPL stage completion",
      "OPL queue admission creates MAS owner receipt",
      "provider completion authorizes publication or artifact readiness"
    ]
  },
  "scheduler_layers": [
    {
      "layer": "stage_graph",
      "owner": "one-person-lab",
      "purpose": "project admitted stage packs, requires/ensures edges, launch blockers, route-back evidence, and integrity digests as a scheduler and App read model",
      "primary_surfaces": [
        "family-stage-graph-projection.schema.json",
        "family-stage-proof-bundle.schema.json",
        "family-stage-replay-certification.schema.json"
      ],
      "authority_boundary": "read_model_only_no_domain_verdict"
    },
    {
      "layer": "owner_route_hydration",
      "owner": "one-person-lab",
      "purpose": "consume domain owner route refs and produce queue, stage-attempt, or conflict/read-model records",
      "primary_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "authority_boundary": "transport_and_projection_only"
    },
    {
      "layer": "reconciliation_loop",
      "owner": "one-person-lab",
      "purpose": "compare desired route/stage refs with actual queue, provider, attempt ledger, human gate, dead-letter, and receipt state",
      "primary_surfaces": [
        "opl family-runtime scheduler tick",
        "opl runtime manager",
        "stage_attempt_workbench",
        "operator_conflicts"
      ],
      "authority_boundary": "reconcile_control_state_without_domain_truth"
    },
    {
      "layer": "attempt_ledger",
      "owner": "one-person-lab",
      "purpose": "record durable stage attempt lifecycle, event history refs, checkpoints, closeout refs, typed blockers, owner receipts, retries, and replay evidence",
      "primary_surfaces": [
        "family-runtime-attempt-contract.json",
        "Temporal workflow history",
        "local_sqlite development ledger"
      ],
      "authority_boundary": "control_metadata_only"
    }
  ],
  "reconciliation_steps": [
    "discover_domain_owner_route_refs",
    "normalize_task_identity_and_idempotency_key",
    "resolve_admitted_stage_pack_or_return_typed_blocker",
    "check_stage_graph_requires_ensures_and_launch_boundary",
    "hydrate_route_ref_into_typed_queue_or_stage_attempt_request",
    "append_attempt_ledger_or_conflict_envelope",
    "dispatch_selected_executor_or_domain_callable_when_authorized",
    "observe_provider_history_checkpoint_closeout_and_receipts",
    "reconcile_actual_status_back_to_operator_read_model",
    "route_back_dead_letter_or_wait_for_human_gate_when_unclosed"
  ],
  "current_control_admission_currentness_policy": {
    "purpose": "Classify which family-runtime default-executor queue rows may represent the current MAS provider admission during supersession and tick selection.",
    "current_admission_statuses": [
      "queued",
      "retry_waiting",
      "running",
      "waiting_approval"
    ],
    "retryable_blocked_dead_letter_reasons": [
      "temporal_stage_attempt_start_failed",
      "temporal_stage_attempt_not_completed",
      "temporal_stage_attempt_failed"
    ],
    "blocked_reasons_not_current_admission": [
      "mas_default_executor_superseded_by_current_source",
      "temporal_stage_attempt_canceled",
      "temporal_workflow_canceled"
    ],
    "terminal_or_canceled_residue_policy": "audit_or_stale_redrive_filter_only",
    "fresh_admission_precedence": "a fresh MAS current owner-route or current-control provider admission with matching study/action/work-unit identity must not be superseded by canceled, terminal, superseded, or otherwise non-retryable blocked residue",
    "authority_boundary": {
      "can_select_transport_task": true,
      "can_filter_stale_redrive": true,
      "can_write_domain_truth": false,
      "can_create_owner_receipt": false,
      "can_create_typed_blocker": false,
      "provider_completion_is_domain_ready": false
    }
  },
  "stage_route_arbiter_substrate_contract": {
    "surface_kind": "opl_stage_route_arbiter_substrate_contract",
    "schema_version": 1,
    "owner": "one-person-lab",
    "purpose": "Define the OPL-owned substrate guarantees that let domain agents run a single smooth stage-route loop without false running, repeated pending echo, or no-progress redrive loops.",
    "ordinary_path": [
      "fresh_current_owner_delta",
      "domain_provider_admission_identity",
      "stage_run_currentness_identity",
      "provider_attempt_or_owner_callable",
      "terminal_closeout_packet_ref",
      "domain_closeout_consumption_ref",
      "next_current_owner_delta_or_typed_blocker"
    ],
    "currentness_precedence": [
      "terminal_closeout_for_same_stage_attempt",
      "strict_live_attempt_for_same_identity",
      "accepted_closeout_or_executed_typed_blocker_for_same_identity",
      "fresh_provider_admission_identity",
      "stable_domain_typed_blocker",
      "diagnostic_or_stale_residue"
    ],
    "paper_autonomy_supervisor_substrate_mapping": {
      "surface_kind": "opl_paper_autonomy_supervisor_substrate_mapping",
      "schema_version": 1,
      "source_target_design": "human_doc:mas_paper_autonomy_supervisor_target_design",
      "status": "existing_opl_surface_mapping_with_contract_gaps",
      "purpose": "Map MAS Paper Autonomy Supervisor target concepts to existing OPL-owned stage-route, current-control, human-gate, state-index, operator, and observability surfaces without creating a second truth source.",
      "allowed_supervisor_decisions": [
        "execute_current_owner_delta",
        "consume_terminal_closeout",
        "materialize_recovery_action",
        "wait_for_owner_with_resume_token",
        "stop_with_stable_typed_blocker"
      ],
      "decision_surface_policy": {
        "query_role": "read_only_current_obligation_and_evidence_refs",
        "update_role": "identity_bound_stage_route_or_recovery_obligation_transition",
        "signal_role": "owner_or_human_resume_token_only",
        "read_model_can_execute": false,
        "observability_can_close_owner_answer": false
      },
      "concepts": {
        "StageRunIdentityPacket": {
          "existing_surfaces": [
            "stage_run_currentness_identity",
            "stage-run-kernel-contract.json",
            "family-runtime-attempt-contract.json",
            "runtime stage-run-authorization ledger"
          ],
          "required_identity_refs": [
            "stage_run_id",
            "route_identity_key",
            "attempt_idempotency_key",
            "selected_dispatch_ref",
            "stage_packet_ref",
            "stage_packet_refs",
            "provider_attempt_ref",
            "attempt_lease_ref",
            "workflow_ref",
            "source_fingerprint",
            "truth_epoch",
            "runtime_health_epoch"
          ],
          "authority_boundary": "opl_identity_and_transport_only_no_domain_receipt_or_publication_verdict"
        },
        "HumanGateTransport": {
          "existing_surfaces": [
            "contracts/family-orchestration/family-human-gate.schema.json",
            "StageAttemptWorkflow resume signals",
            "stage_attempt_workbench resume ledger",
            "owner-answer.schema.json human_decision"
          ],
          "required_transport_refs": [
            "resume_token",
            "owner",
            "allowed_decisions",
            "timeout_policy",
            "default_safe_branch",
            "current_identity",
            "evidence_required"
          ],
          "authority_boundary": "opl_transports_resume_token_domain_or_human_owner_supplies_answer"
        },
        "RecoveryObligationStore": {
          "existing_surfaces": [
            "current-owner-delta.schema.json",
            "stage_route_arbiter_substrate_contract.no_progress_budget_contract",
            "stop-loss-policy.schema.json",
            "state-index-kernel-contract.json"
          ],
          "required_obligation_refs": [
            "obligation_id",
            "desired_delta_ref",
            "current_identity",
            "status",
            "last_evidence_refs",
            "no_progress_budget_state",
            "stale_read_model_lag",
            "supervisor_decision_ref"
          ],
          "gap": "dedicated query_update store and five-decision fixture readback are not yet landed"
        },
        "SupervisorDecisionEngine": {
          "existing_surfaces": [
            "runway readiness",
            "runway reconcile",
            "runway handoff-gates",
            "runway recovery-repair",
            "runway control-loop status",
            "stage_route_arbiter_substrate_contract"
          ],
          "decision_inputs": [
            "current_owner_delta",
            "StageRunIdentityPacket",
            "terminal_closeout_packet_ref",
            "human_gate_ref",
            "no_progress_budget_state",
            "provider_liveness_or_repair_state",
            "observability_refs"
          ],
          "gap": "single SupervisorDecisionEngine output packet for all five decisions is not yet a runtime readback fixture"
        },
        "StateIndexKernel": {
          "existing_surfaces": [
            "state-index-kernel-contract.json",
            "index doctor",
            "index rebuild",
            "operator read-model sqlite sidecar"
          ],
          "allowed_payload": [
            "refs",
            "fingerprint",
            "cursor",
            "checksum",
            "bounded_preview_hash",
            "obligation_id",
            "decision_id"
          ],
          "forbidden_payload": [
            "study_truth_body",
            "publication_verdict_body",
            "artifact_body",
            "memory_body",
            "paper_body"
          ]
        },
        "Workbench Shell": {
          "existing_surfaces": [
            "family-product-operator-projection.json",
            "app state --profile fast",
            "runtime app-operator-drilldown"
          ],
          "default_operator_answers": [
            "current_owner",
            "running_truth",
            "next_safe_action",
            "human_gate_token_state",
            "platform_repair_state",
            "paper_semantic_delta_state"
          ],
          "drilldown_only": [
            "DHD",
            "queue",
            "stage index",
            "trace",
            "lineage",
            "telemetry"
          ]
        },
        "Observability Plane": {
          "existing_surfaces": [
            "evidence-vault-event.schema.json",
            "family-product-operator-projection.runtime_observability_export",
            "trace_span_correlation_refs"
          ],
          "authority_boundary": "telemetry_lineage_and_trace_spans_are_observability_only"
        }
      },
      "not_complete_claims": [
        "mapping_landed_does_not_mean_supervisor_runtime_landed",
        "contract_landed_does_not_mean_five_decision_tick_readback_exists",
        "human_gate_schema_fields_do_not_mean_human_token_runtime_is_complete",
        "state_index_projection_does_not_mean_paper_progress",
        "observability_refs_do_not_close_owner_receipt_quality_gate_or_publication_readiness"
      ]
    },
    "required_substrate_surfaces": {
      "stage_run_currentness_identity": {
        "purpose": "OPL-owned strict StageRun route/run currentness identity used for default-executor live skip, terminal closeout reconciliation, and current-control projection without claiming domain authority.",
        "implementation_ref": "src/family-runtime-stage-run-currentness-identity.ts#buildStageRunCurrentnessIdentity",
        "test_ref": "tests/src/family-runtime-stage-run-currentness-identity.test.ts",
        "test_lane": "fast",
        "comparison_refs": {
          "attempt_match_ref": "src/family-runtime-stage-run-currentness-identity.ts#sameStageRunCurrentnessIdentity",
          "route_currentness_match_ref": "src/family-runtime-stage-run-currentness-identity.ts#sameStageRunRouteCurrentnessIdentity",
          "route_currentness_match_policy": "sameStageRunRouteCurrentnessIdentity compares route/currentness fields without using stage_attempt_id so an admitted attempt and a fresh candidate for the same selected dispatch/stage packet identity can reconcile, while stale work-unit/source/currentness basis or selected dispatch/stage packet mismatch fails closed"
        },
        "consumed_by": [
          {
            "surface": "default_executor_live_skip",
            "policy": "live-skip may only reuse an existing provider attempt when sameStageRunRouteCurrentnessIdentity confirms the same domain, study or quest, stage, action, work unit, source, epoch, idempotency basis, dispatch ref, and stage packet refs"
          },
          {
            "surface": "terminal_closeout_reconcile",
            "policy": "terminal closeout sync may reconcile a queued or running task to the matching stage attempt only when the same route currentness identity matches or the older provider-admission identity matches"
          },
          {
            "surface": "current_control_projection",
            "policy": "current-control read models project the StageRun currentness identity and missing fields so stale, terminal, or incomplete transport residue stays diagnostic instead of becoming default progress"
          }
        ],
        "required_fields": [
          "domain_id",
          "study_id_or_quest_id",
          "stage_id",
          "stage_attempt_id",
          "action_type",
          "work_unit_id",
          "work_unit_fingerprint",
          "source_fingerprint",
          "truth_epoch",
          "runtime_health_epoch",
          "source_eval_id",
          "idempotency_key",
          "route_identity_key",
          "attempt_idempotency_key",
          "dispatch_ref",
          "stage_packet_ref",
          "stage_packet_refs"
        ],
        "match_policy": "all_required_current_owner_delta_provider_admission_selected_dispatch_and_stage_packet_fields_must_match; missing route_identity_key, attempt_idempotency_key, dispatch_ref, stage_packet_ref, or stage_packet_refs fails closed",
        "missing_identity_effect": "fail_closed_no_stage_run_currentness_match_no_live_skip_no_terminal_reconcile",
        "authority_boundary": {
          "opl_can_use_for_live_skip": true,
          "opl_can_use_for_terminal_closeout_reconcile": true,
          "opl_can_project_current_control_identity": true,
          "opl_holds_mas_owner_receipt_authority": false,
          "opl_holds_mas_typed_blocker_authority": false,
          "opl_holds_mas_quality_authority": false,
          "provider_completion_is_domain_ready": false
        },
        "reset_evidence": [
          "fresh_current_owner_delta",
          "domain_owner_receipt_ref",
          "quality_gate_receipt_ref",
          "typed_blocker_ref",
          "human_gate_ref",
          "route_back_evidence_ref",
          "provider_hard_gate_clearance"
        ],
        "provider_admission_identity_policy": {
          "route_identity_key_required": true,
          "attempt_idempotency_key_required": true,
          "generic_idempotency_key_is_not_attempt_idempotency_key": true,
          "missing_provider_admission_identity_effect": "fail_closed_no_stage_run_currentness_match"
        },
        "selected_dispatch_stage_packet_policy": {
          "dispatch_ref_required": true,
          "stage_packet_ref_required": true,
          "stage_packet_refs_required_non_empty": true,
          "stale_selected_dispatch_or_stage_packet_effect": "route_currentness_mismatch_fail_closed"
        }
      },
      "terminal_closeout_precedes_live_projection": {
        "required_observations": [
          "stage_attempt_ledger_terminal_state",
          "typed_closeout_packet_ref_or_blocker_ref",
          "closeout_receipt_status",
          "linked_queue_task_identity"
        ],
        "policy": "before a tick treats a task as live, OPL must sync terminal provider state and suppress older running projections for the same stage_attempt_id or currentness identity",
        "forbidden_fallbacks": [
          "active_run_id_non_null",
          "stale_transport_status",
          "old_queue_running_without_fresh_terminal_sync"
        ]
      },
      "no_progress_budget_contract": {
        "budget_scope": [
          "domain_id",
          "study_id_or_quest_id",
          "action_type",
          "work_unit_id",
          "work_unit_fingerprint",
          "source_eval_id"
        ],
        "no_progress_classes": [
          "receipt_only",
          "read_model_reconcile_only",
          "stale_route_redrive_only",
          "platform_repair_only",
          "owner_output_already_current",
          "no_deliverable_delta"
        ],
        "budget_exhaustion_action": "freeze_default_redrive_and_project_stop_loss_state_until_fresh_owner_delta_domain_answer_human_decision_or_provider_hard_gate_clearance",
        "budget_exhaustion_terminal_blocker_code": "anti_loop_budget_exhausted",
        "same_work_unit_redrive_after_budget_exhaustion_allowed": false,
        "successor_admission_policy": {
          "status": "identity_different_successor_or_gate_required",
          "default_successor_action_type": "publishability_repair_sprint",
          "default_successor_work_unit_id": "publishability_repair_sprint_after_anti_loop_budget_exhausted",
          "identity_must_differ_by_any_of": [
            "action_type",
            "work_unit_id",
            "work_unit_fingerprint",
            "source_fingerprint"
          ],
          "stable_operator_or_human_gate_allowed": true,
          "authority_boundary": {
            "can_write_domain_truth": false,
            "can_create_owner_receipt": false,
            "can_create_typed_blocker": false,
            "can_authorize_quality_verdict": false
          }
        },
        "counts_as_progress_refs": [
          "domain_owner_receipt_ref",
          "quality_gate_receipt_ref",
          "typed_blocker_ref",
          "human_gate_ref",
          "route_back_evidence_ref",
          "paper_or_artifact_delta_ref",
          "reviewer_or_gate_delta_ref",
          "next_current_owner_delta_ref"
        ]
      },
      "worker_source_stale_supervisor_projection": {
        "status": "fail_closed_supervisor_guard",
        "automatic_restart_allowed_when": [
          "explicit_developer_supervisor",
          "temporal_service_reachable",
          "stage_attempt_ledger_readable",
          "active_stage_attempt_count_is_zero"
        ],
        "blocked_when_active_attempt_states": [
          "queued",
          "running",
          "checkpointed",
          "human_gate"
        ],
        "ordinary_path_effect": "project_provider_liveness_blocker_without_killing_active_worker_or_claiming_domain_progress"
      },
      "trace_span_correlation_refs": {
        "required_ref_families": [
          "stage_attempt_ref",
          "queue_task_ref",
          "workflow_ref",
          "closeout_ref",
          "current_owner_delta_ref",
          "domain_receipt_or_blocker_ref",
          "stage_progress_log_ref"
        ],
        "policy": "observability links are refs-only drilldown evidence and never a planning root or domain authority source"
      },
      "attempt_list_audit_safe_readout": {
        "purpose": "Keep default attempt-list operator readout bounded, body-free, and shape-stable so large ledgers cannot be misread as empty, provider-ready, or domain progress.",
        "implementation_ref": "src/family-runtime-stage-attempt-monitoring.ts#listStageAttemptsWithMonitoringProjection",
        "test_ref": "tests/src/cli/cases/family-runtime-stage-attempt-monitoring.test.ts",
        "test_lane": "fast",
        "default_unfiltered_policy": "unfiltered_json_attempt_list_defaults_to_compact_timeline_audit_safe_readout",
        "default_limit": 25,
        "required_default_shape": [
          "view_mode=compact_timeline",
          "filters.compact_timeline=true",
          "summary.compact_timeline_limit=25",
          "summary.compact_timeline_returned_total",
          "summary.compact_timeline_omitted_total",
          "items=array",
          "attempts=array",
          "compact_timeline=array"
        ],
        "omitted_heavy_fields_default": [
          "provider_run",
          "activity_events",
          "route_impact"
        ],
        "filtered_or_explicit_full_boundary": "filtered_or_explicit_full_views_may_return_full_attempt_bodies_but_consumers_must_read_view_mode_summary_and_filters_before_interpreting_attempt_absence_or_provider_readiness",
        "consumer_must_not_interpret": [
          "compact_timeline_omitted_total_as_no_active_attempts",
          "missing_heavy_body_as_missing_attempt",
          "provider_readiness_projection_as_domain_progress",
          "bounded_default_readout_as_worker_restart_authority"
        ],
        "authority_boundary": {
          "opl_can_project_bounded_attempt_readout": true,
          "opl_can_reconcile_attempt_ledger": true,
          "opl_can_infer_no_active_attempts_from_bounded_readout": false,
          "opl_can_restart_worker_from_bounded_readout_only": false,
          "opl_can_create_domain_owner_receipt": false,
          "opl_can_create_domain_typed_blocker": false,
          "provider_completion_is_domain_ready": false
        }
      }
    },
    "current_control_admission_currentness_policy_ref": "current_control_admission_currentness_policy",
    "authority_boundary": {
      "opl_can_select_transport_task": true,
      "opl_can_schedule_stage_attempts": true,
      "opl_can_reconcile_attempt_ledger": true,
      "opl_can_project_operator_read_model": true,
