{
  "contract_kind": "opl_stage_route_scheduler_contract.v1",
  "owner": "one-person-lab",
  "scope": "framework-level stage graph scheduling, route hydration, reconciliation, and attempt ledger boundaries for complex domain agents",
  "model": "stage_graph_reconciliation_with_owner_route_hydration",
  "contract_laws": {
    "route_not_stage_strategy": true,
    "audit_tail_cannot_plan": true,
    "route_reconciler_role": "hydrate_reconcile_owner_routes_only",
    "default_planning_root": "current_owner_delta",
    "audit_tail_inputs": [
      "raw_evidence_envelope",
      "replay_packet",
      "receipt_ledger",
      "typed_blocker_group",
      "private_residue_inventory",
      "diagnostic_trace_or_metric"
    ],
    "audit_tail_default_planning_role": "passive_until_folded_to_current_owner_delta_owner_answer_typed_blocker_or_hard_gate"
  },
  "canonical_definitions": {
    "stage": {
      "owner": "one-person-lab",
      "meaning": "an executable, recoverable, auditable attempt unit launched from an admitted stage pack",
      "machine_surfaces": [
        "family-stage-control-plane.schema.json",
        "family-stage-admission.schema.json",
        "family-stage-graph-projection.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "required_runtime_proof": [
        "stage_attempt_id",
        "provider_receipt",
        "checkpoint_refs",
        "closeout_refs",
        "human_gate_refs",
        "typed_blocker_refs_or_owner_receipt_refs"
      ]
    },
    "route": {
      "owner": "domain-agent",
      "meaning": "a domain owner semantic that names the next owner, route-back target, typed blocker, safe action ref, or owner receipt ref",
      "machine_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "domain-owned owner receipt schema",
        "domain-owned typed blocker schema"
      ],
      "is_executable_stage": false,
      "is_small_stage": false,
      "can_complete_stage_attempt": false
    },
    "route_hydration": {
      "owner": "one-person-lab",
      "meaning": "OPL resolves domain owner route refs into Temporal-backed stage attempt requests, conflict envelopes, or operator projections without executing the route itself",
      "must_only": [
        "hydrate_domain_owner_route_refs",
        "reconcile_provider_attempt_ledger_and_projection_state",
        "emit_conflict_or_operator_projection_refs"
      ],
      "must_not": [
        "generate_stage_candidates",
        "evaluate_or_rank_stage_candidates",
        "complete_stage_attempts",
        "sign_owner_receipts",
        "create_typed_blockers",
        "write_domain_truth",
        "derive_default_plan_from_audit_tail"
      ],
      "machine_surfaces": [
        "opl family-runtime attempt create",
        "opl family-runtime provider-slo tick --provider temporal",
        "family-runtime-attempt-contract.json",
        "family-conflict-envelope.schema.json"
      ]
    },
    "attempt_ledger": {
      "owner": "one-person-lab",
      "meaning": "append-only control metadata for provider-backed stage attempts, checkpoints, human gates, retries, dead letters, closeout refs, and reconciliation status",
      "machine_surfaces": [
        "family-runtime-attempt-contract.json",
        "StageAttemptWorkflow",
        "stage_attempt_workbench"
      ]
    }
  },
  "mas_reference_flow": {
    "role": "complex_domain_agent_reference",
    "domain_owner_outputs": [
      "owner_route_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "source_refs",
      "source_fingerprint",
      "dispatch_ref",
      "recommended_task_kind"
    ],
    "opl_owned_hydration_outputs": [
      "stage_attempt_request",
      "stage_attempt_ledger_entry",
      "operator_projection",
      "conflict_or_blocker_envelope"
    ],
    "forbidden_interpretations": [
      "MAS route is a nested OPL stage",
      "MAS route completion is OPL stage completion",
      "OPL stage-attempt projection creates MAS owner receipt",
      "provider completion authorizes publication or artifact readiness"
    ]
  },
  "scheduler_layers": [
    {
      "layer": "stage_graph",
      "owner": "one-person-lab",
      "purpose": "project admitted stage packs, requires/ensures edges, launch blockers, route-back evidence, and integrity digests as a scheduler and App read model",
      "primary_surfaces": [
        "family-stage-graph-projection.schema.json",
        "family-stage-proof-bundle.schema.json",
        "family-stage-replay-certification.schema.json"
      ],
      "authority_boundary": "read_model_only_no_domain_verdict"
    },
    {
      "layer": "owner_route_hydration",
      "owner": "one-person-lab",
      "purpose": "consume domain owner route refs and produce Temporal stage-attempt or conflict/read-model projection records",
      "primary_surfaces": [
        "family-owner-route.schema.json",
        "family-conflict-envelope.schema.json",
        "family-runtime-attempt-contract.json"
      ],
      "authority_boundary": "transport_and_projection_only"
    },
    {
      "layer": "reconciliation_loop",
      "owner": "one-person-lab",
      "purpose": "compare desired route/stage refs with actual Temporal provider history, stage-attempt ledger, human gate, dead-letter, and receipt state",
      "primary_surfaces": [
        "opl family-runtime provider-slo tick --provider temporal",
        "opl runtime manager",
        "stage_attempt_workbench",
        "operator_conflicts"
      ],
      "authority_boundary": "reconcile_control_state_without_domain_truth"
    },
    {
      "layer": "attempt_ledger",
      "owner": "one-person-lab",
      "purpose": "record durable stage attempt lifecycle, event history refs, checkpoints, closeout refs, typed blockers, owner receipts, retries, and replay evidence",
      "primary_surfaces": [
        "family-runtime-attempt-contract.json",
        "Temporal workflow history",
        "sqlite projection/readback sidecar"
      ],
      "authority_boundary": "control_metadata_only"
    }
  ],
  "reconciliation_steps": [
    "discover_domain_owner_route_refs",
    "normalize_task_identity_and_idempotency_key",
    "resolve_admitted_stage_pack_or_return_typed_blocker",
    "check_stage_graph_requires_ensures_and_launch_boundary",
    "hydrate_route_ref_into_stage_attempt_request",
    "append_attempt_ledger_or_conflict_envelope",
    "dispatch_selected_executor_or_domain_callable_when_authorized",
    "observe_provider_history_checkpoint_closeout_and_receipts",
    "reconcile_actual_status_back_to_operator_read_model",
    "route_back_dead_letter_or_wait_for_human_gate_when_unclosed"
  ],
  "current_control_admission_currentness_policy": {
    "purpose": "Classify which provider-backed stage-attempt projection rows may represent the current MAS provider admission during supersession and provider cadence selection.",
    "current_admission_statuses": [
      "queued",
      "retry_waiting",
      "running",
      "waiting_approval"
    ],
    "retryable_blocked_dead_letter_reasons": [
      "temporal_stage_attempt_start_failed",
      "temporal_stage_attempt_not_completed",
      "temporal_stage_attempt_failed"
    ],
    "blocked_reasons_not_current_admission": [
      "mas_default_executor_superseded_by_current_source",
      "temporal_stage_attempt_canceled",
      "temporal_workflow_canceled"
    ],
    "terminal_or_canceled_residue_policy": "audit_or_stale_redrive_filter_only",
    "fresh_admission_precedence": "a fresh MAS current owner-route or current-control provider admission with matching study/action/work-unit identity must not be superseded by canceled, terminal, superseded, or otherwise non-retryable blocked residue",
    "authority_boundary": {
      "can_select_transport_task": true,
      "can_filter_stale_redrive": true,
      "can_write_domain_truth": false,
      "can_create_owner_receipt": false,
      "can_create_typed_blocker": false,
      "provider_completion_is_domain_ready": false
    }
  },
  "stage_route_transport_substrate_contract": {
    "surface_kind": "opl_stage_route_transport_substrate_contract",
    "schema_version": 1,
    "owner": "one-person-lab",
    "purpose": "Define passive OPL transport and currentness guarantees for Codex-selected stage routes without accepting, rejecting, ranking, or overriding semantic route decisions.",
    "ordinary_path": [
      "fresh_current_owner_delta",
      "domain_provider_admission_identity",
      "stage_run_currentness_identity",
      "provider_attempt_or_owner_callable",
      "terminal_closeout_packet_ref",
      "domain_closeout_consumption_ref",
      "next_current_owner_delta_or_typed_blocker"
    ],
    "currentness_precedence": [
      "terminal_closeout_for_same_stage_attempt",
      "strict_live_attempt_for_same_identity",
      "accepted_closeout_or_executed_typed_blocker_for_same_identity",
      "fresh_provider_admission_identity",
      "stable_domain_typed_blocker",
      "diagnostic_or_stale_residue"
    ],
    "required_substrate_surfaces": {
      "stage_run_currentness_identity": {
        "purpose": "OPL-owned strict StageRun route/run currentness identity used for default-executor live skip, terminal closeout reconciliation, and current-control projection without claiming domain authority.",
        "implementation_ref": "src/modules/runway/family-runtime-stage-run-currentness-identity.ts#buildStageRunCurrentnessIdentity",
        "test_ref": "tests/src/family-runtime-stage-run-currentness-identity.test.ts",
        "test_lane": "fast",
        "comparison_refs": {
          "attempt_match_ref": "src/modules/runway/family-runtime-stage-run-currentness-identity.ts#sameStageRunCurrentnessIdentity",
          "route_currentness_match_ref": "src/modules/runway/family-runtime-stage-run-currentness-identity.ts#sameStageRunRouteCurrentnessIdentity",
          "route_currentness_match_policy": "sameStageRunRouteCurrentnessIdentity compares route/currentness fields without using stage_attempt_id so an admitted attempt and a fresh candidate for the same selected dispatch/stage packet identity can reconcile; mismatch disables reuse and terminal reconciliation only and never blocks Codex from starting another declared stage"
        },
        "consumed_by": [
          {
            "surface": "default_executor_live_skip",
            "policy": "live-skip may only reuse an existing provider attempt when sameStageRunRouteCurrentnessIdentity confirms the same domain, study or quest, stage, action, work unit, source, epoch, idempotency basis, dispatch ref, and stage packet refs"
          },
          {
            "surface": "terminal_closeout_reconcile",
            "policy": "terminal closeout sync may reconcile a pending or running stage-attempt projection to the matching stage attempt only when the same route currentness identity matches or the older provider-admission identity matches"
          },
          {
            "surface": "current_control_projection",
            "policy": "current-control read models project the StageRun currentness identity and missing fields so stale, terminal, or incomplete transport residue stays diagnostic instead of becoming default progress"
          }
        ],
        "required_fields": [
          "domain_id",
          "study_id_or_quest_id",
          "stage_id",
          "stage_attempt_id",
          "action_type",
          "work_unit_id",
          "work_unit_fingerprint",
          "source_fingerprint",
          "truth_epoch",
          "runtime_health_epoch",
          "source_eval_id",
          "idempotency_key",
          "route_identity_key",
          "attempt_idempotency_key",
          "dispatch_ref",
          "stage_packet_ref",
          "stage_packet_refs"
        ],
        "match_policy": "all_required_current_owner_delta_provider_admission_selected_dispatch_and_stage_packet_fields_must_match for reuse or terminal reconciliation only",
        "missing_identity_effect": "no_stage_run_currentness_match_no_live_skip_no_terminal_reconcile_next_declared_stage_still_may_start",
        "authority_boundary": {
          "opl_can_use_for_live_skip": true,
          "opl_can_use_for_terminal_closeout_reconcile": true,
          "opl_can_project_current_control_identity": true,
          "opl_holds_mas_owner_receipt_authority": false,
          "opl_holds_mas_typed_blocker_authority": false,
          "opl_holds_mas_quality_authority": false,
          "provider_completion_is_domain_ready": false
        },
        "reset_evidence": [
          "fresh_current_owner_delta",
          "domain_owner_receipt_ref",
          "quality_gate_receipt_ref",
          "typed_blocker_ref",
          "human_gate_ref",
          "route_back_evidence_ref",
          "provider_hard_gate_clearance"
        ],
        "provider_admission_identity_policy": {
          "route_identity_key_required": true,
          "attempt_idempotency_key_required": true,
          "generic_idempotency_key_is_not_attempt_idempotency_key": true,
          "missing_provider_admission_identity_effect": "no_stage_run_currentness_match_next_declared_stage_still_may_start"
        },
        "selected_dispatch_stage_packet_policy": {
          "dispatch_ref_required": true,
          "stage_packet_ref_required": true,
          "stage_packet_refs_required_non_empty": true,
          "stale_selected_dispatch_or_stage_packet_effect": "route_currentness_mismatch_disables_reuse_only"
        }
      },
      "terminal_closeout_precedes_live_projection": {
        "required_observations": [
          "stage_attempt_ledger_terminal_state",
          "typed_closeout_packet_ref_or_blocker_ref",
          "closeout_receipt_status",
          "linked_stage_attempt_projection_identity"
        ],
        "policy": "before provider cadence readback treats a projection as live, OPL must sync terminal provider state and suppress older running projections for the same stage_attempt_id or currentness identity",
        "forbidden_fallbacks": [
          "active_run_id_non_null",
          "stale_transport_status",
          "stale_stage_attempt_projection_without_fresh_terminal_sync"
        ]
      },
      "worker_source_stale_supervisor_projection": {
        "status": "fail_closed_supervisor_guard",
        "automatic_restart_allowed_when": [
          "explicit_developer_supervisor",
          "temporal_service_reachable",
          "stage_attempt_ledger_readable",
          "active_stage_attempt_count_is_zero"
        ],
        "blocked_when_active_attempt_states": [
          "queued",
          "running",
          "checkpointed",
          "human_gate"
        ],
        "ordinary_path_effect": "project_provider_liveness_blocker_without_killing_active_worker_or_claiming_domain_progress"
      },
      "trace_span_correlation_refs": {
        "required_ref_families": [
          "stage_attempt_ref",
          "stage_attempt_projection_ref",
          "workflow_ref",
          "closeout_ref",
          "current_owner_delta_ref",
          "domain_receipt_or_blocker_ref",
          "stage_progress_log_ref"
        ],
        "policy": "observability links are refs-only drilldown evidence and never a planning root or domain authority source"
      },
      "attempt_list_audit_safe_readout": {
        "purpose": "Keep default attempt-list operator readout bounded, body-free, and shape-stable so large ledgers cannot be misread as empty, provider-ready, or domain progress.",
        "implementation_ref": "src/family-runtime-stage-attempt-monitoring.ts#listStageAttemptsWithMonitoringProjection",
        "test_ref": "tests/src/cli/cases/family-runtime-stage-attempt-monitoring.test.ts",
        "test_lane": "fast",
        "default_unfiltered_policy": "unfiltered_json_attempt_list_defaults_to_compact_timeline_audit_safe_readout",
        "default_limit": 25,
        "required_default_shape": [
          "view_mode=compact_timeline",
          "filters.compact_timeline=true",
          "summary.compact_timeline_limit=25",
          "summary.compact_timeline_returned_total",
          "summary.compact_timeline_omitted_total",
          "items=array",
          "attempts=array",
          "compact_timeline=array"
        ],
        "omitted_heavy_fields_default": [
          "provider_run",
          "activity_events",
          "route_impact"
        ],
        "filtered_or_explicit_full_boundary": "filtered_or_explicit_full_views_may_return_full_attempt_bodies_but_consumers_must_read_view_mode_summary_and_filters_before_interpreting_attempt_absence_or_provider_readiness",
        "consumer_must_not_interpret": [
          "compact_timeline_omitted_total_as_no_active_attempts",
          "missing_heavy_body_as_missing_attempt",
          "provider_readiness_projection_as_domain_progress",
          "bounded_default_readout_as_worker_restart_authority"
        ],
        "authority_boundary": {
          "opl_can_project_bounded_attempt_readout": true,
          "opl_can_reconcile_attempt_ledger": true,
          "opl_can_infer_no_active_attempts_from_bounded_readout": false,
          "opl_can_restart_worker_from_bounded_readout_only": false,
          "opl_can_create_domain_owner_receipt": false,
          "opl_can_create_domain_typed_blocker": false,
          "provider_completion_is_domain_ready": false
        }
      }
    },
    "current_control_admission_currentness_policy_ref": "current_control_admission_currentness_policy",
    "authority_boundary": {
      "opl_can_select_transport_task": true,
      "opl_can_schedule_stage_attempts": true,
      "opl_can_reconcile_attempt_ledger": true,
      "opl_can_project_operator_read_model": true,
      "opl_can_choose_semantic_stage_route": false,
      "opl_can_reject_codex_ai_route": false,
      "opl_can_restart_worker_without_supervisor_guard": false,
      "opl_can_create_domain_owner_receipt": false,
      "opl_can_create_domain_typed_blocker": false,
      "opl_can_authorize_quality_or_publication_ready": false,
      "provider_completion_is_domain_ready": false
    },
    "false_authority_flags": {
      "retired_queue_or_transport_can_generate_domain_authority": false,
      "worker_source_stale_can_generate_owner_answer": false,
      "provider_completion_can_generate_owner_receipt": false,
      "trace_span_can_select_stage_route": false,
      "read_model_refresh_can_create_current_owner_delta": false
    }
  },
  "stage_progress_log_minimum_viability_policy": {
    "purpose": "Define how OPL treats domain-provided user stage logs when projecting terminal StageRun progress and advisory repeated-route signals; this policy cannot authorize or block launch.",
    "canonical_projection_surface": "stage_progress_log.user_stage_log",
    "accepted_domain_sources": [
      "typed_closeout_packet.paper_stage_log",
      "typed_closeout_packet.user_stage_log",
      "typed_closeout_packet.stage_log_summary",
      "route_impact.paper_stage_log",
      "route_impact.user_stage_log",
      "route_impact.stage_log_summary"
    ],
    "required_domain_fields": [
      "stage_name",
      "problem_summary",
      "stage_goal",
      "stage_work_done",
      "changed_stage_surfaces",
      "outcome",
      "remaining_blockers",
      "duration",
      "token_usage",
      "cost",
      "progress_delta_classification",
      "deliverable_progress_delta",
      "platform_repair_delta",
      "next_forced_delta",
      "evidence_refs"
    ],
    "missing_domain_semantics": {
      "projection_status": "missing_domain_fields",
      "quality_debt_reason": "domain_closeout_provided_incomplete_user_stage_log",
      "counts_as_deliverable_progress_when_readable_artifact_exists": true,
      "counts_as_domain_ready": false,
      "may_trigger_default_redrive": false,
      "allowed_next_evidence": [
        "codex_selected_any_declared_stage",
        "fresh_current_owner_delta",
        "human_decision_or_authority_clearance_when_required"
      ]
    },
    "authority_boundary": {
      "opl_can_project_missing_fields": true,
      "opl_can_select_domain_successor": false,
      "opl_can_generate_domain_summary": false,
      "opl_can_create_typed_blocker": false,
      "opl_can_write_domain_truth": false,
      "provider_completion_is_domain_progress": false
    }
  },
  "external_patterns_absorbed": [
    {
      "source": "Temporal durable execution",
      "absorbed_as": [
        "event_history",
        "durable_stage_attempt",
        "activity_retry_timeout",
        "signal_query"
      ],
      "not_absorbed_as": [
        "domain_truth_owner",
        "quality_verdict_owner"
      ]
    },
    {
      "source": "LangGraph checkpoint and conditional edges",
      "absorbed_as": [
        "checkpoint_refs",
        "conditional_route_back_edges",
        "replayable_read_model"
      ],
      "not_absorbed_as": [
        "OPL core graph runtime dependency",
        "stage-internal planner"
      ]
    },
    {
      "source": "Kubernetes controller reconciliation and spec/status split",
      "absorbed_as": [
        "desired_owner_route_refs_vs_actual_attempt_status",
        "reconciliation_status",
        "operator_conflict_projection"
      ],
      "not_absorbed_as": [
        "domain scheduler in domain repos",
        "second truth source"
      ]
    },
    {
      "source": "Dagster asset graph and op boundary",
      "absorbed_as": [
        "graph_projection_for_dependencies",
        "operation_boundary_between_stage_and_callable_action"
      ],
      "not_absorbed_as": [
        "artifact_authority",
        "domain deliverable verdict"
      ]
    }
  ],
  "forbidden_semantics": [
    "route_is_small_stage",
    "route_is_stage_internal_strategy",
    "route_generates_candidates",
    "route_evaluates_or_ranks_candidates",
    "route_executes_without_stage_attempt",
    "route_reconciler_completes_stage_attempt",
    "stage_attempt_index_record_equals_domain_work_done",
    "provider_completed_equals_owner_receipt",
    "attempt_ledger_entry_equals_quality_verdict",
    "replay_packet_generates_default_plan",
    "raw_evidence_envelope_generates_default_plan",
    "typed_blocker_group_generates_default_plan",
    "OPL_hydration_writes_domain_truth",
    "OPL_hydration_signs_owner_receipt",
    "OPL_hydration_creates_typed_blocker",
    "domain_repo_owns_generic_scheduler_or_attempt_loop",
    "App_read_model_infers_domain_ready_from_route_refs"
  ],
  "required_hydration_inputs": [
    "domain_id",
    "route_ref_or_owner_route_refs",
    "source_fingerprint_or_idempotency_key",
    "recommended_task_kind_or_stage_ref",
    "authority_boundary"
  ],
  "required_hydration_outputs": [
    "stage_attempt_request",
    "attempt_ledger_ref_or_conflict_envelope_ref",
    "operator_projection_ref",
    "authority_boundary",
    "no_domain_truth_write"
  ],
  "authority_boundary": {
    "opl_can_hydrate_route_refs": true,
    "opl_can_schedule_stage_attempts": true,
    "opl_can_reconcile_attempt_ledger": true,
    "opl_can_project_operator_read_model": true,
    "opl_can_execute_route_as_stage": false,
    "opl_can_write_domain_truth": false,
    "opl_can_sign_domain_owner_receipt": false,
    "opl_can_authorize_quality_verdict": false,
    "opl_can_mutate_artifact_body": false
  }
}
