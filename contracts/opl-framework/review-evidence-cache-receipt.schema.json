{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/review-evidence-cache-receipt.schema.json",
  "title": "OPL Refs-only Review Evidence Cache Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "status",
    "cache_hit",
    "cache_key_sha256",
    "review_lane",
    "review_scope_sha256",
    "rubric_sha256",
    "evidence_candidate_ref",
    "stored_entry_ref",
    "candidate_origin_reviewer_invocation_ref",
    "candidate_origin_reviewer_evidence_ref",
    "reusable_origin_reviewer_invocation_ref",
    "reusable_origin_reviewer_evidence_ref",
    "context_binding",
    "context_binding_sha256",
    "context_binding_match",
    "cache_reuse_eligible",
    "quality_debt",
    "stage_transition_allowed",
    "typed_blocker_ref",
    "cache_authority",
    "requires_fresh_reviewer_invocation",
    "requires_fresh_reviewer_receipt",
    "requires_mas_judgment",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_review_evidence_cache_receipt" },
    "schema_version": { "const": 2 },
    "status": { "enum": ["cache_miss_stored", "cache_hit", "stored_not_reusable"] },
    "cache_hit": { "type": "boolean" },
    "cache_key_sha256": { "$ref": "#/$defs/sha256" },
    "review_lane": { "const": "display" },
    "review_scope_sha256": { "$ref": "#/$defs/sha256" },
    "rubric_sha256": { "$ref": "#/$defs/sha256" },
    "evidence_candidate_ref": { "$ref": "#/$defs/candidate_exact_ref" },
    "stored_entry_ref": {
      "oneOf": [{ "$ref": "#/$defs/entry_exact_ref" }, { "type": "null" }]
    },
    "candidate_origin_reviewer_invocation_ref": {
      "oneOf": [{ "$ref": "#/$defs/origin_ref" }, { "type": "null" }]
    },
    "candidate_origin_reviewer_evidence_ref": {
      "oneOf": [{ "$ref": "#/$defs/origin_ref" }, { "type": "null" }]
    },
    "reusable_origin_reviewer_invocation_ref": {
      "oneOf": [{ "$ref": "#/$defs/origin_ref" }, { "type": "null" }]
    },
    "reusable_origin_reviewer_evidence_ref": {
      "oneOf": [{ "$ref": "#/$defs/origin_ref" }, { "type": "null" }]
    },
    "context_binding": {
      "oneOf": [{ "$ref": "#/$defs/context_binding" }, { "type": "null" }]
    },
    "context_binding_sha256": {
      "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "context_binding_match": { "type": "boolean" },
    "cache_reuse_eligible": { "type": "boolean" },
    "quality_debt": {
      "oneOf": [{ "$ref": "#/$defs/quality_debt" }, { "type": "null" }]
    },
    "stage_transition_allowed": { "const": true },
    "typed_blocker_ref": { "type": "null" },
    "cache_authority": { "const": false },
    "requires_fresh_reviewer_invocation": { "const": true },
    "requires_fresh_reviewer_receipt": { "const": true },
    "requires_mas_judgment": { "const": true },
    "authority_boundary": { "$ref": "#/$defs/authority_boundary" }
  },
  "allOf": [
    {
      "if": { "type": "object", "properties": { "status": { "const": "stored_not_reusable" } } },
      "then": {
        "type": "object",
        "properties": {
          "cache_hit": { "const": false },
          "stored_entry_ref": { "type": "null" },
          "reusable_origin_reviewer_invocation_ref": { "type": "null" },
          "reusable_origin_reviewer_evidence_ref": { "type": "null" },
          "cache_reuse_eligible": { "const": false },
          "quality_debt": { "$ref": "#/$defs/quality_debt" }
        }
      }
    },
    {
      "if": { "type": "object", "properties": { "status": { "const": "cache_hit" } } },
      "then": {
        "allOf": [
          { "$ref": "#/$defs/reusable_state" },
          { "type": "object", "properties": { "cache_hit": { "const": true } } }
        ]
      }
    },
    {
      "if": { "type": "object", "properties": { "status": { "const": "cache_miss_stored" } } },
      "then": {
        "allOf": [
          { "$ref": "#/$defs/reusable_state" },
          { "type": "object", "properties": { "cache_hit": { "const": false } } }
        ]
      }
    }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "local_exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "size_bytes", "sha256"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "pattern": "^file://" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "candidate_exact_ref": {
      "allOf": [
        { "$ref": "#/$defs/local_exact_ref" },
        { "type": "object", "properties": { "kind": { "const": "scholarskills_page_hash_evidence_candidate" } } }
      ]
    },
    "entry_exact_ref": {
      "allOf": [
        { "$ref": "#/$defs/local_exact_ref" },
        { "type": "object", "properties": { "kind": { "const": "opl_review_evidence_cache_entry" } } }
      ]
    },
    "snapshot_manifest_exact_ref": {
      "allOf": [
        { "$ref": "#/$defs/local_exact_ref" },
        { "type": "object", "properties": { "kind": { "const": "opl_reviewer_input_snapshot_manifest" } } }
      ]
    },
    "origin_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "sha256"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "context_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_attempt_ref",
        "execution_content_binding_sha256",
        "snapshot_manifest_ref",
        "snapshot_manifest_sha256",
        "review_scope_sha256",
        "rubric_sha256",
        "origin_reviewer_invocation_ref",
        "origin_reviewer_evidence_ref"
      ],
      "properties": {
        "reviewer_attempt_ref": { "type": "string", "minLength": 1 },
        "execution_content_binding_sha256": { "$ref": "#/$defs/sha256" },
        "snapshot_manifest_ref": { "$ref": "#/$defs/snapshot_manifest_exact_ref" },
        "snapshot_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "review_scope_sha256": { "$ref": "#/$defs/sha256" },
        "rubric_sha256": { "$ref": "#/$defs/sha256" },
        "origin_reviewer_invocation_ref": { "$ref": "#/$defs/origin_ref" },
        "origin_reviewer_evidence_ref": { "$ref": "#/$defs/origin_ref" }
      }
    },
    "quality_debt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason_code",
        "resume_condition",
        "cache_reuse_allowed",
        "ordinary_progress_may_advance",
        "stage_transition_allowed",
        "typed_blocker_ref"
      ],
      "properties": {
        "status": { "const": "quality_debt" },
        "reason_code": {
          "enum": [
            "review_evidence_cache_context_binding_missing",
            "review_evidence_cache_context_binding_invalid",
            "review_evidence_cache_context_binding_mismatch",
            "review_evidence_cache_receipt_context_mismatch",
            "review_evidence_cache_receipt_unsupported"
          ]
        },
        "resume_condition": {
          "const": "run the required fresh reviewer invocation without cache reuse"
        },
        "cache_reuse_allowed": { "const": false },
        "ordinary_progress_may_advance": { "const": true },
        "stage_transition_allowed": { "const": true },
        "typed_blocker_ref": { "type": "null" }
      }
    },
    "reusable_state": {
      "type": "object",
      "properties": {
        "stored_entry_ref": { "$ref": "#/$defs/entry_exact_ref" },
        "candidate_origin_reviewer_invocation_ref": { "$ref": "#/$defs/origin_ref" },
        "candidate_origin_reviewer_evidence_ref": { "$ref": "#/$defs/origin_ref" },
        "reusable_origin_reviewer_invocation_ref": { "$ref": "#/$defs/origin_ref" },
        "reusable_origin_reviewer_evidence_ref": { "$ref": "#/$defs/origin_ref" },
        "context_binding": { "$ref": "#/$defs/context_binding" },
        "context_binding_sha256": { "$ref": "#/$defs/sha256" },
        "context_binding_match": { "const": true },
        "cache_reuse_eligible": { "const": true },
        "quality_debt": { "type": "null" }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cache_authority",
        "can_emit_verdict",
        "can_sign_reviewer_receipt",
        "can_sign_owner_receipt",
        "can_create_typed_blocker",
        "can_claim_quality_readiness",
        "can_claim_publication_readiness",
        "can_claim_current_package_authority",
        "cache_hit_can_skip_fresh_reviewer_invocation",
        "cache_hit_can_skip_fresh_reviewer_receipt",
        "cache_hit_can_skip_mas_judgment"
      ],
      "properties": {
        "cache_authority": { "const": false },
        "can_emit_verdict": { "const": false },
        "can_sign_reviewer_receipt": { "const": false },
        "can_sign_owner_receipt": { "const": false },
        "can_create_typed_blocker": { "const": false },
        "can_claim_quality_readiness": { "const": false },
        "can_claim_publication_readiness": { "const": false },
        "can_claim_current_package_authority": { "const": false },
        "cache_hit_can_skip_fresh_reviewer_invocation": { "const": false },
        "cache_hit_can_skip_fresh_reviewer_receipt": { "const": false },
        "cache_hit_can_skip_mas_judgment": { "const": false }
      }
    }
  }
}
