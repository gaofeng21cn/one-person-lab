{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/package-owner-cohort-lock.schema.json",
  "title": "OPL Package Owner Cohort Lock",
  "type": "object",
  "required": [
    "surface_kind",
    "generated_at",
    "packages"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_package_owner_cohort_lock.v1"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "packages": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "required": [
          "package_id",
          "repo_name",
          "repo_url",
          "source_commit"
        ],
        "properties": {
          "package_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
          },
          "repo_name": {
            "type": "string",
            "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?$"
          },
          "repo_url": {
            "type": "string",
            "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?\\.git$"
          },
          "source_commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
