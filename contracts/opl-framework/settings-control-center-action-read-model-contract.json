    "settings_verify_workspace": "settings.workspace.verify",
    "settings_sync_capabilities": "settings.capabilities.sync",
    "settings_apply_opl_packages": "settings.packages.apply",
    "settings_reload_codex_surface": "settings.codex_surface.reload",
    "settings_check_app_update": "settings.updates.check_app_update",
    "settings_prune_runtime_roots_dry_run": "settings.runtime_roots.cleanup_plan",
    "settings_rollback_runtime_toolchain": "settings.updates.rollback_runtime_toolchain",
    "settings_install_docker_webui": "settings.docker_webui.install",
    "settings_configure_webui_api_key": "settings.docker_webui.configure_api_key",
    "settings_select_webui_seed": "settings.docker_webui.select_seed",
    "settings_run_webui_startup_maintenance": "settings.docker_webui.startup_maintenance",
