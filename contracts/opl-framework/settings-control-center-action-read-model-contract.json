{
  "contract_kind": "opl_settings_control_center_action_read_model_contract.v2",
  "surface_kind": "opl_settings_control_center_contract",
  "owner": "one-person-lab",
  "scope": "Framework-owned Settings Control Center read/action surface for App settings without moving domain truth into the App or shell.",
  "schema_version": "settings-control-center.v2",
  "compatibility_schema_versions": [
    "settings-control-center.v1"
  ],
  "read_surface": "opl app state --profile fast|full --json#settings_control_center",
  "action_surface": "opl app action execute --json",
  "settings_ia": {
    "ordinary_entry": "settings_control_center",
    "required_fields": [
      "settings_ia",
      "surface_policy",
      "configuration_catalog",
      "settings_projection",
      "app_settings_read_model",
      "connection_registry",
      "app_aion_consumer_only_readback",
      "control_center_groups",
      "action_sections",
      "issue_queue",
      "action_catalog"
    ],
    "ordinary_route_ids": [
      "general",
      "access",
      "capabilities",
      "environment",
      "storage",
      "appearance",
      "advanced"
    ],
    "secondary_or_deep_link_route_ids": [
      "workspace",
      "local-services",
      "about",
      "update",
      "theme"
    ],
    "secondary_or_deep_link_route_policy": "route_metadata_visible_for_search_and_task_entry_navigation_but_not_promoted_to_top_level_tabs",
    "shell_policy": {
      "app_consumes_read_model_only": true,
      "aion_shell_is_renderer_only": true,
      "shell_must_not_infer_domain_truth": true,
      "shell_must_not_execute_unlisted_actions": true
    }
  },
  "surface_policy": {
    "surface_classes": [
      "configuration",
      "status",
      "diagnostic",
      "action"
    ],
    "configuration": "Framework-owned persistent values backed by existing persistent actions only.",
    "status": "Read-only source projections; status must not be inferred as editable configuration.",
    "diagnostic": "Read-only troubleshooting refs kept distinct from ordinary status.",
    "action": "One-time actions remain independent from persistent configuration.",
    "app_product_truth_policy": "App-local preferences and App product truth are not owned or copied by Framework."
  },
  "configuration_catalog": {
    "surface_kind": "opl_settings_configuration_catalog.v1",
    "owner": "one-person-lab",
    "required_configuration_ids": [
      "workspace_root",
      "update_channel",
      "developer_supervisor"
    ],
    "persistent_action_map": {
      "workspace_root": "workspace_root_set",
      "update_channel": "update_channel",
      "developer_supervisor": "developer_supervisor"
    },
    "execution_metadata_required": [
      "stable_id",
      "surface_class",
      "owner",
      "lifecycle",
      "action_id",
      "route",
      "delegated_surface",
      "payload_fields",
      "payload_required",
      "mutates",
      "dry_run_supported",
      "confirmation_required",
      "danger_level",
      "impact",
      "rollback_action_id",
      "follow_up_action_ids",
      "verify_action_id",
      "verify_route",
      "authority_flags"
    ],
    "lifecycle": "persistent_configuration_mutation",
    "allowlist_policy": "Every persistent_action_map value must be present in settings_control_center.allowed_action_ids.",
    "excluded_configuration_ids": [
      "app_local_preferences",
      "model_catalog",
      "theme",
      "notifications",
      "data_retention",
      "connection_credentials"
    ],
    "policy": "No setting may be listed without an existing Framework-owned persistent implementation; excluded surfaces remain with their App, provider, connection, or domain owner."
  },
  "app_settings_read_model": {
    "surface_kind": "opl_app_settings_read_model.v1",
    "purpose": "Typed App/Aion-consumable Settings model derived from OPL app state so shell adapters do not reconstruct policy.",
    "required_fields": [
      "page_structure",
      "codex_model_policy",
      "access_api_key",
      "workspace_services",
      "connections",
      "capability_task_awareness_refs",
      "docker_webui",
      "local_environment",
      "consumer_only_readback",
      "action_policy"
    ],
    "source_refs": [
      "app_state.core.codex",
      "app_state.developer_mode",
      "app_state.modules",
      "app_state.provider",
      "app_state.paths",
      "app_state.release",
      "app_state.settings_control_center.settings_ia",
      "app_state.settings_control_center.action_catalog",
      "app_state.settings_control_center.capability_task_awareness_refs"
    ],
    "settings_projection": {
      "surface_kind": "opl_settings_projection.v1",
      "purpose": "Settings-specific projection sections for App/Aion rendering so the UI does not infer Settings IA from broad app_state.",
      "ordinary_sections": [
        "summary",
        "access",
        "workspace",
        "capabilities",
        "resources",
        "maintenance",
        "storage",
        "diagnostics"
      ],
      "item_required_fields": [
        "surface_class",
        "scope",
        "owner",
        "risk",
        "normal_summary",
        "next_action",
        "details_ref",
        "editable_reason"
      ],
      "section_surface_class_policy": "Every section and item declares status or diagnostic; configuration and one-time actions use their dedicated catalogs.",
      "authority_policy": "settings_projection_is_read_model_only_no_live_readiness_or_release_claim"
    },
    "capability_task_awareness_refs": {
      "surface_kind": "opl_settings_capability_task_awareness_refs.v1",
      "purpose": "Refs-only Settings/Capabilities slice for capability health, connector readiness, reusable workflow refs, and export bundle preview entrypoints without moving domain truth into Settings.",
      "required_fields": [
        "capability_health_refs",
        "connector_readiness_refs",
        "workflow_refs",
        "content_policy",
        "authority_boundary"
      ],
      "content_policy": "refs_only_no_skill_body_no_workflow_body"
    },
    "docker_webui": {
      "surface_kind": "opl_settings_docker_webui_read_model.v1",
      "purpose": "Default App/Aion-consumable WebUI setup read model for one-click install, API key configuration, seed/image selection, runtime proxy, failure recovery, and operator next actions without running Docker probes on ordinary Settings reads.",
      "required_fields": [
        "one_click_install",
        "api_key_configuration",
        "seed_image_selection",
        "startup_maintenance",
        "runtime_proxy",
        "failure_recovery",
        "ordinary_next_actions",
        "authority_boundary"
      ],
      "doctor_surface": "opl system docker-webui doctor --json",
      "doctor_read_model_ref": "docker_webui_doctor",
      "policy": {
        "app_and_opl_are_policy_action_source": true,
        "aion_shell_is_adapter_view_model_consumer_only": true,
        "shell_must_not_copy_webui_policy": true,
        "ordinary_settings_read_must_not_probe_docker": true,
        "secret_payload_policy": "stdin_only_never_json_or_logs",
        "runtime_readiness_claim": "not_claimed"
      }
    },
    "shell_policy": {
      "app_consumes_read_model_only": true,
      "aion_shell_is_renderer_only": true,
      "shell_must_not_rewrite_model_or_reasoning_policy": true,
      "shell_must_not_infer_api_key_or_workspace_service_truth": true,
      "shell_must_not_execute_unlisted_actions": true
    }
  },
  "connection_registry": {
    "surface_kind": "opl_connection_registry.v1",
    "owner": "one-person-lab",
    "source_ref": "app_state.settings_control_center.connection_registry",
    "state_file": "OPL_STATE_DIR/connection-registry.json",
    "credential_policy": "handle_only",
    "allowed_credential_handles": [
      "env:NAME",
      "codex:selected_provider"
    ],
    "forbidden_payload_fields": [
      "api_key",
      "token",
      "secret",
      "password"
    ],
    "allowed_statuses": [
      "untested",
      "ready",
      "attention_needed",
      "disabled"
    ],
    "default_delete_policy": "default_connection_delete_forbidden",
    "test_policy": {
      "env_handle_missing_code": "credential_env_missing",
      "configuration_ready_requires_handle_owner_available_and_valid_endpoint": true,
      "runtime_readiness_claimed": false,
      "response_must_not_include": [
        "body",
        "headers",
        "secret_values"
      ]
    }
  },
  "control_center_groups": [
    "overview",
    "setup_access",
    "capabilities",
    "maintenance_updates",
    "data_storage",
    "preferences",
    "advanced"
  ],
  "action_sections": [
    "model_access",
    "workspace",
    "connections",
    "capabilities",
    "packages",
    "codex_surface",
    "docker_webui",
    "updates",
    "runtime_roots"
  ],
  "issue_status_codes": [
    "needs_reload",
    "manual_required",
    "dirty_checkout",
    "failed_with_repair",
    "developer_profile_active"
  ],
  "allowed_action_ids": [
    "connection_list",
    "connection_create",
    "connection_update",
    "connection_delete",
    "connection_test",
    "connection_set_default",
    "settings_repair_model_access",
    "settings_verify_workspace",
    "settings_sync_capabilities",
    "settings_apply_opl_packages",
    "refresh_registry",
    "install_from_manifest_url",
    "agent_package_update",
    "agent_package_repair",
    "agent_package_uninstall",
    "agent_package_preferences_set",
    "settings_reload_codex_surface",
    "settings_check_app_update",
    "settings_prune_runtime_roots_dry_run",
    "settings_rollback_runtime_substrate",
    "settings_install_docker_webui",
    "settings_configure_webui_api_key",
    "settings_select_webui_seed",
    "settings_run_webui_startup_maintenance",
    "settings_open_docker_webui",
    "settings_diagnose_docker_webui",
    "workspace_root_set",
    "update_channel",
    "developer_supervisor"
  ],
  "action_taxonomy": {
    "connection_list": "settings.connections.list",
    "connection_create": "settings.connections.create",
    "connection_update": "settings.connections.update",
    "connection_delete": "settings.connections.delete",
    "connection_test": "settings.connections.test",
    "connection_set_default": "settings.connections.set_default",
    "settings_repair_model_access": "settings.model_access.repair",
    "settings_verify_workspace": "settings.workspace.verify",
    "settings_sync_capabilities": "settings.capabilities.sync",
    "settings_apply_opl_packages": "settings.packages.apply",
    "refresh_registry": "settings.capabilities.agent_registry.refresh",
    "install_from_manifest_url": "settings.capabilities.agent_package.install",
    "agent_package_update": "settings.capabilities.agent_package.update",
    "agent_package_repair": "settings.capabilities.agent_package.repair",
    "agent_package_uninstall": "settings.capabilities.agent_package.uninstall",
    "agent_package_preferences_set": "settings.capabilities.agent_package.preferences",
    "settings_reload_codex_surface": "settings.codex_surface.reload",
    "settings_check_app_update": "settings.updates.check_app_update",
    "settings_prune_runtime_roots_dry_run": "settings.runtime_roots.cleanup_plan",
    "settings_rollback_runtime_substrate": "settings.updates.rollback_runtime_substrate",
    "settings_install_docker_webui": "settings.docker_webui.install",
    "settings_configure_webui_api_key": "settings.docker_webui.configure_api_key",
    "settings_select_webui_seed": "settings.docker_webui.select_seed",
    "settings_run_webui_startup_maintenance": "settings.docker_webui.startup_maintenance",
    "settings_open_docker_webui": "settings.docker_webui.open",
    "settings_diagnose_docker_webui": "settings.docker_webui.diagnose"
  },
  "task_action_refs": {
    "task_action_receipt_preview": {
      "action_surface": "opl app action execute --action task_action_receipt_preview --dry-run",
      "content_policy": "refs_only_no_action_receipt_body",
      "non_dry_run_policy": "fail_closed_requires_domain_owner_route"
    },
    "task_export_bundle_preview": {
      "action_surface": "opl app action execute --action task_export_bundle_preview --dry-run",
      "content_policy": "refs_only_no_export_bundle_body",
      "non_dry_run_policy": "fail_closed_requires_domain_owner_route"
    }
  },
  "action_catalog_required_metadata": {
    "surface_class": "action",
    "owner": "one-person-lab",
    "lifecycle": "one_time_action",
    "independence_policy": "one_time_actions_are_not_persistent_configuration_items",
    "stable_id": true,
    "impact": true,
    "confirmation_required": true,
    "danger_level": true,
    "rollback_action_id": true,
    "follow_up_action_ids": true,
    "verify_action_id": true,
    "authority_flags": {
      "can_write_domain_truth": false,
      "can_sign_domain_receipt": false,
      "can_create_owner_receipt": false,
      "can_create_typed_blocker": false,
      "can_write_runtime_queue": false,
      "can_write_provider_queue": false,
      "can_read_memory_body": false,
      "can_read_artifact_body": false,
      "can_authorize_quality_verdict": false,
      "can_claim_app_release_ready": false,
      "can_claim_production_ready": false
    }
  },
  "dry_run_apply_verify_boundary": {
    "dry_run": "preflight_only_no_domain_or_runtime_authority_write",
    "apply": "delegates_only_to_existing_opl_owned_app_action_routes",
    "verify": "read_existing_opl_app_state_or_existing_opl_owned_status_actions",
    "issue_queue": "user_readable_projection_from_existing_app_state_and_update_status_codes_only",
    "app_update_check": "reads_managed_update_projection_app_release_truth_remains_app_repo_owned",
    "runtime_roots_cleanup": "dry_run_plan_only_no_delete",
    "docker_webui": "delegates_to_existing_install_configure_startup_maintenance_doctor_routes_without_secret_payloads_or_release_runtime_ready_claims"
  },
  "consumer_only_enforcement": {
    "surface_kind": "opl_app_aion_consumer_only_boundary.v1",
    "readback_surface": "app_state.settings_control_center.app_aion_consumer_only_readback",
    "app_settings_read_model_ref": "app_state.settings_control_center.app_settings_read_model.consumer_only_readback",
    "source_phase": "reuse_first_platform_risk_audit_phase_8",
    "applies_to": [
      "one-person-lab-app",
      "opl-aion-shell"
    ],
    "purpose": "Keep App and Aion as GUI/product consumers of App-owned contracts and OPL read/action surfaces, not truth owners for runtime, update, settings, or domain private-platform state.",
    "truth_owner_matrix": [
      {
        "surface": "settings_policy",
        "truth_owner": "one-person-lab framework settings_control_center contract plus one-person-lab-app product contract",
        "app_aion_role": "render read model and route listed actions",
        "local_truth_allowed": false,
        "required_visible_refs": [
          "source_ref",
          "delegated_action_id"
        ]
      },
      {
        "surface": "app_release_and_installer",
        "truth_owner": "one-person-lab-app release owner",
        "app_aion_role": "display release owner status, blocker, or receipt ref",
        "local_truth_allowed": false,
        "required_visible_refs": [
          "app_owner_receipt_ref_or_typed_blocker_ref",
          "current_source_ref",
          "blocked_reason"
        ]
      },
      {
        "surface": "runtime_provider_and_stage_status",
        "truth_owner": "one-person-lab Runway, StageRun, Temporal provider, and current_owner_delta read model",
        "app_aion_role": "consume opl app state fast/full or explicit operator drilldown",
        "local_truth_allowed": false,
        "required_visible_refs": [
          "current_owner_delta_ref",
          "runtime_status_source_ref",
          "owner_route_ref"
        ]
      },
      {
        "surface": "managed_module_and_capability_packages",
        "truth_owner": "one-person-lab Pack/Connect package channel and managed update receipt projection",
        "app_aion_role": "show package source, owner, action, and receipt/blocker refs",
        "local_truth_allowed": false,
        "required_visible_refs": [
          "package_descriptor_ref",
          "receipt_ref_or_typed_blocker_ref",
          "delegated_action_id"
        ]
      },
      {
        "surface": "domain_private_platform_residue",
        "truth_owner": "wrapper-retirement-gate-policy private_platform_cleanup_lane plus domain owner decision",
        "app_aion_role": "developer/operator detail only; never default Settings or first-screen truth",
        "local_truth_allowed": false,
        "required_visible_refs": [
          "cleanup_lane_ref",
          "domain_owner_decision_ref_or_typed_blocker_ref"
        ]
      }
    ],
    "local_scheduler_policy": {
      "aion_local_scheduler_allowed_roles": [
        "refresh_trigger",
        "ui_maintenance",
        "poll_existing_read_model"
      ],
      "forbidden_roles": [
        "write_policy_truth",
        "write_currentness_truth",
        "write_runtime_truth",
        "write_release_truth",
        "write_domain_private_platform_truth",
        "create_owner_receipt",
        "create_typed_blocker"
      ],
      "scheduler_must_delegate_to": [
        "opl app state --profile fast|full --json",
        "opl app action execute --json",
        "one-person-lab-app release owner receipt or typed blocker"
      ]
    },
    "forbidden_truth_only_paths": [
      "aion_shell_settings_store_as_policy_truth",
      "aion_local_scheduler_as_update_truth",
      "app_local_read_model_as_runtime_truth_without_opl_source_ref",
      "shell_docker_probe_as_runtime_ready_claim",
      "gui_release_status_without_app_owner_receipt_or_typed_blocker",
      "private_platform_cleanup_lane_as_ordinary_settings_status"
    ],
    "required_user_visible_boundary_fields": [
      "owner",
      "current_source_ref",
      "blocked_reason",
      "receipt_ref_or_typed_blocker_ref",
      "delegated_action_id"
    ],
    "validator_status_codes": [
      "pass",
      "attention_required"
    ],
    "validator_finding_policy": "missing_required_visible_boundary_fields_must_surface_as_validator_findings_before_settings_can_imply_truth",
    "authority_boundary": {
      "app_aion_can_write_policy_truth": false,
      "app_aion_can_write_runtime_truth": false,
      "app_aion_can_write_release_truth": false,
      "app_aion_can_write_domain_truth": false,
      "app_aion_can_create_owner_receipt": false,
      "app_aion_can_create_typed_blocker": false,
      "app_aion_can_authorize_private_platform_cleanup": false,
      "app_aion_can_claim_app_release_ready": false,
      "app_aion_can_claim_production_ready": false
    }
  },
  "authority_boundary": {
    "framework_owner": "one-person-lab",
    "app_repo_owner": "one-person-lab-app_gui_product_truth_only",
    "shell_owner": "thin_renderer_and_ipc_adapter",
    "can_write_domain_truth": false,
    "can_sign_domain_receipt": false,
    "can_create_owner_receipt": false,
    "can_create_typed_blocker": false,
    "can_write_runtime_queue": false,
    "can_write_provider_queue": false,
    "can_read_memory_body": false,
    "can_read_artifact_body": false,
    "can_authorize_quality_verdict": false,
    "can_claim_app_release_ready": false,
    "can_claim_production_ready": false
  },
  "non_goals": [
    "does_not_replace_domain_action_catalog",
    "does_not_write_domain_truth",
    "does_not_sign_owner_receipt",
    "does_not_create_typed_blocker",
    "does_not_delete_runtime_roots",
    "does_not_define_app_release_truth",
    "does_not_make_aion_shell_a_truth_owner"
  ]
}
