{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/opl-framework/release-bundle-executor-receipt.schema.json",
  "title": "OPL Release Bundle Executor Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "operation",
    "executor",
    "attempt_id",
    "bundle_digest",
    "track",
    "outcome",
    "assets"
  ],
  "properties": {
    "surface_kind": { "const": "opl_release_bundle_executor_receipt.v1" },
    "schema_ref": {
      "const": "contracts/opl-framework/release-bundle-executor-receipt.schema.json"
    },
    "operation": { "enum": ["build", "remote_inspect"] },
    "executor": { "enum": ["local", "remote"] },
    "attempt_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "bundle_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "track": { "enum": ["standard", "webui", "full"] },
    "outcome": { "enum": ["complete", "unknown"] },
    "release_operation": { "enum": ["standard", "resume_standard", "append_full"] },
    "operation_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "remote_target": {
      "type": "string",
      "minLength": 3,
      "maxLength": 1024,
      "pattern": "^[a-z][a-z0-9+.-]{0,31}:[A-Za-z0-9][A-Za-z0-9._~:/?#@!$&'()*+,;=%-]*$"
    },
    "prior_attempt_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "publication_scope": { "enum": ["track_assets", "external_target"] },
    "assets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "size_bytes", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 255 },
          "size_bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          { "required": ["release_operation"] },
          { "required": ["operation_id"] },
          { "required": ["remote_target"] },
          { "required": ["prior_attempt_id"] }
        ]
      },
      "then": {
        "required": ["release_operation", "operation_id", "remote_target", "prior_attempt_id"]
      }
    },
    {
      "if": { "properties": { "outcome": { "const": "unknown" } } },
      "then": {
        "properties": { "assets": { "maxItems": 0 } },
        "required": ["release_operation", "operation_id", "remote_target", "prior_attempt_id"]
      }
    },
    {
      "if": { "required": ["publication_scope"] },
      "then": { "properties": { "operation": { "const": "remote_inspect" } } }
    },
    {
      "if": {
        "properties": { "publication_scope": { "const": "external_target" } },
        "required": ["publication_scope"]
      },
      "then": {
        "properties": { "assets": { "maxItems": 0 } },
        "required": ["release_operation", "operation_id", "remote_target", "prior_attempt_id"]
      }
    }
  ]
}
