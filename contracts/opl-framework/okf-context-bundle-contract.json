{
  "surface_kind": "opl_okf_context_bundle_contract",
  "version": "opl-okf-context-bundle.v1",
  "owner": "one-person-lab",
  "state": "active_contract",
  "purpose": "Freeze the OPL-native OKF v0.1 context bundle projection boundary as a portable interchange layer, not a runtime or domain authority.",
  "machine_boundary": {
    "opl_owns": [
      "context_bundle_contract",
      "context_bundle_projection",
      "context_bundle_validation",
      "refs_only_readback",
      "non_authority_flags"
    ],
    "opl_does_not_own": [
      "domain_truth",
      "domain_memory_body",
      "runtime_scheduler",
      "quality_verdict",
      "publication_or_submission_verdict",
      "artifact_authority",
      "owner_receipt",
      "typed_blocker"
    ]
  },
  "bundle_role": "context_bundle",
  "supported_bundle_roles": [
    "context_bundle",
    "interchange_layer",
    "advisory_knowledge_projection"
  ],
  "okf_v0_1_source_refs": [
    {
      "ref_kind": "spec",
      "ref": "https://github.com/GoogleCloudPlatform/knowledge-catalog/blob/main/okf/SPEC.md",
      "label": "Google OKF v0.1 SPEC.md",
      "observed_commit": "d44368c15e38e7c92481c5992e4f9b5b421a801d"
    },
    {
      "ref_kind": "blog",
      "ref": "https://cloud.google.com/blog/products/data-analytics/how-the-open-knowledge-format-can-improve-data-sharing",
      "label": "Google Cloud OKF introduction",
      "published_date": "2026-06-12"
    }
  ],
  "reserved_filenames": [
    "index.md",
    "log.md"
  ],
  "frontmatter_contract": {
    "concept_documents_require": [
      "type"
    ],
    "concept_documents_recommended": [
      "title",
      "description",
      "resource",
      "tags",
      "timestamp"
    ],
    "unknown_type_policy": "tolerate_as_generic_concept",
    "unknown_frontmatter_policy": "preserve_and_tolerate",
    "reserved_filename_type_policy": "reserved_files_must_not_be_concept_documents",
    "root_index_okf_version_policy": "root_index_may_declare_okf_version_without_becoming_a_concept"
  },
  "native_frontmatter_migration_policy": {
    "state": "opt_in_advisory_migration_lane",
    "default_bundle_mode": "exporter_generated_body_free_context_bundle",
    "purpose": "Allow stable domain-owned agent/*.md documents to carry OKF-compatible frontmatter without making native frontmatter the default bundle source or an authority surface.",
    "eligible_path_globs": [
      "agent/*.md"
    ],
    "excluded_path_globs": [
      "docs/**",
      "runtime-state/**",
      "control/opl/**",
      "artifacts/**",
      "tests/fixtures/okf/**"
    ],
    "required_fields": [
      "type",
      "body_owner",
      "domain_authority"
    ],
    "required_field_semantics": {
      "type": "OKF-compatible concept type metadata for advisory context exchange.",
      "body_owner": "The domain owner that owns the Markdown body and any semantic changes to it.",
      "domain_authority": "The domain authority surface that owns truth, memory-body acceptance, artifact authority, owner receipts, typed blockers, and quality/export/readiness verdicts."
    },
    "body_owner_policy": "Native OKF frontmatter must preserve the existing body owner. OPL may preserve, validate, inspect, or project refs-only metadata, but must not become the Markdown body owner or rewrite body semantics through OKF migration.",
    "unknown_frontmatter_policy": "preserve_and_tolerate_as_advisory_metadata_without_blocking_ordinary_progress",
    "runtime_consumption_policy": {
      "runway_consumes_okf_for_progress_or_readiness": false,
      "framework_readiness_consumes_okf_for_ready_claims": false,
      "domain_readiness_consumes_okf_for_ready_claims": false
    },
    "false_authority_fields": {
      "native_frontmatter_authorizes_domain_truth": false,
      "native_frontmatter_authorizes_memory_body_write": false,
      "native_frontmatter_authorizes_owner_receipt": false,
      "native_frontmatter_authorizes_typed_blocker": false,
      "native_frontmatter_authorizes_quality_or_export_verdict": false,
      "native_frontmatter_authorizes_artifact_authority": false,
      "native_frontmatter_authorizes_runtime_scheduling": false,
      "native_frontmatter_authorizes_readiness": false
    },
    "stop_conditions": [
      "path_is_not_an_eligible_stable_domain_owned_agent_markdown_file",
      "required_body_owner_or_domain_authority_metadata_missing",
      "frontmatter_claims_opl_domain_truth_memory_body_artifact_owner_receipt_typed_blocker_quality_export_runtime_or_readiness_authority",
      "migration_attempt_would_copy_or_mutate_domain_memory_body_artifact_body_prompt_skill_or_quality_gate_body",
      "migration_attempt_would_make_unknown_frontmatter_a_progress_blocker"
    ],
    "foldback_docs": [
      "human_doc:opl_decisions",
      "human_doc:opl_status",
      "human_doc:opl_architecture",
      "human_doc:opl_current_state_vs_ideal_gap"
    ]
  },
  "conformance_policy": {
    "hard_errors": [
      "non_reserved_markdown_missing_parseable_frontmatter",
      "non_reserved_markdown_missing_non_empty_type",
      "reserved_filename_used_as_concept_document"
    ],
    "soft_warnings": [
      "broken_cross_link",
      "missing_optional_frontmatter",
      "unknown_type",
      "unknown_frontmatter",
      "missing_index_file"
    ]
  },
  "authority_boundary": {
    "projection_only": true,
    "can_write_domain_truth": false,
    "can_write_memory_body": false,
    "can_accept_or_reject_writeback": false,
    "can_apply_memory_writeback": false,
    "can_authorize_quality_verdict": false,
    "can_authorize_domain_ready": false,
    "can_authorize_publication_or_submission_verdict": false,
    "can_write_artifacts": false,
    "can_sign_owner_receipt": false,
    "can_create_typed_blocker": false,
    "can_schedule_runtime": false
  },
  "non_authority_flags": {
    "opl_owns_domain_truth": false,
    "opl_owns_domain_memory_body": false,
    "opl_accepts_or_rejects_domain_memory_writeback": false,
    "opl_applies_domain_memory_writeback": false,
    "opl_authorizes_quality_verdict": false,
    "opl_authorizes_domain_ready": false,
    "opl_authorizes_publication_or_submission_verdict": false,
    "opl_owns_artifact_authority": false,
    "opl_schedules_runtime_from_okf": false
  }
}
