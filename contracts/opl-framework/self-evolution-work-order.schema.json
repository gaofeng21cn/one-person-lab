{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/self-evolution-work-order.schema.json",
  "schema_id": "opl.self_evolution_work_order.v1",
  "surface_kind": "opl_self_evolution_work_order_schema",
  "owner": "one-person-lab",
  "purpose": "Define the refs-only work-order shape used by Agent Lab and OMA to route evaluation or feedback evidence to the correct capability owner.",
  "state": "active_contract",
  "machine_boundary": "A self-evolution work order identifies evidence, capability-map hits, target paths, verification refs, forbidden write surfaces, and owner closeout requirements. It is not a runner, owner receipt, typed blocker, quality verdict, artifact authority, or readiness proof.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "work_order_id",
    "target_agent_id",
    "failure_token_registry_ref",
    "failure_evidence_refs",
    "failure_tokens",
    "capability_hits",
    "canonical_target_paths",
    "required_verification_refs",
    "forbidden_surfaces",
    "owner_closeout_boundary",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_self_evolution_work_order_candidate"
    },
    "schema_version": {
      "const": "opl.self-evolution-work-order.v1"
    },
    "work_order_id": {
      "type": "string",
      "minLength": 1
    },
    "target_agent_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_token_registry_ref": {
      "const": "contracts/opl-framework/agent-lab-failure-token-registry.json"
    },
    "failure_evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_tokens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "capability_hits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/capability_hit"
      }
    },
    "canonical_target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_verification_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner_closeout_boundary": {
      "$ref": "#/$defs/owner_closeout_boundary"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "capability_hit": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "capability_id",
        "canonical_target_paths",
        "required_verification_refs",
        "forbidden_surfaces",
        "owner_closeout_boundary"
      ],
      "properties": {
        "capability_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_target_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_verification_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "owner_closeout_boundary": {
          "$ref": "#/$defs/owner_closeout_boundary"
        }
      }
    },
    "owner_closeout_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "owner",
        "required_return_shapes",
        "oma_can_write_owner_receipt_body",
        "agent_lab_can_create_typed_blocker",
        "target_owner_acceptance_required"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "required_return_shapes": {
          "type": "array",
          "contains": {
            "enum": [
              "owner_receipt_ref",
              "typed_blocker_ref",
              "human_gate_ref",
              "route_back_ref"
            ]
          }
        },
        "oma_can_write_owner_receipt_body": {
          "const": false
        },
        "agent_lab_can_create_typed_blocker": {
          "const": false
        },
        "target_owner_acceptance_required": {
          "const": true
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "can_write_domain_truth",
        "can_write_memory_body",
        "can_mutate_artifact_body",
        "can_sign_owner_receipt",
        "can_create_typed_blocker",
        "can_authorize_quality_or_export",
        "can_claim_domain_ready",
        "can_claim_production_ready"
      ],
      "properties": {
        "can_write_domain_truth": {
          "const": false
        },
        "can_write_memory_body": {
          "const": false
        },
        "can_mutate_artifact_body": {
          "const": false
        },
        "can_sign_owner_receipt": {
          "const": false
        },
        "can_create_typed_blocker": {
          "const": false
        },
        "can_authorize_quality_or_export": {
          "const": false
        },
        "can_claim_domain_ready": {
          "const": false
        },
        "can_claim_production_ready": {
          "const": false
        }
      }
    }
  }
}
