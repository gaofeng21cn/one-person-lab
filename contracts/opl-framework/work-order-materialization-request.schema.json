{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/work-order-materialization-request.schema.json",
  "title": "OPL Work Order Materialization Request",
  "description": "Accepts either the canonical domain-neutral request or an OMA semantic_requests stdout envelope. Absence of semantic_requests in an OMA blocked/no-patch result is not materializable.",
  "oneOf": [
    { "$ref": "#/$defs/canonicalRequest" },
    { "$ref": "#/$defs/omaSemanticEnvelope" }
  ],
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyStringList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "authorityBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_contains_semantics_and_refs_only",
        "request_can_write_target_files",
        "request_can_sign_owner_receipt",
        "opl_owns_work_order_materialization",
        "opl_owns_materialization_receipt",
        "opl_can_write_target_domain_truth",
        "opl_can_sign_target_owner_receipt",
        "target_owner_closeout_required"
      ],
      "properties": {
        "request_contains_semantics_and_refs_only": { "const": true },
        "request_can_write_target_files": { "const": false },
        "request_can_sign_owner_receipt": { "const": false },
        "opl_owns_work_order_materialization": { "const": true },
        "opl_owns_materialization_receipt": { "const": true },
        "opl_can_write_target_domain_truth": { "const": false },
        "opl_can_sign_target_owner_receipt": { "const": false },
        "target_owner_closeout_required": { "const": true }
      }
    },
    "semanticRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_id", "source_evidence_refs", "root_cause", "targeted_fix", "predicted_impact",
        "allowed_editable_surfaces", "target_repo_file_hints", "required_verification_refs",
        "forbidden_target_surfaces", "owner_route_refs", "source_morphology_proof_ref",
        "private_residue_decision_ref", "target_runtime_read_model_consumption_ref",
        "no_forbidden_write_proof_refs", "target_owner_closeout"
      ],
      "properties": {
        "work_order_id": { "$ref": "#/$defs/nonEmptyString" },
        "source_evidence_refs": { "$ref": "#/$defs/nonEmptyStringList" },
        "root_cause": { "$ref": "#/$defs/nonEmptyString" },
        "targeted_fix": { "$ref": "#/$defs/nonEmptyStringList" },
        "predicted_impact": { "$ref": "#/$defs/nonEmptyString" },
        "allowed_editable_surfaces": { "$ref": "#/$defs/nonEmptyStringList" },
        "target_repo_file_hints": { "$ref": "#/$defs/nonEmptyStringList" },
        "required_verification_refs": { "$ref": "#/$defs/nonEmptyStringList" },
        "forbidden_target_surfaces": { "$ref": "#/$defs/nonEmptyStringList" },
        "owner_route_refs": { "$ref": "#/$defs/nonEmptyStringList" },
        "source_morphology_proof_ref": { "$ref": "#/$defs/nonEmptyString" },
        "private_residue_decision_ref": { "$ref": "#/$defs/nonEmptyString" },
        "target_runtime_read_model_consumption_ref": { "$ref": "#/$defs/nonEmptyString" },
        "no_forbidden_write_proof_refs": { "$ref": "#/$defs/nonEmptyStringList" },
        "target_owner_closeout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "accepted_return_shapes"],
          "properties": {
            "owner": { "$ref": "#/$defs/nonEmptyString" },
            "accepted_return_shapes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["domain_receipt", "typed_blocker", "no_regression_evidence"] }
            }
          }
        }
      }
    },
    "canonicalRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind", "version", "canonical_schema_ref", "request_owner", "execution_owner",
        "target_agent", "semantic_request", "authority_boundary"
      ],
      "properties": {
        "surface_kind": { "const": "opl_work_order_materialization_request" },
        "version": { "const": "opl-work-order-materialization-request.v1" },
        "canonical_schema_ref": { "const": "contracts/opl-framework/work-order-materialization-request.schema.json" },
        "request_owner": { "$ref": "#/$defs/nonEmptyString" },
        "execution_owner": { "const": "one-person-lab/OPL Foundry Lab" },
        "target_agent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["domain_id", "repo_dir"],
          "properties": {
            "domain_id": { "$ref": "#/$defs/nonEmptyString" },
            "repo_dir": { "$ref": "#/$defs/nonEmptyString" }
          }
        },
        "semantic_request": { "$ref": "#/$defs/semanticRequest" },
        "authority_boundary": { "$ref": "#/$defs/authorityBoundary" }
      }
    },
    "omaSemanticEnvelope": {
      "type": "object",
      "required": ["semantic_requests"],
      "properties": {
        "agent_building_judgment": { "type": "object" },
        "semantic_requests": {
          "type": "object",
          "required": ["physical_materialization_owner", "oma_writes_request_files"],
          "properties": {
            "physical_materialization_owner": { "const": "one-person-lab/OPL Foundry Lab" },
            "oma_writes_request_files": { "const": false },
            "developer_patch_work_order": { "type": "object" },
            "requested_file_name": { "const": "developer-patch-work-order.json" },
            "execution_surface": { "const": "opl work-order execute --work-order <developer-patch-work-order.json>" },
            "foundry_evaluation_request": { "type": "object" },
            "owner_receipt_refs": { "type": "object" },
            "foundry_lab_work_order": { "type": "object" },
            "requested_file_names": { "type": "object" }
          }
        }
      }
    }
  }
}
