{
  "contract_kind": "opl_domain_pack_compiler_contract.v1",
  "surface_kind": "opl_domain_pack_compiler_contract",
  "owner": "one-person-lab",
  "scope": "framework-owned read model that compiles admitted domain packs into generated-surface handoff projections",
  "contract_version": "opl-domain-pack-compiler.v1",
  "cli_surfaces": [
    "opl agents pack-compiler [--family-defaults]",
    "opl agents pack-compiler inspect [--family-defaults] --domain <domain>",
    "opl agents interfaces (--family-defaults | --domain <domain> | --repo-dir <path>) [--format <cli|mcp|skill|product-entry|openai|ai-sdk>]",
    "opl agents conformance [--repo-dir <path> ...] [--agent <id>=<path> ...]"
  ],
  "pack_compiler_source_modes": {
    "admitted_domain_manifest_mode": {
      "command": "opl agents pack-compiler",
      "source_kind": "admitted_domain_manifests",
      "purpose": "diagnose admitted manifest discovery, descriptor surfaces, generated handoff readiness, and drift for the framework registry"
    },
    "family_default_repo_contract_mode": {
      "command": "opl agents pack-compiler --family-defaults",
      "source_kind": "standard_agent_repo_contracts",
      "purpose": "compile default sibling standard-agent repo contracts through the same generated-surface projection used by App/workbench metadata feeds",
      "repo_discovery": "OPL_FAMILY_WORKSPACE_ROOT or default workspace candidates containing med-autoscience, med-autogrant, redcube-ai, and opl-meta-agent contract packs",
      "authority_boundary": {
        "can_claim_domain_ready": false,
        "can_claim_quality_verdict": false,
        "can_claim_artifact_authority": false,
        "opl_can_write_domain_truth": false,
        "opl_can_write_memory_body": false,
        "opl_can_authorize_quality_or_export": false
      }
    }
  },
  "standard_agent_identity_binding": {
    "canonical_agent_id_source_ref": "contracts/pack_compiler_input.json#/canonical_agent_id",
    "target_domain_id_source_ref": "contracts/domain_descriptor.json#/domain_id",
    "pack_domain_binding_policy": "contracts/pack_compiler_input.json#/domain_id must exactly match contracts/domain_descriptor.json#/domain_id",
    "generated_interface_agent_id_policy": "copy_explicit_canonical_agent_id_without_domain_or_alias_inference",
    "stage_plane_identity_policy": "family_stage_control_plane_remains_domain_scoped_and_does_not_duplicate_canonical_agent_identity",
    "missing_canonical_agent_id_policy": "fail_closed"
  },
  "standard_agent_stage_manifest_compilation": {
    "source_ref": "agent/stages/manifest.json",
    "generated_surface_ref": "opl-generated:family_stage_control_plane",
    "tracked_stage_control_plane_policy": "forbidden_as_standard_agent_source_or_fallback",
    "required_pack_path_policy": "every required_domain_pack_paths entry must resolve to a file inside the target repo before generated interfaces can be ready",
    "hosted_adapter_policy": "active descriptor, stage index, readiness, worklist, and launch-admission readers consume the same compiled stage manifest readout and may not inject a hand-written first-party plane",
    "required_v2_policy": "standard_stage_pack_conformance.required=true_requires_version_standard-stage-pack.v2_and_invalid_or_missing_version_fails_closed",
    "explicit_v2_version_policy": "version_standard-stage-pack.v2_enables_v2_even_when_required_is_false",
    "stagecraft_policy_ownership": {
      "stage_completion_policy": "opl_stagecraft_progress_first_floor_not_domain_overrideable",
