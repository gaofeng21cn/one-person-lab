{
  "contract_kind": "opl_family_transition_runner_contract.v1",
  "surface_kind": "family_transition_runner_contract",
  "owner": "one-person-lab",
  "scope": "domain-neutral state-machine transition spec and matrix runner for OPL-hosted stage attempts",
  "runner_model": "domain_declared_transition_table",
  "contract_version": "family-transition-runner.v1",
  "required_spec_fields": [
    "surface_kind",
    "version",
    "spec_id",
    "target_domain_id",
    "owner",
    "authority_boundary",
    "guards",
    "transitions"
  ],
  "required_transition_fields": [
    "transition_id",
    "current_state",
    "event",
    "next_state",
    "owner_route"
  ],
  "optional_transition_fields": [
    "required_guards",
    "forbidden_guards",
    "next_work_unit",
    "human_gate",
    "typed_blocker",
    "dead_letter_intent",
    "receipt",
    "projection",
    "authority_boundary"
  ],
  "runner_outputs": [
    "next_state",
    "next_work_unit",
    "owner_route",
    "human_gate",
    "typed_blocker",
    "dead_letter_intent",
    "receipt",
    "projection",
    "outcome_path",
    "terminal_input_kind",
    "requires_owner_answer",
    "authority_boundary"
  ],
  "outcome_path_guard": {
    "guard_id": "opl.family_transition.outcome_path_guard.v1",
    "owner": "one-person-lab",
    "surface_kind": "family_transition_outcome_path_guard",
    "purpose": "make owner receipt, typed blocker, human gate, and dead-letter paths machine-distinguishable without changing domain authority",
    "path_priority": [
      "dead_letter_path",
      "human_gate_path",
      "typed_blocker_path",
      "success_refs_path"
    ],
    "path_semantics": {
      "success_refs_path": "transition applied with no typed blocker, human gate, or dead-letter intent",
      "typed_blocker_path": "transition blocked or domain-declared typed blocker is the terminal input",
      "human_gate_path": "domain-declared human gate is the terminal input",
      "dead_letter_path": "unknown or unrouteable transition is carried as dead-letter intent"
    },
    "projection_fields": [
      "outcome_path",
      "terminal_input_kind",
      "requires_owner_answer",
      "success_claimed",
      "domain_ready_claimed",
      "production_ready_claimed"
    ],
    "no_second_truth_guard": {
      "domain_projection_can_override_outcome_path": false,
      "domain_projection_can_set_domain_ready_claimed": false,
      "domain_projection_can_set_production_ready_claimed": false,
      "typed_blocker_path_can_claim_stage_success": false,
      "human_gate_path_can_claim_stage_success": false,
      "dead_letter_path_can_claim_stage_success": false
    },
    "authority_boundary": {
      "outcome_path_guard_can_write_domain_truth": false,
      "outcome_path_guard_can_sign_owner_receipt": false,
      "outcome_path_guard_can_create_typed_blocker": false,
      "outcome_path_guard_can_make_human_decision": false,
      "outcome_path_guard_can_claim_domain_ready": false,
      "outcome_path_guard_can_claim_production_ready": false
    }
  },
  "runner_execution_boundary": {
    "opl_executes": [
      "domain-declared transition spec",
      "guard id matching",
      "matrix fixture evaluation",
      "receipt/projection envelope construction"
    ],
    "opl_records": [
      "transition receipt",
      "owner route refs",
      "typed blocker refs",
      "human gate refs",
      "dead-letter intent refs",
      "outcome path classification"
    ],
    "opl_must_not_interpret": [
      "MAS publication verdict",
      "MAS publication_eval/latest.json",
      "MAS controller_decisions/latest.json",
      "MAS current_package",
      "domain artifact authority",
      "domain quality authority"
    ]
  },
  "fail_closed_cases": [
    "unknown_guard_id",
    "transition_domain_mismatch",
    "unknown_transition",
    "transition_guard_unsatisfied",
    "transition_guard_forbidden",
    "ambiguous_transition"
  ],
  "matrix_runner": {
    "surface_kind": "family_transition_matrix_result",
    "purpose": "table-driven evaluation of domain transition specs, including adjacent-state and guard-boundary cases",
    "summary_fields": [
      "total",
      "transition_applied",
      "blocked",
      "dead_letter_intended"
    ]
  },
  "oracle_ingestion": {
    "purpose": "adapt domain-owned transition oracle surfaces into the generic family transition spec without moving domain verdict authority into OPL",
    "supported_surfaces": [
      "domain_transition_oracle"
    ],
    "compatibility_surfaces": [],
    "adapter_boundary": {
      "opl": [
        "validate oracle table shape",
        "adapt guard ids into generic transition guards",
        "adapt oracle fixtures into matrix cases",
        "run matrix evaluation and project refs"
      ],
      "domain_agent": [
        "transition semantics",
        "guard meaning",
        "owner action semantics",
        "fundability verdict",
        "authoring quality verdict",
        "submission/export readiness verdict"
      ]
    }
  },
  "authority_boundary": {
    "opl": [
      "transition schema",
      "transition table execution",
      "guard id matching",
      "fail-closed blocker/dead-letter intent",
      "receipt/projection envelope",
      "matrix runner"
    ],
    "domain_agent": [
      "domain transition table",
      "guard definitions",
      "quality/truth verdict",
      "artifact authority",
      "owner receipt",
      "oracle fixtures"
    ],
    "forbidden_opl_authority": [
      "publication quality verdict",
      "fundability verdict",
      "visual/export verdict",
      "domain truth interpretation",
      "domain artifact mutation",
      "domain memory body writeback",
      "domain action execution"
    ]
  },
  "domain_truth_boundary": {
    "opl_interprets_domain_quality": false,
    "opl_executes_domain_action": false,
    "opl_writes_domain_truth": false,
    "domain_ready_verdict_owner": "domain_agent",
    "artifact_authority_owner": "domain_agent"
  },
  "reference_states_for_matrix_tests": [
    "bundle_stage_ready",
    "bundle_stage_blocked",
    "publishability_gate_blocked"
  ]
}
