{
  "version": "p19.stage-runtime",
  "scope": "opl_stage_led_task_topology",
  "description": "Machine-readable top-level task topology for OPL as a stage-led, Agent executor-based agent runtime framework. It lists admitted workstreams and under-definition candidates without recreating the retired gateway, federation, or routed-action interfaces.",
  "non_goals": [
    "domain_truth_registry",
    "publication_or_export_gate",
    "domain_artifact_store",
    "generic_persona_router"
  ],
  "topology_rules": [
    "large tasks are decomposed into human-expert-like stages",
    "Codex CLI is the default minimum executor unit inside each stage",
    "OPL may use configured external runtime providers for wakeup, queue, approval, and projection transport",
    "MAS, MAG, and RCA remain independent domain agents with domain-owned truth and quality authority",
    "candidate workstreams stay under definition until a real domain-agent boundary and stage capability package exists"
  ],
  "shared_foundation_reuse": [
    "stage_descriptors",
    "domain_agent_catalog",
    "provider_backed_attempt_ledger",
    "runtime_projection_surfaces",
    "shared_skill_activation"
  ],
  "workstreams": [
