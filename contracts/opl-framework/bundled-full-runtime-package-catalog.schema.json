{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/opl-framework/bundled-full-runtime-package-catalog.schema.json",
  "title": "OPL Bundled Full Runtime Package Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["surface_kind", "schema_ref", "catalog_id", "packages"],
  "properties": {
    "surface_kind": {
      "const": "opl_bundled_full_runtime_package_catalog.v1"
    },
    "schema_ref": {
      "const": "contracts/opl-framework/bundled-full-runtime-package-catalog.schema.json"
    },
    "catalog_id": {
      "const": "opl-framework-bundled-full-runtime-packages"
    },
    "packages": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_role",
        "package_version",
        "owner_source_commit",
        "manifest_ref",
        "manifest_sha256",
        "payload_manifest_ref",
        "payload_manifest_sha256",
        "runtime_module_relative_path"
      ],
      "properties": {
        "package_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9.-]*$"
        },
        "package_role": {
          "enum": ["standard_agent", "framework_capability_package", "workflow_profile"]
        },
        "package_version": {
          "type": "string",
          "minLength": 1
        },
        "owner_source_commit": {
          "$ref": "#/$defs/commit"
        },
        "manifest_ref": {
          "$ref": "#/$defs/relativePath"
        },
        "manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "payload_manifest_ref": {
          "$ref": "#/$defs/relativePath"
        },
        "payload_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "runtime_module_relative_path": {
          "$ref": "#/$defs/relativePath"
        }
      }
    }
  }
}
