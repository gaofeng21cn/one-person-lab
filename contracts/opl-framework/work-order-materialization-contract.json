{
  "surface_kind": "opl_work_order_materialization_contract",
  "version": "opl.work-order-materialization-contract.v1",
  "owner": "one-person-lab/OPL Foundry Lab",
  "command": "opl work-order materialize-request --request <semantic-request.json> --target-dir <new-dir> --json",
  "request_schema_ref": "contracts/opl-framework/work-order-materialization-request.schema.json",
  "work_order_schema_ref": "contracts/opl-framework/developer-patch-work-order.schema.json",
  "closeout_receipt_schema_ref": "contracts/opl-framework/work-order-owner-closeout-receipt.schema.json",
  "materialization_receipt_schema_ref": "contracts/opl-framework/work-order-materialization-receipt.schema.json",
  "accepted_request_shapes": [
    "opl_work_order_materialization_request",
    "opl_meta_agent_stdout_semantic_requests_developer_patch_work_order",
    "opl_meta_agent_stdout_semantic_requests_foundry_evaluation_bundle"
  ],
  "write_policy": {
    "full_preflight_before_target_creation": true,
    "target_directory_must_not_exist": true,
    "atomic_directory_rename": true,
    "json_format": "canonical_pretty_json_with_trailing_newline",
    "digest_algorithm": "sha256",
    "digest_source": "post_format_materialized_bytes"
  },
  "authority_boundary": {
    "domain_or_oma_supplies_semantics_and_refs": true,
    "opl_owns_physical_json_materialization": true,
    "opl_owns_materialization_receipt": true,
    "opl_can_write_target_domain_truth": false,
    "opl_can_sign_target_owner_receipt": false,
    "opl_can_create_target_typed_blocker": false,
    "materialization_receipt_can_claim_execution_or_closeout": false
  }
}
