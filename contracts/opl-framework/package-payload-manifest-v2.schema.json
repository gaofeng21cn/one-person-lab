{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/package-payload-manifest-v2.schema.json",
  "title": "Canonical OPL First-Party Package Payload Manifest v2",
  "type": "object",
  "required": [
    "surface_kind",
    "schema_ref",
    "package_id",
    "plugin_id",
    "package_version",
    "source_repo",
    "source_commit",
    "source_root",
    "content_lock",
    "files"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_package_payload_manifest.v2"
    },
    "schema_ref": {
      "const": "contracts/opl-framework/package-payload-manifest-v2.schema.json"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "package_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "source_repo": {
      "type": "string",
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?\\.git$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_root": {
      "type": "string",
      "pattern": "^(?:\\.|(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+)$"
    },
    "content_lock": {
      "type": "object",
      "required": [
        "algorithm",
        "canonicalization",
        "digest"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "canonicalization": {
          "const": "ordered_path_length_file_length_bytes"
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "package_source": {
      "type": "object",
      "required": [
        "transport",
        "artifact_ref",
        "archive_sha256",
        "archive_root"
      ],
      "properties": {
        "transport": {
          "const": "same_oci_artifact_source_archive"
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "archive_sha256": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "archive_root": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
        }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "path",
          "mode",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
          },
          "mode": {
            "enum": [
              "100644",
              "100755"
            ]
          },
          "source_url": {
            "type": "string",
            "pattern": "^https://raw\\.githubusercontent\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/[0-9a-f]{40}/[^\\u0000-\\u001f\\u007f]+$"
          },
          "source_path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
          },
          "source_artifact_ref": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        },
        "oneOf": [
          {
            "required": [
              "source_url"
            ],
            "not": {
              "anyOf": [
                { "required": ["source_path"] },
                { "required": ["source_artifact_ref"] }
              ]
            }
          },
          {
            "required": [
              "source_path",
              "source_artifact_ref"
            ],
            "not": {
              "required": ["source_url"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
