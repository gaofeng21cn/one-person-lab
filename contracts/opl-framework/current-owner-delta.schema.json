{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/current-owner-delta.schema.json",
  "schema_id": "opl.current_owner_delta.v1",
  "surface_kind": "opl_current_owner_delta_schema",
  "owner": "one-person-lab",
  "purpose": "Define the bounded OPL-owned default owner/delta/hard-gate/action payload used as the root of ordinary planning and App/operator projection.",
  "state": "active_contract",
  "machine_boundary": "OPL owns desired/current reconciliation, launch gating, refs, and projection shape; domain repositories retain successor policy, domain truth, artifact authority, quality verdicts, typed blockers, and owner receipt signing. No-progress observations are advisory unless a canonical admission consumer is declared elsewhere.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "projection_policy",
    "default_planning_root",
    "ordinary_progress_spine",
    "progress_delta_receipt",
    "artifact_tier_policy",
    "audit_sidecar_policy",
    "audit_tail_policy",
    "evidence_ledger_policy",
    "delta_id",
    "domain",
    "desired_delta_kind",
    "desired_delta_description",
    "current_owner",
    "accepted_answer_shape",
    "hard_gate",
    "advisory_warnings",
    "audit_refs",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_current_owner_delta"
    },
    "schema_version": {
      "const": "current-owner-delta.v1"
    },
    "projection_policy": {
      "const": "default_owner_delta_root_audit_tail_passive"
    },
    "default_planning_root": {
      "const": "current_owner_delta"
    },
    "audit_tail_policy": {
      "const": "raw_worklist_raw_evidence_replay_typed_blocker_group_private_residue_are_passive_until_folded"
    },
    "evidence_ledger_policy": {
      "const": "record_everything_plan_from_nothing"
    },
    "ordinary_progress_spine": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "default_planning_root",
        "default_next_action_derives_from",
        "required_operator_answers",
        "raw_worklist_can_generate_default_next_action",
        "evidence_sidecar_can_generate_default_next_action"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_ordinary_progress_spine_policy"
        },
        "default_planning_root": {
          "const": "current_owner_delta"
        },
        "default_next_action_derives_from": {
          "const": "current_owner_delta"
        },
        "required_operator_answers": {
          "type": "array",
          "contains": {
            "const": "accepted_answer_shape"
          }
        },
        "raw_worklist_can_generate_default_next_action": {
          "const": false
        },
        "evidence_sidecar_can_generate_default_next_action": {
          "const": false
        }
      }
    },
    "progress_delta_receipt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "schema_ref",
        "ordinary_receipt_kind",
        "ordinary_delta_classes",
        "required_refs",
        "authority_boundary",
        "cannot_authorize",
        "stage_transition_accepts_consumable_artifact_progress",
        "quality_debt_transition_status",
        "owner_receipt_required_for_quality_or_ready_claim",
        "hard_stop_requires_typed_blocker_or_human_gate"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_progress_delta_receipt_policy"
        },
        "schema_ref": {
          "const": "contracts/opl-framework/progress-delta-receipt.schema.json"
        },
        "ordinary_receipt_kind": {
          "const": "ProgressDeltaReceipt"
        },
        "ordinary_delta_classes": {
          "type": "array",
          "contains": {
            "const": "platform_repair_delta"
          }
        },
        "required_refs": {
          "type": "array",
          "contains": {
            "const": "changed_surfaces"
          }
        },
        "cannot_authorize": {
          "type": "array",
          "contains": {
            "const": "production_ready"
          }
        },
        "authority_boundary": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "can_authorize_stage_complete",
            "can_authorize_publication_ready",
            "can_sign_owner_receipt",
            "can_create_typed_blocker"
          ],
          "properties": {
            "can_authorize_stage_complete": {
              "const": false
            },
            "can_authorize_publication_ready": {
              "const": false
            },
            "can_sign_owner_receipt": {
              "const": false
            },
            "can_create_typed_blocker": {
              "const": false
            }
          }
        },
        "stage_transition_accepts_consumable_artifact_progress": {
          "const": true
        },
        "quality_debt_transition_status": {
          "const": "completed_with_quality_debt"
        },
        "owner_receipt_required_for_quality_or_ready_claim": {
          "const": true
        },
        "hard_stop_requires_typed_blocker_or_human_gate": {
          "const": true
        }
      }
    },
    "artifact_tier_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "default_ordinary_tier",
        "tiers"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_artifact_tier_policy"
        },
        "default_ordinary_tier": {
          "const": "T0_progress_delta"
        }
      }
    },
    "audit_sidecar_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "role",
        "default_planning_role",
        "blocked_refs_only_can_generate_default_next_action",
        "hard_gate_upgrade_conditions"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_audit_sidecar_policy"
        },
        "role": {
          "const": "passive_evidence_ledger_and_drilldown"
        },
        "default_planning_role": {
          "const": "never_default_planning_root_until_folded_into_current_owner_delta"
        },
        "blocked_refs_only_can_generate_default_next_action": {
          "const": false
        },
        "hard_gate_upgrade_conditions": {
          "type": "array",
          "contains": {
            "const": "publication_export_release_production_ready_or_l5_claim"
          }
        }
      }
    },
    "delta_id": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "task_or_study_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "stage_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "required_capability_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/current_owner_delta_capability_requirement"
      },
      "uniqueItems": true
    },
    "lineage_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "source_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "desired_delta_kind": {
      "type": "string",
      "enum": [
        "none",
        "owner_delta",
        "owner_answer",
        "owner_answer_or_typed_blocker",
        "typed_blocker",
        "artifact_delta"
      ]
    },
    "desired_delta_description": {
      "type": "string",
      "minLength": 1
    },
    "current_owner": {
      "type": "string",
      "minLength": 1
    },
    "accepted_answer_shape": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hard_gate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "state",
        "provider_liveness_required",
        "human_or_domain_owner_required",
        "source"
      ],
      "properties": {
        "state": {
          "type": "string",
          "minLength": 1
        },
        "provider_liveness_required": {
          "type": "boolean"
        },
        "human_or_domain_owner_required": {
          "type": "boolean"
        },
        "source": {
          "const": "owner_delta_controller"
        }
      }
    },
    "capability_invocation_hard_gate_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "authority_surface",
        "owner_modules",
        "fail_closed_on",
        "runway_can_write_domain_truth",
        "runway_can_sign_owner_receipt",
        "runway_can_create_typed_blocker"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_capability_invocation_hard_gate_policy"
        },
        "authority_surface": {
          "const": "current_owner_delta"
        },
        "owner_modules": {
          "const": [
            "current_owner_delta",
            "stagecraft",
            "runway"
          ]
        },
        "fail_closed_on": {
          "type": "array",
          "contains": {
            "const": "route_required_missing_capability_ref"
          }
        },
        "runway_can_write_domain_truth": {
          "const": false
        },
        "runway_can_sign_owner_receipt": {
          "const": false
        },
        "runway_can_create_typed_blocker": {
          "const": false
        }
      }
    },
    "advisory_warnings": {
      "type": "array"
    },
    "live_attempt_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "latest_owner_answer_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "audit_refs": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "not": {
    "required": [
      "stop_loss_state"
    ]
  },
  "$defs": {
    "current_owner_delta_capability_requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability_ref",
        "binding_kind"
      ],
      "properties": {
        "capability_ref": {
          "type": "string",
          "minLength": 1
        },
        "binding_kind": {
          "type": "string",
          "enum": [
            "optional",
            "route_required"
          ]
        },
        "hard_boundary": {
          "enum": [
            "source_data_evidence",
            "owner_route_identity",
            "forbidden_write",
            "irreversible_mutation",
            "reviewer_publication_hard_gate",
            null
          ]
        },
        "required_by_delta_ref": {
          "$ref": "#/$defs/nullable_ref"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "binding_kind": {
                "const": "route_required"
              }
            }
          },
          "then": {
            "required": [
              "hard_boundary"
            ],
            "properties": {
              "hard_boundary": {
                "type": "string",
                "enum": [
                  "source_data_evidence",
                  "owner_route_identity",
                  "forbidden_write",
                  "irreversible_mutation",
                  "reviewer_publication_hard_gate"
                ]
              }
            }
          }
        }
      ]
    },
    "nullable_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "can_write_domain_truth",
        "can_create_owner_receipt",
        "can_create_typed_blocker",
        "can_close_domain_ready",
        "can_claim_production_ready",
        "route_not_stage_strategy",
        "route_reconciler_role",
        "route_reconciler_can_generate_candidates",
        "route_reconciler_can_evaluate_or_rank_candidates",
        "route_reconciler_can_complete_stage",
        "route_reconciler_can_sign_receipts",
        "raw_worklist_can_drive_default_planning",
        "raw_evidence_can_drive_default_planning",
        "replay_packet_can_drive_default_planning",
        "typed_blocker_group_can_drive_default_planning",
        "private_residue_inventory_can_drive_default_planning",
        "audit_tail_can_drive_default_planning"
      ],
      "properties": {
        "route_not_stage_strategy": {
          "const": true
        },
        "route_reconciler_role": {
          "const": "hydrate_reconcile_owner_routes_only"
        },
        "route_reconciler_can_generate_candidates": {
          "const": false
        },
        "route_reconciler_can_evaluate_or_rank_candidates": {
          "const": false
        },
        "route_reconciler_can_complete_stage": {
          "const": false
        },
        "route_reconciler_can_sign_receipts": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_create_owner_receipt": {
          "const": false
        },
        "can_create_typed_blocker": {
          "const": false
        },
        "can_close_domain_ready": {
          "const": false
        },
        "can_claim_production_ready": {
          "const": false
        },
        "raw_worklist_can_drive_default_planning": {
          "const": false
        },
        "raw_evidence_can_drive_default_planning": {
          "const": false
        },
        "replay_packet_can_drive_default_planning": {
          "const": false
        },
        "typed_blocker_group_can_drive_default_planning": {
          "const": false
        },
        "private_residue_inventory_can_drive_default_planning": {
          "const": false
        },
        "audit_tail_can_drive_default_planning": {
          "const": false
        }
      }
    }
  }
}
