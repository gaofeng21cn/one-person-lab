{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/current-owner-delta.schema.json",
  "schema_id": "opl.current_owner_delta.v1",
  "surface_kind": "opl_current_owner_delta_schema",
  "owner": "one-person-lab",
  "purpose": "Define the bounded OPL-owned default owner/delta/hard-gate/action payload used as the root of ordinary planning and App/operator projection.",
  "state": "active_contract",
  "machine_boundary": "OPL owns desired/current reconciliation, launch gating, refs, and projection shape; domain repositories retain domain truth, artifact authority, quality verdicts, and owner receipt signing.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "projection_policy",
    "default_planning_root",
    "audit_tail_policy",
    "evidence_vault_policy",
    "delta_id",
    "domain",
    "desired_delta_kind",
    "desired_delta_description",
    "current_owner",
    "accepted_answer_shape",
    "hard_gate",
    "advisory_warnings",
    "stop_loss_state",
    "audit_refs",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_current_owner_delta"
    },
    "schema_version": {
      "const": "current-owner-delta.v1"
    },
    "projection_policy": {
      "const": "default_owner_delta_root_audit_tail_passive"
    },
    "default_planning_root": {
      "const": "current_owner_delta_or_provider_human_hard_gate"
    },
    "audit_tail_policy": {
      "const": "raw_worklist_raw_evidence_replay_typed_blocker_group_private_residue_are_passive_until_folded"
    },
    "evidence_vault_policy": {
      "const": "record_everything_plan_from_nothing"
    },
    "delta_id": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "task_or_study_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "stage_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "lineage_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "source_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "desired_delta_kind": {
      "type": "string",
      "enum": [
        "none",
        "owner_delta",
        "owner_answer",
        "owner_answer_or_typed_blocker",
        "typed_blocker",
        "artifact_delta"
      ]
    },
    "desired_delta_description": {
      "type": "string",
      "minLength": 1
    },
    "current_owner": {
      "type": "string",
      "minLength": 1
    },
    "accepted_answer_shape": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hard_gate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "state",
        "provider_liveness_required",
        "human_or_domain_owner_required",
        "source"
      ],
      "properties": {
        "state": {
          "type": "string",
          "minLength": 1
        },
        "provider_liveness_required": {
          "type": "boolean"
        },
        "human_or_domain_owner_required": {
          "type": "boolean"
        },
        "source": {
          "const": "owner_delta_controller"
        }
      }
    },
    "advisory_warnings": {
      "type": "array"
    },
    "live_attempt_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "latest_owner_answer_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "stop_loss_state": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "fresh_owner_delta_required_to_resume"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "fresh_owner_delta_required_to_resume": {
          "type": "boolean"
        }
      }
    },
    "audit_refs": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "nullable_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "can_write_domain_truth",
        "can_create_owner_receipt",
        "can_create_typed_blocker",
        "can_close_domain_ready",
        "can_claim_production_ready",
        "route_not_stage_strategy",
        "route_reconciler_role",
        "route_reconciler_can_generate_candidates",
        "route_reconciler_can_evaluate_or_rank_candidates",
        "route_reconciler_can_complete_stage",
        "route_reconciler_can_sign_receipts",
        "raw_worklist_can_drive_default_planning",
        "raw_evidence_can_drive_default_planning",
        "replay_packet_can_drive_default_planning",
        "typed_blocker_group_can_drive_default_planning",
        "private_residue_inventory_can_drive_default_planning",
        "audit_tail_can_drive_default_planning"
      ],
      "properties": {
        "route_not_stage_strategy": {
          "const": true
        },
        "route_reconciler_role": {
          "const": "hydrate_reconcile_owner_routes_only"
        },
        "route_reconciler_can_generate_candidates": {
          "const": false
        },
        "route_reconciler_can_evaluate_or_rank_candidates": {
          "const": false
        },
        "route_reconciler_can_complete_stage": {
          "const": false
        },
        "route_reconciler_can_sign_receipts": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_create_owner_receipt": {
          "const": false
        },
        "can_create_typed_blocker": {
          "const": false
        },
        "can_close_domain_ready": {
          "const": false
        },
        "can_claim_production_ready": {
          "const": false
        },
        "raw_worklist_can_drive_default_planning": {
          "const": false
        },
        "raw_evidence_can_drive_default_planning": {
          "const": false
        },
        "replay_packet_can_drive_default_planning": {
          "const": false
        },
        "typed_blocker_group_can_drive_default_planning": {
          "const": false
        },
        "private_residue_inventory_can_drive_default_planning": {
          "const": false
        },
        "audit_tail_can_drive_default_planning": {
          "const": false
        }
      }
    }
  }
}
