{
  "contract_kind": "opl_stage_artifact_runtime_contract.v1",
  "surface_kind": "opl_stage_artifact_runtime_contract",
  "owner": "one-person-lab",
  "scope": "OPL-owned stage artifact folder contract, read model, conformance gate, content hash index, lineage events, workbench projection, canonical pointer, and retention/restore boundary",
  "state_root_layout": {
    "attempt_root_pattern": "runtime-state/domains/<domain>/deliverables/<program>/<topic>/<deliverable>/stages/<nn-stage>/attempts/<attempt_id>",
    "required_attempt_entries": [
      "attempt.json",
      "manifest.json",
      "inputs/",
      "outputs/",
      "evidence/",
      "receipts/"
    ],
    "current_pointer_role": "refs_only_artifact_attempt_pointer_not_stage_run_current_pointer",
    "stage_run_current_is_passive_projection_of_codex_route_context": true,
    "derived_index_role": "rebuildable_projection_not_primary_truth",
    "lineage_root": "lineage/events.jsonl and lineage/graph.json",
    "retention_root": "retention/attempts/<stage_id>/<attempt_id>"
  },
  "read_model_semantics": {
    "status_source_of_truth": "physical_stage_folder",
    "projection_outputs_only": [
      "artifact_projection",
      "progress_projection",
      "evidence_projection"
    ],
    "stage_artifact_current_is_projection_only": true,
    "stage_artifact_current_may_write_stage_current_pointer": false,
    "stage_artifact_current_may_write_stage_run_terminal_state": false,
    "stage_artifact_current_may_publish_current_owner_delta": false,
    "stage_artifact_current_may_close_owner_answer": false,
    "stage_artifact_current_may_close_human_gate": false,
    "stage_artifact_current_may_close_typed_blocker": false,
    "stage_artifact_current_may_declare_domain_ready": false,
    "status_must_not_depend_on_stale_index": true,
    "success_requires": [
      "valid_manifest",
      "required_outputs_present",
      "owner_receipt_ref_and_receipt_file"
    ],
    "completed_with_quality_debt_requires": [
      "readable_output_present"
    ],
    "progress_first_policy": {
      "consumable_artifact_advances_stage": true,
      "quality_budget_exhaustion_blocks_stage_transition": false,
      "quality_debt_blocks_quality_export_or_ready_claims": true,
      "owner_receipt_required_for_quality_acceptance_not_basic_progress": true
    },
    "blocked_requires": [
      "typed_blocker_ref",
      "blocker_evidence_file"
    ],
    "orphan_artifact_is_completion": false,
    "explain_must_report_missing_or_blocking_deltas": true
  },
  "content_hash_semantics": {
    "algorithm": "sha256",
    "manifest_hash_fields": [
      "output_hashes",
      "evidence_hashes",
      "receipt_hashes"
    ],
    "success_with_hash_mismatch_is_broken": true,
    "conformance_requires_hash_entries_for_physical_files": true
  },
  "conformance_gate": {
    "surface_kind": "opl_stage_artifact_runtime_conformance",
    "strict_units": [
      "Stage Folder",
      "Manifest",
      "Receipt",
      "content_hashes",
      "latest_pointer",
      "current_pointer",
      "lineage_events"
    ],
    "fails_on": [
      "missing_deliverable_json",
      "missing_stage_json",
      "missing_required_attempt_entry",
      "missing_latest_pointer",
      "latest_pointer_missing_attempt",
      "missing_current_pointer",
      "missing_manifest_hash_entry",
      "manifest_content_hash_mismatch",
      "attempt_broken",
      "attempt_orphan"
    ],
    "domain_readiness_claim": false,
    "closes_owner_answer": false,
    "closes_human_gate": false,
    "closes_typed_blocker": false
  },
  "workbench_projection": {
    "surface_kind": "opl_stage_artifact_runtime_workbench",
    "projects": [
      "current_pointer",
      "stage_status",
      "attempt_manifest_refs",
      "owner_receipt_refs",
      "quality_debt_refs",
      "typed_blocker_refs",
      "decision_receipt_refs",
      "content_hashes",
      "canonical_artifacts",
      "export_artifacts",
      "lineage_refs",
      "retention_policy",
      "conformance_summary"
    ],
    "artifact_body_access": false,
    "domain_verdict_authority": false
  },
  "retention_restore_policy": {
    "policy_id": "opl_stage_artifact_retention.v1",
    "gc_dry_run_default": true,
    "gc_apply_archives_instead_of_physical_delete": true,
    "preserve_latest_attempt": true,
    "preserve_canonical_attempts": true,
    "restore_requires_restore_proof_ref": true,
    "restore_does_not_create_owner_receipt": true,
    "restore_does_not_declare_domain_truth_or_quality": true
  },
  "lineage_semantics": {
    "event_log": "lineage/events.jsonl",
    "derived_graph": "lineage/graph.json",
    "event_kinds": [
      "attempt_opened",
      "attempt_committed",
      "index_rebuilt",
      "canonical_pointer_promoted",
      "gc_dry_run",
      "gc_archived_attempts",
      "attempt_restored",
      "conformance_checked",
      "validation_checked"
    ],
    "events_are_refs_only": true
  },
  "cli_surfaces": {
    "top_level": "opl stage open|commit|status|explain|rebuild|promote|gc|restore|validate|conformance|workbench",
    "legacy_alias": "opl stage-artifact open|commit|status|explain|rebuild|promote|gc|restore|validate|conformance|workbench",
    "family_runtime": "opl family-runtime stage-artifact open|commit|status|explain|rebuild|promote|gc|restore|validate|conformance|workbench",
    "open": "create a stage attempt workspace with inputs outputs evidence receipts and stage/deliverable descriptors",
    "commit": "validate manifest terminal status against required outputs and owner receipt, quality debt, decision, or blocker evidence; completed_with_quality_debt advances artifact progress without claiming quality or readiness",
    "status": "derive stage and attempt state from physical folders",
    "explain": "explain current incomplete stage, blocker, orphan, or missing receipt/output state",
    "rebuild": "refresh derived index and lineage graph from physical folders",
    "promote": "write refs-only canonical artifact pointer from manifest-declared refs",
    "gc": "dry-run by default and only archive non-latest non-canonical attempts with restore proof refs when applied",
    "restore": "restore an archived attempt only when a matching restore proof ref is provided",
    "validate": "run strict Stage Folder + Manifest + Receipt + hash + pointer + lineage validation without creating domain receipts or writing domain truth",
    "conformance": "run strict Stage Folder + Manifest + Receipt + hash + pointer + lineage checks",
    "workbench": "project artifact-native current/canonical/export/lineage/retention/conformance refs for App/operator consumers"
  },
  "authority_boundary": {
    "opl_can_index_refs": true,
    "opl_can_rebuild_projection": true,
    "opl_can_promote_canonical_pointer": true,
    "output_authority": [
      "artifact_projection",
      "progress_projection",
      "evidence_projection"
    ],
    "can_publish_current_owner_delta": false,
    "can_close_owner_answer": false,
    "can_close_human_gate": false,
    "can_close_typed_blocker": false,
    "can_declare_domain_ready": false,
    "opl_can_create_domain_owner_receipt": false,
    "opl_can_create_rca_owner_receipt": false,
    "opl_can_write_domain_truth": false,
    "opl_can_write_rca_visual_truth": false,
    "opl_can_write_rca_review_export_verdict": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_mutate_rca_artifact_body": false,
    "opl_can_declare_visual_or_quality_verdict": false
  },
  "forbidden_semantics": [
    "stale_index_as_primary_truth",
    "orphan_output_counts_as_success",
    "quality_debt_counts_as_quality_export_or_ready_acceptance",
    "provider_completion_as_domain_owner_receipt",
    "opl_generated_owner_receipt",
    "stage_artifact_projection_as_current_owner_delta",
    "stage_artifact_projection_closes_owner_answer",
    "stage_artifact_projection_closes_human_gate",
    "stage_artifact_projection_closes_typed_blocker",
    "stage_artifact_projection_claims_domain_ready",
    "opl_visual_or_quality_verdict",
    "gc_without_explicit_apply_deleting_attempts"
  ]
}
