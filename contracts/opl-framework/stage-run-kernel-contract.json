{
  "contract_kind": "opl_stage_run_kernel_contract.v2",
  "surface_kind": "opl_stage_run_kernel_contract",
  "owner": "one-person-lab",
  "purpose": "Provide durable refs-only StageRun invocation identity, exact immutable launch-spec binding, pre-start recovery, event history, retry-budget accounting, currentness filtering, decisive-Attempt route ABI validation, and rebuildable read models without creating domain route selection, execution permission, or semantic transition authority.",
  "state": "active_contract",
  "machine_boundary": {
    "opl_owns": {
      "attempt_transport": true,
      "event_log": true,
      "projection_rebuild": true,
      "currentness_filtering": true,
      "retry_budget_accounting": true,
      "operator_observability": true,
      "decisive_attempt_route_abi_validation": true,
      "durable_stage_run_invocation_identity": true,
      "immutable_stage_run_spec_digest": true,
      "pre_start_launch_registry": true,
      "validated_route_transition_materialization": true
    },
    "codex_cli_owns": {
      "semantic_stage_selection": true,
      "skip_repeat_reverse_and_route_back": true,
      "interpretation_of_prior_artifacts": true
    },
    "domain_agent_owns": {
      "domain_truth": true,
      "quality_and_ready_verdicts": true,
      "artifact_and_memory_bodies": true,
      "owner_receipts_and_domain_typed_blockers": true
    },
    "read_model_role": "rebuildable_refs_only_projection_not_truth_or_gate"
  },
  "progress_first_policy": {
    "readable_artifact_allows_any_declared_stage": true,
    "free_text_partial_draft_failed_diagnostic_and_negative_result_are_progress": true,
    "quality_budget_exhaustion_blocks_route": false,
    "typed_closeout_required_for_progress": false,
    "owner_receipt_required_for_next_stage": false,
    "independent_review_required_for_next_stage": false,
    "owner_receipt_or_independent_review_required_for_quality_ready_claim": true,
    "format_manifest_role_receipt_lineage_and_review_gaps_are_quality_debt": true
  },
  "launch_policy": {
    "hard_stops": [
      "identity_conflict_that_would_mutate_wrong_target",
      "unsafe_or_overclaiming_authority_boundary",
      "forbidden_write",
      "permission_credential_or_safety_boundary",
      "irreversible_action_without_required_authority",
      "explicit_human_decision_gate"
    ],
    "advisory_only": [
      "missing_owner_metadata",
      "missing_selected_executor_metadata_defaults_to_codex_cli",
      "missing_scope_refs",
      "missing_provider_attempt_or_lease_ref",
      "missing_source_fingerprint_or_idempotency_key",
      "missing_stage_manifest_or_current_pointer",
      "missing_prompt_skill_tool_knowledge_rubric_or_evaluation_refs",
      "missing_requires_or_ensures_evidence",
      "missing_expected_receipt_shape"
    ],
    "framework_semantic_route_role": "validate_attempt_authority_and_route_abi_then_project_declared_target_without_domain_semantic_judgment"
  },
  "durable_stage_run_launch": {
    "required_workflow_input_fields": [
      "stage_run_id",
      "stage_run_invocation_id",
      "stage_run_spec_sha256",
      "stage_run_spec",
      "parent_route_decision_ref"
    ],
    "stage_run_id_derivation": {
      "algorithm": "stable_id",
      "ordered_inputs": [
        "domain_id",
        "stage_id",
        "stage_run_invocation_id"
      ],
      "immutable_spec_fields_participate_directly": false,
      "currentness_observations_participate": false
    },
    "stage_run_spec_sha256": {
      "algorithm": "sha256_canonical_json",
      "binds": [
        "stable_workspace_identity",
        "stage_manifest_ref_and_sha256",
        "quality_policy_ref_and_body",
        "stage_packet_and_checkpoint_refs",
        "source_fingerprint_and_source_refs",
        "input_artifact_refs_and_hashes",
        "role_prompt_and_quality_rubric_refs",
        "stage_goal_and_lineage_refs",
        "immutable_package_dependency_closure",
        "executor_binding",
        "parent_route_decision_ref"
      ],
      "excludes": [
        "checked_at",
        "use_boundary_id",
        "use_receipt_ref",
        "checkout_currentness_observation",
        "runtime_source_readiness_observation",
        "materialization_or_checkout_path"
      ]
    },
    "invocation_sources": {
      "cli_default": "stable_domain_stage_action_workspace_task_idempotency",
      "hosted_action": "action_run_id_plus_action_run_ref",
      "validated_route": "parent_stage_run_id_plus_decisive_attempt_ref_plus_route_decision_sha256_plus_target_stage",
      "explicit_new_run_option": "--new-stage-run",
      "quality_path_compatibility_alias": "--new-attempt"
    },
    "launch_registry": {
      "database": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
      "table": "stage_run_launches",
      "write_order": "register_exact_input_before_temporal_start",
      "validate_identity_and_spec_before_registry_write": true,
      "statuses": [
        "registered",
        "start_failed",
        "started",
        "closed"
      ],
      "same_invocation_same_spec": "return_existing_running_or_closed_stage_run",
      "same_invocation_different_spec": "typed_fail_closed_stage_run_invocation_spec_conflict",
      "pre_start_crash_recovery": "restart_from_registered_exact_input",
      "post_start_crash_recovery": "recover_existing_temporal_execution_without_duplicate_start",
      "terminal_temporal_readback": "persist_start_receipt_then_mark_launch_closed",
      "closed_state_is_monotonic_under_late_start_receipt": true,
      "stores_domain_truth": false,
      "stores_artifact_or_memory_body": false
    },
    "route_materialization": {
      "semantic_route_decision_owner": "decisive_codex_attempt",
      "stage_transition_materialization_owner": "opl_stage_run_controller",
      "validated_non_complete_route_starts_target_stage_run": true,
      "same_route_replay_is_idempotent": true,
      "later_route_decision_creates_new_stage_run": true,
      "route_back_or_repeat_to_prior_stage_creates_new_stage_run": true
    }
  },
  "route_output_policy": {
    "semantic_route_owner": "decisive_codex_attempt",
    "primary_only_decisive_role": "producer",
    "formal_review_decisive_roles": [
      "reviewer",
      "re_reviewer"
    ],
    "non_decisive_output": "route_impact.stage_route_recommendation",
    "terminal_output": "route_impact.stage_route_decision",
    "framework_validates": [
      "attempt_role_and_terminality",
      "context_and_lineage_identity",
      "output_shape_and_mutual_exclusion",
      "declared_target_identity",
      "legacy_field_absence",
      "re_review_finding_closure_before_terminal_route"
    ],
    "framework_does_not_validate": [
      "domain_reasoning_correctness",
      "scientific_clinical_grant_visual_or_editorial_merit",
      "whether_an_abi_valid_declared_target_is_the_best_route"
    ],
    "invalid_output_effect": "preserve_consumable_progress_record_route_quality_debt_and_leave_attempt_route_unmaterialized",
    "missing_or_invalid_route_fallback": "domain_pack_declared_default_progression_with_route_quality_debt_only",
    "declared_default_progression_resolution": [
      "action_stage_route.required_stage_refs_order",
      "unique_current_stage.next_stage_refs"
    ],
    "manifest_file_order_must_not_select_successor": true,
    "ambiguous_declared_successors_require_decisive_codex_route": true
  },
  "closeout_policy": {
    "progress_outcomes": [
      "completed",
      "completed_with_quality_debt"
    ],
    "zero_output_is_forwarded_as_no_output_diagnostic": true,
    "corrupt_or_unreadable_output_is_forwarded_as_failure_diagnostic": true,
    "hard_stop_only_when": [
      "identity_conflict_that_would_mutate_wrong_target",
      "permission_credential_or_safety_boundary",
      "authority_boundary_or_forbidden_write",
      "irreversible_action_without_required_authority",
      "explicit_human_decision_gate"
    ],
    "closeout_receipt_binding_is_quality_or_ready_evidence_only": true,
    "missing_closeout_receipt_binding_blocks_next_stage": false,
    "missing_independent_review_blocks_next_stage": false,
    "missing_independent_review_blocks_quality_ready_claim": true
  },
  "stage_run_kernel": {
    "spec_role": "desired_transport_refs_only",
    "status_role": "passive_attempt_lifecycle_projection",
    "event_log_role": "append_only_refs_only_stage_run_events",
    "projection_role": "rebuildable_refs_only_read_model",
    "provider_completion_role": "attempt_transport_completed",
    "provider_completion_is_domain_accepted": false,
    "next_stage_ready_role": "validated_codex_route_or_domain_pack_declared_default_progression_not_framework_domain_judgment"
  },
  "event_policy": {
    "required_event_fields": [
      "event_id",
      "event_kind",
      "stage_run_id",
      "generation",
      "observed_at"
    ],
    "generation_rule": "highest matching generation is current; older generations remain audit refs",
    "currentness_mismatch_effect": "disable_reuse_or_wrong_target_mutation_only",
    "retry_budget_key": [
      "stage_run_id",
      "generation",
      "input_fingerprint",
      "failure_signature"
    ],
    "retry_budget_role": "quality_and_compute_budget_only",
    "retry_budget_exhaustion_effect": "carry_best_readable_artifact_forward_with_quality_debt"
  },
  "read_model_projection": {
    "surface_kind": "opl_stage_run_read_model",
    "projection_role": "rebuildable_refs_only_projection",
    "body_access": false,
    "truth_source": false,
    "can_select_route": false,
    "can_block_route_for_missing_format_or_receipt": false,
    "output_fields": [
      "stage_run_id",
      "status",
      "observed_generation",
      "spec_ref",
      "consumed_refs",
      "artifact_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "provider_attempt_refs",
      "retry_budget_ref",
      "input_fingerprint",
      "last_event_ref"
    ]
  },
  "quality_claim_boundary": {
    "quality_debt_blocks": [
      "domain_ready",
      "quality_ready",
      "artifact_ready",
      "visual_ready",
      "export_ready",
      "publication_ready",
      "submission_ready",
      "production_ready"
    ],
    "quality_debt_never_blocks": [
      "next_declared_stage_start",
      "skip",
      "repeat",
      "reverse",
      "route_back",
      "repair",
      "review"
    ]
  },
  "forbidden_payloads": [
    "artifact body",
    "memory body",
    "domain truth body",
    "owner receipt body",
    "typed blocker body",
    "publication verdict body",
    "quality verdict body",
    "large binary/blob body",
    "manuscript body",
    "grant package body",
    "visual package body"
  ],
  "adoption_surface": {
    "surface_kind": "opl_stage_run_kernel_adoption",
    "domain_contract_path": "contracts/stage_run_kernel_adoption.json",
    "domain_agent_required_claims": [
      "stage_semantics_owner",
      "owner_receipt_authority",
      "typed_blocker_authority",
      "artifact_body_authority",
      "publication_or_quality_verdict_authority"
    ],
    "opl_required_claims": [
      "attempt_transport_owner",
      "read_model_projection_owner",
      "currentness_filter_owner",
      "retry_budget_accounting_owner"
    ]
  },
  "authority_boundary": {
    "opl_can_create_and_observe_stage_attempt": true,
    "opl_can_append_stage_run_event_refs": true,
    "opl_can_rebuild_read_model": true,
    "opl_can_account_retry_budget": true,
    "opl_can_filter_stale_reuse": true,
    "opl_can_validate_route_output_abi_and_attempt_authority": true,
    "opl_must_reject_non_authoritative_or_malformed_route_output": true,
    "opl_can_persist_stage_run_transport_launch_identity": true,
    "opl_can_materialize_validated_decisive_attempt_route": true,
    "opl_can_select_semantic_stage_route": false,
    "opl_can_reject_abi_valid_route_on_domain_semantic_merit": false,
    "opl_can_block_next_stage_for_missing_receipt_or_format": false,
    "opl_can_write_domain_truth": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_store_memory_body": false,
    "opl_can_create_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_authorize_publication_or_quality_verdict": false,
    "read_model_can_be_truth_source": false,
    "provider_completion_counts_as_domain_accepted": false
  }
}
