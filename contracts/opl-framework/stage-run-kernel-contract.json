{
  "contract_kind": "opl_stage_run_kernel_contract.v1",
  "surface_kind": "opl_stage_run_kernel_contract",
  "owner": "one-person-lab",
  "purpose": "Freeze the OPL-owned refs-only StageRun transport for execution identity, event-log/projection rebuild, output refs, retry-budget accounting, hold scope, and domain-agent adoption without creating a second semantic route authority.",
  "state": "active_contract",
  "machine_boundary": {
    "opl_owns": {
      "stage_run_spec": true,
      "stage_run_status": true,
      "event_log": true,
      "projection_rebuild": true,
      "observed_generation": true,
      "retry_budget_accounting": true,
      "hold_scope_projection": true
    },
    "mas_owns": {
      "stage_semantics": true,
      "owner_receipt_signing": true,
      "typed_blocker_creation": true,
      "publication_verdict": true,
      "artifact_body": true,
      "memory_body": true
    },
    "read_model_role": "rebuildable_refs_only_projection_not_truth_source"
  },
  "codex_semantic_route_boundary": {
    "semantic_owner": "codex_cli",
    "readable_artifact_allows_any_declared_stage": true,
    "quality_budget_exhaustion_blocks_route": false,
    "framework_can_accept_reject_rank_or_override_route": false,
    "stage_run_status_is_passive_projection": true
  },
  "stage_run_kernel": {
    "spec_role": "desired_stage_run_refs_only",
    "status_role": "opl_owned_current_state_projection",
    "event_log_role": "append_only_refs_only_stage_run_events",
    "projection_role": "rebuildable_refs_only_read_model",
    "status_values": [
      "declared",
      "inputs_ready",
      "admitted",
      "running",
      "terminalizing",
      "domain_accepted",
      "next_stage_ready",
      "needs_human_decision",
      "needs_external_resource",
      "retry_scheduled",
      "typed_blocked",
      "infrastructure_crashed",
      "superseded"
    ],
    "terminal_domain_authority_refs": [
      "owner_receipt_ref",
      "typed_blocker_ref"
    ],
    "provider_completion_status": "terminalizing",
    "domain_acceptance_status": "domain_accepted"
  },
  "contract_writing_rules": {
    "required_for_launch": [
      "stage_run_id",
      "domain_id",
      "stage_id",
      "generation",
      "current_pointer",
      "owner",
      "selected_executor",
      "authority_boundary",
      "provider_attempt_ref",
      "attempt_lease_ref",
      "execution_authorization_decision_ref",
      "workspace_scope_ref",
      "artifact_scope_ref",
      "source_fingerprint",
      "idempotency_key"
    ],
    "required_for_closeout": [
      "consumable_artifact_progress_or_owner_answer",
      "current_pointer"
    ],
    "required_for_quality_or_ready_closeout": [
      "owner_receipt_or_quality_gate_receipt",
      "closeout_receipt_ref",
      "closeout_receipt_stage_run_binding",
      "closeout_receipt_stage_manifest_binding",
      "closeout_receipt_current_pointer_binding",
      "closeout_receipt_source_fingerprint_binding",
      "closeout_owner_answer_idempotency_binding"
    ],
    "advisory_for_context": [
      "prompt_refs",
      "skill_refs",
      "tool_affordance_refs",
      "knowledge_refs",
      "rubric_refs",
      "evaluation_refs",
      "assumption_refs",
      "monitor_refs",
      "stage_manifest",
      "required_role_artifacts",
      "expected_receipt_or_blocker",
      "input_refs",
      "replay_audit_lineage_refs",
      "content_hashes",
      "lineage_refs"
    ],
    "route_back_when_missing": [
      "prompt_refs",
      "skill_refs",
      "tool_affordance_refs",
      "knowledge_refs",
      "rubric_refs",
      "evaluation_refs"
    ],
    "forbidden_as_authority": [
      "State Index",
      "stage_progress_log",
      "provider completion",
      "readiness",
      "verified ledger",
      "file presence",
      "conformance passed"
    ]
  },
  "admission_policy": {
    "launch_hard_blockers": [
      "identity",
      "owner",
      "scope",
      "selected_executor",
      "authority_boundary",
      "forbidden_write",
      "provider_attempt",
      "attempt_lease",
      "execution_authorization_decision",
      "workspace_artifact_scope",
      "source_fingerprint",
      "idempotency_key"
    ],
    "strategy_refs_default": "advisory_or_route_back",
    "prompt_skill_tool_knowledge_missing_blocks_launch_by_default": false,
    "closeout_hard_blockers": [
      "zero_consumable_artifact_without_owner_answer_or_hard_stop",
      "current_pointer",
      "generation",
      "invalid_supplied_owner_answer_binding"
    ],
    "progress_first_closeout": {
      "consumable_artifact_without_owner_answer_status": "completed_with_quality_debt",
      "quality_budget_exhaustion_blocks_route": false,
      "owner_answer_required_for_quality_or_ready_claim": true,
      "typed_blocker_reserved_for_hard_stop": true,
      "format_manifest_role_receipt_or_lineage_gaps_are_quality_debt": true
    }
  },
  "execution_authorization_policy": {
    "surface_kind": "opl_stage_run_execution_authorization_policy",
    "ledger_surface": {
      "surface_kind": "opl_stage_run_execution_authorization_ledger",
      "receipt_surface_kind": "opl_stage_run_execution_authorization_receipt",
      "cli_commands": [
        "opl runtime stage-run-authorization record",
        "opl runtime stage-run-authorization verify",
        "opl runtime stage-run-authorization list"
      ],
      "authority_boundary": {
        "refs_only": true,
        "authorization_receipt_is_domain_owner_answer": false,
        "queued_attempt_counts_as_active_lease": false,
        "registered_workflow_counts_as_execution_authorized": false,
        "provider_attempt_ref_counts_as_closeout_binding": false,
        "can_write_domain_truth": false,
        "can_create_owner_receipt": false,
        "can_create_typed_blocker": false,
        "can_claim_domain_ready": false,
        "can_claim_production_ready": false
      }
    },
    "launch_hard_blockers": [
      "provider_attempt_ref_missing",
      "attempt_lease_ref_missing",
      "attempt_lease_not_active",
      "execution_authorization_decision_ref_missing",
      "workspace_scope_ref_missing",
      "artifact_scope_ref_missing",
      "source_fingerprint_missing",
      "idempotency_key_missing",
      "authority_boundary_invalid",
      "forbidden_write_required"
    ],
    "closeout_binding_blockers": [
      "closeout_receipt_ref_missing",
      "closeout_receipt_stage_run_binding_missing",
      "closeout_receipt_stage_manifest_binding_missing",
      "closeout_receipt_current_pointer_binding_missing",
      "closeout_receipt_source_fingerprint_binding_missing",
      "closeout_owner_answer_idempotency_binding_missing",
      "quality_gate_independent_attempt_binding_missing",
      "quality_gate_same_attempt_self_review_forbidden"
    ],
    "blocked_result": {
      "surface_kind": "opl_stage_run_execution_authorization_blocker",
      "owner": "one-person-lab",
      "blocker_code": "stage_run_execution_authorization_blocked",
      "domain_truth_changed": false,
      "owner_receipt_signed": false,
      "domain_typed_blocker_created": false
    }
  },
  "conformance_output": {
    "required_sections": [
      "status",
      "launch_blockers",
      "closeout_blockers",
      "execution_authorization",
      "closeout_binding_blockers",
      "transition_outcome",
      "quality_debt_reasons",
      "advisory_warnings",
      "route_back_recommendations",
      "audit_drilldown_refs",
      "forbidden_authority_flags"
    ],
    "layers": [
      "launch_blockers",
      "closeout_blockers",
      "execution_authorization",
      "closeout_binding_blockers",
      "transition_outcome",
      "quality_debt_reasons",
      "advisory_warnings",
      "route_back_recommendations",
      "audit_drilldown_refs",
      "forbidden_authority_flags"
    ],
    "default_blocking_sections": [
      "launch_blockers",
      "closeout_blockers",
      "execution_authorization",
      "closeout_binding_blockers"
    ],
    "default_blocking_layers_only": [
      "launch_blockers",
      "closeout_blockers",
      "execution_authorization",
      "closeout_binding_blockers"
    ],
    "non_blocking_default_sections": [
      "quality_debt_reasons",
      "advisory_warnings",
      "route_back_recommendations",
      "audit_drilldown_refs"
    ]
  },
  "forbidden_as_authority": [
    "State Index",
    "stage_progress_log",
    "provider completion",
    "readiness",
    "verified ledger",
    "file presence",
    "conformance passed"
  ],
  "adoption_surface": {
    "surface_kind": "opl_stage_run_kernel_adoption",
    "domain_contract_path": "contracts/stage_run_kernel_adoption.json",
    "domain_agent_required_claims": [
      "stage_semantics_owner",
      "owner_receipt_authority",
      "typed_blocker_authority",
      "artifact_body_authority",
      "publication_or_quality_verdict_authority"
    ],
    "opl_required_claims": [
      "stage_run_spec_status_event_log_owner",
      "read_model_projection_owner",
      "observed_generation_owner",
      "retry_budget_owner",
      "hold_scope_projection_owner"
    ],
    "domain_must_not_claim": [
      "generic_stage_run_kernel_owner",
      "opl_read_model_truth_source",
      "sqlite_body_store_owner"
    ],
    "opl_must_not_claim": [
      "domain_stage_semantics_owner",
      "owner_receipt_signer",
      "typed_blocker_creator",
      "publication_or_quality_verdict_authority",
      "artifact_body_owner",
      "memory_body_owner"
    ]
  },
  "read_model_projection": {
    "surface_kind": "opl_stage_run_read_model",
    "projection_role": "rebuildable_refs_only_projection",
    "rebuild_from": [
      "StageRun event log",
      "StageRun spec refs",
      "input refs",
      "owner receipt refs",
      "typed blocker refs",
      "provider attempt refs",
      "hold refs",
      "retry budget refs"
    ],
    "body_access": false,
    "truth_source": false,
    "output_fields": [
      "stage_run_id",
      "status",
      "observed_generation",
      "spec_ref",
      "consumed_refs",
      "owner_receipt_refs",
      "typed_blocker_refs",
      "provider_attempt_refs",
      "hold_refs",
      "retry_budget_ref",
      "input_fingerprint",
      "last_event_ref"
    ]
  },
  "event_policy": {
    "required_event_fields": [
      "event_id",
      "event_kind",
      "stage_run_id",
      "generation",
      "observed_at"
    ],
    "generation_rule": "only events matching the highest observed generation participate in current projection; older generations remain audit refs",
    "retry_budget_key": [
      "stage_run_id",
      "generation",
      "input_fingerprint",
      "failure_signature"
    ],
    "hold_scope_rule": "holds must identify exact stage_run_id generation and optional work_unit_ref; study-wide opaque holds cannot silently block a current StageRun"
  },
  "forbidden_payloads": [
    "artifact body",
    "memory body",
    "domain truth body",
    "owner receipt body",
    "typed blocker body",
    "publication verdict body",
    "quality verdict body",
    "large binary/blob body",
    "manuscript body",
    "grant package body",
    "visual package body"
  ],
  "authority_boundary": {
    "opl_can_create_stage_run_spec": true,
    "opl_can_update_stage_run_status": true,
    "opl_can_append_stage_run_event_refs": true,
    "opl_can_rebuild_read_model": true,
    "opl_can_account_retry_budget": true,
    "opl_can_project_hold_scope": true,
    "opl_can_select_semantic_stage_route": false,
    "opl_can_accept_reject_rank_or_override_codex_route": false,
    "opl_can_write_domain_truth": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_store_memory_body": false,
    "opl_can_create_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_create_execution_authorization_blocker": true,
    "execution_blocker_is_domain_typed_blocker": false,
    "execution_blocker_can_change_domain_truth": false,
    "opl_can_authorize_publication_or_quality_verdict": false,
    "read_model_can_be_truth_source": false,
    "provider_completion_counts_as_domain_accepted": false,
    "file_presence_counts_as_stage_complete": false,
    "latest_json_counts_as_owner_receipt": false,
    "sqlite_record_counts_as_domain_progress": false
  }
}
