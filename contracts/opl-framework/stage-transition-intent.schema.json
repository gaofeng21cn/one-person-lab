{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/stage-transition-intent.schema.json",
  "schema_id": "opl.stage_transition_intent.v1",
  "surface_kind": "opl_stage_transition_intent_schema",
  "owner": "one-person-lab",
  "purpose": "Define the refs-only transition intent envelope consumed by the OPL Stage Transition Authority. Intents may carry owner answer, typed blocker, human gate, provider, read-model, worklist, Agent Lab, or evidence observations, but they do not directly write Stage current state.",
  "state": "active_contract",
  "machine_boundary": "OPL owns the intent envelope and Stage Transition Authority decision surface; producers retain their domain or product authority while provider/read-model/worklist/evidence signals remain observation-only until accepted by the authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "intent_id",
    "intent_kind",
    "producer_kind",
    "stage_run_id",
    "generation",
    "domain_id",
    "stage_id",
    "owner",
    "source_fingerprint",
    "idempotency_key",
    "stage_manifest_ref",
    "current_pointer_ref",
    "provider_attempt_ref",
    "attempt_lease_ref",
    "execution_authorization_decision_ref",
    "observed_at",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_stage_transition_intent"
    },
    "schema_version": {
      "const": "stage-transition-intent.v1"
    },
    "intent_id": {
      "type": "string",
      "minLength": 1
    },
    "intent_kind": {
      "type": "string",
      "enum": [
        "domain_owner_answer",
        "typed_blocker",
        "human_gate_decision",
        "route_recommendation",
        "provider_observation",
        "read_model_observation",
        "worklist_observation",
        "agent_lab_observation",
        "evidence_observation"
      ]
    },
    "producer_kind": {
      "type": "string",
      "enum": [
        "domain_agent",
        "human_operator",
        "one_person_lab_app",
        "runtime_provider",
        "agent_lab",
        "evidence_ledger",
        "read_model",
        "worklist",
        "stage_transition_authority"
      ]
    },
    "stage_run_id": {
      "type": "string",
      "minLength": 1
    },
    "generation": {
      "type": "integer",
      "minimum": 0
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_id": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "source_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "stage_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "current_pointer_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_attempt_ref": {
      "type": "string",
      "minLength": 1
    },
    "attempt_lease_ref": {
      "type": "string",
      "minLength": 1
    },
    "execution_authorization_decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "minLength": 1
    },
    "owner_answer_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_receipt_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "typed_blocker_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "human_decision_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_answer_stage_run_id": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_answer_generation": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "owner_answer_manifest_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_answer_current_pointer_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_answer_source_fingerprint": {
      "$ref": "#/$defs/nullable_ref"
    },
    "owner_answer_idempotency_key": {
      "$ref": "#/$defs/nullable_ref"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "accepted_answer_shape": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "nullable_ref": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "intent_can_write_stage_current_pointer",
        "intent_can_write_stage_run_terminal_state",
        "intent_can_publish_current_owner_delta",
        "intent_can_write_domain_truth",
        "intent_can_create_owner_receipt",
        "intent_can_create_typed_blocker",
        "provider_completion_counts_as_stage_transition",
        "read_model_update_counts_as_stage_transition",
        "worklist_update_counts_as_stage_transition",
        "evidence_event_counts_as_stage_transition",
        "agent_lab_output_counts_as_stage_transition"
      ],
      "properties": {
        "intent_can_write_stage_current_pointer": {
          "const": false
        },
        "intent_can_write_stage_run_terminal_state": {
          "const": false
        },
        "intent_can_publish_current_owner_delta": {
          "const": false
        },
        "intent_can_write_domain_truth": {
          "const": false
        },
        "intent_can_create_owner_receipt": {
          "const": false
        },
        "intent_can_create_typed_blocker": {
          "const": false
        },
        "provider_completion_counts_as_stage_transition": {
          "const": false
        },
        "read_model_update_counts_as_stage_transition": {
          "const": false
        },
        "worklist_update_counts_as_stage_transition": {
          "const": false
        },
        "evidence_event_counts_as_stage_transition": {
          "const": false
        },
        "agent_lab_output_counts_as_stage_transition": {
          "const": false
        }
      }
    }
  }
}
