{
  "version": "2026-04-13",
  "contract_id": "opl_family_executor_adapter_defaults",
  "scope": "family_executor_adapter_default_stage_selection",
  "description": "Machine-readable freeze for the OPL family default executor-adapter stage-selection semantics and its non-negotiable guardrails. This contract does not select a runtime substrate owner and does not collapse domain authority into OPL.",
  "non_goals": [
    "runtime_substrate_replacement",
    "domain_object_model_unification",
    "chat_completion_relay_as_default_executor",
    "repo_local_model_pin_as_family_default",
    "simple_llm_as_family_backend",
    "openai_compatible_gateway_as_family_backend"
  ],
  "defaults": {
    "default_executor_name": "codex_cli",
    "default_executor_mode": "autonomous",
    "default_model": "inherit_local_codex_default",
    "default_reasoning_effort": "inherit_local_codex_default",
    "default_semantics": "full_agent_loop_autonomous_execution"
  },
  "canonical_executor_backends": [
    "codex_cli",
    "hermes_agent",
    "claude_code",
    "antigravity_cli"
  ],
  "executor_registry": {
    "surface_kind": "opl_agent_executor_registry",
    "request_contract": "AgentExecutionRequest",
    "receipt_contract": "AgentExecutionReceipt",
    "default_resolution_order": [
      "cli_flag",
      "stage_attempt_input",
      "OPL_EXECUTOR_KIND",
      "codex_cli"
    ],
    "non_default_equivalence": "connectivity_lifecycle_receipt_audit_only",
    "capability_activation": {
      "supported_required_capabilities": [
        "image_generation"
      ],
      "image_generation_executor": "codex_cli",
      "unknown_capability_policy": "fail_closed",
      "unsupported_executor_policy": "fail_closed",
      "receipt_fields": [
        "requested_capabilities",
        "activated_capabilities"
      ],
      "artifact_authority": "domain_owned"
    },
    "request_runtime_controls": {
      "timeout_ms": "process_deadline_fail_closed",
      "timeout_error_fields": [
        "timed_out",
        "timeout_ms",
        "timeout_reason",
        "fallback_allowed"
      ],
      "timeout_success_receipt_forbidden": true
    },
    "stage_level_policy_fields": [
      "executor_kind",
      "model",
      "reasoning_effort",
      "provider",
      "executor_binding_ref",
      "executor_labels",
      "required_capabilities",
      "receipt_requirements"
    ]
  },
  "execution_shapes": {
    "structured_call": {
      "summary": "single structured input/output call under a domain-owned schema",
      "allowed_backends": [
        "codex_cli",
        "hermes_agent",
        "claude_code",
        "antigravity_cli"
      ]
    },
    "agent_loop": {
      "summary": "multi-step agent run with events, tool use, repair, and review-loop proof",
      "allowed_backends": [
        "codex_cli",
        "hermes_agent",
        "claude_code",
        "antigravity_cli"
      ]
    }
  },
  "stage_level_executor_policy": {
    "owner": "domain_stage_contract_or_opl_handoff_envelope",
    "scope": "per-stage explicit executor/model/reasoning/provider selection and receipt requirements",
    "fields": {
      "executor_kind": "canonical backend key selected for the stage; defaults to codex_cli unless explicitly bound",
      "model": "stage-selected model id or inherit_local_codex_default for Codex CLI default paths",
      "reasoning_effort": "stage-selected reasoning effort or inherit_local_codex_default for Codex CLI default paths",
      "provider": "runtime/provider reference for the selected executor; provider catalog ownership stays outside domain repos",
      "executor_binding_ref": "auditable reference to the explicit non-default binding, handoff, or runtime-manager selection",
      "executor_labels": "human-readable labels for selected and candidate executors",
      "required_capabilities": "stage-declared capabilities the selected executor must prove before launch",
      "receipt_requirements": "required execution receipt fields, tool/event proof, status, and fail-closed evidence"
    },
    "default_executor_kind": "codex_cli",
    "non_default_executor_binding_required": true
  },
  "layered_executor_semantics": {
    "user_interaction_shell": {
      "owner": "opl_or_domain_product_entry",
      "scope": "user-facing natural-language or session shell",
      "surfaces": [
        "opl",
        "opl_tui",
        "opl_app",
        "opl_acp_stdio",
        "domain_direct_skill_entry"
      ],
      "selects_effective_default_executor": false,
      "holds_domain_truth": false,
      "adapter_changes_default_interaction_semantics": false
    },
    "frontend_executor_policy": {
      "owner": "opl_tui_or_opl_app_frontend",
      "scope": "user-facing frontend behavior for TUI, App, and ACP shells",
      "default_behavior": "preserve_existing_codex_cli_interaction",
      "may_pass_explicit_executor_selection": true,
      "may_resolve_implicit_default_executor": false,
      "may_silently_substitute_non_default_executor": false,
      "non_default_selection_requires_user_or_stage_explicit_signal": true
    },
    "effective_default_executor": {
      "owner": "opl_family_runtime_config",
      "scope": "family-level default executor resolution",
      "default_backend": "codex_cli",
      "concrete_executor_implementation_owned_here": false,
      "domain_truth_owned_here": false
    },
    "stage_level_structured_call_selection": {
      "owner": "domain_stage_contract",
      "scope": "domain-owned schema and stage-level structured_call selection",
      "execution_shape": "structured_call",
      "may_accept_request_explicit_executor": true
    }
  },
  "effective_default_executor_resolution": [
    {
      "priority": 1,
      "source": "request_explicit_executor",
      "summary": "A request-scoped explicit executor wins when present."
    },
    {
      "priority": 2,
      "source": "opl_runtime_manager_or_handoff_default_executor",
      "summary": "An OPL Runtime Manager or handoff-level default executor wins when no request explicit executor is present."
    },
    {
      "priority": 3,
      "source": "domain_local_user_config",
      "summary": "Domain-local user config applies when no request or OPL handoff default is present."
    },
    {
      "priority": 4,
      "source": "domain_built_in_default_codex_cli",
      "executor": "codex_cli",
      "summary": "The domain built-in default remains Codex CLI."
    }
  ],
  "executor_labels": {
    "codex_cli": "Codex CLI",
    "hermes_agent": "Hermes-Agent",
    "claude_code": "Claude Code",
    "antigravity_cli": "Antigravity CLI"
  },
  "executor_statuses": {
    "codex_cli": "default",
    "hermes_agent": "experimental",
    "claude_code": "experimental",
    "antigravity_cli": "experimental_non_default_explicit_adapter"
  },
  "executor_backend_notes": {
    "antigravity_cli": {
      "status": "experimental_non_default_explicit_adapter",
      "recommended_example_scope": "rca_html_route_stage_selection_with_gemini_flash_or_high",
      "requires_explicit_stage_binding": true,
      "quality_tool_resume_equivalence_with_codex_cli": false,
      "default_path": false
    }
  },
  "guardrails": {
    "chat_completion_only_executor_forbidden": true,
    "hermes_agent_requires_full_agent_loop": true,
    "hermes_agent_not_provider_or_gateway_surface": true,
    "non_default_executor_requires_explicit_selection": true,
    "non_default_executor_forbids_silent_codex_fallback": true,
    "simple_llm_backend_forbidden": true,
    "openai_compatible_gateway_backend_forbidden": true,
    "domain_repo_provider_catalog_forbidden": true,
    "migration_bridge_label_required_for_non_default_stage_selections": true,
    "experimental_label_required_for_non_default_stage_selections": true,
    "regression_oracle_label_required_for_non_default_stage_selections": true,
    "domain_runtime_authority_stays_domain_owned": true
  },
  "ownership_boundaries": {
    "opl_owns": [
      "family_level_user_runtime_config",
      "effective_default_executor_semantics"
    ],
    "opl_does_not_own": [
      "redcube_domain_truth",
      "domain_artifact_truth",
      "concrete_executor_implementation",
      "provider_catalog"
    ],
    "domain_truth_stays_domain_owned": true,
    "concrete_executor_implementation_stays_runtime_or_domain_owned": true
  },
  "standalone_domain_behavior": {
    "without_opl_config": "use_domain_defaults",
    "domain_default_executor": "codex_cli",
    "opl_config_required_for_family_override": true
  },
  "runtime_profile_catalog_boundary": {
    "catalog_owner": "opl_runtime_manager_or_hermes_agent_config_reference",
    "domain_repo_provider_catalog_forbidden": true,
    "forbidden_domain_repo_fields": [
      "provider",
      "base_url",
      "api_key",
      "model_list"
    ]
  },
  "configuration_examples": {
    "activation_status": "example_only_not_default_active",
    "default_active_backend": "codex_cli",
    "sample_non_default_backend": "hermes_agent",
    "sample_stage_level_explicit_backend": "antigravity_cli",
    "activation_requires": "explicit_request_or_runtime_manager_handoff_config"
  },
  "topology_split": {
    "opl_role": "stage_led_agent_executor_family_framework_contract",
    "runtime_substrate_role": "provider_backed_stage_attempt_orchestration",
    "executor_adapter_role": "domain_owned_stage_selection",
    "concrete_executor_role": "task_local_autonomous_execution"
  },
  "allowed_non_default_stage_selection_labels": [
    "migration_bridge",
    "experimental",
    "regression_oracle"
  ],
  "verification_refs": [
    "contracts/opl-framework/standard-domain-agent-skeleton-contract.json",
    "contracts/opl-framework/stage-selection-vocabulary.json",
    "human_doc:family_executor_adapter_defaults",
    "human_doc:four_repo_executor_follow_up_and_hermes_evaluation"
  ]
}
