{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/agent-package-manifest.schema.json",
  "title": "OPL Agent Package Manifest",
  "type": "object",
  "required": [
    "surface_kind",
    "agent_id",
    "package_id",
    "version",
    "source",
    "carrier_source_role",
    "codex_surface",
    "capability_dependencies"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_agent_package_manifest.v1"
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "registry_entry": {
      "type": "object",
      "required": [
        "registry_kind",
        "registry_source_ref",
        "base_contract_role",
        "base_contract_invariant",
        "identity_fields"
      ],
      "properties": {
        "registry_kind": {
          "type": "string",
          "minLength": 1
        },
        "registry_source_ref": {
          "type": "string",
          "minLength": 1
        },
        "base_contract_role": {
          "const": "registry_data_not_base_invariant"
        },
        "base_contract_invariant": {
          "const": false
        },
        "identity_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "admitted_domain_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "carrier_source_role": {
      "const": "codex_plugin_default_carrier_not_package_truth"
    },
    "package_core": {
      "type": "object",
      "required": [
        "core_kind",
        "identity_fields",
        "content_identity_fields",
        "dependency_source",
        "lock_owner",
        "lifecycle_receipt_owner",
        "exposure_owner"
      ],
      "properties": {
        "core_kind": {
          "const": "opl_agent_package_core"
        },
        "identity_fields": {
          "type": "array",
          "items": {
            "enum": [
              "package_id",
              "agent_id",
              "version"
            ]
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "content_identity_fields": {
          "type": "array",
          "items": {
            "enum": [
              "manifest_sha256",
              "payload_digest_ref",
              "required_skill_pack_lock_refs",
              "package_lock_ref"
            ]
          },
          "minItems": 4,
          "uniqueItems": true
        },
        "dependency_source": {
          "const": "manifest_declared_capability_dependencies"
        },
        "lock_owner": {
          "const": "opl_connect_agent_package_registry"
        },
        "lifecycle_receipt_owner": {
          "const": "opl_connect_agent_package_registry"
        },
        "exposure_owner": {
          "const": "opl_connect_agent_package_registry"
        }
      },
      "additionalProperties": true
    },
    "distribution_payload": {
      "description": "Optional published distribution metadata. Source-only or unpublished packages omit this property.",
      "type": "object",
      "required": [
        "payload_kind",
        "payload_ref",
        "payload_digest_ref",
        "required_skill_pack_lock_refs",
        "proof_status",
        "live_download_proof",
        "installed_reload_proof",
        "oci_ref",
        "oci_media_type",
        "immutable_tag",
        "rolling_tag",
        "promotion_policy",
        "install_truth"
      ],
      "properties": {
        "payload_kind": {
          "type": "string",
          "minLength": 1
        },
        "payload_ref": {
          "type": "string",
          "minLength": 1
        },
        "payload_digest_ref": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "required_skill_pack_lock_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "proof_status": {
          "type": "string",
          "minLength": 1
        },
        "live_download_proof": {
          "const": false
        },
        "installed_reload_proof": {
          "const": false
        },
        "oci_ref": {
          "type": "string",
          "minLength": 1
        },
        "oci_media_type": {
          "type": "string",
          "minLength": 1
        },
        "immutable_tag": {
          "type": "string",
          "minLength": 1
        },
        "rolling_tag": {
          "const": "latest"
        },
        "promotion_policy": {
          "const": "daily_candidate_gates_then_promote_latest"
        },
        "install_truth": {
          "const": "resolved_digest_lock"
        }
      },
      "additionalProperties": true
    },
    "codex_surface": {
      "type": "object",
      "required": [
        "plugin_id",
        "standalone_distribution",
        "required_skill_ids"
      ],
      "properties": {
        "plugin_id": {
          "type": "string",
          "minLength": 1
        },
        "standalone_distribution": {
          "const": "repo_carrier_source"
        },
        "required_skill_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    },
    "carrier_adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "adapter_kind",
          "carrier",
          "source_surface",
          "projection_role",
          "owns_package_core",
          "owns_domain_truth"
        ],
        "properties": {
          "adapter_kind": {
            "const": "codex_plugin_carrier"
          },
          "carrier": {
            "const": "codex_plugin"
          },
          "source_surface": {
            "const": "codex_surface"
          },
          "projection_role": {
            "const": "package_carrier_adapter"
          },
          "owns_package_core": {
            "const": false
          },
          "owns_domain_truth": {
            "const": false
          }
        },
        "additionalProperties": true
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "dependency_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile_id",
          "profile_kind",
          "profile_owner",
          "domain_id",
          "domain_truth_owner",
          "source",
          "opl_role",
          "authority_boundary"
        ],
        "properties": {
          "profile_id": {
            "type": "string",
            "minLength": 1
          },
          "profile_kind": {
            "const": "domain_dependency_profile"
          },
          "profile_owner": {
            "type": "string",
            "minLength": 1
          },
          "domain_id": {
            "type": "string",
            "minLength": 1
          },
          "domain_truth_owner": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "object",
            "required": [
              "source_kind",
              "profile_ref",
              "helper_ref"
            ],
            "properties": {
              "source_kind": {
                "const": "domain_profile_ref"
              },
              "profile_ref": {
                "type": "string",
                "minLength": 1
              },
              "helper_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          },
          "opl_role": {
            "const": "dependency_environment_check"
          },
          "source_descriptor_ref": {
            "type": "string",
            "minLength": 1
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "dependency_id",
                "kind",
                "required_level",
                "purpose"
              ],
              "properties": {
                "dependency_id": {
                  "type": "string",
                  "minLength": 1
                },
                "kind": {
                  "enum": [
                    "executable",
                    "latex_package"
                  ]
                },
                "required_level": {
                  "enum": [
                    "required",
                    "optional",
                    "legacy_not_required"
                  ]
                },
                "purpose": {
                  "type": "string",
                  "minLength": 1
                },
                "install_target": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "authority_boundary": {
            "type": "object",
            "required": [
              "can_write_domain_truth",
              "can_write_artifact_body",
              "can_authorize_domain_readiness",
              "can_authorize_artifact_or_export_readiness",
              "can_issue_owner_receipt"
            ],
            "properties": {
              "can_write_domain_truth": {
                "const": false
              },
              "can_write_artifact_body": {
                "const": false
              },
              "can_authorize_domain_readiness": {
                "const": false
              },
              "can_authorize_artifact_or_export_readiness": {
                "const": false
              },
              "can_issue_owner_receipt": {
                "const": false
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "uniqueItems": true
    },
    "capability_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module_id",
          "package_id",
          "kind",
          "codex_distribution",
          "opl_distribution",
          "developer_distribution",
          "required_for",
          "install_owner",
          "install_update_source",
          "sync_scopes",
          "sync_command_refs",
          "authority_boundary"
        ],
        "properties": {
          "module_id": {
            "type": "string",
            "minLength": 1
          },
          "package_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "const": "framework_capability_package"
          },
          "codex_distribution": {
            "const": "bundled"
          },
          "opl_distribution": {
            "const": "managed_dependency"
          },
          "developer_distribution": {
            "const": "source_checkout"
          },
          "required_for": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "install_owner": {
            "const": "one-person-lab"
          },
          "install_update_source": {
            "const": "ghcr_capability_packages_channel"
          },
          "sync_scopes": {
            "type": "array",
            "items": {
              "enum": [
                "workspace",
                "quest"
              ]
            },
            "minItems": 2,
            "uniqueItems": true
          },
          "sync_command_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "authority_boundary": {
            "type": "object",
            "required": [
              "can_write_domain_truth",
              "can_sign_owner_receipt",
              "can_create_typed_blocker",
              "can_write_runtime_queue"
            ],
            "properties": {
              "can_write_domain_truth": {
                "const": false
              },
              "can_sign_owner_receipt": {
                "const": false
              },
              "can_create_typed_blocker": {
                "const": false
              },
              "can_write_runtime_queue": {
                "const": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
