{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/workspace-index.schema.json",
  "schema_id": "opl.workspace_index.v1",
  "surface_kind": "opl_workspace_index_schema",
  "owner": "one-person-lab",
  "purpose": "Define the workspace-local index materialized by OPL workspace init and ensure for standard domain agents, including canonical topology, display labels, shared resources, project stage output roots, and authority boundaries.",
  "state": "active_contract",
  "machine_boundary": "OPL owns the workspace index shape, topology projection, registry-facing refs, user inspection pointers, and authority false flags. Domain agents own domain truth, source/artifact/memory bodies, owner receipts, typed blockers, quality verdicts, export verdicts, and product-specific workspace semantics.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "version",
    "workspace_id",
    "agent",
    "workspace_topology_profile",
    "canonical_topology",
    "display_labels",
    "shared_resource_roots",
    "shared_resources",
    "generated_refs",
    "profile_binding",
    "topology_events",
    "projects",
    "user_inspection",
    "runtime_state_boundary",
    "authority_boundary",
    "workspace_norm",
    "interface_projection"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_workspace_index"
    },
    "version": {
      "const": "workspace-index.v1"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "agent_id",
        "project_id",
        "workspace_kind",
        "project_kind"
      ],
      "properties": {
        "agent_id": {
          "enum": [
            "mas",
            "mag",
            "rca",
            "oma",
            "obf"
          ]
        },
        "project_id": {
          "type": "string"
        },
        "workspace_kind": {
          "type": "string"
        },
        "project_kind": {
          "type": "string"
        }
      }
    },
    "workspace_topology_profile": {
      "$ref": "#/$defs/workspace_topology_profile_ref"
    },
    "canonical_topology": {
      "$ref": "#/$defs/canonical_topology"
    },
    "display_labels": {
      "$ref": "#/$defs/display_labels"
    },
    "shared_resource_roots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shared_resources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/shared_resource"
      }
    },
    "generated_refs": {
      "$ref": "#/$defs/generated_refs"
    },
    "profile_binding": {
      "$ref": "#/$defs/profile_binding"
    },
    "topology_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/topology_event"
      }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project"
      }
    },
    "user_inspection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ordinary_user_default_surface",
        "workspace_inspection_ref",
        "workspace_resource_inventory_ref",
        "workspace_report_ref",
        "default_stage_outputs_index_ref",
        "default_current_stage_pointer_ref",
        "project_stage_outputs_pattern",
        "runtime_state_is_default_user_surface",
        "product_views_are_stage_outputs"
      ],
      "properties": {
        "ordinary_user_default_surface": {
          "const": "workspace_local_project_stage_outputs"
        },
        "workspace_inspection_ref": {
          "const": "workspace_inspection.json"
        },
        "workspace_resource_inventory_ref": {
          "const": "workspace_resource_inventory.json"
        },
        "workspace_report_ref": {
          "const": "workspace_report.json"
        },
        "default_stage_outputs_index_ref": {
          "type": "string"
        },
        "default_current_stage_pointer_ref": {
          "type": "string"
        },
        "project_stage_outputs_pattern": {
          "const": "<project-root>/artifacts/stage_outputs/<stage-id>/"
        },
        "runtime_state_is_default_user_surface": {
          "const": false
        },
        "product_views_are_stage_outputs": {
          "const": false
        }
      }
    },
    "runtime_state_boundary": {
      "$ref": "#/$defs/runtime_state_boundary"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "workspace_norm": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "norm_id",
        "default_workspace_precondition",
        "descriptor_delegates",
        "topology_contract",
        "user_inspection"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_agent_workspace_norm_projection"
        },
        "norm_id": {
          "const": "opl.agent_workspace_norm.v1"
        },
        "descriptor_delegates": {
          "$ref": "#/$defs/descriptor_delegates"
        },
        "topology_contract": {
          "$ref": "#/$defs/norm_topology_contract"
        },
        "domain_topology_profile": {
          "$ref": "#/$defs/domain_topology_profile"
        },
        "user_inspection": {
          "$ref": "#/$defs/norm_user_inspection"
        }
      }
    }
  },
  "$defs": {
    "workspace_topology_profile_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "contract_ref",
        "profile_id",
        "workspace_mode",
        "project_collection_path",
        "shared_resource_roots",
        "project_stage_outputs_root"
      ],
      "properties": {
        "profile_id": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "workspace_mode": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "project_collection_path": {
          "type": "string"
        },
        "project_stage_outputs_root": {
          "const": "artifacts/stage_outputs"
        },
        "shared_resource_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "profile_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "profile_contract_ref",
        "profile_fingerprint",
        "applied_at",
        "applied_by",
        "migration_history"
      ],
      "properties": {
        "profile_id": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "profile_version": {
          "const": "workspace-topology-profile.v2"
        },
        "profile_contract_ref": {
          "const": "contracts/opl-framework/foundry-agent-series-contract.json#/workspace_topology_profile"
        },
        "profile_fingerprint": {
          "const": "opl-workspace-topology-profile-v2-projects-stage-outputs"
        },
        "applied_at": {
          "type": "string",
          "minLength": 1
        },
        "applied_by": {
          "enum": [
            "opl_workspace_init",
            "opl_workspace_ensure",
            "opl_workspace_adopt",
            "opl_workspace_upgrade"
          ]
        },
        "migration_history": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "event",
              "profile_version",
              "applied_at",
              "project_roots_moved",
              "note"
            ],
            "properties": {
              "event": {
                "enum": [
                  "initialized",
                  "ensured",
                  "adopted",
                  "upgraded",
                  "project_appended",
                  "project_lifecycle_updated"
                ]
              },
              "profile_version": {
                "const": "workspace-topology-profile.v2"
              },
              "applied_at": {
                "type": "string",
                "minLength": 1
              },
              "project_roots_moved": {
                "const": false
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "topology_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event",
        "at",
        "profile_id",
        "workspace_mode",
        "project_collection_path",
        "project_roots_moved",
        "triggered_by"
      ],
      "properties": {
        "event": {
          "enum": [
            "initialized",
            "ensured",
            "adopted",
            "upgraded",
            "project_appended",
            "project_lifecycle_updated"
          ]
        },
        "at": {
          "type": "string",
          "minLength": 1
        },
        "profile_id": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "workspace_mode": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "project_collection_path": {
          "const": "projects"
        },
        "project_roots_moved": {
          "const": false
        },
        "triggered_by": {
          "enum": [
            "opl_workspace_init",
            "opl_workspace_ensure",
            "opl_workspace_adopt",
            "opl_workspace_upgrade"
          ]
        }
      }
    },
    "canonical_topology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_unit",
        "project_collection_role",
        "project_collection_path",
        "project_unit_kind",
        "stage_artifact_unit",
        "stage_outputs_root",
        "owner_answer_unit"
      ],
      "properties": {
        "workspace_unit": {
          "const": "workspace_group"
        },
        "project_collection_role": {
          "const": "project_units"
        },
        "project_collection_path": {
          "type": "string"
        },
        "project_unit_kind": {
          "type": "string"
        },
        "stage_artifact_unit": {
          "const": "stage_artifact_unit"
        },
        "stage_outputs_root": {
          "const": "artifacts/stage_outputs"
        },
        "owner_answer_unit": {
          "const": "owner_receipt_or_typed_blocker"
        }
      }
    },
    "display_labels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace",
        "project_collection",
        "project_unit",
        "stage_outputs",
        "shared_resources"
      ],
      "properties": {
        "workspace": {
          "type": "string"
        },
        "project_collection": {
          "type": "string"
        },
        "project_unit": {
          "type": "string"
        },
        "stage_outputs": {
          "const": "artifacts/stage_outputs"
        },
        "shared_resources": {
          "const": "shared_resources"
        }
      }
    },
    "descriptor_delegates": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mcp",
        "skill",
        "openai",
        "ai_sdk"
      ],
      "properties": {
        "mcp": {
          "$ref": "#/$defs/descriptor_delegate"
        },
        "skill": {
          "$ref": "#/$defs/descriptor_delegate"
        },
        "openai": {
          "$ref": "#/$defs/descriptor_delegate"
        },
        "ai_sdk": {
          "$ref": "#/$defs/descriptor_delegate"
        }
      }
    },
    "descriptor_delegate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "delegates_to_action_id",
        "descriptor_only",
        "public_runtime"
      ],
      "properties": {
        "delegates_to_action_id": {
          "const": "opl_workspace_ensure"
        },
        "descriptor_only": {
          "const": true
        },
        "public_runtime": {
          "const": false
        }
      }
    },
    "norm_topology_contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "canonical_project_collection_role",
        "canonical_project_unit_semantics",
        "stage_output_root_protocol"
      ],
      "properties": {
        "canonical_project_collection_role": {
          "const": "project_units"
        },
        "canonical_project_unit_semantics": {
          "$ref": "#/$defs/canonical_project_unit_semantics"
        },
        "stage_output_root_protocol": {
          "$ref": "#/$defs/stage_output_root_protocol"
        }
      }
    },
    "canonical_project_unit_semantics": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workspace_unit",
        "project_collection_role",
        "project_unit_kind",
        "stage_artifact_unit",
        "owner_answer_unit"
      ],
      "properties": {
        "workspace_unit": {
          "const": "workspace_group"
        },
        "project_collection_role": {
          "const": "project_units"
        },
        "project_unit_kind": {
          "const": "project_unit"
        },
        "stage_artifact_unit": {
          "const": "stage_artifact_unit"
        },
        "owner_answer_unit": {
          "const": "owner_receipt_or_typed_blocker"
        }
      }
    },
    "stage_output_root_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "stage_folder_unit",
        "stage_outputs_index_file",
        "current_stage_pointer_file",
        "stage_lifecycle_model",
        "required_stage_folder_shape"
      ],
      "properties": {
        "root": {
          "const": "artifacts/stage_outputs"
        },
        "stage_folder_unit": {
          "const": "stage_artifact_unit"
        },
        "stage_outputs_index_file": {
          "const": "stage_outputs_index.json"
        },
        "current_stage_pointer_file": {
          "const": "current_stage.json"
        },
        "stage_lifecycle_model": {
          "type": "array",
          "prefixItems": [
            { "const": "open" },
            { "const": "active" },
            { "const": "completed" },
            { "const": "blocked" },
            { "const": "superseded" },
            { "const": "archived" }
          ],
          "minItems": 6,
          "maxItems": 6
        },
        "required_stage_folder_shape": {
          "type": "array",
          "prefixItems": [
            {
              "const": "inputs"
            },
            {
              "const": "outputs"
            },
            {
              "const": "review"
            },
            {
              "const": "receipts"
            },
            {
              "const": "handoff"
            },
            {
              "const": "stage_manifest.json"
            }
          ],
          "minItems": 6,
          "maxItems": 6
        }
      }
    },
    "domain_topology_profile": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "profile",
        "workspace_mode",
        "project_kind",
        "project_collection_path",
        "canonical_project_collection_role",
        "user_inspection_roots",
        "shared_resource_roots"
      ],
      "properties": {
        "profile": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "workspace_mode": {
          "enum": [
            "one_off",
            "series",
            "portfolio"
          ]
        },
        "project_kind": {
          "type": "string",
          "minLength": 1
        },
        "canonical_project_collection_role": {
          "const": "project_units"
        },
        "user_inspection_roots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "shared_resource_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "project_collection_path": {
          "const": "projects"
        }
      }
    },
    "norm_user_inspection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ordinary_user_default_surface",
        "project_stage_outputs_pattern",
        "canonical_user_inspection_roots",
        "runtime_state_is_default_user_surface",
        "product_views_are_stage_outputs"
      ],
      "properties": {
        "ordinary_user_default_surface": {
          "const": "workspace_local_project_stage_outputs"
        },
        "project_stage_outputs_pattern": {
          "const": "<project-root>/artifacts/stage_outputs/<stage-id>/"
        },
        "canonical_user_inspection_roots": {
          "type": "array",
          "prefixItems": [
            {
              "const": "<project-root>/artifacts/stage_outputs"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/inputs"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/outputs"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/review"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/receipts"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/handoff"
            },
            {
              "const": "<project-root>/artifacts/stage_outputs/<stage-id>/stage_manifest.json"
            }
          ],
          "minItems": 7,
          "maxItems": 7
        },
        "runtime_state_is_default_user_surface": {
          "const": false
        },
        "product_views_are_stage_outputs": {
          "const": false
        }
      }
    },
    "shared_resource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "manifest_ref",
        "owner",
        "user_visible",
        "domain_truth_owner"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "manifest_ref": {
          "type": "string"
        },
        "owner": {
          "enum": [
            "workspace_group",
            "opl_framework_projection"
          ]
        },
        "user_visible": {
          "type": "boolean"
        },
        "domain_truth_owner": {
          "const": "domain_agent"
        }
      }
    },
    "shared_resource_record": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "resource_id",
        "body_ref"
      ],
      "properties": {
        "resource_id": {
          "type": "string",
          "minLength": 1
        },
        "source_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "material_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "checksum": {
          "type": [
            "string",
            "null"
          ]
        },
        "provenance_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reuse_scope": {
          "type": [
            "string",
            "null"
          ]
        },
        "staleness": {
          "type": [
            "string",
            "null"
          ]
        },
        "recorded_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "body_ref": {
          "const": null
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "project_id",
        "project_root",
        "project_config_ref",
        "project_index_ref",
        "stage_outputs_root",
        "stage_outputs_manifest_ref",
        "stage_outputs_index_ref",
        "current_stage_pointer_ref",
        "control_root",
        "inputs_root",
        "exports_root",
        "packages_root",
        "review_root",
        "handoff_root",
        "archive_root",
        "canonical_semantics",
        "lifecycle"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "project_root": {
          "type": "string"
        },
        "project_config_ref": {
          "type": "string"
        },
        "project_index_ref": {
          "type": "string"
        },
        "stage_outputs_root": {
          "type": "string"
        },
        "stage_outputs_manifest_ref": {
          "type": "string"
        },
        "stage_outputs_index_ref": {
          "type": "string"
        },
        "current_stage_pointer_ref": {
          "type": "string"
        },
        "control_root": {
          "type": "string"
        },
        "inputs_root": {
          "type": "string"
        },
        "exports_root": {
          "type": "string"
        },
        "packages_root": {
          "type": "string"
        },
        "review_root": {
          "type": "string"
        },
        "handoff_root": {
          "type": "string"
        },
        "archive_root": {
          "type": "string"
        },
        "canonical_semantics": {
          "$ref": "#/$defs/project_canonical_semantics"
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "archived_at",
            "archive_reason",
            "paused_at",
            "pause_reason",
            "superseded_at",
            "superseded_by_project_id",
            "locked_at",
            "lock_reason",
            "retention_policy",
            "safe_delete_gate"
          ],
          "properties": {
            "status": {
              "enum": [
                "active",
                "paused",
                "archived",
                "superseded",
                "locked"
              ]
            },
            "archived_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "archive_reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "paused_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "pause_reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "superseded_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "superseded_by_project_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "locked_at": {
              "type": [
                "string",
                "null"
              ]
            },
            "lock_reason": {
              "type": [
                "string",
                "null"
              ]
            },
            "retention_policy": {
              "enum": [
                "keep_until_explicit_archive",
                "keep_until_explicit_delete_receipt"
              ]
            },
            "safe_delete_gate": {
              "const": "domain_owner_receipt_required"
            }
          }
        }
      }
    },
    "project_canonical_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unit",
        "collection_role",
        "domain_alias_is_canonical"
      ],
      "properties": {
        "unit": {
          "const": "project_unit"
        },
        "collection_role": {
          "const": "project_units"
        },
        "domain_alias_is_canonical": {
          "const": false
        }
      }
    },
    "generated_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workspace_config_ref",
        "workspace_index_ref",
        "workspace_map_ref",
        "workspace_health_ref",
        "workspace_inspection_ref",
        "workspace_resource_inventory_ref",
        "workspace_report_ref",
