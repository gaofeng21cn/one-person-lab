{
  "contract_kind": "opl_agent_lab_contract.v1",
  "surface_kind": "opl_agent_lab_contract",
  "owner": "one-person-lab",
  "scope": "framework-level agent evaluation, recovery, quality-ref projection, and improvement control plane",
  "contract_version": "opl-agent-lab.v1",
  "input_surfaces": [
    "agent_lab_task_manifest",
    "agent_trajectory_refs",
    "domain_quality_scorecard_refs",
    "recovery_probe_refs",
    "failure_taxonomy_refs",
    "improvement_candidate_refs",
    "promotion_gate_refs"
  ],
  "required_observations": [
    "task_manifests_observed",
    "agent_trajectories_observed",
    "recovery_probes_observed",
    "domain_quality_scorecard_refs_observed",
    "failure_taxonomy_observed",
    "improvement_candidates_observed",
    "promotion_gates_observed",
    "no_memory_body_observed",
    "forbidden_authority_flags_all_false"
  ],
  "result_surface": {
    "surface_kind": "opl_agent_lab_suite_result",
    "suite_kinds": [
      "agent_lab_sample_suite",
      "agent_lab_longline_suite"
    ],
    "statuses": [
      "passed",
      "blocked"
    ],
    "summary_fields": [
      "task_count",
      "run_count",
      "passed_run_count",
      "blocked_run_count",
      "recovery_probe_count",
      "recovery_passed_count",
      "scorecard_passed_count",
      "improvement_candidate_count",
      "promotable_candidate_count",
      "memory_body_observed",
      "forbidden_authority_flag_count"
    ],
    "ref_fields": [
      "task_refs",
      "trajectory_refs",
      "recovery_probe_refs",
      "domain_quality_scorecard_refs",
      "scorer_refs",
      "oracle_refs",
      "improvement_candidate_refs",
      "promotion_gate_refs",
      "artifact_refs",
      "receipt_refs"
    ]
  },
  "longline_surface": {
    "surface_kind": "opl_agent_lab_longline_summary",
    "suite_kind": "agent_lab_longline_suite",
    "summary_fields": [
      "longline_task_count",
      "domain_ids",
      "repo_test_replacement_candidate_count",
      "ready_to_reduce_domain_longline_tests",
      "recommended_repo_test_disposition"
    ],
    "domain_repo_tests_to_keep": [
      "domain-owned quality scorer",
      "domain owner receipt fixture",
      "domain artifact authority checks"
    ],
    "repo_test_candidates_to_move_to_opl": [
      "provider-hosted soak orchestration",
      "resume/retry/dead-letter recovery probe",
      "receipt or hosted-attempt reconciliation projection",
      "no-forbidden-write cross-domain regression"
    ],
    "authority_boundary": "refs-only projection; OPL cannot authorize domain truth, quality verdicts, artifact mutation, memory body writes, or owner receipts"
  },
  "complete_control_plane_surface": {
    "surface_kind": "opl_agent_lab_complete_control_plane",
    "status": "ready_for_opl_native_use",
    "eval_adapters": [
      "opl-native-agent-lab",
      "inspect-ai",
      "metr-task-standard"
    ],
    "observability_exports": [
      "opl-runtime-observability-export",
      "openinference-opentelemetry",
      "langfuse",
      "phoenix"
    ],
    "optimizer_loop_fields": [
      "candidate_kinds",
      "loop_steps",
      "pattern_refs",
      "rl_boundary"
    ],
    "readiness_fields": [
      "complete_control_plane_ready",
      "ready_to_connect_inspect_ai_adapter",
      "ready_to_export_observability_refs",
      "ready_to_emit_optimizer_candidate_refs",
      "ready_to_emit_rl_transition_refs",
      "automatic_model_training_ready",
      "automatic_default_agent_promotion_ready",
      "app_workbench_consumption_ready"
    ]
  },
  "meta_agent_builder_surface": {
    "surface_kind": "opl_meta_agent_builder_plan",
    "agent_id": "opl-foundry-agent-builder",
    "stage_ids": [
      "intent-intake",
      "web-experience-research",
      "stage-decomposition",
      "agent-skeleton-build",
      "eval-suite-build",
      "baseline-run",
      "optimizer-iteration",
      "baseline-delivery",
      "online-learning"
    ],
    "authority_boundary": "build and optimize OPL-compatible agent packages through explicit gates; cannot write domain truth or promote default agents without gate"
  },
  "agent_lab_proves": [
    "OPL can normalize domain-declared evaluation task manifests",
    "OPL can carry agent trajectory refs without reading private domain truth bodies",
    "OPL can project recovery probes for resume, retry, dead-letter repair, human gate resume, and artifact restore",
    "OPL can aggregate domain-owned quality scorecard refs without authorizing quality verdicts",
    "OPL can turn run evidence into improvement candidates and promotion gates",
    "OPL can centralize cross-domain longline soak orchestration and recovery projections while leaving domain scorer and owner authority in domain repos",
    "OPL can expose a complete eval adapter, observability export, and optimizer-loop control plane without requiring external services in core",
    "OPL can describe a meta-agent builder plan that creates and optimizes OPL-compatible agents through explicit gates",
    "OPL can fail closed on memory body payloads and forbidden authority claims"
  ],
  "agent_lab_does_not_prove": [
    "live soak completion",
    "domain ready verdict",
    "publication verdict",
    "fundability verdict",
    "visual quality verdict",
    "artifact mutation success",
    "memory body application",
    "writeback accept or reject decision",
    "default agent configuration promotion without explicit gate",
    "automatic model training or weight deployment"
  ],
  "domain_retained_authority": [
    "domain truth",
    "domain quality verdict",
    "domain artifact authority",
    "domain memory body",
    "writeback accept/reject decision",
    "owner receipt",
    "typed blocker",
    "publication/fundability/visual judgment"
  ],
  "forbidden_authority": [
    "domain truth write",
    "memory body write",
    "memory writeback accept/reject verdict",
    "domain ready verdict",
    "quality/export verdict",
    "domain artifact mutation",
    "default agent promotion without gate"
  ],
  "external_framework_policy": {
    "primary_eval_runner": "Inspect AI adapter optional",
    "task_standard_reference": "METR task standard pattern only",
    "observability_exports": [
      "OpenTelemetry/OpenInference-compatible trace refs",
      "Inspect log refs",
      "Phoenix/Langfuse-compatible dataset and run refs"
    ],
    "rl_training_boundary": "downstream consumer only after stable trajectory and reward surfaces"
  },
  "authority_boundary": {
    "opl": "agent_lab_eval_improvement_control_plane_refs_only",
    "domain": "truth_quality_artifact_memory_body_and_owner_receipt_authority",
    "can_write_domain_truth": false,
    "can_write_memory_body": false,
    "can_accept_or_reject_memory_writeback": false,
    "can_authorize_domain_ready": false,
    "can_authorize_quality_verdict": false,
    "can_authorize_export_verdict": false,
    "can_mutate_domain_artifact": false,
    "can_promote_default_agent_without_gate": false
  }
}
