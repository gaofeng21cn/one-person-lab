{
  "contract_kind": "opl_state_index_kernel_contract.v1",
  "surface_kind": "opl_state_index_kernel_contract",
  "owner": "one-person-lab",
  "purpose": "Freeze OPL-owned SQLite boundaries for the durable pre-start StageRun transport registry plus rebuildable stage-attempt projection, lifecycle refs, artifact locators, lineage, outbox, retention, restore, and operator read-model projections.",
  "state": "active_contract",
  "truth_split": {
    "file_truth": {
      "role": "portable_truth",
      "surfaces": [
        "Stage Folder",
        "manifest.json",
        "receipt body",
        "typed blocker body",
        "artifact body",
        "human-readable evidence",
        "canonical/export bundle body"
      ],
      "source_of_truth": true
    },
    "sqlite_sidecar_index": {
      "role": "rebuildable_operational_index",
      "source_of_truth": false,
      "rebuild_from": [
        "physical Stage Folder",
        "manifest refs",
        "receipt refs",
        "content hashes",
        "domain-owned projection refs",
        "provider receipts",
        "Temporal/provider visibility refs"
      ]
    },
    "durable_runtime_transport_registry": {
      "role": "pre_start_write_ahead_stage_run_identity_and_transport_recovery",
      "source_of_domain_truth": false,
      "durability_required": true,
      "rebuildable_before_temporal_start": false,
      "reconcile_after_temporal_start_from": [
        "registered_exact_stage_run_input",
        "Temporal_workflow_identity_and_status",
        "provider_start_receipt"
      ],
      "must_not_store": [
        "domain_truth_body",
        "artifact_body",
        "memory_body",
        "quality_or_export_verdict_authority"
      ]
    },
    "temporal_provider": {
      "role": "production_durable_execution",
      "production_required": true,
      "sqlite_sidecar_role": "projection_and_readback_index_only"
    }
  },
  "sqlite_database_layout": {
    "state_root": "${OPL_STATE_DIR}/family-runtime",
    "databases": [
      {
        "database_id": "stage_attempt_index",
        "path": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
        "path_status": "legacy_filename_retained_for_migration_compat",
        "owned_tables": [
          "tasks",
          "events",
          "notifications",
          "queue_holds",
          "stage_attempts",
          "stage_quality_cycles",
          "stage_run_launches"
        ],
        "storage_role": "runtime_transport_registry_and_sqlite_sidecar_index"
      },
      {
        "database_id": "lifecycle_index",
        "path": "${OPL_STATE_DIR}/family-runtime/lifecycle-index.sqlite",
        "owned_tables": [
          "lifecycle_refs",
          "lifecycle_apply_receipts"
        ],
        "storage_role": "sqlite_sidecar_index"
      },
      {
        "database_id": "artifact_index",
        "path": "${OPL_STATE_DIR}/family-runtime/artifact-index.sqlite",
        "owned_tables": [
          "stage_current_pointers",
          "manifest_index",
          "artifact_refs",
          "receipt_refs",
          "blocker_refs",
          "lineage_events",
          "lineage_edges",
          "retention_ledger",
          "restore_proofs"
        ],
        "storage_role": "sqlite_sidecar_index",
        "implementation_status": "landed_rebuildable_stage_folder_projection"
      },
      {
        "database_id": "operator_read_model",
        "path": "${OPL_STATE_DIR}/family-runtime/read-model.sqlite",
        "owned_tables": [
          "operator_tasks",
          "artifact_drilldown",
          "owner_route_index",
          "source_fingerprints",
          "work_unit_outbox",
          "maintenance_runs"
        ],
        "storage_role": "projection_cache",
        "implementation_status": "landed_rebuildable_stage_folder_read_model"
      }
    ]
  },
  "stage_run_launch_registry": {
    "database_id": "stage_attempt_index",
    "table": "stage_run_launches",
    "required_fields": [
      "stage_run_id",
      "stage_run_invocation_id",
      "stage_run_spec_sha256",
      "domain_id",
      "stage_id",
      "workflow_id",
      "parent_route_decision_ref",
      "stage_run_input_json",
      "launch_status",
      "temporal_start_receipt_json",
      "terminal_status",
      "last_start_error",
      "created_at",
      "updated_at"
    ],
    "allowed_payload": "bounded_exact_stage_run_launch_envelope_refs_hashes_policies_and_transport_receipts_only",
    "validate_identity_and_spec_before_write": true,
    "register_before_provider_start": true,
    "invocation_spec_conflict_effect": "typed_fail_closed",
    "closed_replay_returns_existing_stage_run": true,
    "late_provider_start_receipt_cannot_reopen_closed_stage_run": true,
    "registry_is_stage_current_pointer": false,
    "registry_is_domain_truth": false
  },
  "paper_autonomy_supervisor_index_policy": {
    "surface_kind": "opl_paper_autonomy_supervisor_index_policy",
    "schema_version": 1,
    "role": "refs_only_obligation_and_decision_projection",
    "may_index": [
      "obligation_id",
      "decision_id",
      "stage_run_id",
      "route_identity_key",
      "attempt_idempotency_key",
      "source_fingerprint",
      "work_unit_fingerprint",
      "cursor",
      "checksum",
      "bounded_preview_hash",
      "evidence_ref",
      "human_gate_ref",
      "owner_answer_ref",
      "terminal_closeout_ref",
      "recovery_receipt_ref"
    ],
    "must_not_store": [
      "study_truth_body",
      "publication_verdict_body",
      "artifact_body",
      "memory_body",
      "paper_body",
      "domain_owner_receipt_body",
      "typed_blocker_body"
    ],
    "query_update_boundary": {
      "query_reads_projection_only": true,
      "update_must_be_identity_bound": true,
      "read_model_can_execute_recovery_action": false,
      "read_model_can_consume_closeout": false,
      "read_model_can_sign_owner_answer": false
    }
  },
  "stage_folder_rebuild_projection": {
    "command": "opl index rebuild --domain <domain> --json",
    "source_root": "${OPL_STATE_DIR}/runtime-state/domains",
    "projects_to": [
      "artifact-index.sqlite/stage_current_pointers",
      "artifact-index.sqlite/manifest_index",
      "artifact-index.sqlite/artifact_refs",
      "artifact-index.sqlite/receipt_refs",
      "artifact-index.sqlite/blocker_refs",
      "artifact-index.sqlite/lineage_events",
      "artifact-index.sqlite/lineage_edges",
      "artifact-index.sqlite/retention_ledger",
      "artifact-index.sqlite/restore_proofs",
      "read-model.sqlite/artifact_drilldown",
      "read-model.sqlite/owner_route_index",
      "read-model.sqlite/source_fingerprints",
      "read-model.sqlite/operator_tasks"
    ],
    "payload_policy": "refs_hashes_and_bounded_locator_json_only",
    "stage_current_pointers_role": "artifact_attempt_pointer_cache_not_stage_run_current_pointer",
    "stage_current_pointers_can_write_stage_run_current_pointer": false,
    "stage_current_pointers_can_write_stage_run_terminal_state": false,
    "stage_current_pointers_can_publish_current_owner_delta": false,
    "body_access": false,
    "domain_authority_created": false
  },
  "required_index_fields": [
    "domain_id",
    "program_id",
    "stage_id",
    "attempt_id",
    "surface_id",
    "source_ref",
    "receipt_ref",
    "content_hash",
    "observed_at",
    "indexed_at",
    "index_version",
    "rebuild_epoch"
  ],
  "write_order": [
    "materialize_physical_stage_folder",
    "write_manifest_receipt_or_typed_blocker_body",
    "compute_content_hashes",
    "atomically_update_current_or_latest_pointer",
    "rebuild_or_refresh_sqlite_sidecar_projection"
  ],
  "status_rule": "Stage progress = physical outputs + manifest validity + receipt authority + current pointer; SQLite can accelerate discovery but cannot promote stale or missing file truth into progress.",
  "maintenance_policy": {
    "journal_mode": "WAL",
    "busy_timeout_ms": 5000,
    "single_writer_assumption": true,
    "network_filesystem_multi_writer_supported": false,
    "checkpoint_required": true,
    "backup_required": true,
    "integrity_check_required": true,
    "optimize_required": true,
    "vacuum_after_large_delete_only": true,
    "bounded_payload_envelope_required": true,
    "large_payload_strategy": "store preview length hash and refs, never body"
  },
  "forbidden_payloads": [
    "domain truth body",
    "memory body",
    "artifact body",
    "PNG/PPTX/PDF/blob body",
    "manuscript body",
    "grant package body",
    "quality verdict body",
    "review/export verdict authority",
    "owner receipt authority",
    "production readiness authority"
  ],
  "cli_surfaces": {
    "doctor": "opl index doctor --json",
    "rebuild": "opl index rebuild --domain <domain> --json materializes schemas and projects Stage Folder refs into artifact/read-model sidecars",
    "backup": "opl index backup --json",
    "checkpoint": "opl index checkpoint --json",
    "integrity": "opl index integrity-check --json",
    "explain": "opl stage explain --json reads Stage Folder truth and sidecar index freshness"
  },
  "authority_boundary": {
    "opl_can_index_refs": true,
    "opl_can_cache_projection": true,
    "opl_can_rebuild_from_file_truth": true,
    "opl_can_compact_observability_payloads": true,
    "opl_can_persist_pre_start_stage_run_transport_identity": true,
    "opl_can_write_domain_truth": false,
    "opl_can_write_memory_body": false,
    "opl_can_write_artifact_body": false,
    "opl_can_store_large_artifact_blob_in_sqlite": false,
    "opl_can_create_domain_owner_receipt": false,
    "opl_can_authorize_quality_or_export": false,
    "sqlite_record_counts_as_stage_complete": false,
    "provider_completion_counts_as_domain_ready": false
  },
  "domain_adoption_policy": {
    "med-autoscience": "primary small-file compaction candidate; MAS keeps study truth publication quality artifact/package authority owner receipts and typed blockers",
    "med-autogrant": "consume OPL sidecar indexes as opaque refs; no private generic SQLite migration required",
    "redcube-ai": "deferred or trigger-based SQLite locator index only; no PNG/PPTX/PDF blob or visual verdict storage",
    "opl-meta-agent": "refs-only Agent Lab/work-order/proposal indexes; no target truth runtime worktree lifecycle or promotion verdict ownership"
  }
}
