{
  "contract_kind": "opl_app_runtime_fast_work_item_projection_producer.v1",
  "owner": "one-person-lab",
  "producer_surface": "opl app state --profile fast --json#app_state.operator.workbench.work_item_projection_v2",
  "projection_schema_ref": "contracts/opl-framework/work-item-projection-v2.schema.json",
  "consumer_role": "default_runtime_page_state",
  "runtime_capability_bridge": {
    "capability_id": "opl_app.runtime_state_profile.v1",
    "discovery_field": "app_state.meta.capabilities[]",
    "runtime_state_surface": "opl app state --profile runtime --json",
    "runtime_projection_surface": "opl app state --profile runtime --json#app_state.operator.workbench.work_item_projection_v2",
    "projection_detail_profile": "fast",
    "default_state_profile": "fast",
    "runtime_profile_is_default": false,
    "fast_compatibility_required": true,
    "legacy_consumer_policy": {
      "capability_absent_requires_fast_fallback": true,
      "runtime_command_probe_before_capability_discovery": false
    }
  },
  "compatibility_capabilities": {
    "ids": [
      "opl_app.domain_detail_views.v2"
    ],
    "definitions": [
      {
        "capability_id": "opl_app.domain_detail_views.v2",
        "producer_owner": "one-person-lab",
        "state_surface": "opl app state --profile fast --json#app_state.operator.workbench.work_item_projection_v2",
        "state_field": "items[].domain_detail_views",
        "descriptor_contract_ref": "contracts/opl-framework/standard-agent-interface.schema.json#/properties/domain_detail_views",
        "projection_contract_ref": "contracts/opl-framework/work-item-projection-v2.schema.json#/$defs/domainDetailView",
        "accepted_descriptor_schema_versions": [
          "scientific-reasoning-map.v1",
          "scientific-reasoning-map.v2"
        ],
        "missing_descriptor_projection": [],
        "lazy_read_command": "opl app view read --item-id <canonical-item-id> --view-id <view-id> [--if-revision <n>] --json",
        "lazy_read_surface_kind": "opl_domain_detail_view",
        "lazy_read_schema_version": "opl_domain_detail_view.v1",
        "legacy_consumer_policy": {
          "capability_discovery_additive": true,
          "domain_detail_views_optional_in_agent_descriptor": true,
          "missing_domain_detail_views_projects_empty_array": true,
          "consumer_may_ignore_capability": true
        }
      }
    ]
  },
  "cognitive_model": [
    "Agent",
    "Project",
    "Work Item",
    "Stage",
    "Attempt",
    "Action"
  ],
  "inventory_policy": {
    "source": "registered_workspace_binding_plus_agent_declared_inventory",
    "all_registered_work_item_summaries_included": true,
    "archived_work_items_included": true,
    "runtime_history_may_create_work_items": false,
    "legacy_runtime_views_repopulated_from_work_items": false,
    "workspace_binding_deduplication_required": true,
    "project_identity_source": "workspace_binding.project_scope_id",
    "workspace_path_is_project_identity": false
  },
  "execution_identity_policy": {
    "authoritative_scope_source": "attempt.execution_scope",
    "join_key": "execution_scope.work_item_scope_id",
    "cross_checks": [
      "execution_scope.project_scope_id",
      "execution_scope.domain_id",
      "execution_scope.domain_work_item_id",
      "execution_scope.scope_digest",
      "identity_state"
    ],
    "workspace_locator_aliases_may_assign_work_item": false,
    "legacy_locator_execution_scope_policy": "diagnostic_only_identity_unresolved",
    "unresolved_or_conflicting_execution_is_quarantined": true,
    "stage_run_without_attempt_policy": {
      "record_kind": "stage_run_without_stage_attempt",
      "scope_source": "stage_run.execution_scope",
      "projection_effect": "diagnostic_only",
      "resolved_scope_may_mark_matching_work_item_execution_unknown": true,
      "may_create_attempt_workflow_wake_running_proof_or_usage": false,
      "untrusted_claimed_scope_is_detail_only": true,
      "unresolved_quarantined_or_conflicting_scope_may_assign_work_item": false,
      "diagnostic_details_are_bounded": true
    },
    "non_work_item_scope_kinds": [
      "domain",
      "system"
    ]
  },
  "session_activity_policy": {
    "projection_field": "items[].session_activity",
    "summary_field": "summary.active_session_count",
    "coordination_source": "opl_work_item_execution_session_binding_ledger",
    "controlled_execution_source": "opl_stage_attempt_execution_session_binding",
    "coordination_can_affect_execution": false,
    "controlled_execution_requires_resolved_execution_scope": true,
    "runtime_history_may_create_work_items": false,
    "human_gate_precedence": true,
    "fast_reader_scope": "registered_inventory_exact_resolved_work_item_scope_only",
    "full_profile_retains_identity_diagnostics": true
  },
  "default_summary_axes": [
    "identity.agent_id",
    "identity.project_id",
    "identity.work_item_id",
    "identity.work_item_scope_id",
    "identity_health",
    "lifecycle.primary_state",
    "visibility.state",
    "execution.state",
    "execution.current_stage_id",
    "execution.current_stage_display_name",
    "execution.next_stage_id",
    "execution.next_stage_display_name",
    "execution.attempt_id",
    "session_activity.state",
    "session_activity.active_session_count",
    "telemetry.current_stage",
    "telemetry.cumulative",
    "action"
  ],
  "stage_popover_axes": [
    "stage_map[].stage_id",
    "stage_map[].display_name",
    "stage_map[].display_names",
    "stage_map[].state",
    "stage_map[].elapsed_seconds",
    "stage_map[].usage",
    "stage_map[].next_action",
    "execution.attempt_id"
  ],
  "bounded_fast_policy": {
    "max_serialized_work_item_summary_bytes_per_item": 16384,
    "current_projection_acceptance_budget_bytes": 131072,
    "attempt_ref_limit_per_item": 1,
    "diagnostic_details": "lazy",
    "diagnostic_items_embedded": false,
    "identity_health_summary_embedded": true,
    "identity_health_sample_attempt_ref_limit": 1,
    "stage_attempt_read_scope": "registered_inventory_exact_resolved_work_item_scope_only",
    "irrelevant_runtime_history_parsed": false,
    "unresolved_execution_details_embedded": false,
    "condition_details_embedded": false,
    "source_ref_details_embedded": false,
    "token_source_ref_details_embedded": false,
    "inventory_detail": "included",
    "full_detail_surface": "opl app state --profile full --json",
    "forbidden_embedded_detail": [
      "raw_evidence_envelope",
      "raw_ledger_browser",
      "provider_internal_trace",
      "runtime_tray_snapshot",
      "stage_attempt_history_body"
    ]
  },
  "authority_boundary": {
    "projection_only": true,
    "can_write_domain_truth": false,
    "can_create_owner_receipt": false,
    "can_create_typed_blocker": false,
    "can_authorize_quality_verdict": false,
    "can_authorize_publication_or_submission": false
  }
}
