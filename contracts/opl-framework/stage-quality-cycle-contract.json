{
  "contract_kind": "opl_stage_quality_cycle_contract.v1",
  "surface_kind": "opl_stage_quality_cycle_contract",
  "owner": "one-person-lab",
  "state": "active_contract",
  "purpose": "Define context-isolated Stage Review as independent StageAttempts under one StageRun, without turning attempts into top-level stages or moving domain quality authority into OPL.",
  "framework_contract_ref": "contracts/opl-framework/stage-quality-cycle-contract.json",
  "pack_bound_creation": {
    "canonical_request_surface": "opl family-runtime attempt create",
    "runtime_binding_surface_kind": "opl_pack_bound_stage_quality_runtime_binding",
    "runtime_binding_source": "compiled_standard_agent_stage_manifest_plus_stage_quality_cycle_policy",
    "stage_run_input_builder": "buildPackBoundTemporalStageRunInput",
    "required_binding_fields": [
      "stage_id",
      "declared_stage_ids",
      "policy_ref",
      "stage_prompt_ref",
      "quality_policy",
      "handoff_review_boundary",
      "role_prompt_refs",
      "quality_rubric_refs",
      "stage_goal_refs",
      "source_refs",
      "lineage_refs",
      "manifest_ref",
      "manifest_sha256"
    ],
    "stage_run_id_binds_manifest_sha256": false,
    "stage_run_spec_sha256_binds_manifest_sha256": true,
    "raw_stage_run_start_cli_retired": true,
    "stage_run_cli_allowed_actions": [
      "query"
    ],
    "direct_unbound_stage_run_creation_forbidden": true
  },
  "stage_attempt_roles": [
    "producer",
    "reviewer",
    "repairer",
    "re_reviewer"
  ],
  "terminology": {
    "in_thread_refinement": "Non-authoritative self-check and revision inside one provider thread. It is not Stage Review and cannot create a review receipt.",
    "stage_review": "A new reviewer StageAttempt and provider thread under the same StageRun, consuming only declared refs and hashes.",
    "meta_review": "An independent top-level StageRun whose producer-role Attempt performs the cross-stage Meta Review from declared refs without inheriting upstream conversations.",
    "protocol_closeout_resume": "Same-thread Codex resume used only to materialize a missing typed closeout. It is not review and consumes no quality budget."
  },
  "policy": {
    "surface_kind": "opl_stage_quality_cycle_policy",
    "version": "stage-quality-cycle-policy.v1",
    "default_max_repair_rounds": 3,
    "initial_producer_attempt_counts_as_repair": false,
    "repair_round_unit": "one_repairer_attempt_followed_by_one_fresh_re_reviewer_attempt",
    "provider_retry_consumes_quality_budget": false,
    "domain_helper_retry_consumes_quality_budget": false,
    "protocol_closeout_resume_consumes_quality_budget": false,
    "budget_exhaustion_with_consumable_artifact": "completed_with_quality_debt",
    "budget_exhaustion_without_consumable_artifact": "hard_stop",
    "same_thread_refinement_can_close_review": false
  },
  "stage_run_controller": {
    "workflow_name": "StageRunWorkflow",
    "controller_kind": "non_model_durable_temporal_state_machine",
    "child_workflow_name": "StageAttemptWorkflow",
    "only_controller_can_create_next_authoritative_attempt": true,
    "codex_attempt_cannot_expand_quality_loop": true,
    "attempt_instances_declared_in_manifest": false,
    "attempt_instances_materialized_dynamically_from_policy": true,
    "maximum_attempt_instances": 8,
    "maximum_shape": "one_producer_plus_one_initial_reviewer_plus_three_repairer_re_reviewer_pairs",
    "provider_retry_budget_is_separate": true,
    "temporal_activity_retry_budget_is_separate": true,
    "structured_output_retry_budget_is_separate": true,
    "stage_run_runtime_retry_budget_is_separate": true
  },
  "cross_stage_route_selection": {
    "stage_run_controller_owns_child_attempt_topology_only": true,
    "opl_transition_approval_or_rejection_authority": false,
    "opl_domain_semantic_route_judgment_authority": false,
    "opl_route_output_abi_validation_required": true,
    "primary_only_decisive_attempt_role": "producer",
    "formal_review_decisive_attempt_roles": [
      "reviewer",
      "re_reviewer"
    ],
    "repairer_can_make_terminal_route_selection": false,
    "non_decisive_attempt_output": "route_impact.stage_route_recommendation",
    "terminal_attempt_output": "route_impact.stage_route_decision",
    "route_output_contract": {
      "decision_kind_values": [
        "advance",
        "skip",
        "repeat",
        "reverse",
        "route_back",
        "complete"
      ],
      "non_complete_decision_requires_declared_target_stage_id": true,
      "complete_forbids_target_stage_id": true,
      "recommendation_reason_required": true,
      "non_empty_evidence_refs_required": true,
      "decision_and_recommendation_are_mutually_exclusive": true
    },
    "passive_transport_materializes_codex_selected_declared_stage": true,
    "attempt_route_output_is_closeout_judgment_not_stage_topology_or_transition_authority": true,
    "attempt_context_surface_kind": "opl_stage_run_route_selection_context",
    "legacy_terminal_route_fields_forbidden": [
      "route_back_stage_ref",
      "selected_next_stage_ref",
      "next_stage_ref",
      "workflow_complete"
    ],
    "runtime_closeout_guard_required": true,
    "route_abi_rejection_conditions": [
      "non_decisive_attempt_writes_terminal_decision",
      "decision_and_recommendation_both_present",
      "route_output_shape_invalid",
      "legacy_terminal_route_field_present",
      "target_stage_not_declared",
      "hard_stop_attempt_writes_terminal_decision",
      "review_or_re_review_not_terminal"
    ],
    "invalid_route_output_is_rejected_without_discarding_consumable_progress": true,
    "repair_required_review_may_select_terminal_route": false,
    "hard_stop_attempt_may_select_terminal_route": false,
    "declared_default_progression_resolution": [
      "action_stage_route.required_stage_refs_order",
      "unique_current_stage.next_stage_refs"
    ],
    "manifest_file_order_must_not_select_successor": true,
    "ambiguous_declared_successors_require_decisive_codex_route": true
  },
  "multi_attempt_stage_boundary": {
    "decision_rule": "Repeated generation, review, and repair toward the same goal are Attempts; a changed goal, owner, quality gate, or delivery relationship requires a new Stage.",
    "shared_stage_fields": [
      "stage_id",
      "stage_run_id",
      "goal",
      "canonical_artifact_family",
      "owner",
      "requires",
      "ensures",
      "next_stage_boundary",
      "authority_boundary"
    ],
    "attempt_variant_fields": [
      "stage_attempt_id",
      "attempt_role",
      "quality_round_index",
      "execution_session_ref",
      "artifact_revision"
    ],
    "role_round_contract": {
      "producer": [0],
      "reviewer": [0],
      "repairer": [1, 2, 3],
      "re_reviewer": [1, 2, 3]
    },
    "non_producer_parent_attempt_ref_required": true,
    "non_producer_parent_lineage_fields": [
      "parent_attempt_lineage.stage_run_id",
      "parent_attempt_lineage.quality_cycle_id"
    ],
    "parent_lineage_must_match_current_stage_run_and_quality_cycle": true,
    "forbidden_attempt_fields_rejected_recursively": true,
    "forbidden_attempt_fields": [
      "next_stage_refs",
      "requires",
      "ensures",
      "stage_route",
      "sub_stage_graph",
      "independent_owner",
      "stage_current_pointer",
      "stage_transition_authority"
    ],
    "stage_split_or_route_back_when": [
      "different_primary_open_judgment",
      "different_owner",
      "different_source_or_knowledge_authority",
      "independent_quality_gate",
      "formal_handoff_artifact",
      "different_downstream_route",
      "new_irreversible_permission",
      "human_decision"
    ],
    "codex_subagent_role": "attempt_internal_optional_helper_not_opl_stage_or_attempt"
  },
  "context_isolation": {
    "fresh_session_required_for_roles": [
      "producer",
      "reviewer",
      "repairer",
      "re_reviewer"
    ],
    "required_for_roles": [
      "reviewer",
      "re_reviewer"
    ],
    "required_fields": [
      "producer_attempt_ref",
      "reviewer_attempt_ref",
      "producer_session_ref",
      "reviewer_session_ref",
      "no_context_inheritance",
      "reviewed_artifact_refs",
      "reviewed_artifact_hashes",
      "rubric_refs"
    ],
    "session_identity_rule": "reviewer_session_ref_must_differ_from_producer_or_repairer_session_ref",
    "review_context_allowlist": [
      "stage_goal_refs",
      "exact_artifact_refs_and_hashes",
      "domain_owned_artifact_identity_receipt_refs",
      "source_refs_and_fingerprint",
      "quality_rubric_refs",
      "necessary_artifact_lineage_refs",
      "prior_finding_refs_and_acceptance_criteria_for_re_review"
    ],
    "forbidden_context": [
      "producer_conversation_history",
      "producer_or_reviewer_thread_resume",
      "chain_of_thought",
      "undeclared_ephemeral_context"
    ]
  },
  "review_receipt": {
    "surface_kind": "opl_stage_review_receipt",
    "version": "stage-review-receipt.v1",
    "verdicts": [
      "pass",
      "repair_required",
      "quality_debt",
      "hard_stop"
    ],
    "required_fields": [
      "stage_run_id",
      "quality_cycle_id",
      "producer_attempt_ref",
      "reviewer_attempt_ref",
      "producer_session_ref",
      "reviewer_session_ref",
      "no_context_inheritance",
      "reviewed_artifact_refs",
      "reviewed_artifact_hashes",
      "rubric_refs",
      "verdict"
    ],
    "reviewed_hash_must_match_current_artifact": true,
    "producer_and_repairer_identity_source": "typed_closeout_ref_metadata_sha256_owned_by_domain",
    "producer_and_repairer_artifact_identity_receipt_refs_required_before_formal_review": true,
    "reviewed_artifact_ref_hash_cardinality_must_match": true,
    "no_context_inheritance_required": true,
    "same_model_different_session_allowed": true
  },
  "finding_closure_contract": {
    "initial_finding_required_fields": [
      "finding_id",
      "severity",
      "required",
      "evidence_refs",
      "repair_expectation"
    ],
    "repair_map_required_fields": [
      "finding_id",
      "repair_status",
      "changed_artifact_refs",
      "repair_evidence_refs"
    ],
    "re_review_required_inputs": [
      "prior_findings",
      "repair_map",
      "exact_new_artifact_refs_and_hashes",
      "original_source_refs",
      "original_rubric_refs"
    ],
    "finding_closure_statuses": [
      "closed",
      "partially_closed",
      "still_open"
    ],
    "next_repair_triggers": [
      "required_finding_not_closed",
      "repair_regression",
      "critical_new_finding"
    ],
    "ordinary_new_suggestion_policy": "optional_observation_or_quality_debt_only_cannot_reopen_loop",
    "re_reviewer_must_use_fresh_attempt_and_session": true
  },
  "risk_tiers": {
    "low": "one isolated reviewer with a focused rubric",
    "medium": "one isolated reviewer with the full domain rubric",
    "high": "one isolated reviewer Attempt with a multi-axis rubric; optional parallel Codex subagents remain internal to that Attempt and the final receipt stays bound to it"
  },
  "handoff_review_boundary": {
    "source_field": "agent/stages/manifest.json#/stages/*/handoff_review_boundary",
    "required_for_stage_kind": "packaging",
    "required_fields": [
      "artifact_effect",
      "freezes_canonical_artifact_bytes",
      "issues_quality_export_publication_or_ready_claim",
      "downstream_owner_retains_acceptance"
    ],
    "artifact_effect_values": [
      "reviewed_immutable_refs_only",
      "mechanical_repackaging_of_reviewed_bytes",
      "new_or_transformed_reviewable_bytes"
    ],
    "formal_review_required_if_any_true": [
      "artifact_effect=new_or_transformed_reviewable_bytes",
      "freezes_canonical_artifact_bytes",
      "issues_quality_export_publication_or_ready_claim"
    ],
    "formal_review_required_implies_quality_cycle_enabled": true,
    "primary_only_allowed_when": "artifact_effect is reviewed_immutable_refs_only or mechanical_repackaging_of_reviewed_bytes, no canonical freeze or ready claim occurs, and downstream_owner_retains_acceptance=true",
    "human_gate_is_orthogonal_to_formal_review": true,
    "meta_review_before_handoff_does_not_cover_later_generated_bytes": true
  },
  "operator_projection": {
    "default_user_fields": [
      "current_stage",
      "stage_artifact",
      "completed_or_quality_debt",
      "next_stage"
    ],
    "developer_operator_drilldown_only": [
      "attempt_role",
      "quality_round_index",
      "execution_session_ref",
      "finding_lineage",
      "repair_lineage",
      "token_and_cost"
    ],
    "attempt_must_not_be_presented_as_sub_stage": true
  },
  "authority_boundary": {
    "opl_owns_attempt_identity_budget_lineage_and_context_isolation": true,
    "domain_agent_owns_review_method_findings_repair_and_quality_verdict": true,
    "opl_can_write_domain_truth": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_create_domain_owner_receipt": false,
    "opl_can_create_domain_typed_blocker": false,
    "provider_completion_is_quality_acceptance": false
  }
}
