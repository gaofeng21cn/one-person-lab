{
  "contract_kind": "opl_stage_artifact_progress_truth_policy.v1",
  "owner": "one-person-lab",
  "purpose": "Freeze the family-level progress-first rule that any readable Stage artifact is consumable progress while quality metadata controls claims only.",
  "state": "active_contract",
  "machine_boundary": "OPL owns progress projection over stage artifact units; domain repositories retain artifact body authority, owner answer authority, quality verdicts, and export readiness.",
  "progress_truth_required_signals": [
    "stage_attempt_or_failure_diagnostic_observed"
  ],
  "counts_as_deliverable_progress_when_all_required_signals_true": true,
  "single_signal_non_progress_reasons": [
    "provider_completion_only",
    "receipt_verified_without_matching_manifest",
    "identity_or_currentness_mismatch",
    "authority_safety_permission_or_human_gate"
  ],
  "projection_surfaces": [
    "opl_current_owner_delta",
    "opl_current_owner_delta_read_model",
    "opl_stage_artifact_unit",
    "opl_stage_progress_log",
    "opl_family_product_operator_projection"
  ],
  "source_contracts": [
    "contracts/opl-framework/stage-artifact-unit.schema.json",
    "contracts/opl-framework/stage-artifact-runtime-contract.json",
    "contracts/opl-framework/state-index-kernel-contract.json"
  ],
  "authority_boundary": {
    "opl_can_mutate_artifact_body": false,
    "opl_can_create_domain_owner_answer": false,
    "opl_can_authorize_quality_or_export": false,
    "provider_completion_counts_as_progress": false,
    "raw_receipt_count_counts_as_progress": false,
    "readable_file_counts_as_progress": true,
    "raw_evidence_envelope_counts_as_progress": true,
    "no_output_diagnostic_counts_as_progress": true,
    "corrupt_output_diagnostic_counts_as_progress": true,
    "artifact_attempt_pointer_can_write_stage_current_pointer": false,
    "codex_cli_route_context_is_semantic_owner": true,
    "framework_can_accept_reject_or_override_codex_route": false
  }
}
