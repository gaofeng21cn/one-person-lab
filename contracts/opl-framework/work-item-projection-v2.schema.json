{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/work-item-projection-v2.schema.json",
  "title": "OPL Work Item Projection V2",
  "type": "object",
  "required": ["surface_kind", "schema_version", "profile", "generated_at", "agent_catalog", "agent_availability", "project_catalog", "summary", "items", "diagnostics", "detail_policy", "authority_boundary"],
  "properties": {
    "surface_kind": { "const": "opl_work_item_projection" },
    "schema_version": { "const": "work-item-projection.v2" },
    "profile": { "enum": ["fast", "full"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "agent_catalog": {
      "type": "array",
      "items": { "$ref": "#/$defs/agentCatalogEntry" }
    },
    "agent_availability": {
      "type": "array",
      "items": { "$ref": "#/$defs/agentAvailability" }
    },
    "project_catalog": {
      "type": "array",
      "items": { "$ref": "#/$defs/projectCatalogEntry" }
    },
    "summary": {
      "type": "object",
      "required": ["agent_count", "project_count", "work_item_count", "visible_work_item_count", "archived_work_item_count", "total_work_item_count", "running_count", "user_attention_count", "system_attention_count", "telemetry_observed_count", "telemetry_missing_count"],
      "properties": {
        "agent_count": { "type": "integer", "minimum": 0 },
        "project_count": { "type": "integer", "minimum": 0 },
        "work_item_count": { "type": "integer", "minimum": 0 },
        "visible_work_item_count": { "type": "integer", "minimum": 0 },
        "archived_work_item_count": { "type": "integer", "minimum": 0 },
        "total_work_item_count": { "type": "integer", "minimum": 0 },
        "running_count": { "type": "integer", "minimum": 0 },
        "user_attention_count": { "type": "integer", "minimum": 0 },
        "system_attention_count": { "type": "integer", "minimum": 0 },
        "telemetry_observed_count": { "type": "integer", "minimum": 0 },
        "telemetry_missing_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/workItem" }
    },
    "diagnostics": {
      "type": "object",
      "required": ["count", "items", "detail_policy"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "items": { "type": "array", "items": { "type": "object" } },
        "detail_policy": { "enum": ["summary_only", "included"] }
      },
      "additionalProperties": false
    },
    "detail_policy": {
      "type": "object",
      "required": ["all_work_item_summaries_included", "attempt_ref_limit_per_item", "diagnostic_details"],
      "properties": {
        "all_work_item_summaries_included": { "const": true },
        "attempt_ref_limit_per_item": { "type": "integer", "minimum": 1 },
        "diagnostic_details": { "enum": ["lazy", "included"] }
      },
      "additionalProperties": false
    },
    "authority_boundary": {
      "type": "object",
      "required": ["projection_only", "can_write_domain_truth", "can_create_owner_receipt", "can_create_typed_blocker", "can_authorize_quality_verdict", "temporal_is_work_item_inventory"],
      "properties": {
        "projection_only": { "const": true },
        "can_write_domain_truth": { "const": false },
        "can_create_owner_receipt": { "const": false },
        "can_create_typed_blocker": { "const": false },
        "can_authorize_quality_verdict": { "const": false },
        "temporal_is_work_item_inventory": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullableString": { "type": ["string", "null"] },
    "sourceRef": {
      "type": "object",
      "required": ["ref_kind", "ref", "role"],
      "properties": {
        "ref_kind": { "enum": ["file", "sqlite", "projection"] },
        "ref": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "agentCatalogEntry": {
      "type": "object",
      "required": ["agent_id", "domain_id", "display_name", "short_label", "package_id", "scope_id"],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "domain_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "short_label": { "type": "string", "minLength": 1 },
        "package_id": { "type": "string", "minLength": 1 },
        "scope_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "agentAvailability": {
      "type": "object",
      "required": ["agent_id", "domain_id", "display_name", "availability", "reason", "last_checked_at", "source", "independent_from_work_item_state", "package_id", "source_ref", "inventory_descriptor", "package_launch_readiness"],
      "properties": {
        "agent_id": { "type": "string", "minLength": 1 },
        "domain_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "availability": { "enum": ["available", "attention_required", "unavailable"] },
        "reason": { "type": "string", "minLength": 1 },
        "last_checked_at": { "type": "string", "format": "date-time" },
        "source": { "enum": ["package_directory", "package_status"] },
        "independent_from_work_item_state": { "const": true },
        "package_id": { "type": "string", "minLength": 1 },
        "source_ref": { "$ref": "#/$defs/nullableString" },
        "inventory_descriptor": {
          "type": "object",
          "required": ["status", "reason", "source_ref"],
          "properties": {
            "status": { "enum": ["readable", "unreadable", "not_checked"] },
            "reason": { "type": "string", "minLength": 1 },
            "source_ref": { "$ref": "#/$defs/nullableString" }
          },
          "additionalProperties": false
        },
        "package_launch_readiness": {
          "type": "object",
          "required": ["status", "launch_allowed", "reason"],
          "properties": {
            "status": { "enum": ["ready", "blocked", "unknown"] },
            "launch_allowed": { "type": ["boolean", "null"] },
            "reason": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "projectCatalogEntry": {
      "type": "object",
      "required": ["project_id", "scope_id", "agent_id", "agent_display_name", "domain_id", "display_name", "workspace_path", "binding_status", "selected_binding_id", "binding_ids", "source_refs"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "scope_id": { "type": "string", "minLength": 1 },
        "agent_id": { "type": "string", "minLength": 1 },
        "agent_display_name": { "type": "string", "minLength": 1 },
        "domain_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "workspace_path": { "type": "string", "minLength": 1 },
        "binding_status": { "enum": ["active", "inactive"] },
        "selected_binding_id": { "type": "string", "minLength": 1 },
        "binding_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } }
      },
      "additionalProperties": false
    },
    "tokenObservation": {
      "type": "object",
      "required": ["state", "input_tokens", "output_tokens", "total_tokens", "observed_at", "missing_reason", "source_refs"],
      "properties": {
        "state": { "enum": ["observed", "missing", "stale"] },
        "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "output_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "total_tokens": { "type": ["integer", "null"], "minimum": 0 },
        "observed_at": { "$ref": "#/$defs/nullableString" },
        "missing_reason": { "$ref": "#/$defs/nullableString" },
        "source_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "observed" } } },
          "then": {
            "properties": {
              "input_tokens": { "type": "integer", "minimum": 0 },
              "output_tokens": { "type": "integer", "minimum": 0 },
              "total_tokens": { "type": "integer", "minimum": 0 },
              "missing_reason": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "input_tokens": { "type": "null" },
              "output_tokens": { "type": "null" },
              "total_tokens": { "type": "null" },
              "missing_reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": ["type", "status", "reason", "message", "owner", "severity", "last_transition_time", "observed_generation", "ref"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "status": { "enum": ["True", "False", "Unknown"] },
        "reason": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["none", "info", "warning", "error"] },
        "last_transition_time": { "$ref": "#/$defs/nullableString" },
        "observed_generation": { "$ref": "#/$defs/nullableString" },
        "ref": { "$ref": "#/$defs/nullableString" }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "required": ["kind", "title", "title_key", "summary", "summary_key", "message_args", "owner", "owner_kind", "owner_display_name", "action_ref", "dry_run_required"],
      "properties": {
        "kind": { "enum": ["user_action", "system_action", "agent_action", "safe_action", "blocked_no_action"] },
        "title": { "type": "string", "minLength": 1 },
        "title_key": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "summary_key": { "type": "string", "minLength": 1 },
        "message_args": { "type": "object" },
        "owner": { "type": "string", "minLength": 1 },
        "owner_kind": { "enum": ["user", "system", "agent", "other"] },
        "owner_display_name": { "type": "string", "minLength": 1 },
        "action_ref": { "type": "string", "minLength": 1 },
        "dry_run_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "stage": {
      "type": "object",
      "required": ["stage_id", "display_name", "state", "owner", "owner_display_name", "elapsed_seconds", "usage", "next_action"],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string", "minLength": 1 },
        "state": { "enum": ["completed", "current", "next", "pending", "waiting_user", "system_attention", "stopped", "failed"] },
        "owner": { "$ref": "#/$defs/nullableString" },
        "owner_display_name": { "$ref": "#/$defs/nullableString" },
        "elapsed_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "usage": { "oneOf": [{ "$ref": "#/$defs/tokenObservation" }, { "type": "null" }] },
        "next_action": { "$ref": "#/$defs/nullableString" }
      },
      "additionalProperties": false
    },
    "workItem": {
      "type": "object",
      "required": ["item_id", "identity", "lifecycle", "visibility", "execution", "attention", "telemetry", "action", "stage_map", "conditions", "freshness", "source_refs"],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "identity": {
          "type": "object",
          "required": ["agent_id", "agent_display_name", "domain_id", "project_id", "project_display_name", "project_scope_id", "workspace_binding_id", "workspace_path", "work_item_id", "work_item_display_name", "work_item_kind", "work_item_root", "work_item_scope_id", "source_kind"],
          "properties": {
            "agent_id": { "type": "string", "minLength": 1 },
            "agent_display_name": { "type": "string", "minLength": 1 },
            "domain_id": { "type": "string", "minLength": 1 },
            "project_id": { "type": "string", "minLength": 1 },
            "project_display_name": { "type": "string", "minLength": 1 },
            "project_scope_id": { "type": "string", "minLength": 1 },
            "workspace_binding_id": { "type": "string", "minLength": 1 },
            "workspace_path": { "type": "string", "minLength": 1 },
            "work_item_id": { "type": "string", "minLength": 1 },
            "work_item_display_name": { "type": "string", "minLength": 1 },
            "work_item_kind": { "type": "string", "minLength": 1 },
            "work_item_root": { "$ref": "#/$defs/nullableString" },
            "work_item_scope_id": { "type": "string", "minLength": 1 },
            "source_kind": { "enum": ["domain_inventory", "runtime_only"] }
          },
          "additionalProperties": false
        },
        "lifecycle": {
          "type": "object",
          "required": ["business_state", "domain_business_state", "control_state", "primary_state", "primary_state_label", "primary_state_reason", "reason", "last_transition_at", "raw_business_status", "current_stage_id", "current_stage_display_name", "current_stage_status", "package_status", "lifecycle_ref", "source", "control_ref", "control_updated_at", "observed_generation"],
          "properties": {
            "business_state": { "$ref": "#/$defs/businessState" },
            "domain_business_state": { "$ref": "#/$defs/businessState" },
            "control_state": { "oneOf": [{ "$ref": "#/$defs/controlState" }, { "type": "null" }] },
            "primary_state": { "$ref": "#/$defs/primaryState" },
            "primary_state_label": { "type": "string", "minLength": 1 },
            "primary_state_reason": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 },
            "last_transition_at": { "type": "string", "minLength": 1 },
            "raw_business_status": { "$ref": "#/$defs/nullableString" },
            "current_stage_id": { "$ref": "#/$defs/nullableString" },
            "current_stage_display_name": { "$ref": "#/$defs/nullableString" },
            "current_stage_status": { "$ref": "#/$defs/nullableString" },
            "package_status": { "$ref": "#/$defs/nullableString" },
            "lifecycle_ref": { "$ref": "#/$defs/nullableString" },
            "source": { "enum": ["work_item_control_ledger", "domain_inventory_projection", "runtime_only"] },
            "control_ref": { "$ref": "#/$defs/nullableString" },
            "control_updated_at": { "$ref": "#/$defs/nullableString" },
            "observed_generation": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "visibility": {
          "type": "object",
          "required": ["state", "source", "updated_at", "control_ref", "generation"],
          "properties": {
            "state": { "enum": ["visible", "archived"] },
            "source": { "enum": ["default", "work_item_control_ledger"] },
            "updated_at": { "$ref": "#/$defs/nullableString" },
            "control_ref": { "$ref": "#/$defs/nullableString" },
            "generation": { "type": "integer", "minimum": 0 }
          },
          "allOf": [
            {
              "if": { "properties": { "source": { "const": "default" } } },
              "then": {
                "properties": {
                  "updated_at": { "type": "null" },
                  "control_ref": { "type": "null" }
                }
              },
              "else": {
                "properties": {
                  "updated_at": { "type": "string", "minLength": 1 },
                  "control_ref": { "type": "string", "minLength": 1 }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "execution": {
          "type": "object",
          "required": ["state", "stage_id", "stage_status", "current_stage_id", "current_stage_display_name", "next_stage_id", "next_stage_display_name", "attempt_id", "attempt_ids", "workflow_id", "provider_kind", "started_at", "last_heartbeat_at", "updated_at", "running_proof_status", "diagnostic_reason"],
          "properties": {
            "state": { "enum": ["running", "queued", "idle", "succeeded", "failed", "unknown"] },
            "stage_id": { "$ref": "#/$defs/nullableString" },
            "stage_status": { "$ref": "#/$defs/nullableString" },
            "current_stage_id": { "$ref": "#/$defs/nullableString" },
            "current_stage_display_name": { "$ref": "#/$defs/nullableString" },
            "next_stage_id": { "$ref": "#/$defs/nullableString" },
            "next_stage_display_name": { "$ref": "#/$defs/nullableString" },
            "attempt_id": { "$ref": "#/$defs/nullableString" },
            "attempt_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "workflow_id": { "$ref": "#/$defs/nullableString" },
            "provider_kind": { "$ref": "#/$defs/nullableString" },
            "started_at": { "$ref": "#/$defs/nullableString" },
            "last_heartbeat_at": { "$ref": "#/$defs/nullableString" },
            "updated_at": { "$ref": "#/$defs/nullableString" },
            "running_proof_status": { "type": "string", "minLength": 1 },
            "diagnostic_reason": { "$ref": "#/$defs/nullableString" }
          },
          "additionalProperties": false
        },
        "attention": {
          "type": "object",
          "required": ["kind", "reason", "owner", "responsible_component", "issue", "impact", "repair_action", "expected_outcome"],
          "properties": {
            "kind": { "enum": ["none", "user", "system"] },
            "reason": { "type": "string", "minLength": 1 },
            "owner": { "$ref": "#/$defs/nullableString" },
            "responsible_component": { "$ref": "#/$defs/nullableString" },
            "issue": { "$ref": "#/$defs/nullableString" },
            "impact": { "$ref": "#/$defs/nullableString" },
            "repair_action": { "$ref": "#/$defs/nullableString" },
            "expected_outcome": { "$ref": "#/$defs/nullableString" }
          },
          "allOf": [
            {
              "if": { "properties": { "kind": { "const": "system" } } },
              "then": {
                "properties": {
                  "owner": { "type": "string", "minLength": 1 },
                  "responsible_component": { "type": "string", "minLength": 1 },
                  "issue": { "type": "string", "minLength": 1 },
                  "impact": { "type": "string", "minLength": 1 },
                  "repair_action": { "type": "string", "minLength": 1 },
                  "expected_outcome": { "type": "string", "minLength": 1 }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "telemetry": {
          "type": "object",
          "required": ["state", "current_stage", "cumulative", "missing_reason"],
          "properties": {
            "state": { "enum": ["observed", "partial", "missing", "stale"] },
            "current_stage": { "$ref": "#/$defs/tokenObservation" },
            "cumulative": { "$ref": "#/$defs/tokenObservation" },
            "missing_reason": { "$ref": "#/$defs/nullableString" }
          },
          "additionalProperties": false
        },
        "action": { "$ref": "#/$defs/action" },
        "stage_map": { "type": "array", "items": { "$ref": "#/$defs/stage" } },
        "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "freshness": {
          "type": "object",
          "required": ["state", "inventory_observed_at", "execution_observed_at", "last_transition_time", "observed_generation", "reason"],
          "properties": {
            "state": { "enum": ["current", "stale", "unknown"] },
            "inventory_observed_at": { "type": "string", "minLength": 1 },
            "execution_observed_at": { "$ref": "#/$defs/nullableString" },
            "last_transition_time": { "type": "string", "minLength": 1 },
            "observed_generation": { "type": "string", "minLength": 1 },
            "reason": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "source_refs": { "type": "array", "items": { "$ref": "#/$defs/sourceRef" } }
      },
      "additionalProperties": false
    },
    "businessState": {
      "enum": ["active", "delivered_paused", "paused", "stopped", "archived", "unknown"]
    },
    "controlState": {
      "enum": ["active", "delivered_paused", "paused", "stopped"]
    },
    "primaryState": {
      "enum": ["automatically_advancing", "awaiting_user_decision", "system_attention", "delivered_auto_paused", "paused", "stopped", "sync_pending"]
    }
  }
}
