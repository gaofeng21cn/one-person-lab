{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/package-payload-manifest.schema.json",
  "title": "Legacy OPL Package Payload Manifest v1",
  "type": "object",
  "required": [
    "surface_kind",
    "schema_ref",
    "package_id",
    "package_version",
    "source_repo",
    "source_commit",
    "source_root",
    "files"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_package_payload_manifest.v1"
    },
    "schema_ref": {
      "const": "contracts/opl-framework/package-payload-manifest.schema.json"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "package_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "source_repo": {
      "type": "string",
      "pattern": "^https://github\\.com/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?\\.git$"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "source_root": {
      "type": "string",
      "pattern": "^(?:\\.|(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+)$"
    },
    "agent_id": false,
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "path",
          "source_url",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
          },
          "source_url": {
            "type": "string",
            "pattern": "^https://raw\\.githubusercontent\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/[0-9a-f]{40}/[^\\u0000-\\u001f\\u007f]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
