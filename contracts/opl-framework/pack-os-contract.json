{
  "schema_version": 1,
  "contract_id": "opl-pack-os-contract.v1",
  "owner": "One Person Lab",
  "purpose": "Generic Pack OS lifecycle contract for capability-pack descriptor intake, registry install, content-addressed cache, refs-only distribution, lock projection, artifact lifecycle refs, and review receipt transport.",
  "state": "active_l4_structural_baseline",
  "machine_boundary": "This contract covers OPL-owned pack descriptor transport, registry install records, content-addressed cache records for present local resources, refs-only distribution manifests, resolver/lock projection, content hash refs, artifact locator refs, lifecycle state refs, and reviewer receipt refs. It does not authorize domain truth, artifact body mutation, owner receipt signing, quality verdicts, publication readiness, grant readiness, visual export readiness, App release readiness, or production maturity.",
  "source_module": "src/modules/pack/pack-os.ts",
  "cli_surfaces": {
    "inspect": "opl pack os inspect --descriptor <path>",
    "install": "opl pack os install --descriptor <path> --registry <path> [--cache-root <dir>]",
    "registry": "opl pack os registry --registry <path>",
    "cache": "opl pack os cache --descriptor <path> --cache-root <dir>",
    "distribute": "opl pack os distribute --descriptor <path> --output <path> [--cache-root <dir>]",
    "lock": "opl pack os lock --descriptor <path>",
    "validate": "opl pack os validate --descriptor <path>"
  },
  "descriptor_contract": {
    "surface_kind": "opl_generic_capability_pack_descriptor",
    "required_fields": [
      "pack_id",
      "version",
      "pack_kind",
      "owner",
      "capabilities",
      "resources",
      "artifact_lifecycle",
      "review_transport",
      "authority_boundary",
      "provenance"
    ],
    "allowed_pack_kinds": [
      "display_pack",
      "domain_pack",
      "deck_pack",
      "report_pack",
      "app_ui_pack",
      "generic_capability_pack"
    ],
    "resource_roles": [
      "descriptor",
      "template",
      "schema",
      "renderer",
      "style_tokens",
      "qc_profile",
      "golden",
      "exemplar_ref",
      "receipt_ref",
      "artifact_ref"
    ],
    "relationship_to_domain_packs": "Declarative Domain Pack and generated surfaces remain OPL Pack module responsibilities. Generic Pack OS adds install/registry/cache/distribution/resolve/lock/lifecycle transport for capability packs and can transport domain-declared refs without becoming the domain authority."
  },
  "registry_cache_distribution_contract": {
    "registry_surface_kind": "opl_pack_os_registry",
    "install_receipt_surface_kind": "opl_pack_os_install_receipt",
    "cache_manifest_surface_kind": "opl_pack_os_cache_manifest",
    "distribution_manifest_surface_kind": "opl_pack_os_distribution_manifest",
    "distribution_bundle_surface_kind": "opl_pack_os_distribution_bundle",
    "cache_layout": "sha256/<sha256>",
    "oci_descriptor_fields": [
      "mediaType",
      "digest",
      "size"
    ],
    "oci_media_types": {
      "descriptor": "application/vnd.opl.pack.descriptor.v1+json",
      "resource": "application/vnd.opl.pack.resource.v1"
    },
    "registry_rule": "Registry entries are keyed by pack_id@version and store descriptor refs, descriptor hashes, lock ids, resource counts, cache refs, and false-authority boundaries. They do not store domain truth or artifact bodies.",
    "distribution_rule": "Distribution bundles contain pack locks, cache manifests, registry-entry shape, authority boundaries, and not_claims. They are refs-only manifests and do not become quality, publication, export, App release, or production readiness evidence."
  },
  "lock_contract": {
    "surface_kind": "opl_generic_pack_lock",
    "output_role": "refs_only_pack_resolution_lock",
    "required_fields": [
      "lock_id",
      "pack_id",
      "version",
      "pack_kind",
      "descriptor_ref",
      "descriptor_sha256",
      "descriptor_oci",
      "content_addressed_lock_policy",
      "resolved_resources",
      "artifact_lifecycle",
      "review_transport",
      "authority_boundary",
      "provenance"
    ],
    "content_hash_algorithm": "sha256",
    "lock_projection_rule": "The lock is derived from a descriptor and refs. It records paths, refs, hashes, lifecycle states, and review receipt transport status. It does not copy artifact bodies or convert review receipts into domain verdicts.",
    "content_addressed_lock_policy": {
      "policy_id": "opl.pack_os.content_addressed_lock.v1",
      "digest_algorithm": "sha256",
      "descriptor_media_type": "application/vnd.opl.pack.descriptor.v1+json",
      "resource_media_type": "application/vnd.opl.pack.resource.v1",
      "descriptor_digest_required": true,
      "present_local_resource_digest_required": true,
      "external_refs_cached": false,
      "lock_records_refs_only": true,
      "registry_push_pull_implemented": false,
      "stores_artifact_body": false,
      "closes_stage": false,
      "writes_domain_truth": false
    }
  },
  "lifecycle_model": {
    "allowed_states": [
      "declared",
      "resolved",
      "locked",
      "cached",
      "artifact_refs_observed",
      "review_receipts_observed",
      "handoff_ready",
      "retained",
      "restored",
      "retired"
    ],
    "hard_boundaries": [
      "content_hash_required_for_present_local_file",
      "artifact_body_not_stored_in_opl_contract",
      "review_receipt_transport_does_not_authorize_quality_verdict",
      "domain_owner_receipt_required_for_domain_truth_or_artifact_authority"
    ]
  },
  "authority_boundary": {
    "opl_can_resolve_pack_descriptor": true,
    "opl_can_write_pack_lock": true,
    "opl_can_cache_pack_assets": true,
    "opl_can_project_artifact_locator_refs": true,
    "opl_can_transport_review_receipt_refs": true,
    "opl_can_write_domain_truth": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_sign_domain_owner_receipt": false,
    "opl_can_authorize_quality_verdict": false,
    "opl_can_authorize_publication_readiness": false,
    "opl_can_authorize_grant_readiness": false,
    "opl_can_authorize_visual_export_readiness": false,
    "opl_can_authorize_app_release_readiness": false,
    "provider_completion_is_pack_quality_ready": false
  },
  "forbidden_claims": [
    "pack_lock_is_domain_ready",
    "review_receipt_transport_is_quality_verdict",
    "artifact_locator_ref_is_artifact_authority",
    "provider_completion_is_pack_quality_ready"
  ],
  "verification": {
    "focused_tests": [
      "tests/src/cli/cases/contracts-help.test.ts",
      "tests/src/profile-capability-plan.test.ts"
    ],
    "required_commands_when_changed": [
      "node --experimental-strip-types --test tests/src/cli/cases/contracts-help.test.ts tests/src/profile-capability-plan.test.ts",
      "npm run typecheck",
      "scripts/verify.sh"
    ]
  }
}
