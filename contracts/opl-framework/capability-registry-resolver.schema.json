{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/capability-registry-resolver.schema.json",
  "schema_id": "opl.capability_registry_resolver.v1",
  "surface_kind": "opl_capability_registry_resolver_schema",
  "owner": "one-person-lab",
  "purpose": "Define the W3 current-owner-delta-bound Capability Registry resolver ABI and three-layer invocation lifecycle boundary for Atlas, Pack, Stagecraft, and Runway.",
  "state": "active_contract",
  "machine_boundary": "OPL resolves capability refs and emits advisory readouts or typed blocker candidates only. Domain owners retain capability execution, domain truth, owner receipt, typed blocker, and quality/export authority.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "resolver_policy",
    "capability_ref",
    "work_unit_ref",
    "resolution_status",
    "current_owner_delta_binding",
    "selection",
    "route_required_policy",
    "blocker_candidate",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_capability_registry_resolution"
    },
    "schema_version": {
      "const": "capability-registry-resolver.v1"
    },
    "resolver_policy": {
      "const": "current_delta_bound_jit_or_fail_open"
    },
    "capability_ref": {
      "type": "string",
      "minLength": 1
    },
    "work_unit_ref": {
      "type": "string",
      "minLength": 1
    },
    "resolution_status": {
      "enum": [
        "resolved",
        "fail_open",
        "route_required_blocker_candidate"
      ]
    },
    "current_owner_delta_binding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "bound",
        "default_planning_root",
        "current_owner_delta_ref",
        "domain_id",
        "current_owner"
      ],
      "properties": {
        "bound": {
          "type": "boolean"
        },
        "default_planning_root": {
          "enum": [
            "current_owner_delta",
            "missing"
          ]
        },
        "current_owner_delta_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "domain_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "current_owner": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action",
        "capability_found",
        "capability_ref",
        "source_family",
        "surface_ref"
      ],
      "properties": {
        "action": {
          "enum": [
            "select_capability_ref",
            "advisory_or_audit",
            "route_required_blocker_candidate"
          ]
        },
        "capability_found": {
          "type": "boolean"
        },
        "capability_ref": {
          "type": "string"
        },
        "source_family": {
          "type": [
            "string",
            "null"
          ]
        },
        "surface_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "route_required_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "is_route_required",
        "hard_boundary",
        "policy"
      ],
      "properties": {
        "is_route_required": {
          "type": "boolean"
        },
        "hard_boundary": {
          "enum": [
            "source_data_evidence",
            "owner_route_identity",
            "forbidden_write",
            "irreversible_mutation",
            "reviewer_publication_hard_gate",
            null
          ]
        },
        "policy": {
          "enum": [
            "optional_missing_fail_open",
            "route_required_current_owner_delta_hard_boundary_missing_ref",
            "capability_ref_resolved"
          ]
        }
      }
    },
    "blocker_candidate": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/typed_blocker_candidate"
        }
      ]
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "domain_pack_external_learning_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "capability_ref",
        "source_family",
        "work_unit_ref"
      ],
      "properties": {
        "capability_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_family": {
          "type": "string",
          "minLength": 1
        },
        "work_unit_ref": {
          "type": "string",
          "minLength": 1
        },
        "binding_kind": {
          "enum": [
            "optional",
            "route_required"
          ]
        },
        "surface_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capability_registry_readout": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "schema_version",
        "owner_modules",
        "default_behavior",
        "resolver_abi_ref",
        "lifecycle_layers",
        "invocation_lifecycle_policy",
        "source_families",
        "summary",
        "domain_pack_external_learning_refs",
        "resolutions",
        "domain_local_selector_created",
        "always_on_sidecar_created",
        "default_preflight_created",
        "second_active_backlog_created",
        "authority_boundary"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_capability_registry_readout"
        },
        "schema_version": {
          "const": "capability-registry-resolver.v1"
        },
        "owner_modules": {
          "const": [
            "atlas",
            "pack",
            "stagecraft",
            "runway"
          ]
        },
        "default_behavior": {
          "const": "current_owner_delta_bound_jit_or_fail_open"
        },
        "resolver_abi_ref": {
          "const": "contracts/opl-framework/capability-registry-resolver.schema.json"
        },
        "lifecycle_layers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability_invocation_lifecycle_layer"
          },
          "prefixItems": [
            {
              "properties": {
                "layer_id": {
                  "const": "soft_discovery"
                }
              }
            },
            {
              "properties": {
                "layer_id": {
                  "const": "scored_fit"
                }
              }
            },
            {
              "properties": {
                "layer_id": {
                  "const": "hard_gate"
                }
              }
            }
          ],
          "minItems": 3,
          "maxItems": 3
        },
        "invocation_lifecycle_policy": {
          "$ref": "#/$defs/capability_invocation_lifecycle_policy"
        },
        "source_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "summary": {
          "$ref": "#/$defs/resolution_summary"
        },
        "domain_pack_external_learning_refs": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "consumed_count",
            "resolved_count",
            "fail_open_count",
            "blocker_candidate_count",
            "source_families"
          ],
          "properties": {
            "consumed_count": {
              "type": "integer",
              "minimum": 0
            },
            "resolved_count": {
              "type": "integer",
              "minimum": 0
            },
            "fail_open_count": {
              "type": "integer",
              "minimum": 0
            },
            "blocker_candidate_count": {
              "type": "integer",
              "minimum": 0
            },
            "source_families": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "resolutions": {
          "type": "array",
          "items": {
            "$ref": "#"
          }
        },
        "domain_local_selector_created": {
          "const": false
        },
        "always_on_sidecar_created": {
          "const": false
        },
        "default_preflight_created": {
          "const": false
        },
        "second_active_backlog_created": {
          "const": false
        },
        "authority_boundary": {
          "$ref": "#/$defs/authority_boundary"
        }
      }
    },
    "resolution_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "requested_count",
        "resolved_count",
        "fail_open_count",
        "blocker_candidate_count"
      ],
      "properties": {
        "requested_count": {
          "type": "integer",
          "minimum": 0
        },
        "resolved_count": {
          "type": "integer",
          "minimum": 0
        },
        "fail_open_count": {
          "type": "integer",
          "minimum": 0
        },
        "blocker_candidate_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "capability_invocation_lifecycle_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "surface_kind",
        "schema_version",
        "soft_discovery",
        "scored_fit",
        "hard_gate"
      ],
      "properties": {
        "surface_kind": {
          "const": "opl_capability_invocation_lifecycle_policy"
        },
        "schema_version": {
          "const": "capability-invocation-lifecycle.v1"
        },
        "soft_discovery": {
          "$ref": "#/$defs/capability_invocation_lifecycle_layer"
        },
        "scored_fit": {
          "$ref": "#/$defs/capability_invocation_lifecycle_layer"
        },
        "hard_gate": {
          "$ref": "#/$defs/capability_invocation_lifecycle_layer"
        }
      }
    },
    "capability_invocation_lifecycle_layer": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "layer_id",
        "owner_modules",
        "authority_role",
        "source_surfaces",
        "fail_closed_on",
        "forbidden_claims",
        "authority_surface",
        "runway_can_write_domain_truth",
        "runway_can_sign_owner_receipt",
        "runway_can_create_typed_blocker"
      ],
      "properties": {
        "layer_id": {
          "enum": [
            "soft_discovery",
            "scored_fit",
            "hard_gate"
          ]
        },
        "owner_modules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority_role": {
          "enum": [
            "high_recall_advisory_discovery",
            "explainable_fit_advisory_not_authority",
            "fail_closed_current_owner_delta_gate"
          ]
        },
        "source_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fail_closed_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden_claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authority_surface": {
          "type": [
            "string",
            "null"
          ]
        },
        "runway_can_write_domain_truth": {
          "const": false
        },
        "runway_can_sign_owner_receipt": {
          "const": false
        },
        "runway_can_create_typed_blocker": {
          "const": false
        }
      }
    },
    "typed_blocker_candidate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_kind",
        "blocker_policy",
        "missing_capability_ref",
        "current_owner_delta_ref",
        "work_unit_ref",
        "route_back_owner",
        "may_create_domain_typed_blocker",
        "repair_action"
      ],
      "properties": {
        "candidate_kind": {
          "const": "typed_blocker_candidate"
        },
        "blocker_policy": {
          "const": "route_required_current_owner_delta_hard_boundary_missing_ref"
        },
        "may_create_domain_typed_blocker": {
          "const": false
        },
        "repair_action": {
          "const": "domain_or_gate_owner_must_supply_capability_ref_or_signed_typed_blocker"
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "can_execute_capability",
        "can_write_domain_truth",
        "can_sign_owner_receipt",
        "can_create_domain_typed_blocker",
        "can_claim_quality_or_export_verdict",
        "can_create_domain_local_selector",
        "can_create_always_on_sidecar",
        "can_create_default_preflight",
        "can_create_second_active_backlog"
      ],
      "properties": {
        "can_execute_capability": {
          "const": false
        },
        "can_write_domain_truth": {
          "const": false
        },
        "can_sign_owner_receipt": {
          "const": false
        },
        "can_create_domain_typed_blocker": {
          "const": false
        },
        "can_claim_quality_or_export_verdict": {
          "const": false
        },
        "can_create_domain_local_selector": {
          "const": false
        },
        "can_create_always_on_sidecar": {
          "const": false
        },
        "can_create_default_preflight": {
          "const": false
        },
        "can_create_second_active_backlog": {
          "const": false
        }
      }
    }
  }
}
