{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/domain-progress-transition-runtime-live-readback.schema.json",
  "schema_id": "opl.domain_progress_transition_runtime_live_readback.v1",
  "owner": "one-person-lab",
  "purpose": "Validate the DomainProgressTransitionRuntime live readback JSON boundary before current-control/provider-admission code consumes it.",
  "state": "active_contract",
  "machine_boundary": "This schema validates runtime readback shape and false-authority fields. It does not authorize domain truth, owner receipts, typed blockers, readiness, release, or production claims.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "runtime_id",
    "storage_contract",
    "runtime_readback_status",
    "transaction_complete",
    "append_only_log_entry_count",
    "identity",
    "causality",
    "authority_boundary",
    "replay_audit",
    "exactly_one_outcome",
    "projection_metadata",
    "read_model_readback",
    "latest_transaction_readback"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_domain_progress_transition_runtime_live_readback"
    },
    "runtime_id": {
      "const": "opl_domain_progress_transition_runtime"
    },
    "storage_contract": {
      "const": "append_only_physical_jsonl"
    },
    "runtime_readback_status": {
      "enum": [
        "complete_transaction",
        "incomplete_transaction",
        "empty"
      ]
    },
    "transaction_complete": {
      "type": "boolean"
    },
    "append_only_log_entry_count": {
      "type": "integer",
      "minimum": 0
    },
    "identity": {
      "type": "object",
      "additionalProperties": true
    },
    "causality": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "same_transaction_event_and_outbox",
        "runtime_readback_status",
        "transaction_complete"
      ],
      "properties": {
        "same_transaction_event_and_outbox": {
          "type": "boolean"
        },
        "runtime_readback_status": {
          "enum": [
            "complete_transaction",
            "incomplete_transaction",
            "empty"
          ]
        },
        "transaction_complete": {
          "type": "boolean"
        }
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "replay_audit": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "read_model_projection_consumable"
      ],
      "properties": {
        "read_model_projection_consumable": {
          "type": "boolean"
        }
      }
    },
    "exactly_one_outcome": {
      "type": "object",
      "additionalProperties": true
    },
    "projection_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "authority",
        "projection_role",
        "read_model_projection_consumable",
        "runtime_readback_status",
        "transaction_complete"
      ],
      "properties": {
        "authority": {
          "const": false
        },
        "projection_role": {
          "enum": [
            "complete_runtime_readback",
            "fail_closed_runtime_readback"
          ]
        },
        "read_model_projection_consumable": {
          "type": "boolean"
        },
        "runtime_readback_status": {
          "enum": [
            "complete_transaction",
            "incomplete_transaction",
            "empty"
          ]
        },
        "transaction_complete": {
          "type": "boolean"
        }
      }
    },
    "read_model_readback": {
      "type": "object",
      "additionalProperties": true
    },
    "idempotency_readback": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "latest_transaction_readback": {
      "$ref": "#/$defs/latest_transaction_readback"
    }
  },
  "$defs": {
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "authority",
        "runtime_owner",
        "opl_can_write_domain_truth",
        "opl_can_create_domain_owner_receipt",
        "opl_can_create_domain_typed_blocker",
        "provider_completion_is_domain_completion",
        "provider_completion_is_domain_ready",
        "read_model_can_execute",
        "projection_can_authorize_provider_admission"
      ],
      "properties": {
        "authority": {
          "const": false
        },
        "runtime_owner": {
          "const": "one-person-lab"
        },
        "opl_can_write_domain_truth": {
          "const": false
        },
        "opl_can_write_mas_truth": {
          "const": false
        },
        "opl_can_create_domain_owner_receipt": {
          "const": false
        },
        "opl_can_create_domain_typed_blocker": {
          "const": false
        },
        "provider_completion_is_domain_completion": {
          "const": false
        },
        "provider_completion_is_domain_ready": {
          "const": false
        },
        "read_model_can_execute": {
          "const": false
        },
        "projection_can_authorize_provider_admission": {
          "const": false
        }
      }
    },
    "latest_transaction_readback": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "command_present",
        "event_present",
        "outbox_item_present",
        "same_outbox_identity",
        "same_transaction_event_and_outbox",
        "same_stage_run_identity"
      ],
      "properties": {
        "transaction_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "command_present": {
          "type": "boolean"
        },
        "event_present": {
          "type": "boolean"
        },
        "outbox_item_present": {
          "type": "boolean"
        },
        "same_outbox_identity": {
          "type": "boolean"
        },
        "same_transaction_event_and_outbox": {
          "type": "boolean"
        },
        "same_stage_run_identity": {
          "type": "boolean"
        },
        "stage_run_identity_readback": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
