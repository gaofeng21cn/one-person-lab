{
  "contract_kind": "opl_standard_agent_hosted_action_runtime_contract.v1",
  "surface_kind": "opl_standard_agent_hosted_action_runtime_contract",
  "owner": "one-person-lab",
  "purpose": "Host Standard OPL Agent actions from exact managed package sources without restoring per-agent command control planes or moving domain authority into OPL.",
  "state": "active_contract",
  "brand_module_ownership": {
    "primary_module": "runway",
    "collaborating_modules": [
      "connect",
      "atlas",
      "pack",
      "workspace",
      "ledger"
    ]
  },
  "entry_surface": {
    "command": "opl agents run --domain <agent> --action <action_id> --workspace <absolute_path>",
    "registered_standard_agent_required": true,
    "absolute_existing_workspace_required": true,
    "unmanaged_repo_checkout_allowed": false
  },
  "managed_package_gate": {
    "owner_module": "connect",
    "package_status_surface": "opl packages status --package-id <agent_id> --scope workspace --target-workspace <absolute_path> --json",
    "ordinary_user_distribution": {
      "moving_pointer": "latest-stable",
      "install_truth": "resolved_digest_lock",
      "release_set_schema_ref": "contracts/opl-framework/release-set-v2.schema.json"
    },
    "developer_mode_source_carrier_allowed": true,
    "developer_mode_source_carrier_must_enter_same_managed_package_status": true,
    "launch_requirements": {
      "package_status_launch_allowed": true,
      "runtime_source_status": "current",
      "runtime_source_operational_ready": true,
      "checkout_path_absolute": true,
      "expected_tree_sha256_equals_actual_tree_sha256": true,
      "workspace_scope_activation_attempted_for_installed_package": true
    },
    "use_binding_surface_kind": "opl_agent_package_use_binding.v1",
    "moving_pointer_is_install_truth": false,
    "origin_main_is_implicit_launch_target": false,
    "dirty_or_diverged_development_checkout_repair_in_action_runtime": false,
    "failure_policy": "fail_closed_before_handler_or_stage_launch"
  },
  "domain_pack_action_abi": {
    "catalog_ref": "contracts/action_catalog.json",
    "catalog_version": "family-action-catalog.v2",
    "handler_registry_ref": "contracts/domain_handler_registry.json",
    "handler_registry_version": "domain-handler-registry.v1",
    "catalog_and_registry_are_closed_objects": true,
    "execution_binding_union": [
      {
        "kind": "handler_ref",
        "required_shape": {
          "kind": "handler_ref",
          "handler_ref": "handler:<handler_id>"
        }
      },
      {
        "kind": "stage_binding",
        "required_shape": {
          "kind": "stage_binding",
          "stage_manifest_ref": "agent/stages/manifest.json"
        }
      }
    ],
    "handler_binding_union": [
      "typescript_export",
      "python_callable"
    ],
    "input_schema_validation_before_launch": true,
    "handler_output_schema_validation_before_success": true,
    "stage_output_schema_is_expected_domain_output_contract_not_launch_receipt_schema": true,
    "handler_refs_must_resolve_before_launch": true,
    "stage_manifest_must_compile_before_launch": true
  },
  "handler_execution": {
    "host_owner": "runway",
    "supported_bindings": [
      "typescript_export",
      "python_callable"
    ],
    "current_runtime_kinds": [
      "node_permission_model",
      "python_audit_hook"
    ],
    "current_sandbox_kind": "macos_sandbox_exec",
    "sandbox_required": true,
    "network_allowed": false,
    "filesystem_write_allowed": false,
    "subprocess_allowed_for_python_handler": false,
    "managed_checkout_and_workspace_read_only_access": true,
    "stdout_contract": "exactly_one_canonical_json_value",
    "timeout_fail_closed": true,
    "completed_status_means": "handler_process_and_schema_validation_completed",
    "completed_status_is_domain_ready": false
  },
  "stage_execution": {
    "host_owner": "runway",
    "provider": "temporal",
    "controller": "StageRun",
    "request_persisted_before_launch": true,
    "request_sha256_bound_as_source_fingerprint": true,
    "request_ref_bound_as_checkpoint_ref": true,
    "request_ref_and_sha256_bound_as_input_artifact": true,
    "stage_run_invocation_id_source": "domain_id_plus_entry_stage_plus_action_id_plus_run_id_plus_action_run_ref",
    "same_action_run_replay_returns_same_stage_run": true,
    "same_action_run_replay_uses_durable_launch_registry": true,
    "concurrent_action_run_output_policy": "first_published_exact_bytes_are_canonical_and_all_callers_read_back_the_winner",
    "same_action_run_provider_start_rpc_delivery": "at_least_once_when_starting_has_unknown_success",
    "same_action_run_temporal_execution_count": 1,
    "later_action_run_creates_new_stage_run": true,
    "stage_run_spec_sha256_binds_managed_package_closure_and_exact_request": true,
    "stage_run_spec_sha256_binds_prompt_rubric_policy_source_checkpoint_and_manifest_bytes": true,
    "root_package_content_digest_required": true,
    "exact_stage_run_input_registered_before_temporal_start": true,
    "durable_launch_registry": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_run_launches",
    "same_invocation_different_spec_fails_closed": true,
    "pre_and_post_start_crash_recovery_required": true,
    "stage_manifest_and_entry_stage_are_domain_declared": true,
    "launch_statuses": [
      "started",
      "blocked"
    ],
    "started_means": "temporal_stage_run_start_receipt_created",
    "started_is_domain_completion": false,
    "post_launch_query_is_observation_only": true,
    "post_launch_query_failure_changes_started_to_failed": false,
    "launch_receipt_is_domain_output": false,
    "provider_completion_is_domain_ready": false
  },
  "exact_byte_persistence": {
    "owner_module": "workspace",
    "workspace_relative_root": "control/opl/action_runs",
    "files": [
      "identity.json",
      "request.json",
      "output.json"
    ],
    "canonical_request_bytes": true,
    "handler_output_bytes_equal_validated_stdout_bytes": true,
    "stage_output_bytes_equal_canonical_launch_receipt_bytes": true,
    "sha256_and_byte_size_recorded": true,
    "atomic_publish_and_fsync_required": true,
    "symbolic_link_or_workspace_escape_forbidden": true,
    "same_run_identity_same_bytes_is_idempotent": true,
    "same_run_identity_conflicting_bytes_fail_closed": true
  },
  "refs_only_ledger": {
    "owner_module": "ledger",
    "surface_kind": "opl_standard_agent_action_run_ledger_entry",
    "version": "opl-standard-agent-action-run-ledger.v1",
    "event_type": "standard_agent_action_run_recorded",
    "statuses": [
      "started",
      "completed",
      "blocked",
      "failed"
    ],
    "timestamp_fields": [
      "started_at",
      "recorded_at"
    ],
    "stored_fields": [
      "run_id",
      "domain_id",
      "action_id",
      "binding_ref",
      "status",
      "input.ref",
      "input.sha256",
      "input.byte_size",
      "output.ref",
      "output.sha256",
      "output.byte_size"
    ],
    "contains_request_or_output_body": false,
    "started_is_terminal_domain_completion": false
  },
  "retired_private_control_plane_fields": [
    "entry_command_template",
    "manifest_command_template",
    "runtime.dispatch_command",
    "source_command",
    "domain_handler_command_env_projection",
    "per_agent_scheduler",
    "per_agent_queue",
    "per_agent_session_store",
    "per_agent_lifecycle_store",
    "per_agent_workbench"
  ],
  "authority_boundary": {
    "opl_can_host_transport_and_schema_validation": true,
    "opl_can_persist_exact_request_and_output_bytes": true,
    "opl_can_record_refs_only_action_ledger": true,
    "opl_can_write_domain_truth": false,
    "opl_can_write_memory_body": false,
    "opl_can_mutate_domain_artifact_body": false,
    "opl_can_sign_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_satisfy_human_gate": false,
    "opl_can_claim_quality_or_export_ready": false,
    "opl_can_claim_domain_ready": false,
    "opl_can_claim_production_ready": false
  },
  "verification_refs": [
    "src/modules/runway/standard-agent-managed-checkout.ts",
    "src/modules/runway/standard-agent-action-runtime.ts",
    "src/modules/runway/family-runtime-stage-run-identity.ts",
    "src/modules/runway/family-runtime-stage-run-launch-registry.ts",
    "src/modules/runway/family-runtime-stage-run-launch.ts",
    "src/modules/runway/standard-agent-action-run-recorder.ts",
    "src/modules/runway/standard-agent-handler-sandbox.ts",
    "src/modules/workspace/standard-agent-action-output.ts",
    "src/modules/ledger/standard-agent-action-run-ledger.ts",
    "tests/src/standard-agent-hosted-action-runtime-contract.test.ts",
    "tests/src/standard-agent-action-runtime.test.ts",
    "tests/src/family-runtime-stage-run-launch.test.ts",
    "tests/src/standard-agent-action-output.test.ts"
  ]
}
