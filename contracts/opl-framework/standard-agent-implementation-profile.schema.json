{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/standard-agent-implementation-profile.schema.json",
  "title": "OPL Standard Domain Agent Implementation Profile",
  "type": "object",
  "required": [
    "profile_id",
    "agent_identity",
    "pack_formats",
    "helpers",
    "generated_surfaces_owner"
  ],
  "properties": {
    "profile_id": { "const": "opl.standard_domain_agent.v1" },
    "agent_identity": { "const": "declarative_standard_agent_pack" },
    "pack_formats": { "const": ["markdown", "json"] },
    "helpers": { "$ref": "#/$defs/helpers" },
    "generated_surfaces_owner": { "const": "one-person-lab" }
  },
  "additionalProperties": false,
  "$defs": {
    "helpers": {
      "type": "object",
      "required": ["optional", "entries", "language_is_identity", "rust_policy"],
      "properties": {
        "optional": { "const": true },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/helper" }
        },
        "language_is_identity": { "const": false },
        "rust_policy": { "const": "framework_hot_path_only" }
      },
      "additionalProperties": false
    },
    "helper": {
      "type": "object",
      "required": ["language", "role", "source_roots"],
      "properties": {
        "language": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "not": { "const": "rust" }
        },
        "role": {
          "enum": ["authority_function", "domain_helper", "native_helper"]
        },
        "source_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+/$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
