{
  "surface_kind": "opl_agent_workspace_norm_contract",
  "version": "agent-workspace-norm.v1",
  "norm_id": "opl.agent_workspace_norm.v1",
  "owner": "one-person-lab",
  "scope": "OPL-owned executable workspace norm for MAS, MAG, RCA, OMA, and future Foundry Agents",
  "machine_boundary": "This contract fixes the framework-owned workspace precondition, topology, registry, descriptor delegate, user inspection, and authority boundary. Domain agents keep domain truth, source/artifact/memory bodies, owner receipts, typed blockers, and quality/export verdicts.",
  "supported_agents": [
    "mas",
    "mag",
    "rca",
    "oma"
  ],
  "default_workspace_precondition": {
    "action_id": "opl_workspace_ensure",
    "command": "opl workspace ensure",
    "app_action_id": "workspace_ensure",
    "required_inputs": [
      "agent_id"
    ],
    "optional_inputs": [
      "workspace_path_or_workspace_root",
      "workspace_id",
      "project_id",
      "mode",
      "title",
      "dry_run",
      "force",
      "bind"
    ],
    "must_run_before_domain_task_when_no_active_binding": true,
    "reuse_active_binding_first": true,
    "initialize_missing_workspace": true,
    "append_missing_project_in_compatible_series_or_portfolio": true,
    "default_entry_for_agents": true
  },
  "explicit_initialization": {
    "command": "opl workspace init",
    "app_action_id": "workspace_initialize",
    "role": "explicit_initialization_or_operator_override",
    "default_entry_for_agents": false
  },
  "descriptor_delegates": {
    "mcp": {
      "tool_name": "opl_workspace_ensure",
      "execution": "delegate_to_opl_cli",
      "delegates_to_action_id": "opl_workspace_ensure",
      "descriptor_only": true,
      "public_runtime": false
    },
    "skill": {
      "intent": "ensure_opl_workspace",
      "command_contract_id": "opl_workspace_ensure",
      "delegates_to_action_id": "opl_workspace_ensure",
      "descriptor_only": true,
      "public_runtime": false
    },
    "openai": {
      "tool_name": "opl_workspace_ensure",
      "delegates_to_action_id": "opl_workspace_ensure",
      "descriptor_only": true,
      "public_runtime": false
    },
    "ai_sdk": {
      "tool_name": "oplWorkspaceEnsure",
      "delegates_to_action_id": "opl_workspace_ensure",
      "descriptor_only": true,
      "public_runtime": false
    }
  },
  "topology_contract": {
    "contract_ref": "contracts/opl-framework/workspace-topology-profile.schema.json",
    "profile_id": "opl.workspace_topology_profile.v1",
    "topology_model": [
      "workspace_group",
      "project_unit",
      "stage_artifact_unit",
      "owner_receipt_or_typed_blocker"
    ],
    "canonical_project_collection_role": "project_units",
    "canonical_project_unit_semantics": {
      "workspace_unit": "workspace_group",
      "project_collection_role": "project_units",
      "project_unit_kind": "project_unit",
      "stage_artifact_unit": "stage_artifact_unit",
      "owner_answer_unit": "owner_receipt_or_typed_blocker",
      "mas_studies_boundary": {
        "project_collection_path": "projects",
        "alias_role": "legacy_display_domain_alias",
        "canonical_role": "project_units",
        "canonical_project_unit_kind": "project_unit",
        "legacy_project_collection_path": "studies"
      }
    },
    "project_stage_outputs_root": "artifacts/stage_outputs",
    "stage_output_root_protocol": {
      "root": "artifacts/stage_outputs",
      "stage_folder_unit": "stage_artifact_unit",
      "stage_outputs_index_file": "stage_outputs_index.json",
      "current_stage_pointer_file": "current_stage.json",
      "stage_lifecycle_model": [
        "open",
        "active",
        "completed",
        "blocked",
        "superseded",
        "archived"
      ],
      "required_stage_folder_shape": [
        "inputs",
        "outputs",
        "review",
        "receipts",
        "handoff",
        "stage_manifest.json"
      ]
    },
    "default_project_collection_path": "projects",
    "workspace_modes": [
      "one_off",
      "series",
      "portfolio"
    ],
    "series_capable_one_off_skeleton": true,
    "legacy_project_collection_aliases": [
      "deliverables",
      "studies"
    ]
  },
  "domain_topology_profiles": {
    "mas": {
      "profile": "mas_portfolio",
      "workspace_mode": "portfolio",
      "project_kind": "study",
      "project_collection_path": "projects",
      "canonical_project_collection_role": "project_units",
      "project_collection_alias_role": "legacy_display_alias",
      "project_collection_display_label": "studies",
      "project_semantic_aliases": [
        "study",
        "studies"
      ],
      "user_inspection_roots": [
        "projects/<project-id>/artifacts/stage_outputs"
      ],
      "shared_resource_roots": [
        "data",
        "literature",
        "memory",
        "shared/sources"
      ],
      "legacy_project_collection_aliases": [
        "studies"
      ]
    },
    "mag": {
      "profile": "one_off",
      "workspace_mode": "one_off",
      "project_kind": "grant_project",
      "project_collection_path": "projects",
      "canonical_project_collection_role": "project_units",
      "project_collection_alias_role": "legacy_display_alias",
      "project_collection_display_label": "deliverables",
      "project_semantic_aliases": [
        "grant_project",
        "deliverable"
      ],
      "user_inspection_roots": [
        "projects/<project-id>/artifacts/stage_outputs"
      ],
      "shared_resource_roots": [
        "shared/sources",
        "shared/memory",
        "shared/style_system"
      ],
      "legacy_project_collection_aliases": [
        "deliverables"
      ]
    },
    "rca": {
      "profile": "rca_series",
      "workspace_mode": "series",
      "project_kind": "slide_deck",
      "project_collection_path": "projects",
      "canonical_project_collection_role": "project_units",
      "project_collection_alias_role": "legacy_display_alias",
      "project_collection_display_label": "deliverables",
      "project_semantic_aliases": [
        "slide_deck",
        "deck",
        "deliverable"
      ],
      "user_inspection_roots": [
        "projects/<project-id>/artifacts/stage_outputs"
      ],
      "shared_resource_roots": [
        "shared/sources",
        "shared/brand",
        "shared/visual_memory",
        "shared/style_system",
        "shared/material_inventory"
      ],
      "legacy_project_collection_aliases": [
        "deliverables"
      ]
    },
    "oma": {
      "profile": "one_off",
      "workspace_mode": "one_off",
      "project_kind": "agent_capability",
      "project_collection_path": "projects",
      "canonical_project_collection_role": "project_units",
      "project_collection_alias_role": "legacy_display_alias",
      "project_collection_display_label": "deliverables",
      "project_semantic_aliases": [
        "agent_capability",
        "deliverable"
      ],
      "user_inspection_roots": [
        "projects/<project-id>/artifacts/stage_outputs"
      ],
      "shared_resource_roots": [
        "shared/sources",
        "shared/memory",
        "shared/style_system"
      ],
      "legacy_project_collection_aliases": [
        "deliverables"
      ]
    }
  },
  "user_inspection": {
    "ordinary_user_default_surface": "workspace_local_project_stage_outputs",
    "project_stage_outputs_pattern": "<project-root>/artifacts/stage_outputs/<stage-id>/",
    "workspace_index_file": "workspace_index.json",
    "workspace_config_file": "workspace.yaml",
    "workspace_inspection_file": "workspace_inspection.json",
    "workspace_resource_inventory_file": "workspace_resource_inventory.json",
    "stage_outputs_index_file": "stage_outputs_index.json",
    "current_stage_pointer_file": "current_stage.json",
    "canonical_user_inspection_roots": [
      "<project-root>/artifacts/stage_outputs",
      "<project-root>/artifacts/stage_outputs/<stage-id>/inputs",
      "<project-root>/artifacts/stage_outputs/<stage-id>/outputs",
      "<project-root>/artifacts/stage_outputs/<stage-id>/review",
      "<project-root>/artifacts/stage_outputs/<stage-id>/receipts",
      "<project-root>/artifacts/stage_outputs/<stage-id>/handoff",
      "<project-root>/artifacts/stage_outputs/<stage-id>/stage_manifest.json"
    ],
    "runtime_state_is_default_user_surface": false,
    "product_views_are_stage_outputs": false
  },
  "registry_policy": {
    "writes_opl_workspace_registry": true,
    "binding_owner": "one-person-lab",
    "domain_repo_can_write_opl_registry": false
  },
  "runtime_state_boundary": {
    "role": "provider_backing_provenance_restore_audit",
    "runtime_state_can_be_canonical_project_root": false,
    "runtime_state_can_close_stage": false,
    "runtime_state_can_replace_owner_receipt_or_typed_blocker": false
  },
  "authority_boundary": {
    "opl_can_define_topology_contract": true,
    "opl_can_project_workspace_refs": true,
    "opl_can_write_domain_truth": false,
    "opl_can_write_memory_body": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_create_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_authorize_quality_or_export": false,
    "runtime_state_counts_as_user_default_surface": false,
    "conformance_pass_counts_as_domain_ready": false
  },
  "conformance_policy": {
    "family_conformance_must_report_workspace_norm": true,
    "workspace_norm_pass_is_structural_only": true,
    "workspace_norm_pass_can_claim_domain_ready": false,
    "workspace_norm_pass_can_claim_artifact_or_quality_ready": false,
    "blocked_reasons": [
      "agent_workspace_norm_missing",
      "workspace_ensure_not_default_precondition",
      "workspace_ensure_descriptor_delegate_drift",
      "workspace_user_inspection_surface_drift",
      "workspace_runtime_state_boundary_drift",
      "workspace_authority_boundary_overclaim"
    ]
  }
}
