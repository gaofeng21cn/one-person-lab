{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/reviewer-input-snapshot-materialization-request.schema.json",
  "title": "OPL Reviewer Input Snapshot Materialization Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "generation_ref",
    "review_lane",
    "review_scope_sha256",
    "workspace_root",
    "members"
  ],
  "properties": {
    "surface_kind": { "const": "opl_reviewer_input_snapshot_materialization_request" },
    "schema_version": { "const": 1 },
    "generation_ref": { "type": "string", "minLength": 1 },
    "review_lane": {
      "enum": ["medical", "statistical", "reference", "display", "publication", "exact_byte_package"]
    },
    "review_scope_sha256": { "$ref": "#/$defs/sha256" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["member_id", "role", "source_ref", "sha256", "size_bytes"],
        "properties": {
          "member_id": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "source_ref": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^(?:sha256:)?[a-fA-F0-9]{64}$" }
  }
}
