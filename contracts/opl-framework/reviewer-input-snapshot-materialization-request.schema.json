{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/reviewer-input-snapshot-materialization-request.schema.json",
  "title": "OPL Reviewer Input Snapshot Materialization Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "owner_authority_ref",
    "producer_attempt_ref",
    "execution_content_binding_sha256",
    "workspace_root",
    "members"
  ],
  "properties": {
    "surface_kind": { "const": "opl_reviewer_input_snapshot_materialization_request" },
    "schema_version": { "const": 2 },
    "owner_authority_ref": { "$ref": "#/$defs/exact_ref" },
    "producer_attempt_ref": {
      "type": "string",
      "pattern": "^opl://stage_attempts/.+$"
    },
    "execution_content_binding_sha256": { "$ref": "#/$defs/sha256" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/member" }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "size_bytes", "sha256"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["member_id", "source_ref", "sha256", "size_bytes"],
      "properties": {
        "member_id": { "type": "string", "minLength": 1 },
        "source_ref": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
