{
  "contract_kind": "opl_cli_command_registry.v1",
  "surface_kind": "opl_cli_command_registry",
  "owner": "one-person-lab",
  "purpose": "Freeze protected CLI command metadata so parser adapters, option shapes, output schemas and authority boundaries are visible from the command surface instead of staying implicit in ad-hoc parsers.",
  "state": "active_contract",
  "machine_boundary": "This registry describes command metadata and output schemas. It does not execute commands, write domain truth, create owner receipts, create typed blockers, or claim domain, artifact, App, production, release, or L5 readiness.",
  "protected_command_prefixes": [
    "connect pubmed",
    "status"
  ],
  "required_command_ids": [
    "connect pubmed search",
    "connect install",
    "connect update",
    "connect reinstall",
    "connect remove",
    "status workspace",
    "status runtime",
    "status dashboard"
  ],
  "commands": {
    "connect_install": {
      "command_id": "connect install",
      "owner": "OPL Connect",
      "parser_adapter": "node_util_parse_args",
      "options": [
        {
          "name": "module",
          "flag": "--module",
          "value_kind": "string",
          "required": true
        }
      ],
      "output_schema": {
        "type": "object",
        "required": [
          "version",
          "module_action"
        ],
        "additionalProperties": true,
        "properties": {
          "version": {
            "const": "g2"
          },
          "module_action": {
            "type": "object",
            "required": [
              "surface_id",
              "action",
              "status",
              "module",
              "turnkey"
            ],
            "additionalProperties": true,
            "properties": {
              "surface_id": {
                "const": "opl_module_action"
              },
              "action": {
                "const": "install"
              },
              "status": {
                "const": "completed"
              },
              "module": {
                "type": "object",
                "required": [
                  "module_id"
                ],
                "additionalProperties": true
              },
              "turnkey": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "authority_boundary": {
        "can_write_domain_truth": false,
        "can_create_owner_receipt": false,
        "can_create_typed_blocker": false,
        "can_claim_domain_ready": false,
        "can_claim_production_ready": false
      }
    },
    "connect_update": {
      "command_id": "connect update",
