{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/opl-framework/release-bundle-checkpoint.schema.json",
  "title": "OPL Release Bundle Portable Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "checkpoint_digest",
    "bundle_digest",
    "checkpoint_stage",
    "tracks",
    "entries",
    "policy"
  ],
  "properties": {
    "surface_kind": { "const": "opl_release_bundle_checkpoint.v1" },
    "schema_ref": {
      "const": "contracts/opl-framework/release-bundle-checkpoint.schema.json"
    },
    "checkpoint_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "bundle_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "checkpoint_stage": {
      "enum": [
        "frozen",
        "standard_built",
        "standard_qualified",
        "full_built",
        "full_qualified"
      ]
    },
    "operation_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "append_full"],
      "properties": {
        "standard": {
          "anyOf": [
            {
              "allOf": [
                { "$ref": "#/$defs/operation_control" },
                {
                  "properties": {
                    "operation_kind": { "const": "standard" },
                    "track": { "const": "standard" }
                  }
                }
              ]
            },
            { "type": "null" }
          ]
        },
        "append_full": {
          "anyOf": [
            {
              "allOf": [
                { "$ref": "#/$defs/operation_control" },
                {
                  "properties": {
                    "operation_kind": { "const": "append_full" },
                    "track": { "const": "full" }
                  }
                }
              ]
            },
            { "type": "null" }
          ]
        }
      }
    },
    "active_unknown_markers": {
      "type": "array",
      "maxItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/unknown_outcome_marker" }
    },
    "tracks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "full"],
      "properties": {
        "standard": { "$ref": "#/$defs/track" },
        "full": { "$ref": "#/$defs/track" }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/entry" }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "portable_between_executors",
        "import_never_rebuilds",
        "publish_state_requires_fresh_remote_readback"
      ],
      "properties": {
        "portable_between_executors": { "const": true },
        "import_never_rebuilds": { "const": true },
        "publish_state_requires_fresh_remote_readback": { "const": true }
      }
    }
  },
  "$defs": {
    "operation_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_ref",
        "control_digest",
        "bundle_digest",
        "operation_id",
        "operation_kind",
        "track",
        "operation_started_at",
        "operation_deadline_at"
      ],
      "properties": {
        "surface_kind": { "const": "opl_release_bundle_operation_control.v1" },
        "schema_ref": {
          "const": "contracts/opl-framework/release-bundle-operation-control.schema.json"
        },
        "control_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "bundle_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "operation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "operation_kind": { "enum": ["standard", "append_full"] },
        "track": { "enum": ["standard", "full"] },
        "operation_started_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "operation_deadline_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        }
      }
    },
    "unknown_outcome_marker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_kind",
        "schema_ref",
        "marker_digest",
        "bundle_digest",
        "operation_id",
        "operation_kind",
        "stage_operation",
        "publication_scope",
        "track",
        "remote_target",
        "prior_mutation_attempt_id",
        "executor"
      ],
      "properties": {
        "surface_kind": { "const": "opl_release_bundle_unknown_outcome.v1" },
        "schema_ref": {
          "const": "contracts/opl-framework/release-bundle-unknown-outcome.schema.json"
        },
        "marker_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "bundle_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "operation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "operation_kind": { "enum": ["standard", "append_full"] },
        "stage_operation": { "enum": ["build", "publish"] },
        "publication_scope": {
          "type": ["string", "null"],
          "enum": ["track_assets", "external_target", null]
        },
        "track": { "enum": ["standard", "full"] },
        "remote_target": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1024,
          "pattern": "^[a-z][a-z0-9+.-]{0,31}:[A-Za-z0-9][A-Za-z0-9._~:/?#@!$&'()*+,;=%-]*$"
        },
        "prior_mutation_attempt_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "executor": { "enum": ["local", "remote"] }
      },
      "allOf": [
        {
          "if": { "properties": { "stage_operation": { "const": "build" } } },
          "then": { "properties": { "publication_scope": { "type": "null" } } },
          "else": {
            "properties": {
              "publication_scope": { "enum": ["track_assets", "external_target"] }
            }
          }
        }
      ]
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "built",
        "verified",
        "asset_names",
        "qualification_receipt_path",
        "qualification_receipt_sha256"
      ],
      "properties": {
        "built": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "asset_names": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 255 }
        },
        "qualification_receipt_path": { "type": ["string", "null"] },
        "qualification_receipt_sha256": {
          "type": ["string", "null"],
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "track",
        "asset_name",
        "size_bytes",
        "sha256"
      ],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "role": {
          "enum": ["bundle", "prepared_notes", "track_asset", "qualification_receipt"]
        },
        "track": { "type": ["string", "null"], "enum": ["standard", "full", null] },
        "asset_name": { "type": ["string", "null"], "maxLength": 255 },
        "size_bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    }
  }
}
