{
  "contract_kind": "opl_stage_transition_authority_contract.v1",
  "surface_kind": "opl_stage_transition_authority_contract",
  "owner": "one-person-lab",
  "purpose": "Freeze the OPL-owned single-writer Stage transition authority: modules may submit transition intents, observations, owner answers, typed blockers, or human-gate receipts, but only the Stage Transition Authority may derive Stage current pointer, StageRun terminal state, and current_owner_delta.",
  "state": "active_contract",
  "machine_boundary": {
    "opl_owns": {
      "stage_transition_authority": true,
      "append_only_authority_event_log": true,
      "stage_current_pointer_derivation": true,
      "stage_run_terminal_state_derivation": true,
      "current_owner_delta_publication": true,
      "read_model_rebuild": true
    },
    "domain_agents_own": {
      "domain_truth": true,
      "stage_semantics": true,
      "owner_receipt_signing": true,
      "typed_blocker_creation": true,
      "quality_or_export_verdict": true,
      "artifact_body": true,
      "memory_body": true
    },
    "app_owns": {
      "human_gate_decision_receipt_transport": true,
      "operator_intervention_payload": true,
      "stage_transition_authority": false,
      "stage_current_pointer": false,
      "stage_run_terminal_state": false,
      "domain_verdict": false
    },
    "provider_owns": {
      "durable_execution_history": true,
      "attempt_liveness_observation": true,
      "stage_transition_authority": false,
      "stage_closeout": false,
      "domain_ready": false
    }
  },
  "single_writer_policy": {
    "stage_current_pointer_writer": "stage_transition_authority",
    "stage_run_terminal_state_writer": "stage_transition_authority",
    "current_owner_delta_publisher": "stage_transition_authority",
    "authority_event_log_policy": "append_only_events_folded_by_stage_run_generation_and_idempotency",
    "parallel_intent_policy": "many_producers_one_authority_decision",
    "duplicate_intent_policy": "dedupe_by_stage_run_generation_idempotency_key",
    "stale_generation_policy": "reject_for_default_transition_keep_as_audit_observation",
    "old_controller_decision_policy": "cannot_close_current_stage_without_current_closeout_binding",
    "read_model_policy": "rebuildable_projection_not_truth_source"
  },
  "intent_producers": [
    {
      "producer_kind": "domain_agent",
      "allowed_intent_kinds": [
        "domain_owner_answer",
        "typed_blocker",
        "route_recommendation"
      ],
      "may_sign_owner_receipt": true,
      "may_create_typed_blocker": true,
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false
    },
    {
      "producer_kind": "human_operator",
      "allowed_intent_kinds": [
        "human_gate_decision"
      ],
      "may_sign_owner_receipt": false,
      "may_create_typed_blocker": false,
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false
    },
    {
      "producer_kind": "one_person_lab_app",
      "allowed_intent_kinds": [
        "human_gate_decision",
        "read_model_observation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false,
      "may_write_domain_truth": false
    },
    {
      "producer_kind": "runtime_provider",
      "allowed_intent_kinds": [
        "provider_observation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false,
      "provider_completion_counts_as_stage_transition": false
    },
    {
      "producer_kind": "agent_lab",
      "allowed_intent_kinds": [
        "agent_lab_observation",
        "route_recommendation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false,
      "may_authorize_domain_ready": false
    },
    {
      "producer_kind": "evidence_vault",
      "allowed_intent_kinds": [
        "evidence_observation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false
    },
    {
      "producer_kind": "read_model",
      "allowed_intent_kinds": [
        "read_model_observation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false
    },
    {
      "producer_kind": "worklist",
      "allowed_intent_kinds": [
        "worklist_observation"
      ],
      "may_write_stage_current_pointer": false,
      "may_write_stage_run_terminal_state": false,
      "may_publish_current_owner_delta": false
    }
  ],
  "transition_capable_intents": [
    "domain_owner_answer",
    "typed_blocker",
    "human_gate_decision"
  ],
  "observation_only_intents": [
    "provider_observation",
    "read_model_observation",
    "worklist_observation",
    "agent_lab_observation",
    "evidence_observation",
    "route_recommendation"
  ],
  "required_identity_binding_fields": [
    "stage_run_id",
    "generation",
    "domain_id",
    "stage_id",
    "source_fingerprint",
    "idempotency_key",
    "stage_manifest_ref",
    "current_pointer_ref",
    "provider_attempt_ref",
    "attempt_lease_ref",
    "execution_authorization_decision_ref"
  ],
  "required_closeout_binding_fields": [
    "owner_answer_stage_run_id",
    "owner_answer_generation",
    "owner_answer_manifest_ref",
    "owner_answer_current_pointer_ref",
    "owner_answer_source_fingerprint",
    "owner_answer_idempotency_key"
  ],
  "authority_event_log": {
    "surface_kind": "opl_stage_transition_authority_event_log",
    "event_log_role": "append_only_refs_only_transition_authority_events",
    "event_kinds": [
      "transition_intent_accepted",
      "transition_intent_recorded",
      "transition_intent_rejected"
    ],
    "fold_keys": [
      "stage_run_id",
      "generation",
      "idempotency_key"
    ],
    "read_model_surface_kind": "opl_stage_transition_authority_read_model",
    "read_model_role": "single_writer_stage_transition_projection"
  },
  "decision_statuses": [
    "transition_accepted",
    "observation_recorded",
    "rejected"
  ],
  "forbidden_as_authority": [
    "provider completion",
    "read model refresh",
    "worklist count",
    "verified ledger",
    "file presence",
    "conformance passed",
    "agent lab candidate",
    "evidence vault event",
    "old controller decision",
    "stale typed blocker",
    "stale owner receipt"
  ],
  "authority_boundary": {
    "stage_transition_single_writer": true,
    "only_stage_transition_authority_can_write_stage_current_pointer": true,
    "only_stage_transition_authority_can_write_stage_run_terminal_state": true,
    "only_stage_transition_authority_can_publish_current_owner_delta": true,
    "intent_producer_can_write_stage_current_pointer": false,
    "intent_producer_can_write_stage_run_terminal_state": false,
    "intent_producer_can_publish_current_owner_delta": false,
    "provider_completion_counts_as_stage_transition": false,
    "read_model_update_counts_as_stage_transition": false,
    "worklist_update_counts_as_stage_transition": false,
    "evidence_event_counts_as_stage_transition": false,
    "agent_lab_output_counts_as_stage_transition": false,
    "opl_can_write_domain_truth": false,
    "opl_can_create_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_authorize_domain_ready": false,
    "opl_can_claim_production_ready": false
  }
}
