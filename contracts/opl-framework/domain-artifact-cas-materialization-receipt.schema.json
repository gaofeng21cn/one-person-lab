{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/domain-artifact-cas-materialization-receipt.schema.json",
  "title": "OPL Domain Artifact CAS Materialization Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "version",
    "capability_id",
    "status",
    "request_id",
    "request_sha256",
    "domain_id",
    "authorization_ref",
    "authority_receipt_ref",
    "satisfied_gate_ids",
    "domain_authority_result",
    "operations_sha256",
    "operations",
    "transaction",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_domain_artifact_cas_materialization_receipt"
    },
    "version": {
      "const": "opl-domain-artifact-cas-materialization-receipt.v1"
    },
    "capability_id": {
      "const": "opl_domain_artifact_cas_materialization.v1"
    },
    "status": {
      "enum": ["materialized", "already_materialized", "failed_rolled_back"]
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "request_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "domain_id": {
      "type": "string",
      "minLength": 1
    },
    "authorization_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_receipt_ref": {
      "type": "string",
      "minLength": 1
    },
    "satisfied_gate_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "domain_authority_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "action_id",
        "handler_ref",
        "hosted_runtime_binding_ref",
        "output_ref",
        "output_sha256"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "action_id": { "type": "string", "minLength": 1 },
        "handler_ref": { "type": "string", "minLength": 1 },
        "hosted_runtime_binding_ref": { "type": "string", "minLength": 1 },
        "output_ref": { "type": "string", "minLength": 1 },
        "output_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "operations_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_ref",
          "before_state",
          "after_sha256",
          "after_byte_size"
        ],
        "properties": {
          "target_ref": { "type": "string", "minLength": 1 },
          "before_state": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "sha256", "byte_size"],
                "properties": {
                  "kind": { "const": "existing_exact" },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "byte_size": { "type": "integer", "minimum": 1 }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind"],
                "properties": { "kind": { "const": "absent" } }
              }
            ]
          },
          "after_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "after_byte_size": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "transaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all_targets_preflighted_before_write",
        "all_targets_revalidated_before_switch",
        "rollback_on_failure",
        "durable_recovery_journal",
        "recovery_action",
        "visibility_model",
        "journal_must_be_absent_for_admission"
      ],
      "properties": {
        "all_targets_preflighted_before_write": { "const": true },
        "all_targets_revalidated_before_switch": { "const": true },
        "rollback_on_failure": { "const": true },
        "durable_recovery_journal": { "const": true },
        "visibility_model": { "const": "journaled_all_or_rollback_for_cooperating_opl_readers" },
        "journal_must_be_absent_for_admission": { "const": true },
        "single_use_request_binding_ref": { "type": "string", "minLength": 1 },
        "exact_request_replay_is_idempotent": { "const": true },
        "created_parent_directory_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "recovery_action": {
          "enum": [
            "none",
            "resumed_interrupted_transaction",
            "finalized_interrupted_transaction",
            "completed_receipt_reused",
            "rolled_back_after_failure"
          ]
        }
      }
    },
    "failure": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "rolled_back"],
          "properties": {
            "code": { "const": "domain_artifact_cas_materialization_failed" },
            "message": { "type": "string", "minLength": 1 },
            "rolled_back": { "const": true }
          }
        }
      ]
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opl_role",
        "domain_role",
        "opl_interprets_domain_semantics",
        "provider_completion_is_domain_truth",
        "receipt_is_domain_owner_receipt"
      ],
      "properties": {
        "opl_role": { "const": "exact_byte_cas_transport_and_receipt" },
        "domain_role": { "const": "mutation_semantics_and_authorization_owner" },
        "opl_interprets_domain_semantics": { "const": false },
        "provider_completion_is_domain_truth": { "const": false },
        "receipt_is_domain_owner_receipt": { "const": false }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "failed_rolled_back" } } },
      "then": {
        "required": ["failure"],
        "properties": {
          "failure": { "type": "object" },
          "transaction": {
            "required": [
              "single_use_request_binding_ref",
              "exact_request_replay_is_idempotent",
              "created_parent_directory_refs"
            ]
          }
        }
      },
      "else": { "properties": { "failure": { "type": "null" } } }
    }
  ]
}
