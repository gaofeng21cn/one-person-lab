{
  "contract_kind": "opl_agent_platform_surface_ownership_contract.v1",
  "surface_kind": "opl_agent_platform_surface_ownership_contract",
  "owner": "one-person-lab",
  "scope": "Framework-owned classification of generic platform surfaces that standard domain agents must not own privately.",
  "command": "opl agents platform-surfaces [--repo-dir <path> ...] [--agent <id>=<path> ...] [--family-defaults]",
  "default_caller_readiness_command": "opl agents default-callers [--repo-dir <path> ...] [--agent <id>=<path> ...] [--family-defaults]",
  "framework_owned_generic_subdomains": [
    "generated_cli_mcp_skill_product_shell",
    "generated_sidecar_dispatch_shell",
    "generated_action_metadata_command_registration_shell",
    "status_read_model_and_workbench_shell",
    "workspace_source_artifact_memory_locator",
    "stage_attempt_queue_retry_dead_letter"
  ],
  "hard_gate_sources": {
    "source_policy": "machine_contracts_receipts_and_proofs_only",
    "required_machine_sources": [
      "contracts/functional_privatization_audit.json#authority_boundary",
      "contracts/functional_privatization_audit.json#/physical_source_morphology_policy/authority_boundary",
      "contracts/physical_source_morphology_policy.json#authority_boundary",
      "domain_owner_receipt_ref",
      "typed_blocker_ref",
      "no_forbidden_write_proof_ref"
    ],
    "compatibility_machine_sources": [
      "contracts/private_functional_surface_policy.json#authority_boundary"
    ],
    "blocks_standard_agent_admission": true,
    "prose_path_filename_or_markdown_text_can_block_admission": false
  },
  "advisory_diagnostics": {
    "source_policy": "filename_markdown_prose_and_contract_text_scans_are_operator_diagnostics_only",
    "reported_fields": [
      "advisory_diagnostic_refs",
      "observed_source_refs"
    ],
    "observed_source_refs_role": "compatibility_alias_for_advisory_diagnostic_refs",
    "can_block_standard_agent_admission": false,
    "can_claim_domain_ready": false,
    "can_claim_production_ready": false
  },
  "domain_agent_retained_authority": [
    "domain_truth",
    "quality_or_export_or_publication_or_visual_verdict",
    "artifact_body_and_mutation_authority",
    "source_readiness_verdict",
    "memory_body_accept_reject",
    "owner_receipt_signing",
    "typed_blocker_materialization",
    "domain_specific_policy_rubric_or_quality_gate"
  ],
  "migration_gate": {
    "replacement_parity_required": true,
    "active_caller_cutover_required": true,
    "no_active_caller_proof_required": true,
    "domain_owner_receipt_or_typed_blocker_required": true,
    "no_forbidden_write_proof_required": true,
    "tombstone_or_provenance_ref_required": true,
    "retirement_guard_target_classes": [
      "legacy_reconcile_compensation_path",
      "legacy_materialize_compensation_path",
      "legacy_dispatch_compensation_path",
      "retained_domain_wrapper"
    ],
    "mandatory_gate_ids": [
      "replacement_parity",
      "no_active_caller_proof",
      "domain_owner_receipt_or_typed_blocker",
      "no_forbidden_write_proof",
      "tombstone_or_provenance_ref"
    ],
    "default_caller_readiness_surface": "opl_agent_generated_default_caller_readiness_report",
    "default_caller_deletion_evidence_worklist_surface": "opl_default_caller_surface_deletion_evidence_worklist",
    "runtime_evidence_worklist_projection_surface": "opl_default_caller_deletion_evidence_refs",
    "runtime_evidence_worklist_claim_scope": "default_caller_deletion_evidence",
    "default_caller_readiness_is_structural_replacement_evidence_only": true,
    "generated_or_hosted_active_caller_target_proof_observes_no_active_caller_proof": true,
    "no_active_caller_proof_from_generated_target_remains_refs_only": true,
    "conformance_readiness_and_refs_only_receipts_authorize_physical_delete": false,
    "per_surface_deletion_evidence_worklist_required": true,
    "deletion_evidence_worklist_count_semantics": "active_open_surface_retirement_gate_count_only",
    "surface_retirement_gate_count_semantics": "all_generated_or_hosted_default_caller_retirement_gates_including_closed_owner_decision_refs",
    "closed_surface_retirement_gate_count_semantics": "retirement_gates_with_owner_decision_ref_observed_and_no_active_deletion_worklist_item",
    "closed_surface_detail_default_payload_policy": "closed_retirement_gate_details_are_omitted_from_default_payload_use_counts_and_tombstone_refs",
    "zero_missing_deletion_evidence_is_not_delete_ready": true,
    "observed_deletion_evidence_refs_are_refs_only_inputs": true,
    "owner_decision_after_structural_prerequisites_observed_required": true,
    "next_required_owner_action_after_structural_prerequisites_observed": "domain_owner_choose_delete_authorize_keep_or_typed_blocker",
    "accepted_refs_only_result_shapes_after_structural_prerequisites_observed": [
      "physical_delete_authorization_ref",
      "keep_as_authority_adapter_ref",
      "typed_blocker_ref"
    ],
    "owner_decision_closeout_readout_fields": [
      "owner_decision_result_shape",
      "owner_decision_closeout_status",
      "no_further_opl_default_caller_delete_work",
      "next_opl_default_caller_delete_action"
    ],
    "no_further_opl_default_caller_delete_work_is_not_physical_delete_authority": true,
    "deletion_evidence_requirements_are_completion_claims": false,
    "not_authorized_claims": [
      "domain_repo_physical_delete_authorization",
      "default_caller_delete_ready",
      "domain_ready",
      "production_ready",
      "quality_verdict",
      "artifact_authority"
    ],
    "runtime_evidence_worklist_can_sign_domain_owner_receipt": false,
    "default_caller_readiness_can_authorize_physical_delete": false,
    "descriptor_ready_is_not_production_ready": true
  },
  "authority_boundary": {
    "opl_owns_generic_platform_surfaces": true,
    "opl_can_write_domain_truth": false,
    "opl_can_write_memory_body": false,
    "opl_can_authorize_quality_or_export": false,
    "opl_can_mutate_domain_artifacts": false,
    "report_can_claim_domain_ready": false,
    "report_can_claim_production_ready": false
  }
}
