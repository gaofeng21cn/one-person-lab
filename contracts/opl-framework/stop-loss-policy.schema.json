{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/stop-loss-policy.schema.json",
  "schema_id": "opl.stop_loss_policy.v1",
  "surface_kind": "opl_stop_loss_policy_schema",
  "owner": "one-person-lab",
  "purpose": "Define OPL stop-loss rules for repeated receipt-only, platform-repair-only, read-model-reconcile-only, stale-route, and similar non-progress lineages.",
  "state": "active_contract",
  "machine_boundary": "OPL may freeze default launch for a repeated lineage and accept only a fresh owner delta, stable typed blocker, human decision, or provider hard-gate clearance; it does not discard domain truth or synthesize fallback verdicts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "schema_version",
    "policy_id",
    "lineage_ref",
    "freeze_state",
    "release_conditions",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_stop_loss_policy"
    },
    "schema_version": {
      "const": "stop-loss-policy.v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "lineage_ref": {
      "$ref": "#/$defs/ref"
    },
    "freeze_state": {
      "type": "string",
      "enum": [
        "clear",
        "watch",
        "frozen",
        "released"
      ]
    },
    "release_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "fresh_owner_delta",
          "stable_typed_blocker",
          "human_decision",
          "provider_hard_gate_clearance",
          "manual_owner_release"
        ]
      }
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "opl_can_freeze_default_launch",
        "opl_can_delete_domain_attempts",
        "opl_can_ignore_fresh_owner_delta",
        "opl_can_ignore_stable_typed_blocker",
        "opl_can_synthesize_fallback_verdict",
        "opl_can_authorize_domain_ready",
        "opl_can_authorize_quality_verdict"
      ],
      "properties": {
        "opl_can_freeze_default_launch": {
          "const": true
        },
        "opl_can_delete_domain_attempts": {
          "const": false
        },
        "opl_can_ignore_fresh_owner_delta": {
          "const": false
        },
        "opl_can_ignore_stable_typed_blocker": {
          "const": false
        },
        "opl_can_synthesize_fallback_verdict": {
          "const": false
        },
        "opl_can_authorize_domain_ready": {
          "const": false
        },
        "opl_can_authorize_quality_verdict": {
          "const": false
        }
      }
    }
  }
}
