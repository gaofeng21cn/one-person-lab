{
  "contract_kind": "opl_family_product_operator_projection.v1",
  "owner": "one-person-lab",
  "scope": "operator-facing aggregation of family runtime, quality, and incident source refs",
  "source_contracts": [
    "contracts/opl-framework/family-runtime-attempt-contract.json",
    "contracts/opl-framework/stage-quality-cycle-contract.json",
    "contracts/opl-framework/family-domain-quality-projection-contract.json",
    "contracts/opl-framework/family-incident-learning-loop.json"
  ],
  "stage_quality_cycle_visibility": {
    "default_user_fields": [
      "current_stage",
      "stage_artifact",
      "completed_or_quality_debt",
      "next_stage"
    ],
    "developer_operator_drilldown_only": [
      "attempt_role",
      "quality_round_index",
      "execution_session_ref",
      "artifact_identity_receipt_refs",
      "review_receipts",
      "finding_lineage",
      "repair_lineage",
      "quality_debt_refs",
      "token_and_cost"
    ],
    "attempt_must_not_be_presented_as_sub_stage": true,
    "completed_with_quality_debt_blocks_quality_export_publication_submission_ready_claims": true
  },
  "required_projection_fields": [
    "domain_id",
    "active_item",
    "attempt_summary",
    "quality_summary",
    "incident_summary",
    "current_blocker",
    "auto_continue",
    "next_surface_ref",
    "human_gate_reason",
    "source_refs",
    "freshness",
    "owner_split",
    "control_loop_summary",
    "effective_current_context",
    "family_stall_lineage",
    "usage_projection",
    "resource_pressure",
    "observability_export"
  ],
  "runtime_observability_export": {
    "command": "opl runtime observability-export [--format json|openmetrics|collector-config-json]",
    "metrics_endpoint_command": "opl runtime observability-endpoint [--host <host>] [--port <port>] [--metrics-path <path>]",
    "formats": [
      "json",
      "openmetrics",
      "collector-config-json",
      "http_openmetrics_endpoint"
    ],
    "source_surfaces": [
      "opl_runtime_ledger",
      "temporal_provider_proof_receipts",
      "runtime_tray_snapshot",
      "stage_attempt_workbench",
      "domain_owned_projection_refs"
    ],
    "authority": "read_only_non_authoritative"
  },
  "app_runtime_boundary": {
    "framework_role": "gui_ready_state_action_producer_only",
    "default_state_command": "opl app state --profile fast --json",
    "default_operator_payload": "current_owner_delta",
    "full_state_command": "opl app state --profile full --json",
    "action_command": "opl app action execute --action <id> [--payload <json>] [--dry-run] --json",
    "full_runtime_drilldown_exception": "opl runtime app-operator-drilldown --detail full --json",
    "default_read_surface_policy": {
      "default_projection": "opl_current_owner_delta",
      "first_screen_answers": [
        "current_owner_delta",
        "next_safe_action_or_none",
        "current_owner",
        "required_delta",
        "accepted_return_shapes",
        "ordinary_progress_spine",
        "progress_delta_receipt",
        "artifact_tier_policy",
        "audit_sidecar_policy",
        "readiness_false_flags",
        "hard_gate",
        "latest_owner_answer_ref"
      ],
      "diagnostic_only_answers": [
        "count_summary",
        "audit_next_safe_action_or_none",
        "full_detail_refs"
      ],
      "full_detail_policy": "explicit_full_detail_or_lazy_diagnostic_only",
      "raw_refs_policy": "raw_refs_require_explicit_full_detail",
      "projection_cache_currentness_policy": {
        "cache_surface_kind": "opl_current_owner_delta_read_model_projection_cache",
        "cache_role": "non_authoritative_fast_projection_cache_only",
        "ordinary_read_requires_currentness_identity": true,
        "currentness_identity_fields": [
          "source_fingerprint",
          "work_unit_fingerprint",
          "truth_epoch",
          "runtime_health_epoch",
          "source_eval_id"
        ],
        "accepted_source_surfaces": [
          "framework_readiness"
        ],
        "stale_cache_result": "cache_miss_return_null",
        "legacy_cache_without_currentness_identity_result": "cache_miss_return_null",
        "stale_projection_allowed_role": "explicit_drilldown_or_audit_only",
        "ordinary_fresh_sources": [
          "current_execution_envelope",
          "current_owner_delta",
          "owner_route_currentness_basis"
        ],
        "cache_can_generate_default_next_action_when_stale": false
      },
      "full_detail_auto_poll": false,
      "shell_must_not_derive_layout_from_raw_runtime_projection": true,
      "shell_must_not_use_full_drilldown_as_normal_state": true
    },
    "state_owner": "one-person-lab",
    "gui_product_truth_owner": "one-person-lab-app",
    "gui_product_contract_owner": "one-person-lab-app",
    "app_release_owner": "one-person-lab-app",
    "shell_role": "implementation_adapter_only",
    "active_shell_implementation_carrier": "opl-aion-shell",
    "ordinary_app_product_shape": "codex_app_wrapper",
    "ordinary_app_fixed_executor": "codex_cli",
    "ordinary_app_builtin_foundry_entries": [
      "mas",
      "mag",
      "rca"
    ],
    "ordinary_app_exposes_shell_backend_selector": false,
    "ordinary_app_exposes_non_default_executor_selector": false,
    "rules": [
      "GUI pages read default OPL runtime state from the app state command instead of page-local command composition.",
      "GUI mutations go through the app action command.",
      "Full operator/status drilldown may call the explicit runtime drilldown exception on demand, but shell adapters must not use it as normal GUI page state.",
      "App state/action projections do not move domain truth, quality verdicts, artifact authority, or runtime provider ownership into the GUI shell.",
      "The ordinary App product is a Codex App wrapper with Codex CLI fixed as the concrete executor and MAS/MAG/RCA presented as built-in Foundry task entries.",
      "Shell backend or non-default executor selectors may appear only in explicit developer/operator diagnostics or stage-level bindings, not in the ordinary user product surface."
    ]
  },
  "external_stability_learning_policy": {
    "allowed_learning": [
      "control_loop_classification",
      "observed_usage_budget_projection",
      "typed_slo_retry_policy_language",
      "read_only_event_and_alert_projection",
      "dashboard_grouping_vocabulary"
    ],
    "not_core_runtime_mechanisms": [
      "generic_fallback_completion",
      "string_rule_retry_execution",
      "generic_event_bus_as_truth",
      "generic_runtime_adapter_success_semantics"
    ],
    "allowed_degraded_surface": {
      "surface": "degraded_attempt_or_alternative_route_proposal",
      "can_mark_success": false,
      "required_operator_fields": [
        "blocker",
        "evidence_gap",
        "owner_receipt_ref",
        "next_surface_ref"
      ]
    },
    "operator_stability_definition": "failure_is_classified_recoverable_and_auditable_without_pretending_quality_completion"
  },
  "preserved_runtime_semantics": [
    "Codex-default session/runtime",
    "explicit domain activation",
    "explicit runtime switch"
  ],
  "non_goals": [
    "local daemon",
    "scheduler takeover",
    "session kernel ownership",
    "memory kernel ownership",
    "domain runtime truth ownership",
    "domain quality authority",
    "executor auto-degradation",
    "domain action execution from observability",
    "generic fallback completion",
    "string rule retry execution",
    "generic event bus truth source",
    "generic runtime adapter success semantics"
  ],
  "fail_closed_rules": [
    "source_refs_required",
    "freshness_required_for_completed_or_passed",
    "owner_split_required",
    "domain_owned_proof_or_eval_required_for_quality_closure"
  ]
}
