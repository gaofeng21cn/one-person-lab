{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/standard-agent-interface.schema.json",
  "title": "OPL Standard Agent Interface",
  "type": "object",
  "required": ["version", "workspace_binding", "runtime", "progress", "routing"],
  "properties": {
    "version": { "const": "opl_standard_agent_interface.v1" },
    "inventory_projection": {
      "type": "object",
      "required": ["source_kind", "relative_path", "items_pointer", "field_map"],
      "properties": {
        "source_kind": { "const": "workspace_relative_json" },
        "relative_path": { "type": "string", "minLength": 1 },
        "items_pointer": { "type": "string", "pattern": "^/" },
        "work_item_root_template": { "type": "string", "minLength": 1 },
        "field_map": {
          "type": "object",
          "required": ["work_item_id", "work_item_root", "business_status", "current_stage_id", "current_stage_status", "package_status", "lifecycle_ref"],
          "properties": {
            "display_name": { "type": "string", "minLength": 1 },
            "next_action": { "type": "string", "minLength": 1 },
            "stage_index_ref": { "type": "string", "minLength": 1 },
            "work_item_id": { "type": "string", "minLength": 1 },
            "work_item_root": { "type": "string", "minLength": 1 },
            "business_status": { "type": "string", "minLength": 1 },
            "current_stage_id": { "type": "string", "minLength": 1 },
            "current_stage_status": { "type": "string", "minLength": 1 },
            "package_status": { "type": "string", "minLength": 1 },
            "lifecycle_ref": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "stage_catalog": {
      "type": "object",
      "required": ["source_kind", "relative_path", "items_pointer", "field_map"],
      "properties": {
        "source_kind": { "const": "agent_repo_relative_json" },
        "relative_path": { "type": "string", "minLength": 1 },
        "items_pointer": { "type": "string", "pattern": "^/" },
        "field_map": {
          "type": "object",
          "required": ["stage_id", "display_name", "display_names"],
          "properties": {
            "stage_id": { "type": "string", "minLength": 1 },
            "display_name": { "type": "string", "minLength": 1 },
            "display_names": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "domain_detail_views": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["view_id", "view_kind", "source_kind", "relative_path"],
        "properties": {
          "view_id": { "type": "string", "minLength": 1 },
          "view_kind": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "schema_ref": { "type": "string", "minLength": 1 },
          "schema_version": { "type": "string", "minLength": 1 },
          "source_kind": { "const": "work_item_relative_json" },
          "relative_path": { "type": "string", "minLength": 1 },
          "revision_pointer": { "type": "string", "pattern": "^/" },
          "owner_task_binding": {
            "type": "object",
            "required": ["task_id_pointer", "task_ref_pointer", "task_ref_template"],
            "properties": {
              "task_id_pointer": { "type": "string", "pattern": "^/" },
              "task_ref_pointer": { "type": "string", "pattern": "^/" },
              "task_ref_template": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "anyOf": [
          { "required": ["schema_ref"] },
          { "required": ["schema_version"] }
        ],
        "additionalProperties": false
      }
    },
    "workspace_binding": {
      "type": "object",
      "required": ["locator_surface_kind", "default_profile_id", "workspace_kind", "project_kind", "project_collection_label", "default_workspace_id", "default_project_id", "required_locator_fields", "optional_locator_fields"],
      "properties": {
        "locator_surface_kind": { "type": "string", "minLength": 1 },
        "default_profile_id": { "enum": ["one_off", "series", "portfolio"] },
        "workspace_kind": { "type": "string", "minLength": 1 },
        "project_kind": { "type": "string", "minLength": 1 },
        "project_collection_label": { "type": "string", "minLength": 1 },
        "default_workspace_id": { "type": "string", "minLength": 1 },
        "default_project_id": { "type": "string", "minLength": 1 },
        "required_locator_fields": { "$ref": "#/$defs/locatorFields" },
        "optional_locator_fields": { "$ref": "#/$defs/locatorFields" }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["runtime_domain_id", "registration_ref"],
      "properties": {
        "runtime_domain_id": { "type": "string", "minLength": 1 },
        "registration_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "progress": {
      "type": "object",
      "required": ["deliverable_delta_aliases", "platform_delta_aliases"],
      "properties": {
        "deliverable_delta_aliases": { "$ref": "#/$defs/stringList" },
        "platform_delta_aliases": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "required": ["explicit_aliases", "workstream_ids", "intent_signals", "ambiguity_policy"],
      "properties": {
        "explicit_aliases": { "$ref": "#/$defs/stringList" },
        "workstream_ids": {
          "allOf": [{ "$ref": "#/$defs/stringList" }, { "maxItems": 1 }]
        },
        "intent_signals": { "$ref": "#/$defs/stringList" },
        "ambiguity_policy": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "locatorFields": {
      "type": "array",
      "items": { "enum": ["workspace_root", "workspace_path", "profile_ref", "input_path"] },
      "uniqueItems": true
    }
  }
}
