{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/reviewer-input-snapshot-manifest.schema.json",
  "title": "OPL Immutable Reviewer Input Snapshot Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_version",
    "generation_ref",
    "review_lane",
    "review_scope_sha256",
    "members",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_reviewer_input_snapshot_manifest" },
    "schema_version": { "const": 1 },
    "generation_ref": { "type": "string", "minLength": 1 },
    "review_lane": {
      "enum": ["medical", "statistical", "reference", "display", "publication", "exact_byte_package"]
    },
    "review_scope_sha256": { "$ref": "#/$defs/sha256" },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["member_id", "role", "sha256", "size_bytes", "immutable_ref"],
        "properties": {
          "member_id": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "immutable_ref": {
            "allOf": [
              { "$ref": "#/$defs/exact_ref" },
              { "properties": { "kind": { "const": "opl_reviewer_input_snapshot_member" } } }
            ]
          }
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storage_role",
        "mas_selects_review_lane_scope_and_members",
        "framework_can_select_or_narrow_members",
        "framework_can_interpret_member_roles",
        "framework_can_write_domain_truth",
        "framework_can_sign_reviewer_receipt",
        "framework_can_sign_owner_receipt",
        "framework_can_create_typed_blocker",
        "framework_can_claim_quality_readiness",
        "framework_can_claim_publication_readiness",
        "framework_can_claim_artifact_authority"
      ],
      "properties": {
        "storage_role": { "const": "immutable_reviewer_input_transport" },
        "mas_selects_review_lane_scope_and_members": { "const": true },
        "framework_can_select_or_narrow_members": { "const": false },
        "framework_can_interpret_member_roles": { "const": false },
        "framework_can_write_domain_truth": { "const": false },
        "framework_can_sign_reviewer_receipt": { "const": false },
        "framework_can_sign_owner_receipt": { "const": false },
        "framework_can_create_typed_blocker": { "const": false },
        "framework_can_claim_quality_readiness": { "const": false },
        "framework_can_claim_publication_readiness": { "const": false },
        "framework_can_claim_artifact_authority": { "const": false }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "exact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "size_bytes", "sha256"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "pattern": "^file://" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
