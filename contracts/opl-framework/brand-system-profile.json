  "agent_naming": {
    "family_label": "One Person Lab Foundry Agent",
    "public_name_policy": "Public names use domain brands while preserving the Foundry Agent family label in developer/operator surfaces.",
    "machine_id_policy": "Machine ids remain stable lowercase agent ids and domain ids; public labels must not become machine truth.",
    "required_agent_ids": [
      "mas",
      "mag",
      "rca",
      "oma"
    ],
    "foundry_series_contract_ref": "contracts/opl-framework/foundry-agent-series-contract.json"
  },
  "app_status_language": {
    "default_terms": [
      "current owner",
      "next action",
      "artifact",
      "receipt",
      "typed blocker",
      "human gate"
    ],
    "diagnostic_only_terms": [
      "ledger",
      "trace",
      "provider",
      "worklist",
      "sidecar",
      "full drilldown",
      "replay"
    ],
    "forbidden_default_terms": [
      "domain ready",
      "quality verdict",
      "production ready",
      "App release ready",
      "owner accepted",
      "provider completion equals receipt"
    ],
    "default_state_ref": "contracts/opl-framework/family-product-operator-projection.json#/app_runtime_boundary/default_read_surface_policy",
    "full_detail_policy_ref": "contracts/opl-framework/family-product-operator-projection.json#/app_runtime_boundary/full_runtime_drilldown_exception"
  },
  "visual_system": {
    "pattern_groups": [
      {
        "group_id": "design_tokens",
        "purpose": "Keep product surfaces visually consistent across Framework, App, and Foundry Agent projections.",
        "required_patterns": [
          "semantic_color_tokens",
          "spacing_and_density_tokens",
          "typography_scale_tokens",
          "focus_and_interaction_tokens"
        ]
      },
      {
        "group_id": "icons",
        "purpose": "Represent brand modules, agents, actions, blockers, receipts, and artifacts with stable symbolic categories.",
        "required_patterns": [
          "module_icon_family",
          "foundry_agent_icon_shape",
          "artifact_icon",
          "receipt_icon",
          "typed_blocker_icon",
          "human_gate_icon"
        ]
      },
      {
        "group_id": "cards",
        "purpose": "Keep user-facing task, agent, artifact, receipt, and blocker cards scannable and authority-aware.",
        "required_patterns": [
          "agent_card",
          "current_owner_card",
          "artifact_card",
          "receipt_card",
          "typed_blocker_card",
          "human_gate_card"
        ]
      },
      {
        "group_id": "status_patterns",
        "purpose": "Separate ready, waiting, blocked, review, diagnostic, and evidence-required states without overclaiming readiness.",
        "required_patterns": [
          "current_owner_status",
          "next_action_status",
          "artifact_available_status",
          "receipt_recorded_status",
          "typed_blocker_required_status",
          "evidence_required_status"
        ]
      }
    ]
  },
  "receipt_blocker_language": {
    "success_shape": "domain_owner_receipt_ref",
    "blocked_shape": "domain_owned_typed_blocker_ref",
    "route_back_shape": "route_back_or_human_gate_ref",
    "owner_answer_schema_ref": "contracts/opl-framework/owner-answer.schema.json",
    "owner_receipt_schema_ref": "contracts/opl-framework/stage-owner-receipt.schema.json",
    "typed_blocker_schema_ref": "contracts/opl-framework/stage-typed-blocker.schema.json",
    "wording_rules": [
      "Say receipt only when a domain or human owner-signed receipt ref exists.",
      "Say typed blocker only when an owner-signed blocker ref names the required owner and next safe action.",
      "Say human gate when the next action requires owner or human input.",
      "Do not turn provider completion, file presence, verified ledger refs, or contract validation into owner acceptance.",
      "Do not let OPL Framework, Console, Ledger, or Connect claim domain quality, artifact authority, or production readiness."
    ]
  },
  "authority_boundary": {
    "can_claim_domain_ready": false,
    "can_claim_quality_verdict": false,
    "can_claim_artifact_authority": false,
    "can_claim_production_ready": false,
    "can_write_domain_truth": false,
    "can_write_memory_body": false,
    "can_mutate_artifact_body": false,
    "can_sign_owner_receipt": false,
    "can_create_typed_blocker": false,
    "can_replace_domain_owner": false,
    "can_replace_ai_executor_planning": false
  },
  "forbidden_claims": [
    "brand_system_profile_claims_l5",
    "brand_system_profile_claims_domain_ready",
    "brand_system_profile_claims_quality_verdict",
    "brand_system_profile_claims_artifact_authority",
    "brand_system_profile_claims_app_release_ready",
    "brand_system_profile_claims_owner_receipt_creation",
    "brand_system_profile_claims_typed_blocker_creation",
    "provider_completion_counts_as_receipt"
  ],
  "ordinary_app_experience": {
    "surface_kind": "opl_brand_ordinary_app_experience_profile",
    "default_read_surface_ref": "app_state.operator.ordinary_cockpit",
    "experience_axes": [
      {
        "axis_id": "running_fluency",
        "user_visible_goal": "The ordinary App path shows one current owner, one next action, and artifact or blocker refs without exposing runtime ledgers.",
        "app_projection_ref": "app_state.operator.ordinary_cockpit.display_payload",
        "l5_evidence_class_ref": "contracts/opl-framework/brand-module-l5-operating-evidence.json#evidence_classes.ordinary_app_experience",
        "must_not_claim": [
          "runtime_projection_is_domain_progress",
          "app_projection_counts_as_l5",
          "provider_completion_counts_as_owner_receipt"
        ]
      },
      {
        "axis_id": "output_quality",
        "user_visible_goal": "The ordinary App path names artifact, receipt, blocker, review, and human-gate shapes while leaving quality verdicts with domain or human owners.",
        "app_projection_ref": "app_state.operator.brand_experience_profile.display_language_refs",
        "l5_evidence_class_ref": "contracts/opl-framework/brand-module-l5-operating-evidence.json#evidence_classes.ordinary_app_experience",
        "must_not_claim": [
          "schema_pass_is_quality_verdict",
          "receipt_ref_exists_means_owner_accepted",
          "app_profile_authorizes_export_or_publication"
        ]
      },
      {
        "axis_id": "brand_feel",
        "user_visible_goal": "The ordinary App path derives status words, cards, icons, and evidence language from the OPL brand profile instead of per-surface wording.",
        "app_projection_ref": "app_state.operator.brand_experience_profile.display_language_refs",
        "l5_evidence_class_ref": "contracts/opl-framework/brand-module-l5-operating-evidence.json#evidence_classes.ordinary_app_experience",
        "must_not_claim": [
          "visual_tokens_are_release_ready",
          "brand_profile_claims_production_ready",
          "app_shell_rendering_claims_domain_ready"
        ]
      }
    ],
    "l5_evidence_refs_only": true,
    "authority_boundary": {
      "can_claim_l5": false,
      "can_claim_app_release_ready": false,
      "can_authorize_quality_verdict": false,
      "can_create_owner_receipt": false,
      "can_create_typed_blocker": false
    }
  }
}
