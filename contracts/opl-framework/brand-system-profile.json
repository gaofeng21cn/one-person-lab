{
  "version": "brand-system-profile.v1",
  "scope": "opl_brand_system_freeze_profile",
  "owner": "One Person Lab",
  "purpose": "Freeze the One Person Lab brand system baseline across product cognition, module product grammar, Foundry Agent naming, App status language, visual patterns, and receipt/blocker wording.",
  "state": "active_contract",
  "machine_boundary": "This profile is a machine-readable brand-system baseline. It governs naming, language, pattern refs, and false-authority claims only; it does not store domain truth, artifact bodies, memory bodies, GUI release truth, quality verdicts, owner receipts, typed blockers, runtime readiness, or production readiness.",
  "source_refs": [
    "human_doc:opl_family_ideal_system_assessment",
    "human_doc:opl_brand_modules_reference",
    "contracts/opl-framework/brand-module-registry.json",
    "contracts/opl-framework/brand-module-surfaces.json",
    "contracts/opl-framework/foundry-agent-series-contract.json",
    "contracts/opl-framework/family-product-operator-projection.json",
    "contracts/opl-framework/owner-answer.schema.json",
    "contracts/opl-framework/stage-owner-receipt.schema.json",
    "contracts/opl-framework/stage-typed-blocker.schema.json",
    "human_doc:opl_family_ideal_operating_model_redesign#ideal_experience_redesign",
    "contracts/opl-framework/brand-module-l5-operating-evidence.json#evidence_classes.ordinary_app_experience"
  ],
  "product_cognition_layers": [
    {
      "layer_id": "opl_framework",
      "product_name": "OPL Framework",
      "user_understanding": "The foundation that makes agents creatable, runnable, recoverable, and auditable.",
      "maintainer_understanding": "Agent platform, runtime, contracts, pack compiler, generated surfaces, Ledger, Runway, and Console projection producer.",
      "owner": "one-person-lab",
      "authority_boundary": [
        "owns_framework_runtime_contracts",
        "owns_generated_surface_contracts",
        "does_not_own_domain_truth",
        "does_not_own_gui_release_truth"
      ]
    },
    {
      "layer_id": "one_person_lab_app",
      "product_name": "One Person Lab App",
      "user_understanding": "The cockpit for choosing work, seeing progress, resolving blockers, and opening deliverables.",
      "maintainer_understanding": "GUI product surface that consumes OPL state/action projections; release truth and user-path evidence stay with the App owner.",
      "owner": "one-person-lab-app",
      "authority_boundary": [
        "owns_gui_product_truth",
        "owns_app_release_user_path_evidence",
        "does_not_own_runtime_truth",
        "does_not_own_domain_truth"
      ]
    },
    {
      "layer_id": "foundry_agents",
      "product_name": "Foundry Agents",
      "user_understanding": "Domain agents that complete medical papers, grants, visual deliverables, and agent-building work.",
      "maintainer_understanding": "Domain packs plus authority functions; each domain owns truth, artifact authority, quality/export verdicts, receipts, and blockers.",
      "owner": "domain-agent repositories",
      "authority_boundary": [
        "owns_domain_truth",
        "owns_artifact_and_memory_authority",
        "owns_quality_or_export_verdict",
        "owns_owner_receipt_and_typed_blocker_creation"
      ]
    }
  ],
