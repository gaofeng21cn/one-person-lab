        "brand_doc_ref",
        "registry_entry",
        "contract_or_policy_ref",
        "cli_surface_ref",
        "app_or_operator_surface_ref",
        "descriptor_surface_ref",
        "validation_surface_ref",
        "status_or_maturity_doc_ref",
        "authority_boundary",
        "forbidden_claims"
      ]
    }
  ],
  "external_reference_principles": [
    "Backstage Software Catalog pattern: keep discoverability, ownership, and metadata in a catalog that tools consume instead of duplicating ad hoc UI or CLI truth.",
    "CNCF platform engineering maturity pattern: evaluate maturity through explicit multidimensional gates instead of one vague readiness label.",
    "Team Topologies Thinnest Viable Platform pattern: expose enough self-service surface for users and agents while keeping platform modules thin and owner boundaries explicit."
