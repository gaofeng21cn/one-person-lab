  "baseline_module_id": "workspace",
  "maturity_model": [
    {
      "level": "L4_structural_baseline",
      "definition": "Workspace-level structural completion: brand doc, registry entry, machine contract or policy ref, CLI surface, App/operator projection surface, descriptor surface, validation surface, status or maturity doc ref, authority boundary, and forbidden claims are all present.",
