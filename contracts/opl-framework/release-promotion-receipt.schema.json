{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/opl-framework/release-promotion-receipt.schema.json",
  "title": "OPL Release Set promotion receipt",
  "type": "object",
  "required": [
    "surface_kind",
    "status",
    "promotion_target",
    "promotion_request_id",
    "release_set_generation",
    "carrier",
    "framework_run",
    "app",
    "components",
    "anonymous_readback"
  ],
  "properties": {
    "surface_kind": { "const": "opl_release_set_promotion_receipt.v1" },
    "status": { "enum": ["published_immutable_candidate", "promoted_latest_stable"] },
    "promotion_target": { "enum": ["candidate", "latest-stable"] },
    "promotion_request_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "release_gate": { "type": "string", "minLength": 1 },
    "release_set_generation": { "type": "string", "pattern": "^[0-9]{2}\\.[0-9]{1,2}\\.[0-9]{1,2}(?:-r[1-9][0-9]*)?$" },
    "carrier": {
      "type": "object",
      "required": ["immutable_ref", "digest", "channel_ref"],
      "properties": {
        "immutable_ref": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "channel_ref": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "framework_run": {
      "type": "object",
      "required": ["repository", "run_id", "run_attempt"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "pattern": "^[0-9]+$" },
        "run_attempt": { "type": "string", "pattern": "^[0-9]+$" }
      },
      "additionalProperties": false
    },
    "source_app_run_id": { "type": ["string", "null"] },
    "app": { "$ref": "#/$defs/component" },
    "components": {
      "type": "object",
      "required": ["base", "packages"],
      "properties": {
        "base": { "$ref": "#/$defs/component" },
        "packages": {
          "type": "object",
          "minProperties": 7,
          "maxProperties": 7,
          "additionalProperties": { "$ref": "#/$defs/component" }
        }
      },
      "additionalProperties": false
    },
    "anonymous_readback": {
      "type": "object",
      "required": ["status", "verified_refs"],
      "properties": {
        "status": { "const": "verified" },
        "verified_refs": { "type": "array", "minItems": 9, "uniqueItems": true, "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": ["component_id", "version", "source_commit", "artifact_ref", "artifact_digest"],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "artifact_ref": { "type": "string", "minLength": 1 },
        "artifact_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
