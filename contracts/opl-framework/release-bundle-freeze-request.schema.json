{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.dev/contracts/opl-framework/release-bundle-freeze-request.schema.json",
  "title": "OPL Release Bundle Freeze Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind",
    "schema_ref",
    "release",
    "sources",
    "framework_release_set",
    "packages",
    "prepared_notes",
    "tracks"
  ],
  "properties": {
    "surface_kind": { "const": "opl_release_bundle_freeze_request.v1" },
    "schema_ref": {
      "const": "contracts/opl-framework/release-bundle-freeze-request.schema.json"
    },
    "release": { "$ref": "#/$defs/release" },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app", "shell", "framework"],
      "properties": {
        "app": { "$ref": "#/$defs/source" },
        "shell": { "$ref": "#/$defs/source" },
        "framework": { "$ref": "#/$defs/source" }
      }
    },
    "framework_release_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generation", "manifest_ref", "digest"],
      "properties": {
        "generation": {
          "type": "string",
          "pattern": "^[0-9]{2}\\.[0-9]{1,2}\\.[0-9]{1,2}(?:-r[1-9][0-9]*)?$"
        },
        "manifest_ref": { "$ref": "#/$defs/ref" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "packages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mas",
        "mag",
        "rca",
        "oma",
        "obf",
        "mas-scholar-skills",
        "opl-flow"
      ],
      "properties": {
        "mas": { "$ref": "#/$defs/package" },
        "mag": { "$ref": "#/$defs/package" },
        "rca": { "$ref": "#/$defs/package" },
        "oma": { "$ref": "#/$defs/package" },
        "obf": { "$ref": "#/$defs/package" },
        "mas-scholar-skills": { "$ref": "#/$defs/package" },
        "opl-flow": { "$ref": "#/$defs/package" }
      }
    },
    "prepared_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "format", "markdown", "evidence"],
      "properties": {
        "source": { "const": "prepared_ai" },
        "format": { "const": "markdown" },
        "markdown": { "type": "string", "minLength": 1, "maxLength": 2097152 },
        "evidence": { "type": "object" }
      }
    },
    "source_cutoff": { "$ref": "#/$defs/sourceCutoff" },
    "tracks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standard", "full"],
      "properties": {
        "standard": {
          "allOf": [
            { "$ref": "#/$defs/track" },
            {
              "properties": {
                "required_for_latest": { "const": true },
                "additive_only": { "const": false },
                "updater_metadata_allowed": { "const": true }
              }
            }
          ]
        },
        "webui": {
          "allOf": [
            { "$ref": "#/$defs/track" },
            {
              "properties": {
                "required_for_latest": { "const": true },
                "additive_only": { "const": false },
                "updater_metadata_allowed": { "const": false }
              }
            }
          ]
        },
        "full": {
          "allOf": [
            { "$ref": "#/$defs/track" },
            {
              "properties": {
                "required_for_latest": { "const": false },
                "additive_only": { "const": true },
                "updater_metadata_allowed": { "const": false }
              }
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "sourceCutoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_at",
        "policy",
        "frozen_base_release_set",
        "post_freeze_remote_refresh_allowed",
        "later_authority_advancement_invalidates_bundle"
      ],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
        },
        "policy": { "const": "single_read_at_freeze_admission" },
        "frozen_base_release_set": {
          "anyOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["generation", "digest"],
              "properties": {
                "generation": {
                  "type": "string",
                  "pattern": "^[0-9]{2}\\.[0-9]{1,2}\\.[0-9]{1,2}(?:-r[1-9][0-9]*)?$"
                },
                "digest": { "$ref": "#/$defs/digest" }
              }
            },
            { "type": "null" }
          ]
        },
        "post_freeze_remote_refresh_allowed": { "const": false },
        "later_authority_advancement_invalidates_bundle": { "const": false }
      }
    },
    "gitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "version", "display_version", "updater_version", "tag", "prerelease"],
      "properties": {
        "channel": { "enum": ["stable", "nightly"] },
        "version": {
          "type": "string",
          "pattern": "^[0-9]{2}\\.[0-9]{1,2}\\.[0-9]{1,2}(?:-[0-9A-Za-z.-]+)?$"
        },
        "display_version": {
          "type": "string",
          "pattern": "^[0-9]{2}\\.[0-9]{1,2}\\.[0-9]{1,2}(?:-[0-9A-Za-z.-]+)?$"
        },
        "updater_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
        },
        "tag": { "type": "string", "minLength": 2 },
        "prerelease": { "type": "boolean" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "source_commit"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "source_commit": { "$ref": "#/$defs/gitSha" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "version",
        "owner_source_commit",
        "manifest_ref",
        "manifest_sha256",
        "payload_manifest_ref",
        "payload_manifest_sha256"
      ],
      "properties": {
        "package_id": {
          "enum": ["mas", "mag", "rca", "oma", "obf", "mas-scholar-skills", "opl-flow"]
        },
        "version": { "type": "string", "minLength": 1 },
        "owner_source_commit": { "$ref": "#/$defs/gitSha" },
        "manifest_ref": { "$ref": "#/$defs/ref" },
        "manifest_sha256": { "$ref": "#/$defs/digest" },
        "payload_manifest_ref": { "$ref": "#/$defs/ref" },
        "payload_manifest_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "assetName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[^/\\\\\\u0000]+$"
    },
    "ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_asset_names",
        "required_for_latest",
        "additive_only",
        "updater_metadata_allowed"
      ],
      "properties": {
        "required_asset_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/assetName" }
        },
        "required_for_latest": { "type": "boolean" },
        "additive_only": { "type": "boolean" },
        "updater_metadata_allowed": { "type": "boolean" }
      }
    }
  }
}
