{
  "contract_kind": "opl_wrapper_retirement_gate_policy.v1",
  "owner": "one-person-lab",
  "purpose": "Define the machine-readable delete/tombstone gate for retiring domain private wrappers, aliases, facades, status shells, workbenches, and compatibility-only tests after OPL generated or hosted surfaces replace them.",
  "state": "active_contract",
  "machine_boundary": "OPL owns the read-only gate, lifecycle receipt projection, and no-resurrection guard; domain repositories own physical delete authority, domain truth, owner answers, artifacts, and quality verdicts.",
  "required_before_physical_delete": [
    "replacement_parity_ref",
    "no_active_caller_ref",
    "no_forbidden_write_ref",
    "tombstone_or_provenance_ref"
  ],
  "read_model_count_semantics": {
    "deletion_evidence_worklist_count": "active open retirement gate items only",
    "surface_retirement_gate_count": "all generated or hosted default-caller retirement gates, including closed owner-decision refs",
    "closed_surface_retirement_gate_count": "retirement gates with owner decision ref observed and therefore removed from the active deletion worklist",
    "closed_surface_detail_default_payload_policy": "closed retirement gate details are omitted from default payload; use counts, tombstone/provenance refs, and active worklist detail only when open"
  },
  "owner_delete_keep_or_blocker_decision_shapes": [
    "physical_delete_authorization_ref",
    "keep_as_authority_adapter_ref",
    "typed_blocker_ref"
  ],
  "owner_decision_closeout_readout": {
    "owner_decision_result_shape": "observed domain-owner decision ref shape when available",
    "owner_decision_closeout_status": "machine-readable closeout status for OPL default-caller delete work",
    "no_further_opl_default_caller_delete_work": "true only when OPL has no remaining default-caller deletion work for the observed gate; this does not authorize domain repo physical delete",
    "next_opl_default_caller_delete_action": "no_further_opl_default_caller_delete_work when the OPL worklist is closed, otherwise the next OPL/operator action",
    "physical_delete_authorized_remains_required_for_delete_ready": true
  },
  "same_work_unit_live_evidence_scope": {
