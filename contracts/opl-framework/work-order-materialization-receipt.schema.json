{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/work-order-materialization-receipt.schema.json",
  "title": "OPL Work Order Materialization Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_kind", "version", "canonical_schema_ref", "status", "work_order_id",
    "request_ref", "request_sha256", "target_dir", "materialized_files", "work_order_path",
    "closeout_receipt_schema_ref", "execution_command", "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_work_order_materialization_receipt" },
    "version": { "const": "opl.work-order-materialization-receipt.v1" },
    "canonical_schema_ref": { "const": "contracts/opl-framework/work-order-materialization-receipt.schema.json" },
    "status": { "const": "materialized" },
    "work_order_id": { "type": "string", "minLength": 1 },
    "request_ref": { "type": "string", "minLength": 1 },
    "request_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "target_dir": { "type": "string", "minLength": 1 },
    "materialized_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "schema_ref", "sha256"],
        "properties": {
          "path": { "type": "string", "pattern": "^[^/\\\\]+\\.json$" },
          "role": { "type": "string", "minLength": 1 },
          "schema_ref": { "type": ["string", "null"] },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "work_order_ref": { "type": ["string", "null"] },
    "work_order_path": { "type": "string", "minLength": 1 },
    "closeout_receipt_schema_ref": { "const": "contracts/opl-framework/work-order-owner-closeout-receipt.schema.json" },
    "execution_command": { "type": "string", "minLength": 1 },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receipt_proves_materialization_only", "receipt_can_claim_patch_execution",
        "receipt_can_claim_target_owner_closeout", "receipt_can_write_target_domain_truth",
        "receipt_can_sign_target_owner_receipt"
      ],
      "properties": {
        "receipt_proves_materialization_only": { "const": true },
        "receipt_can_claim_patch_execution": { "const": false },
        "receipt_can_claim_target_owner_closeout": { "const": false },
        "receipt_can_write_target_domain_truth": { "const": false },
        "receipt_can_sign_target_owner_receipt": { "const": false }
      }
    }
  }
}
