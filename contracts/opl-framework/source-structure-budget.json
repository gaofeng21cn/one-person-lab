{
  "contract_kind": "opl_source_structure_budget.v1",
  "surface_kind": "opl_source_structure_budget",
  "owner": "one-person-lab",
  "purpose": "Define the repo-source line budget as a scheduled advisory maintenance signal with an explicit strict ratchet mode for maintainers and daily structure jobs.",
  "state": "active_contract",
  "machine_boundary": "This contract owns line-budget thresholds and reviewed oversized-file baselines for tracked source files. It does not define domain truth, production readiness, release readiness, or quality verdict authority.",
  "default_limit": 1000,
  "advisory_near_limit": 850,
  "baseline_policy": {
    "mode": "scheduled_advisory_with_explicit_strict_ratchet",
    "default_developer_behavior": "advisory_exit_zero",
    "strict_entrypoints": [
      "scripts/line-budget.mjs --strict",
      "OPL_LINE_BUDGET_STRICT=1 node scripts/line-budget.mjs",
      "npm run line-budget:strict",
      "./scripts/verify.sh line-budget:strict",
      "./scripts/verify.sh structure:strict"
    ],
    "new_oversized_file": "advisory_until_scheduled_maintenance_or_explicit_reviewed_baseline",
    "reviewed_baseline_growth": "advisory_by_default_strict_blocks",
    "stale_baseline": "advisory_by_default_strict_blocks",
    "retired_baseline": "advisory_by_default_strict_blocks_until_removed",
    "line_count_ledger_owner": "this_contract_and_scripts_line_budget"
  },
  "reviewed_baselines": []
}
