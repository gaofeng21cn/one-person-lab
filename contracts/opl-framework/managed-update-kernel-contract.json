{
  "schema_version": 1,
  "owner": "one-person-lab",
  "purpose": "managed_update_kernel_contract",
  "state": "active",
  "surface_id": "opl_managed_updater_kernel",
  "public_cli_surfaces": [
    "opl update status --json",
    "opl update check --json",
    "opl update plan --json",
    "opl update apply --json",
    "opl update repair --receipt <receipt_id> --json",
    "opl update rollback --json",
    "opl packages list --json",
    "opl packages install --manifest-url <url> --trust-tier <tier> --json",
    "opl packages update --json",
    "opl packages enable --package-id <id> --json",
    "opl packages disable --package-id <id> --json",
    "opl packages repair --package-id <id> --json",
    "opl packages uninstall --package-id <id> --json"
  ],
  "kernel_lifecycle": [
    "read_manifest",
    "read_current_state",
    "diff_plan",
    "fetch_artifacts",
    "verify",
    "stage",
    "activate",
    "post_apply",
    "write_receipt",
    "report_status_or_repair"
  ],
  "component_state_vocabulary": [
    "current",
    "update_available",
    "staged",
    "needs_restart",
    "needs_reload",
    "failed_with_repair",
    "skipped_manual_required"
  ],
  "coordination_roles": [
    "executable_target",
    "derived_projection",
    "owner_handoff"
  ],
  "lifecycle_owners": [
    {
      "lifecycle_owner": "opl_base",
      "label": "OPL Base",
      "public_surface": "opl update",
      "provider_id": "runtime_substrate",
      "nested_status_fields": [
        "dependency_status",
        "integration_status"
      ]
    },
    {
      "lifecycle_owner": "opl_app",
      "label": "OPL App",
      "public_surface": "One Person Lab App updater and App state",
      "provider_id": "installation_carrier",
      "required_status_fields": [
        "host_update_route",
        "host_executor_required"
      ]
    },
    {
      "lifecycle_owner": "opl_packages",
      "label": "OPL Packages",
      "public_surface": "opl packages",
      "provider_id": "capability_packages",
      "nested_status_fields": [
        "projection_status",
        "profile_migration_status"
      ]
    }
  ],
  "update_plane_state_machine": {
    "purpose": "three_owner_coordination_plane_for_opl_base_opl_app_and_opl_packages",
    "state_axis": [
      "auto_apply",
      "controlled_apply",
      "prompt_only",
      "projection_only"
    ],
    "states": [
      {
        "state_id": "auto_apply",
        "meaning": "Framework may fetch, verify, stage, activate, run post-apply hooks, and write a component receipt without asking when the managed target is clean.",
        "allowed_component_classes": [
          "opl_packages"
        ],
        "required_identity": [
          "digest",
          "sha256",
          "source_fingerprint",
          "git_head_sha"
        ],
        "forbidden_when": [
          "dirty checkout",
          "developer checkout",
          "ahead",
          "diverged",
          "no_upstream",
          "unknown identity"
        ]
      },
      {
        "state_id": "controlled_apply",
        "meaning": "Framework may mutate only an OPL/App-owned runtime root through an explicit controlled command and receipt.",
        "allowed_component_classes": [
          "opl_base"
        ],
        "required_identity": [
          "current_pointer",
          "staged_root",
          "rollback_pointer",
          "runtime_version"
        ],
        "forbidden_when": [
          "would mutate Homebrew",
          "would mutate global npm",
          "would mutate system PATH Codex",
          "would mutate system Temporal",
          "target is developer checkout"
        ]
      },
      {
        "state_id": "prompt_only",
        "meaning": "Framework may show owner-specific route guidance, but the actual update belongs to the host, App release, package manager, or Codex semantic merge owner.",
        "allowed_component_classes": [
          "opl_app"
        ],
        "required_identity": [
          "route_owner",
          "route_ref",
          "manual_required_reason"
        ],
        "forbidden_when": [
          "would claim host carrier replacement",
          "would silently overwrite user profile",
          "would require host executor without host proof"
        ]
      },
      {
        "state_id": "projection_only",
        "meaning": "Framework may expose status, reload guidance, refs, and safe action labels derived from another owner; it is not an apply target.",
        "allowed_component_classes": [
          "opl_app"
        ],
        "required_identity": [
          "source_projection_ref",
          "authority_boundary"
        ],
        "forbidden_when": [
          "would create domain truth",
          "would create owner receipt",
          "would claim App release currentness",
          "would claim carrier update complete"
        ]
      }
    ],
    "component_routes": [
      {
        "component_class": "opl_app",
        "coordination_role": "owner_handoff",
        "canonical_route_state": "prompt_only",
        "readback_state": "projection_only",
        "owner": "one-person-lab-app",
        "examples": [
          "desktop_app_bundle",
          "docker_webui_image",
          "linux_package_carrier"
        ],
        "not_runtime_substrate": true,
        "not_opl_update_apply_target": true
      },
      {
        "component_class": "opl_base",
        "coordination_role": "executable_target",
        "canonical_route_state": "controlled_apply",
        "readback_state": "controlled_apply",
        "owner": "one-person-lab-app-and-opl-framework",
        "examples": [
          "app_owned_runtime_root",
          "embedded_codex_executor",
          "opl_framework_runtime_artifact_channel"
        ],
        "not_installation_carrier": true,
        "not_global_toolchain": true
      },
      {
        "component_class": "opl_packages",
        "coordination_role": "executable_target",
        "canonical_route_state": "auto_apply",
        "readback_state": "auto_apply",
        "owner": "one-person-lab-managed-modules",
        "examples": [
          "domain_module_package_channel",
          "framework_capability_package_channel"
        ],
        "not_installation_carrier": true,
        "not_domain_truth": true
      }
    ]
  },
  "idempotency_lock": {
    "lock_id": "opl_managed_updater_kernel.global",
    "lock_scope": "single_writer_for_fetch_verify_stage_activate_post_apply_write_receipt",
    "read_operations": [
      "status",
      "check",
      "plan"
    ],
    "exclusive_operations": [
      "apply",
      "repair",
      "rollback"
    ],
    "stale_after_seconds": 1800,
    "contention_policy": "report_in_progress_or_skip_without_parallel_stage_or_plugin_sync"
  },
  "owner_route_contract": {
    "required_fields": [
      "owner",
      "authority_surface",
      "route_kind",
      "readback_ref",
      "apply_owner",
      "package_manager_claim",
      "forbidden_claims"
    ],
    "route_kinds": [
      "projection_only",
      "manual_owner_route",
      "controlled_framework_executor",
      "clean_managed_package_executor"
    ],
    "package_manager_claim_must_be_false": true,
    "purpose": "Each managed update component must name the owner/readback route that owns truth and apply semantics so the kernel remains a projection/receipt surface, not a general package manager."
  },
  "owner_execution_boundary_contract": {
    "required_fields": [
      "owner_executor_id",
      "executor_kind",
      "runner_can_execute",
      "allowed_operations",
      "readback_ref",
      "receipt_projection",
      "diagnostic_only",
      "package_manager_claim",
      "notes"
    ],
    "executor_kinds": [
      "none",
      "diagnostic_readback",
      "manual_owner_route",
      "controlled_framework_executor",
      "clean_managed_package_executor"
    ],
    "receipt_projection_values": [
      "read_only_projection",
      "component_receipt_with_owner_route",
      "external_owner_receipt_required"
    ],
    "runner_can_execute_only_for": [
      "opl_base",
      "opl_packages"
    ],
    "package_manager_claim_must_be_false": true,
    "purpose": "reuse-first: allow owner-routed managed update boundary. The runner must name the owner executor and readback boundary per component before apply/repair/rollback, so prompt-only and projection-only components remain receipt/readback projections instead of generic package-manager targets."
  },
  "providers": [
    {
      "lifecycle_owner": "opl_app",
      "provider_id": "installation_carrier",
      "adapter_id": "installation_carrier_status_adapter",
      "owner": "one-person-lab-app",
      "role": "App installation carrier status projection for macOS app, Docker/WebUI image, and Linux package carrier routes",
      "authority": "App-owned install/update taxonomy defines carrier variants; Framework projects status and safe routes only.",
      "default_policy": "carrier_specific_status_with_host_update_route",
      "mutation_scope": "projection_only_no_opl_update_apply_component_target",
      "apply_allowed": false,
      "managed_kernel_apply_allowed": false,
      "opl_update_apply_must_not_claim_carrier_update_complete": true,
      "status_fields": [
        "carrier_type",
        "carrier_status",
        "currentness",
        "update_available",
        "image_ref",
        "image_digest",
        "container_id",
        "compose_file",
        "package_manager",
        "package_name",
        "installed_version",
        "detected_package_managers",
        "host_update_route",
        "host_update_route_examples",
        "host_executor_required",
        "manual_required",
        "manual_required_when",
        "data_volume_preservation",
        "repair_actions"
      ],
      "carrier_variants": [
        {
          "carrier_type": "docker_webui_image",
          "carrier_status_source": "GHCR image digest, compose/container image readback, and Docker/WebUI installer or smoke-gate diagnostics",
          "host_update_route": "host_executor_runs_documented_installer_or_compose_pull_and_up",
          "host_update_route_examples": [
            "install-docker-webui.sh --yes --update",
            "install-docker-webui.ps1 -Yes -Update",
            "docker compose pull && docker compose up -d"
          ],
          "managed_kernel_apply_allowed": false,
          "host_executor_required": true,
          "manual_required": true,
          "currentness_values": [
            "unknown",
            "current",
            "update_available"
          ],
          "data_volume_preservation_proof_required": true,
          "preserved_mounts": [
            "OnePersonLab/data -> /data",
            "OnePersonLab/projects -> /projects"
          ]
        },
        {
          "carrier_type": "linux_package_carrier",
          "carrier_status_source": "host package manager, package metadata, or documented Linux package carrier readback",
          "host_update_route": "host_package_manager_or_documented_host_executor",
          "host_update_route_examples": [
            "sudo apt update && sudo apt install --only-upgrade one-person-lab",
            "sudo dnf upgrade one-person-lab",
            "sudo zypper update one-person-lab"
          ],
          "managed_kernel_apply_allowed": false,
          "host_executor_required": true,
          "manual_required": true,
          "manual_required_when": [
            "package_manager_requires_sudo_or_root",
            "host_policy_disallows_app_executor",
            "repository_or_signature_configuration_required"
          ],
          "currentness_values": [
            "unknown",
            "current",
            "update_available"
          ]
        }
      ],
      "repair_action_scope": "carrier_specific_check_download_host_route_or_manual_recovery_only"
    },
    {
      "lifecycle_owner": "opl_base",
      "provider_id": "runtime_substrate",
      "adapter_id": "runtime_substrate_adapter",
      "owner": "one-person-lab-app-and-opl-framework",
      "role": "app_owned_runtime_substrate_with_embedded_codex_executor",
      "authority": "App-owned runtime roots, current pointer, staged root, health smoke, and rollback pointer.",
      "default_policy": "silent_stage_apply_on_restart_or_startup_maintenance",
      "mutation_scope": "app_owned_runtime_root_only",
      "controlled_execution_path": "opl system startup-maintenance --json",
      "repair_action": "run_startup_maintenance",
      "rollback_action": "rollback_opl_framework_runtime_or_restart_app_with_previous_runtime_pointer",
      "status_fields": [
        "current_pointer",
        "staged_root",
        "rollback_pointer",
        "opl_framework_runtime"
      ]
    },
    {
      "lifecycle_owner": "opl_packages",
      "provider_id": "capability_packages",
      "adapter_id": "capability_packages_adapter",
      "owner": "one-person-lab-managed-modules",
      "role": "GHCR module package channel for MAS/MAG/RCA/OMA ordinary users",
      "authority": "GHCR tag selects a channel target; digest or sha identifies installed content.",
      "default_policy": "silent_background_for_clean_managed_modules",
      "mutation_scope": "clean_opl_managed_module_roots_only",
      "auto_apply": {
        "mode": "auto_apply",
        "app_background_safe": true,
        "command_ref": "opl packages update --json",
        "eligible_scope": "clean_opl_managed_module_roots_only",
        "eligible_when": [
          "default managed module root is missing and can be installed into the managed root",
          "installed module origin is managed_root",
          "module health status is ready or package-channel updateable",
          "git dirty is false",
          "git sync status is not ahead, diverged, no_upstream, or unknown"
        ],
        "blocked_when": [
          "dirty checkout",
          "developer checkout",
          "sibling workspace or env override source",
          "ahead, diverged, no_upstream, or unknown git state",
          "missing digest, sha256, source fingerprint, or git head identity after apply"
        ]
      },
      "transaction_status_fields": [
        "projection_status",
        "profile_migration_status"
      ],
      "transaction_guards": {
        "installed_digest_required": true,
        "dirty_checkout_policy": "fail_closed_no_overwrite",
        "developer_checkout_policy": "fail_closed_no_auto_update",
        "codex_skill_plugin_sync": "same_transaction_post_apply",
        "receipt_policy": "single_package_transaction_receipt"
      },
      "profile_migration_policy": {
        "semantic_merge_required": true,
        "silent_overwrite_allowed": false,
        "failure_policy": "fail_closed_owner_handoff"
      },
      "post_apply_actions": [
        "reconcile_modules",
        "sync_skills",
        "sync_codex_skill_plugin_projection"
      ]
    }
  ],
  "components": [
    "opl_base",
    "opl_app",
    "opl_packages"
  ],
  "component_classes": [
    "opl_base",
    "opl_app",
    "opl_packages"
  ],
  "app_action_consumer_policy": {
    "purpose": "App and Settings update actions consume this managed update coordinator instead of hand-writing package, carrier, or runtime update shells.",
    "canonical_delegated_surfaces": {
      "module_sync": "opl packages update",
      "settings_sync_capabilities": "opl packages update",
      "settings_apply_opl_packages": "opl packages update",
      "settings_check_app_update": "opl app state --profile fast",
      "settings_rollback_runtime_substrate": "opl update rollback"
    },
    "non_goals": [
      "does_not_replace_target_bound_workspace_or_quest_skill_sync",
      "does_not_claim_app_release_currentness",
      "does_not_turn_projection_status_or_profile_migration_status_into_lifecycle_owners"
    ]
  },
  "runtime_substrate_required_projection_fields": [
    "current_pointer",
    "staged_root",
    "rollback_pointer",
    "opl_framework_runtime"
  ],
  "operation_modes": {
    "status": "read_only_projection",
    "check": "read_only_projection",
    "plan": "read_only_projection",
    "apply": "controlled_apply",
    "repair": "controlled_repair",
    "rollback": "controlled_rollback"
  },
  "receipt_write_policy": {
    "status": "read_only",
    "check": "read_only",
    "plan": "read_only",
    "apply": "recorded_component_receipt",
    "repair": "recorded_component_receipt",
    "rollback": "recorded_component_receipt"
  },
  "runner_result_shape": {
    "surface_kind": "opl_managed_update_execution",
    "lock_status_values": [
      "acquired",
      "released",
      "held"
    ],
    "execution_status_values": [
      "completed",
      "skipped",
      "manual_required",
      "failed_with_repair"
    ],
    "adapter_result_status_values": [
      "completed",
      "skipped",
      "manual_required",
      "failed"
    ],
    "adapter_result_owner_boundary_shape": {
      "required_fields": [
        "owner_route",
        "owner_execution_boundary"
      ],
      "runner_can_execute_only_for": [
        "opl_base",
        "opl_packages"
      ]
    },
    "adapter_post_apply_action_shape": {
      "required_fields": [
        "action_id",
        "command_ref",
        "status",
        "result_ref",
        "result"
      ],
      "status_values": [
        "completed",
        "skipped",
        "manual_required",
        "failed"
      ]
    },
    "adapter_status_detail_shape": {
      "required_fields": [
        "component_state",
        "auto_apply_eligible",
        "app_background_safe",
        "clean_managed_targets_count",
        "manual_required_targets_count",
        "post_apply_status",
        "reload_status"
      ],
      "post_apply_status_values": [
        "not_run",
        "completed",
        "manual_required",
        "failed",
        "skipped",
        "unknown"
      ],
      "reload_status_values": [
        "not_required",
        "recommended",
        "required",
        "manual_required",
        "unknown"
      ]
    },
    "reload_guidance_shape": {
      "required_fields": [
        "reload_required",
        "reload_recommended",
        "reload_targets",
        "command_ref",
        "reason"
      ],
      "reload_targets": [
        "one_person_lab_app",
        "codex_plugin_cache"
      ]
    },
    "runtime_substrate_adapter_result_shape": {
      "required_fields": [
        "action",
        "receipt_ref",
        "rollback_ref",
        "repair_action"
      ],
      "controlled_execution_path": "startup_maintenance_runtime_substrate_adapter"
    },
    "receipt_ledger_file": "managed-update-component-receipts.json",
    "lock_file": "managed-update-kernel.lock"
  },
  "component_receipt_shape": {
    "schema_version": "opl_managed_update_component_receipt.v1",
    "required_fields": [
      "source_manifest_ref",
      "from_version",
      "from_digest",
      "to_version",
      "to_digest",
      "verify_result",
      "activated_at",
      "post_apply_hooks",
      "rollback_ref",
      "repair_action",
      "apply_mode",
      "owner_projection",
      "status_detail",
      "post_apply_action_statuses",
      "reload_guidance"
    ],
    "identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha",
      "runtime_version",
      "current_pointer",
      "staged_root",
      "plugin_manifest_hash",
      "skill_pack_hash",
      "generated_surface_hash"
    ]
  },
  "condition_shape": {
    "required_fields": [
      "type",
      "status",
      "reason",
      "message",
      "observed_generation"
    ],
    "status_values": [
      "True",
      "False",
      "Unknown"
    ],
    "style": "kubernetes_status_conditions"
  },
  "authority_boundary": {
    "can_silently_mutate_app_owned_runtime_root": true,
    "can_silently_update_clean_managed_modules": true,
    "can_sync_codex_plugin_skill_projection": true,
    "can_mutate_user_global_homebrew": false,
    "can_mutate_user_global_npm": false,
    "can_mutate_system_path_tools": false,
    "can_overwrite_dirty_or_developer_checkout": false,
    "can_write_domain_truth": false,
    "can_write_domain_memory_body": false,
    "can_mutate_domain_artifact_body": false,
    "can_create_owner_receipt": false,
    "can_claim_quality_or_export_verdict": false
  },
  "artifact_integrity": {
    "channel_tag_role": "selector_only",
    "content_identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha"
    ],
    "future_hardening": [
      "signed_channel_metadata",
      "metadata_expiry",
      "rollback_protection",
      "artifact_provenance",
      "sbom_ref"
    ]
  }
}
