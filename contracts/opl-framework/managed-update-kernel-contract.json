{
  "schema_version": 1,
  "owner": "one-person-lab",
  "purpose": "managed_update_kernel_contract",
  "state": "active",
  "surface_id": "opl_managed_updater_kernel",
  "public_cli_surfaces": [
    "opl update status --json",
    "opl update check --json",
    "opl update plan --json",
    "opl update apply --component <component_id> --json",
    "opl update repair --receipt <receipt_id> --json",
    "opl update rollback --component <component_id> --json"
  ],
  "kernel_lifecycle": [
    "read_manifest",
    "read_current_state",
    "diff_plan",
    "fetch_artifacts",
    "verify",
    "stage",
    "activate",
    "post_apply",
    "write_receipt",
    "report_status_or_repair"
  ],
  "component_state_vocabulary": [
    "current",
    "update_available",
    "staged",
    "needs_restart",
    "needs_reload",
    "failed_with_repair",
    "skipped_manual_required"
  ],
  "idempotency_lock": {
    "lock_id": "opl_managed_updater_kernel.global",
    "lock_scope": "single_writer_for_fetch_verify_stage_activate_post_apply_write_receipt",
    "read_operations": [
      "status",
      "check",
      "plan"
    ],
    "exclusive_operations": [
      "apply",
      "repair",
      "rollback"
    ],
    "stale_after_seconds": 1800,
    "contention_policy": "report_in_progress_or_skip_without_parallel_stage_or_plugin_sync"
  },
  "providers": [
    {
      "provider_id": "app_binary",
      "adapter_id": "electron_standard_updater",
      "owner": "one-person-lab-app",
      "role": "desktop_app_standard_updater_projection",
      "authority": "App release metadata and Electron updater assets remain App-owned.",
      "default_policy": "background_download_then_user_restart",
      "mutation_scope": "desktop_app_bundle_only"
    },
    {
      "provider_id": "runtime_toolchain",
      "adapter_id": "runtime_toolchain_adapter",
      "owner": "one-person-lab-app-and-opl-framework",
      "role": "app_owned_runtime_fallback_and_toolchain_layer",
      "authority": "App-owned runtime roots, current pointer, staged root, health smoke, and rollback pointer.",
      "default_policy": "silent_stage_apply_on_restart_or_startup_maintenance",
      "mutation_scope": "app_owned_runtime_root_only"
    },
    {
      "provider_id": "agent_package_channel",
      "adapter_id": "agent_package_channel_adapter",
      "owner": "one-person-lab-managed-modules",
      "role": "GHCR module package channel for MAS/MAG/RCA/OMA ordinary users",
      "authority": "GHCR tag selects a channel target; digest or sha identifies installed content.",
      "default_policy": "silent_background_for_clean_managed_modules",
      "mutation_scope": "clean_opl_managed_module_roots_only"
    },
    {
      "provider_id": "capability_exposure",
      "adapter_id": "codex_exposure_status_adapter",
      "owner": "one-person-lab-connect",
      "role": "Codex plugin registry, plugin-packaged skills, and generated OMA plugin surface projection",
      "authority": "Derived exposure from managed module state, not a second domain truth source.",
      "default_policy": "post_apply_sync_then_reload_prompt_when_cache_changes",
      "mutation_scope": "codex_plugin_registry_and_skill_projection_only"
    }
  ],
  "components": [
    "app_binary",
    "runtime_toolchain",
    "agent_package_channel",
    "capability_exposure"
  ],
  "runtime_toolchain_required_projection_fields": [
    "current_pointer",
    "staged_root",
    "rollback_pointer"
  ],
  "operation_modes": {
    "status": "read_only_projection",
    "check": "read_only_projection",
    "plan": "read_only_projection",
    "apply": "controlled_projection",
    "repair": "controlled_projection",
    "rollback": "controlled_projection"
  },
  "receipt_write_policy": {
    "status": "read_only",
    "check": "read_only",
    "plan": "read_only",
    "apply": "projection_only_no_receipt_write",
    "repair": "projection_only_no_receipt_write",
    "rollback": "projection_only_no_receipt_write"
  },
  "component_receipt_shape": {
    "schema_version": "opl_managed_update_component_receipt.v1",
    "required_fields": [
      "source_manifest_ref",
      "from_version",
      "from_digest",
      "to_version",
      "to_digest",
      "verify_result",
      "activated_at",
      "post_apply_hooks",
      "rollback_ref",
      "repair_action"
    ],
    "identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha",
      "runtime_version",
      "current_pointer",
      "staged_root",
      "plugin_manifest_hash",
      "skill_pack_hash",
      "generated_surface_hash"
    ]
  },
  "condition_shape": {
    "required_fields": [
      "type",
      "status",
      "reason",
      "message",
      "observed_generation"
    ],
    "status_values": [
      "True",
      "False",
      "Unknown"
    ],
    "style": "kubernetes_status_conditions"
  },
  "authority_boundary": {
    "can_silently_mutate_app_owned_runtime_root": true,
    "can_silently_update_clean_managed_modules": true,
    "can_sync_codex_plugin_skill_projection": true,
    "can_mutate_user_global_homebrew": false,
    "can_mutate_user_global_npm": false,
    "can_mutate_system_path_tools": false,
    "can_overwrite_dirty_or_developer_checkout": false,
    "can_write_domain_truth": false,
    "can_write_domain_memory_body": false,
    "can_mutate_domain_artifact_body": false,
    "can_create_owner_receipt": false,
    "can_claim_quality_or_export_verdict": false
  },
  "artifact_integrity": {
    "channel_tag_role": "selector_only",
    "content_identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha"
    ],
    "future_hardening": [
      "signed_channel_metadata",
      "metadata_expiry",
      "rollback_protection",
      "artifact_provenance",
      "sbom_ref"
    ]
  }
}
