{
  "schema_version": 1,
  "owner": "one-person-lab",
  "purpose": "managed_update_kernel_contract",
  "state": "active",
  "surface_id": "opl_managed_updater_kernel",
  "public_cli_surfaces": [
    "opl update status --json",
    "opl update check --json",
    "opl update plan --json",
    "opl update apply --component <component_id> --json",
    "opl update repair --receipt <receipt_id> --json",
    "opl update rollback --component <component_id> --json"
  ],
  "kernel_lifecycle": [
    "read_manifest",
    "read_current_state",
    "diff_plan",
    "fetch_artifacts",
    "verify",
    "stage",
    "activate",
    "post_apply",
    "write_receipt",
    "report_status_or_repair"
  ],
  "component_state_vocabulary": [
    "current",
    "update_available",
    "staged",
    "needs_restart",
    "needs_reload",
    "failed_with_repair",
    "skipped_manual_required"
  ],
  "idempotency_lock": {
    "lock_id": "opl_managed_updater_kernel.global",
    "lock_scope": "single_writer_for_fetch_verify_stage_activate_post_apply_write_receipt",
    "read_operations": [
      "status",
      "check",
      "plan"
    ],
    "exclusive_operations": [
      "apply",
      "repair",
      "rollback"
    ],
    "stale_after_seconds": 1800,
    "contention_policy": "report_in_progress_or_skip_without_parallel_stage_or_plugin_sync"
  },
  "providers": [
    {
      "provider_id": "runtime_substrate",
      "adapter_id": "runtime_substrate_adapter",
      "owner": "one-person-lab-app-and-opl-framework",
      "role": "app_owned_runtime_substrate_with_embedded_codex_executor",
      "authority": "App-owned runtime roots, current pointer, staged root, health smoke, and rollback pointer.",
      "default_policy": "silent_stage_apply_on_restart_or_startup_maintenance",
      "mutation_scope": "app_owned_runtime_root_only",
      "controlled_execution_path": "opl system startup-maintenance --json",
      "repair_action": "run_startup_maintenance",
      "rollback_action": "restart_app_with_previous_runtime_pointer_or_run_startup_maintenance"
    },
    {
      "provider_id": "capability_packages",
      "adapter_id": "capability_packages_adapter",
      "owner": "one-person-lab-managed-modules",
      "role": "GHCR module package channel for MAS/MAG/RCA/OMA ordinary users",
      "authority": "GHCR tag selects a channel target; digest or sha identifies installed content.",
      "default_policy": "silent_background_for_clean_managed_modules",
      "mutation_scope": "clean_opl_managed_module_roots_only",
      "auto_apply": {
        "mode": "auto_apply",
        "app_background_safe": true,
        "command_ref": "opl update apply --component capability_packages --json",
        "eligible_scope": "clean_opl_managed_module_roots_only",
        "eligible_when": [
          "default managed module root is missing and can be installed into the managed root",
          "installed module origin is managed_root",
          "module health status is ready or package-channel updateable",
          "git dirty is false",
          "git sync status is not ahead, diverged, no_upstream, or unknown"
        ],
        "blocked_when": [
          "dirty checkout",
          "developer checkout",
          "sibling workspace or env override source",
          "ahead, diverged, no_upstream, or unknown git state",
          "missing digest, sha256, source fingerprint, or git head identity after apply"
        ]
      },
      "post_apply_actions": [
        "reconcile_modules",
        "sync_skills",
        "codex_surface"
      ]
    },
    {
      "provider_id": "codex_surface",
      "adapter_id": "codex_surface_status_adapter",
      "owner": "one-person-lab-connect",
      "role": "Codex plugin registry, plugin-packaged skills, and generated OMA plugin surface projection",
      "authority": "Derived exposure from managed module state, not a second domain truth source.",
      "default_policy": "post_apply_projection_then_reload_prompt_when_cache_changes",
      "mutation_scope": "projection_only_no_opl_update_apply_component_target",
      "apply_allowed": false
    },
    {
      "provider_id": "companion_tools",
      "adapter_id": "companion_tools_status_adapter",
      "owner": "one-person-lab-companion-tools",
      "role": "recommended Office and document extraction tool status class",
      "authority": "Companion tools such as officecli and mineru_open_api are tool availability, not runtime substrate or domain truth.",
      "default_policy": "manual_companion_status_or_explicit_companion_apply",
      "mutation_scope": "recommended_companion_tools_only"
    },
    {
      "provider_id": "workflow_profile",
      "adapter_id": "workflow_profile_adapter",
      "owner": "opl-flow",
      "role": "OPL Flow workflow profile status and semantic merge guidance",
      "authority": "User Codex profile surfaces require semantic merge and must not be silently overwritten.",
      "default_policy": "semantic_merge_required_no_silent_overwrite",
      "mutation_scope": "projection_only_no_opl_update_apply_component_target",
      "apply_allowed": false
    }
  ],
  "components": [
    "runtime_substrate",
    "capability_packages",
    "codex_surface",
    "companion_tools",
    "workflow_profile"
  ],
  "component_classes": [
    "runtime_substrate",
    "capability_packages",
    "codex_surface",
    "companion_tools",
    "workflow_profile"
  ],
  "legacy_component_aliases": [
    {
      "legacy_component_id": "runtime_toolchain",
      "component_id": "runtime_substrate",
      "scope": "transition_cli_selector_only"
    },
    {
      "legacy_component_id": "codex_cli_fallback",
      "component_id": "runtime_substrate",
      "scope": "transition_cli_selector_only"
    },
    {
      "legacy_component_id": "agent_packages",
      "component_id": "capability_packages",
      "scope": "transition_cli_selector_only"
    },
    {
      "legacy_component_id": "agent_package_channel",
      "component_id": "capability_packages",
      "scope": "transition_cli_selector_only"
    },
    {
      "legacy_component_id": "capability_exposure",
      "component_id": "codex_surface",
      "scope": "transition_cli_selector_only"
    }
  ],
  "runtime_substrate_required_projection_fields": [
    "current_pointer",
    "staged_root",
    "rollback_pointer"
  ],
  "operation_modes": {
    "status": "read_only_projection",
    "check": "read_only_projection",
    "plan": "read_only_projection",
    "apply": "controlled_apply",
    "repair": "controlled_repair",
    "rollback": "controlled_rollback"
  },
  "receipt_write_policy": {
    "status": "read_only",
    "check": "read_only",
    "plan": "read_only",
    "apply": "recorded_component_receipt",
    "repair": "recorded_component_receipt",
    "rollback": "recorded_component_receipt"
  },
  "runner_result_shape": {
    "surface_kind": "opl_managed_update_execution",
    "lock_status_values": [
      "acquired",
      "released",
      "held"
    ],
    "execution_status_values": [
      "completed",
      "skipped",
      "manual_required",
      "failed_with_repair"
    ],
    "adapter_result_status_values": [
      "completed",
      "skipped",
      "manual_required",
      "failed"
    ],
    "adapter_post_apply_action_shape": {
      "required_fields": [
        "action_id",
        "command_ref",
        "status",
        "result_ref",
        "result"
      ],
      "status_values": [
        "completed",
        "skipped",
        "manual_required",
        "failed"
      ]
    },
    "adapter_status_detail_shape": {
      "required_fields": [
        "component_state",
        "auto_apply_eligible",
        "app_background_safe",
        "clean_managed_targets_count",
        "manual_required_targets_count",
        "post_apply_status",
        "reload_status"
      ],
      "post_apply_status_values": [
        "not_run",
        "completed",
        "manual_required",
        "failed",
        "skipped",
        "unknown"
      ],
      "reload_status_values": [
        "not_required",
        "recommended",
        "required",
        "manual_required",
        "unknown"
      ]
    },
    "reload_guidance_shape": {
      "required_fields": [
        "reload_required",
        "reload_recommended",
        "reload_targets",
        "command_ref",
        "reason"
      ],
      "reload_targets": [
        "one_person_lab_app",
        "codex_plugin_cache"
      ]
    },
    "runtime_substrate_adapter_result_shape": {
      "required_fields": [
        "action",
        "receipt_ref",
        "rollback_ref",
        "repair_action"
      ],
      "controlled_execution_path": "startup_maintenance_runtime_substrate_adapter"
    },
    "receipt_ledger_file": "managed-update-component-receipts.json",
    "lock_file": "managed-update-kernel.lock"
  },
  "component_receipt_shape": {
    "schema_version": "opl_managed_update_component_receipt.v1",
    "required_fields": [
      "source_manifest_ref",
      "from_version",
      "from_digest",
      "to_version",
      "to_digest",
      "verify_result",
      "activated_at",
      "post_apply_hooks",
      "rollback_ref",
      "repair_action",
      "apply_mode",
      "status_detail",
      "post_apply_action_statuses",
      "reload_guidance"
    ],
    "identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha",
      "runtime_version",
      "current_pointer",
      "staged_root",
      "plugin_manifest_hash",
      "skill_pack_hash",
      "generated_surface_hash"
    ]
  },
  "condition_shape": {
    "required_fields": [
      "type",
      "status",
      "reason",
      "message",
      "observed_generation"
    ],
    "status_values": [
      "True",
      "False",
      "Unknown"
    ],
    "style": "kubernetes_status_conditions"
  },
  "authority_boundary": {
    "can_silently_mutate_app_owned_runtime_root": true,
    "can_silently_update_clean_managed_modules": true,
    "can_sync_codex_plugin_skill_projection": true,
    "can_mutate_user_global_homebrew": false,
    "can_mutate_user_global_npm": false,
    "can_mutate_system_path_tools": false,
    "can_overwrite_dirty_or_developer_checkout": false,
    "can_write_domain_truth": false,
    "can_write_domain_memory_body": false,
    "can_mutate_domain_artifact_body": false,
    "can_create_owner_receipt": false,
    "can_claim_quality_or_export_verdict": false
  },
  "artifact_integrity": {
    "channel_tag_role": "selector_only",
    "content_identity_fields": [
      "digest",
      "sha256",
      "source_fingerprint",
      "git_head_sha"
    ],
    "future_hardening": [
      "signed_channel_metadata",
      "metadata_expiry",
      "rollback_protection",
      "artifact_provenance",
      "sbom_ref"
    ]
  }
}
