{
  "schema_version": 1,
  "owner": "one-person-lab",
  "purpose": "managed_update_kernel_contract",
  "state": "active",
  "surface_id": "opl_managed_updater_kernel",
  "public_cli_surfaces": [
    "opl update status --json",
    "opl update check --json",
    "opl update plan --json",
    "opl update apply --json",
    "opl update repair --receipt <receipt_id> --json",
    "opl update rollback --json",
    "opl packages list --json",
    "opl packages install --manifest-url <url> --trust-tier <tier> --json",
    "opl packages update --json",
    "opl packages enable --package-id <id> --json",
    "opl packages disable --package-id <id> --json",
    "opl packages repair --package-id <id> --json",
    "opl packages rollback --package-id <id> --json",
    "opl packages uninstall --package-id <id> --json"
  ],
  "kernel_lifecycle": [
    "read_manifest",
    "read_current_state",
    "diff_plan",
    "fetch_artifacts",
    "verify",
    "stage",
    "activate",
    "post_apply",
    "write_receipt",
    "report_status_or_repair"
  ],
  "component_state_vocabulary": [
    "current",
    "update_available",
    "staged",
    "needs_restart",
    "needs_reload",
    "failed_with_repair",
    "skipped_manual_required"
  ],
  "base_dependency_catalog_contract": {
    "surface_kind": "opl_base_managed_dependency_catalog.v1",
    "required_dependency_fields": [
      "dependency_id",
      "dependency_kind",
      "installed",
      "version",
      "latest_version",
      "currentness",
      "ownership",
      "update_mode",
      "update_action"
    ],
    "currentness_values": [
      "current",
      "update_available",
      "unknown",
      "missing"
    ],
    "update_mode_values": [
      "silent_managed",
      "explicit_owner_delegated",
      "detect_only_guidance"
    ],
    "silent_managed_scope": [
      "opl_managed_codex_cli",
      "opl_framework_temporal_sdk_generation",
      "opl_managed_officecli",
      "opl_managed_mineru_open_api"
    ],
    "external_dependency_policy": {
      "recognized_owner_kinds": [
        "homebrew_formula",
        "homebrew_cask",
        "global_npm"
      ],
      "update_action_required_fields": [
        "action_id",
        "label",
        "surface",
        "delegated_surface",
        "payload_fields",
        "confirmation_required",
        "danger_level",
        "owner_kind",
        "auto_apply_allowed"
      ],
      "confirmation_required": true,
      "auto_apply_allowed": false,
      "unverified_owner_action": null,
      "system_path_overwrite_allowed": false,
      "temporal_server_currentness_inference_allowed": false
    },
    "flow_dependencies_projection": {
      "field": "flow_dependencies",
      "source": "installed_opl_flow_package_lock_workflow_policy_migration_dependencies",
      "required_fields": [
        "dependency_id",
        "dependency_kind",
        "activation",
        "lifecycle_owner",
        "update_mode",
        "installed",
        "currentness"
      ],
      "legacy_ids_field": "flow_dependency_ids",
      "app_hardcoded_dependency_classification_allowed": false
    }
  },
  "coordination_roles": [
    "executable_target",
    "derived_projection",
    "owner_handoff"
  ],
  "lifecycle_owners": [
    {
      "lifecycle_owner": "opl_base",
      "label": "OPL Base",
      "public_surface": "opl update",
      "provider_id": "runtime_substrate",
      "nested_status_fields": [
        "dependency_status",
        "integration_status"
      ]
    },
    {
      "lifecycle_owner": "opl_app",
      "label": "OPL App",
      "public_surface": "One Person Lab App updater and App state",
      "provider_id": "installation_carrier",
      "required_status_fields": [
        "host_update_route",
        "host_executor_required"
      ]
    },
    {
      "lifecycle_owner": "opl_packages",
      "label": "OPL Packages",
      "public_surface": "opl packages",
      "provider_id": "capability_packages",
      "nested_status_fields": [
        "projection_status",
        "profile_migration_status"
      ]
    }
  ],
  "update_plane_state_machine": {
    "purpose": "three_owner_coordination_plane_for_opl_base_opl_app_and_opl_packages",
    "state_axis": [
      "auto_apply",
      "controlled_apply",
      "prompt_only",
      "projection_only"
    ],
    "states": [
      {
        "state_id": "auto_apply",
        "meaning": "Framework may fetch, verify, stage, activate package content, run post-apply hooks, and write a component receipt without asking when an installed digest-locked Package target is clean, including an App-carried bundled Full runtime closure selected by the canonical bundled catalog.",
        "allowed_component_classes": [
          "opl_packages"
        ],
        "required_identity": [
          "digest",
          "sha256",
          "source_fingerprint",
          "git_head_sha"
        ],
        "forbidden_when": [
          "dirty checkout",
          "developer checkout",
          "ahead",
          "diverged",
          "no_upstream",
          "unknown identity"
        ]
      },
      {
        "state_id": "controlled_apply",
        "meaning": "Framework may mutate only an OPL/App-owned runtime root through an explicit controlled command and receipt.",
        "allowed_component_classes": [
          "opl_base"
        ],
        "required_identity": [
          "current_pointer",
          "staged_root",
          "rollback_pointer",
          "runtime_version"
        ],
        "forbidden_when": [
          "would mutate Homebrew",
          "would mutate global npm",
          "would mutate system PATH Codex",
          "would mutate system Temporal",
          "target is developer checkout",
          "framework source is an explicit developer/source override"
        ]
      },
      {
        "state_id": "prompt_only",
        "meaning": "Framework may show owner-specific route guidance, but the actual update belongs to the host, App release, package manager, or Codex semantic merge owner.",
        "allowed_component_classes": [
          "opl_app"
        ],
        "required_identity": [
          "route_owner",
          "route_ref",
          "manual_required_reason"
        ],
        "forbidden_when": [
          "would claim host carrier replacement",
          "would silently overwrite user profile",
          "would require host executor without host proof"
        ]
      },
      {
        "state_id": "projection_only",
        "meaning": "Framework may expose status, reload guidance, refs, and safe action labels derived from another owner; it is not an apply target.",
        "allowed_component_classes": [
          "opl_app"
        ],
        "required_identity": [
          "source_projection_ref",
          "authority_boundary"
        ],
        "forbidden_when": [
          "would create domain truth",
          "would create owner receipt",
          "would claim App release currentness",
          "would claim carrier update complete"
        ]
      }
    ],
    "component_routes": [
      {
        "component_class": "opl_app",
        "coordination_role": "owner_handoff",
        "canonical_route_state": "prompt_only",
        "readback_state": "projection_only",
        "owner": "one-person-lab-app",
        "examples": [
          "desktop_app_bundle",
          "docker_webui_image",
          "linux_package_carrier"
        ],
        "not_runtime_substrate": true,
        "not_opl_update_apply_target": true
      },
      {
        "component_class": "opl_base",
        "coordination_role": "executable_target",
        "canonical_route_state": "controlled_apply",
        "readback_state": "controlled_apply",
        "owner": "one-person-lab-app-and-opl-framework",
        "examples": [
          "app_owned_runtime_root",
          "embedded_codex_executor",
          "opl_framework_runtime_artifact_channel"
        ],
        "not_installation_carrier": true,
        "not_global_toolchain": true
      },
      {
        "component_class": "opl_packages",
        "coordination_role": "executable_target",
        "canonical_route_state": "auto_apply",
        "readback_state": "auto_apply",
        "owner": "one-person-lab-managed-modules",
        "examples": [
          "domain_module_package_channel",
          "framework_capability_package_channel",
          "catalog_owned_bundled_full_runtime_packages"
        ],
        "not_installation_carrier": true,
        "not_domain_truth": true
      }
    ]
  },
  "idempotency_lock": {
    "lock_id": "opl_managed_updater_kernel.global",
    "lock_scope": "single_writer_for_fetch_verify_stage_activate_post_apply_write_receipt",
    "read_operations": [
      "status",
      "check",
      "plan"
    ],
    "exclusive_operations": [
      "apply",
      "repair",
      "rollback"
    ],
    "stale_after_seconds": 1800,
    "contention_policy": "report_in_progress_or_skip_without_parallel_stage_or_plugin_sync"
  },
  "owner_route_contract": {
    "required_fields": [
      "owner",
      "authority_surface",
      "route_kind",
      "readback_ref",
      "apply_owner",
      "package_manager_claim",
      "forbidden_claims"
    ],
    "route_kinds": [
      "projection_only",
      "manual_owner_route",
      "controlled_framework_executor",
      "clean_managed_package_executor"
    ],
    "package_manager_claim_must_be_false": true,
    "purpose": "Each managed update component must name the owner/readback route that owns truth and apply semantics so the kernel remains a projection/receipt surface, not a general package manager."
  },
  "owner_execution_boundary_contract": {
    "required_fields": [
      "owner_executor_id",
      "executor_kind",
      "runner_can_execute",
      "allowed_operations",
      "readback_ref",
      "receipt_projection",
      "diagnostic_only",
      "package_manager_claim",
      "notes"
    ],
    "executor_kinds": [
      "none",
      "diagnostic_readback",
      "manual_owner_route",
      "controlled_framework_executor",
      "clean_managed_package_executor"
    ],
    "receipt_projection_values": [
      "read_only_projection",
      "component_receipt_with_owner_route",
      "external_owner_receipt_required"
    ],
    "runner_can_execute_only_for": [
      "opl_base",
      "opl_packages"
    ],
    "package_manager_claim_must_be_false": true,
    "purpose": "reuse-first: allow owner-routed managed update boundary. The runner must name the owner executor and readback boundary per component before apply/repair/rollback, so prompt-only and projection-only components remain receipt/readback projections instead of generic package-manager targets."
  },
  "providers": [
    {
      "lifecycle_owner": "opl_app",
      "provider_id": "installation_carrier",
      "adapter_id": "installation_carrier_status_adapter",
      "owner": "one-person-lab-app",
      "role": "App installation carrier status projection for macOS app, Docker/WebUI image, and Linux package carrier routes",
      "authority": "App-owned install/update taxonomy defines carrier variants; Framework projects status and safe routes only.",
      "default_policy": "carrier_specific_status_with_host_update_route",
      "mutation_scope": "projection_only_no_opl_update_apply_component_target",
      "apply_allowed": false,
      "managed_kernel_apply_allowed": false,
      "opl_update_apply_must_not_claim_carrier_update_complete": true,
      "status_fields": [
        "carrier_type",
        "carrier_status",
        "currentness",
        "update_available",
        "image_ref",
        "image_digest",
        "container_id",
        "compose_file",
        "package_manager",
        "package_name",
        "installed_version",
        "detected_package_managers",
        "host_update_route",
        "host_update_route_examples",
        "host_executor_required",
        "manual_required",
        "manual_required_when",
        "data_volume_preservation",
        "repair_actions"
      ],
      "carrier_variants": [
        {
          "carrier_type": "docker_webui_image",
          "carrier_status_source": "GHCR image digest, compose/container image readback, and Docker/WebUI installer or smoke-gate diagnostics",
          "host_update_route": "host_executor_runs_documented_installer_or_compose_pull_and_up",
          "host_update_route_examples": [
            "install-docker-webui.sh --yes --update",
            "install-docker-webui.ps1 -Yes -Update",
            "docker compose pull && docker compose up -d"
          ],
          "managed_kernel_apply_allowed": false,
          "host_executor_required": true,
          "manual_required": true,
          "currentness_values": [
            "unknown",
            "current",
            "update_available"
          ],
          "data_volume_preservation_proof_required": true,
          "preserved_mounts": [
            "OnePersonLab/data -> /data",
            "OnePersonLab/projects -> /projects"
          ]
        },
        {
          "carrier_type": "linux_package_carrier",
          "carrier_status_source": "host package manager, package metadata, or documented Linux package carrier readback",
          "host_update_route": "host_package_manager_or_documented_host_executor",
          "host_update_route_examples": [
            "sudo apt update && sudo apt install --only-upgrade one-person-lab",
            "sudo dnf upgrade one-person-lab",
            "sudo zypper update one-person-lab"
          ],
          "managed_kernel_apply_allowed": false,
          "host_executor_required": true,
          "manual_required": true,
          "manual_required_when": [
            "package_manager_requires_sudo_or_root",
            "host_policy_disallows_app_executor",
            "repository_or_signature_configuration_required"
          ],
          "currentness_values": [
            "unknown",
            "current",
            "update_available"
          ]
        }
      ],
      "repair_action_scope": "carrier_specific_check_download_host_route_or_manual_recovery_only"
    },
    {
      "lifecycle_owner": "opl_base",
      "provider_id": "runtime_substrate",
      "adapter_id": "runtime_substrate_adapter",
      "owner": "one-person-lab-app-and-opl-framework",
      "role": "app_owned_runtime_substrate_with_embedded_codex_executor",
      "authority": "App-owned runtime roots, current pointer, staged root, health smoke, and rollback pointer.",
      "default_policy": "silent_stage_apply_on_restart_or_startup_maintenance",
      "pending_activation_trigger": "OPL_APP_PROCESS_INSTANCE_ID differs from the staging marker",
      "pending_reconcile_policy": "same version or artifact identity is a no-op that preserves the original staging marker",
      "daily_background_activation_allowed": false,
      "mutation_scope": "app_owned_runtime_root_only",
      "controlled_execution_path": "opl system startup-maintenance --json",
      "repair_action": "run_startup_maintenance",
      "rollback_action": "rollback_opl_framework_runtime_or_restart_app_with_previous_runtime_pointer",
      "status_fields": [
        "current_pointer",
        "staged_root",
        "rollback_pointer",
        "opl_framework_runtime",
        "dependency_catalog",
        "pending_runtime_activation"
      ],
      "dependency_currentness_refresh_policy": {
        "status": "receipt_or_process_cache_only",
        "check": "bounded_upstream_lookup",
        "plan": "bounded_upstream_lookup",
        "apply": "bounded_upstream_lookup_then_owner_scoped_reconcile",
        "fast_app_state_network_lookup_allowed": false
      }
    },
    {
      "lifecycle_owner": "opl_packages",
      "provider_id": "capability_packages",
      "adapter_id": "capability_packages_adapter",
      "owner": "one-person-lab-managed-modules",
      "role": "Installed OPL Package lock reconciliation through the canonical package lifecycle",
      "authority": "Each installed root package lock selects its manifest/channel target; App-carried bundled roots select the canonical bundled Full runtime catalog; digest and package lifecycle receipt identify installed content.",
      "default_policy": "silent_background_for_clean_digest_locked_installed_packages",
      "mutation_scope": "installed_root_package_locks_or_catalog_owned_bundled_full_runtime_root_closure_only",
      "source_policy": {
        "authority": "effective Developer Mode and per-package source preference",
        "developer_checkout_effect": "compare_installed_lock_to_live_release_set_target_then_relock_and_reproject_from_the_exact_effective_checkout_without_overwriting_checkout_content",
        "managed_effect": "compare_installed_lock_to_release_set_target_then_apply_only_when_identity_differs",
        "bundled_full_runtime_effect": "compare bundled locks to canonical catalog manifest payload content owner and catalog authority then independently update each selected root and its required dependency closure through opl update apply",
        "external_package_effect": "manual_explicit_update_only"
      },
      "release_catalog_cache_policy": {
        "live_refresh_operations": [
          "check",
          "plan",
          "apply"
        ],
        "status_and_fast_app_state": "validated_cache_or_framework_projection_only",
        "dry_run_refresh": "live_lookup_without_catalog_cache_persistence",
        "fresh_cache_max_age_hours": 24,
        "expired_cache_role": "last_known_good_read_model_only"
      },
      "currentness_identity_fields": [
        "source_kind",
        "package_version",
        "manifest_sha256",
        "content_digest",
        "artifact_digest"
      ],
      "auto_apply": {
        "mode": "auto_apply",
        "app_background_safe": true,
        "command_ref": "opl packages update --json",
        "bundled_full_runtime_command_ref": "opl update apply --json",
        "eligible_scope": "clean_digest_locked_installed_root_package_locks_only",
        "eligible_when": [
          "installed root package lock exists",
          "effective source policy selects managed release target with a different identity",
          "or effective source policy selects an available developer checkout whose lock source, version, manifest digest, content digest, or artifact digest differs from the live Release Set target",
          "manifest sha256, content digest, and lock ref are present",
          "physical package surface has no recorded failure"
        ],
        "blocked_when": [
          "dirty checkout",
          "developer checkout selected but unavailable",
          "external package without Framework source authority",
          "missing manifest sha256, content digest, or lock ref",
          "physical surface requires repair",
          "package lifecycle update failed without overwriting the installed lock"
        ],
        "current_noop_receipt_policy": "do_not_write_component_receipt"
      },
      "bundled_full_runtime_reconciliation": {
        "authority_surface": "contracts/opl-framework/bundled-full-runtime-package-catalog.json",
        "public_apply_command": "opl update apply --json",
        "public_selector": null,
        "top_level_selection_policy": "component_neutral_selected_managed_update_components",
        "package_adapter_component_id": "opl_packages",
        "bundled_source_plane_scope": "opl_packages_adapter_only",
        "top_level_components_forced_or_excluded": [],
        "root_package_ids_exact": [
          "mag",
          "mas",
          "obf",
          "oma",
          "opl-flow",
          "rca"
        ],
        "dependency_closure_package_ids_exact": [
          "mag",
          "mas",
          "mas-scholar-skills",
          "obf",
          "oma",
          "opl-flow",
          "rca"
        ],
        "currentness_identity_fields": [
          "source_kind",
          "package_version",
          "manifest_sha256",
          "content_digest",
          "owner_source_commit",
          "carrier_authority.catalog_ref",
          "carrier_authority.catalog_sha256"
        ],
        "managed_lifecycle_action": "update",
        "managed_provenance": {
          "trigger": "managed_update_kernel_apply",
          "initiator": "opl_managed_update_kernel",
          "source_policy": "bundled_full_runtime_modules"
        },
        "execution_receipt_authority": {
          "framework_commit_field": "result.framework_commit",
          "catalog_ref_field": "result.catalog_ref",
          "catalog_sha256_field": "result.catalog_sha256",
          "target_receipt_ref_field": "target.result.lifecycle_receipt.receipt_ref",
          "component_aggregate_binding_field": "component_receipt.adapter_result_ref",
          "duplicate_target_receipt_ref_list": false
        },
        "source_root_authority": {
          "required_for_public_apply": true,
          "accepted_authority": "catalog_exact_explicit_roots_or_controlled_full_runtime_carrier",
          "missing_or_incomplete_policy": "fail_closed_without_generic_package_fallback"
        },
        "post_apply_currentness": {
          "writes_performed": false,
          "command_ref": "opl packages status --json",
          "ordinary_package_update_guidance_allowed": false
        },
        "recovery": {
          "command_ref": "opl update plan --json, then opl update apply --json, then opl packages status --json",
          "configure_codex_allowed": false
        },
        "orchestration": {
          "failure_policy": "fail_open_per_root_package",
          "successful_root_policy": "commit_and_retain",
          "failed_root_policy": "rollback_only_the_failed_root_and_its_required_dependency_closure",
          "continuation_policy": "continue_independent_remaining_roots",
          "aggregate_status_values": [
            "completed",
            "partial",
            "failed"
          ],
          "target_status_values": [
            "completed",
            "failed",
            "manual_required",
            "skipped"
          ],
          "component_receipt_policy": "record_partial_aggregate_with_per_target_lifecycle_and_rollback_details"
        },
        "package_mutation_unit": {
          "scope": "one_root_package_and_its_required_dependency_closure",
          "failure_policy": "fail_closed_with_local_prestate_restored",
          "snapshot_policy": "exact_paths_written_by_this_package_unit_only",
          "commit_point": "after_catalog_and_materialized_lock_final_verification",
          "rollback_success_evidence": "restored_snapshot_paths_mechanically_match_local_prestate",
          "unproven_restore_reporting": "local_prestate_restored_is_false_or_null_never_true",
          "excluded_snapshot_surfaces": [
            "other_root_packages",
            "managed_update_component_receipt_ledger",
            "unrelated_home_or_codex_home_ancestor_trees"
          ],
          "package_lifecycle_exclusion": {
            "required": true,
            "scope": "single_package_preview_snapshot_apply_verify_and_local_commit_or_rollback",
            "release_policy": "release_before_the_next_independent_root"
          }
        },
        "caller_action_policy": {
          "system_configure_and_startup_reconciliation": "install",
          "managed_update_kernel_apply": "update"
        },
        "explicit_public_bundled_source_policy": "fail_closed_internal_only"
      },
      "transaction_status_fields": [
        "projection_status",
        "profile_migration_status"
      ],
      "transaction_guards": {
        "installed_digest_required": true,
        "dirty_checkout_policy": "fail_closed_no_overwrite",
        "developer_checkout_policy": "source_reconcile_then_protect_no_channel_overwrite",
        "codex_skill_plugin_sync": "same_transaction_post_apply",
        "receipt_policy": "single_package_transaction_receipt"
      },
      "profile_migration_policy": {
        "semantic_merge_required": true,
        "silent_overwrite_allowed": false,
        "failure_policy": "fail_closed_owner_handoff"
      },
      "post_apply_actions": [
        "reconcile_packages",
        "sync_skills",
        "sync_codex_skill_plugin_projection"
      ],
      "partial_outcome_policy": "apply_all_eligible_targets_run_post_apply_when_any_target_changed_and_report_current_changed_manual_failed_separately"
    }
  ],
  "components": [
    "opl_base",
    "opl_app",
    "opl_packages"
  ],
  "component_classes": [
    "opl_base",
    "opl_app",
    "opl_packages"
  ],
  "app_action_consumer_policy": {
    "purpose": "App and Settings update actions consume this managed update coordinator instead of hand-writing package, carrier, or runtime update shells.",
    "canonical_delegated_surfaces": {
      "module_sync": "opl packages update",
      "settings_sync_capabilities": "opl packages update",
      "settings_apply_opl_packages": "opl packages update",
      "settings_check_app_update": "opl app state --profile fast",
      "settings_rollback_runtime_substrate": "opl update rollback"
    },
    "non_goals": [
      "does_not_replace_target_bound_workspace_or_quest_skill_sync",
      "does_not_claim_app_release_currentness",
      "does_not_turn_projection_status_or_profile_migration_status_into_lifecycle_owners"
    ]
  },
  "runtime_substrate_required_projection_fields": [
    "current_pointer",
    "staged_root",
    "rollback_pointer",
    "opl_framework_runtime"
  ],
  "operation_modes": {
    "status": "read_only_projection",
    "check": "read_only_projection",
    "plan": "read_only_projection",
    "apply": "controlled_apply",
    "repair": "controlled_repair",
    "rollback": "controlled_rollback"
  },
  "receipt_write_policy": {
    "status": "read_only",
    "check": "read_only",
