    "pack_can_create_owner_receipt": false,
    "pack_can_create_domain_typed_blocker": false,
    "pack_can_closeout_fail_closed_rule_as_success": false,
    "tool_result_envelope_can_share_unsafe_data": false
  },
  "readback_contract": {
    "surface_kind": "opl_evidence_grounded_decision_agent_profile_source_readback_contract",
    "version": "evidence-grounded-decision-agent-profile-source-readback.v1",
    "source_module_ref": "src/modules/pack/evidence-grounded-decision-agent-profile.ts",
    "contract_ref": "contracts/opl-framework/evidence-grounded-decision-agent-profile.json",
    "exported_builder": "buildEvidenceGroundedDecisionAgentProfileReadback",
    "module_surface_readback_available": true,
    "readback_is_stable_json": true,
    "profile_catalog_can_claim_target_agent_design": false,
    "source_derived_design_refs_required_for_reference_backed_build": true,
    "readback_can_claim_runtime_ready": false,
    "readback_can_claim_domain_ready": false
  },
  "consumption_contract": {
    "pack_consumers_may": [
      "inspect_profile_identity",
      "read_first_class_object_names",
      "read_module_ownership",
      "read_fail_closed_rules",
      "read_forbidden_claims",
      "read_non_live_module_surface_refs"
    ],
    "pack_consumers_must_not": [
      "treat_contract_as_domain_agent",
      "treat_profile_catalog_as_agent_design_source",
      "treat_contract_validation_as_quality_verdict",
      "treat_source_readback_as_owner_receipt",
      "treat_focused_test_as_production_ready"
    ]
  }
}
