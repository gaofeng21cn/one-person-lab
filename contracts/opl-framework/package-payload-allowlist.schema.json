{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/package-payload-allowlist.schema.json",
  "title": "OPL First-Party Package Payload Allowlist",
  "type": "object",
  "required": [
    "surface_kind",
    "package_id",
    "plugin_id",
    "source_repo",
    "source_root",
    "paths"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_package_payload_allowlist.v1"
    },
    "package_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "plugin_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "source_repo": {
      "type": "string",
      "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$"
    },
    "source_root": {
      "type": "string",
      "pattern": "^(?:\\.|(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+)$"
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f\\u007f]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
