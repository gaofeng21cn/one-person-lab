{
  "surface_id": "opl_docker_webui_seed_contract",
  "schema_version": "opl_docker_webui_seed_contract.v1",
  "owner": "OPL Framework",
  "purpose": "Define the Framework-owned image seed, data-volume install manifest, and startup-maintenance reconcile receipt boundary for Docker/WebUI runtimes.",
  "runtime_truth_boundary": {
    "source_of_truth": "OPL Framework install/update/receipt runtime truth",
    "not_second_runtime_truth": true,
    "webui_shell_owner": "one-person-lab-app / opl-aion-shell",
    "canonical_image_manifest_path": "/opt/opl/image-manifest.json",
    "canonical_seed_metadata_path": "/opt/opl/seed/metadata.json",
    "state_file": "${OPL_STATE_DIR:-<data-dir>/opl/state}/install-manifest.json",
    "commands": [
      "opl system docker-webui doctor --json",
      "opl system seed-apply --from <seed-dir> --data-dir <data-dir> --projects-dir <projects-dir> --json",
      "opl system startup-maintenance --json"
    ]
  },
  "doctor_read_model": {
    "command": "opl system docker-webui doctor --json",
    "surface_kind": "opl_docker_webui_doctor",
    "execution_policy": "read_only_json_first",
    "stable_status_values": [
      "ok",
      "attention",
      "not_configured"
    ],
    "startup_phase_values": [
      "not_configured",
      "api_key_missing",
      "needs_startup_maintenance",
      "initializing",
      "seed_applied",
      "enterable",
      "repairable_failure"
    ],
    "startup_state_fields": [
      "phase",
      "api_key_required",
      "api_key_present",
      "seed_applied",
      "initializing",
      "enterable",
      "needs_startup_maintenance",
      "repairable_failure",
      "runtime_readiness_claim",
      "can_claim_runtime_ready",
      "can_claim_release_ready",
      "can_claim_module_current",
      "reasons"
    ],
    "diagnostic_summary_fields": [
      "status",
      "image_version",
      "image_digest",
      "data_dir",
      "data_dir_status",
      "projects_dir",
      "projects_dir_status",
      "browser_url",
      "browser_url_status",
      "install_manifest_status",
      "seed_status",
      "startup_maintenance_status",
      "api_key_status",
      "next_action_ids",
      "diagnostic_friendly",
      "runtime_readiness_claim",
      "can_claim_runtime_ready"
    ],
    "observation_status_values": [
      "configured",
      "not_configured",
      "exists",
      "missing",
      "found",
      "invalid",
      "not_visible",
      "present"
    ],
    "next_action_status_values": [
      "recommended",
      "available"
    ],
    "api_key_readback": {
      "source": "local_codex_defaults_read_model",
      "stable_status_values": [
        "present",
        "missing"
      ],
      "secret_value_redacted": true,
      "write_surface": "opl system configure-codex --api-key-stdin --json"
    },
    "startup_maintenance_status_values": [
      "needed",
      "initializing",
      "seed_applied",
      "repairable_failure"
    ],
    "forbidden_claims": [
      "release_ready",
      "runtime_ready",
      "module_current",
      "domain_truth",
      "owner_receipt",
      "typed_blocker"
    ]
  },
  "image_manifest": {
    "seed_strategy_values": [
      "payload_manifest",
      "payload_preheated",
      "metadata_only"
    ],
    "stable_latest_policy": {
      "metadata_only_allowed": false,
      "forbidden_third_strategy_names": [
        "manifest_payload_dir"
      ]
    }
  },
  "seed_metadata": {
    "filename": "/opt/opl/seed/metadata.json",
    "schema": "dev.onepersonlab.opl-webui-image-seed.v1",
    "full_seed_minimum_component_ids": [
      "opl_framework",
      "codex_cli",
      "companion_skills",
      "domain_modules"
    ],
    "component_required_fields": [
      "id",
      "version",
      "source",
      "payload_path",
      "receipt_kind"
    ],
    "component_integrity_requirement": "Each component must provide sha256 or source_fingerprint.",
    "component_materialization": [
      {
        "component_id": "opl_framework",
        "materialized_path": "<data-dir>/opl/framework"
      },
      {
        "component_id": "codex_cli",
        "materialized_path": "<data-dir>/opl/toolchains/codex"
      },
      {
        "component_id": "companion_skills",
        "materialized_path": "<data-dir>/opl/skills"
      },
      {
        "component_id": "domain_modules",
        "materialized_path": "<data-dir>/opl/modules"
      }
    ]
  },
  "install_manifest_public_shape": {
    "component_ids": [
      "image_manifest",
      "opl_framework",
      "codex_cli",
      "companion_skills",
      "domain_modules",
      "data_dir",
      "projects_dir"
    ],
    "legacy_component_ids_not_public": [
      "framework_install_dir",
      "codex_toolchain",
      "modules_skills"
    ],
    "component_fields": [
      "component_id",
      "component_kind",
      "version",
      "source",
      "payload_path",
      "receipt_kind",
      "receipt_ref",
      "sha256",
      "source_fingerprint",
      "materialized_path",
      "size_bytes"
    ],
    "operation_kinds": [
      "image_seed",
      "managed_update",
      "migration"
    ]
  },
  "authority_boundary": {
    "can_write_domain_truth": false,
    "can_write_runtime_db": false,
    "can_write_provider_queue": false,
    "can_create_owner_receipt": false,
    "can_claim_ready_or_current": false,
    "api_key_configuration_is_separate": true
  }
}
