{
  "version": "v2",
  "contract_id": "opl_runtime_manager_contract",
  "contract_ref": "contracts/opl-framework/runtime-manager-contract.json",
  "scope": "opl_product_control_plane_over_provider_backed_family_runtime",
  "description": "Freezes the OPL Runtime Manager boundary. OPL owns Temporal provider selection, stage attempt ledger/index, diagnostics, status projection, optional native helper catalog, and high-frequency state indexes while domain repositories keep truth and quality authority.",
  "pack_bound_stage_run": {
    "surface_kind": "opl_pack_bound_stage_run_runtime_contract",
    "canonical_request_surface": "opl family-runtime attempt create",
    "binding_surface_kind": "opl_pack_bound_stage_quality_runtime_binding",
    "binding_owner": "opl_pack_compiler",
    "controller_workflow": "StageRunWorkflow",
    "child_workflow": "StageAttemptWorkflow",
    "raw_stage_run_start_cli_retired": true,
    "stage_run_cli_allowed_actions": [
      "query"
    ],
    "required_stage_run_fields": [
      "stage_run_id",
      "stage_run_invocation_id",
      "stage_run_spec_sha256",
      "stage_run_spec",
      "parent_route_decision_ref"
    ],
    "stage_run_id_derives_only_from": [
      "domain_id",
      "stage_id",
      "stage_run_invocation_id"
    ],
    "manifest_sha256_participates_in_stage_run_id": false,
    "manifest_sha256_participates_in_stage_run_spec_sha256": true,
    "currentness_observations_participate_in_stage_run_id_or_spec_sha256": false,
    "durable_launch_registry": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_run_launches",
    "register_exact_input_before_temporal_start": true,
    "same_invocation_same_spec_replays_existing_run": true,
    "same_invocation_different_spec_fails_closed": true,
    "explicit_new_stage_run_option": "--new-stage-run",
    "quality_path_new_attempt_compatibility_alias": true,
    "direct_unbound_stage_run_creation_forbidden": true
  },
  "owner_split": {
    "product_control_plane_owner": "one-person-lab",
    "online_runtime_substrate_owner": "provider_backed_family_runtime",
    "domain_truth_owners_projection": {
      "source_of_truth_ref": "src/kernel/standard-agent-registry.ts#family_runtime_profile",
      "runtime_projection": "runtimeDomainOwnerProfiles",
      "entry_fields": [
        "domain_id",
        "domain_owner",
        "executor_owner"
      ]
    },
    "concrete_executor_owner": "stage_selected_by_domain_contract"
  },
  "provider_runtime": {
    "provider_model": "provider_backed_stage_attempt_runtime",
    "standard_agent_default_runtime_path": "opl_temporal_hosted_autonomous",
    "temporal_hosted_autonomy_default_enabled": true,
    "codex_app_drives_long_running_tasks": false,
    "allowed_providers": [
      "temporal"
    ],
    "default_resolution": {
      "env": "OPL_FAMILY_RUNTIME_PROVIDER",
      "fallback": "temporal",
      "fail_closed_when_temporal_not_ready": true
    },
    "production_required_provider": "temporal",
    "production_candidate": "temporal",
    "retired_local_provider": "local_sqlite",
    "sqlite_sidecar_role": "projection_and_readback_index_only"
  },
  "manager_responsibilities": [
    "select_supported_family_runtime_provider",
    "project_provider_readiness_and_stage_attempt_history",
    "own_stage_attempt_index_and_provider_projection_contracts",
    "create_stage_runs_only_from_pack_bound_stage_quality_runtime_bindings",
    "persist_exact_stage_run_invocation_and_immutable_spec_before_temporal_start",
    "recover_pre_start_and_post_start_stage_run_launches_without_duplicate_execution",
    "orchestrate_bounded_stage_quality_attempt_roles_through_temporal_stage_run_controller",
    "materialize_validated_decisive_attempt_routes_as_target_stage_runs",
    "wire_provider_signal_delivery_transport",
    "project_runtime_status_into_opl_sessions_progress_artifacts",
    "provide_runtime_doctor_repair_resume_entrypoints",
    "catalog_optional_native_helpers",
    "catalog_high_frequency_state_indexes"
  ],
  "domain_registration_registry": {
    "surface_kind": "opl_stage_runtime_registration_registry",
    "version": "v1",
    "registration_status": "declared_projection_contracts",
    "source_of_truth_rule": "OPL indexes declared domain registration surfaces and must dereference domain-owned durable truth before acting.",
    "registered_domains_projection": {
      "source_of_truth_ref": "src/kernel/standard-agent-registry.ts#family_runtime_profile.runtime_manager_registration",
      "runtime_projection": "runtimeManagerDomainProfiles"
    },
    "required_domain_registration_fields": [
      "surface_kind",
      "registration_id",
      "domain_id",
      "domain_owner",
      "runtime_owner",
      "domain_entry_surface",
      "consumable_projection_refs",
      "state_index_inputs",
      "non_goals"
    ],
    "domain_surface_refs": [
      "/skill_catalog/skills/0/domain_projection/opl_stage_runtime_registration"
    ]
  },
  "standard_domain_agent_scaffold": {
    "surface_kind": "opl_standard_domain_agent_scaffold",
    "version": "standard-domain-agent-scaffold.v1",
    "owner": "one-person-lab",
    "state": "scaffold_contract_available",
    "command": "opl agents scaffold",
    "contract_ref": "contracts/opl-framework/standard-domain-agent-skeleton-contract.json",
    "generation_policy": {
      "scaffold_command_is_read_only": true,
      "creates_files": false,
      "default_mode": "describe_without_target_dir",
      "write_requires_explicit_target_dir": true,
      "scaffold_role": "physical_skeleton_and_lower_bound_guardrail",
      "scaffold_is_agent_design_template_source": false,
      "scaffold_shape_source_ref": "contracts/opl-framework/standard-domain-agent-skeleton-contract.json",
      "generate_command": "opl agents scaffold --target-dir <path> --domain-id <id>",
      "validate_command": "opl agents scaffold --validate <repo-dir>",
      "copy_existing_domain_repo_as_template": false
    },
    "design_source_boundary": {
      "scaffold_is_agent_design_template_source": false,
      "scaffold_can_cap_target_agent_design_ceiling": false,
      "scaffold_can_claim_target_agent_ready": false,
      "profile_catalog_is_lower_bound_guardrail": true,
      "reference_design_sources_remain_design_source": true,
      "source_derived_design_consumption_refs_required_for_reference_backed_agents": true
    },
    "authority_boundary": {
      "opl": "framework_runtime_development_primitives_contracts_read_models_projection_and_checklist_owner",
      "domain_agent": "domain_truth_quality_export_artifact_memory_body_and_owner_receipt_authority"
    }
  },
  "non_goals": [
    "not_a_domain_runtime_truth_owner",
    "not_a_domain_quality_verdict_owner",
    "not_a_domain_artifact_gate_owner",
    "not_a_domain_truth_owner",
    "not_a_concrete_executor",
    "not_a_private_fork_of_external_executor_runtime",
    "not_a_domain_temporal_server_owner"
  ],
  "native_helper_target": {
    "status": "contracted_optional_rust_helpers",
    "language": "rust",
    "protocol_ref": "contracts/opl-framework/native-helper-contract.json",
    "allowed_shape": "small_json_stdio_or_cli_helpers_managed_by_opl",
    "lifecycle": {
      "status_surface": "native_helper_target.lifecycle",
      "build_command": "npm run native:build",
      "prebuild_install_command": "npm run native:prebuild",
      "prebuild_pack_command": "npm run native:prebuild-pack",
      "prebuild_check_command": "npm run native:prebuild-check",
      "doctor_command": "npm run native:doctor",
      "repair_command": "npm run native:repair",
      "test_command": "npm run native:test",
      "packaged_source_files": [
        "Cargo.toml",
        "Cargo.lock",
        "native/opl-native-helper/Cargo.toml",
        "native/opl-native-helper/src",
        "scripts/native-helper-doctor.mjs",
        "scripts/native-helper-prebuild.mjs",
        "scripts/native-helper-repair.mjs"
      ],
      "prebuild_cache_strategy": {
        "manifest": "native-helper-prebuilds/<target_triple>/<crate_version>/manifest.json",
        "restore_order": [
          "OPL_NATIVE_HELPER_PREBUILD_ROOT",
          "package native-helper-prebuilds",
          "GHCR one-person-lab-native-helper OCI archive",
          "local Cargo build fallback"
        ],
        "cache_destination": "${OPL_STATE_DIR}/native-helper/bin/<target_triple>/<crate_version>"
      }
    },
    "runtime_invocation": {
      "status_surface": "native_helper_target.runtime",
      "discovery_env": "OPL_NATIVE_HELPER_BIN_DIR",
      "repair_command": "npm run native:repair",
      "required_runtime_manager_invocations": [
        "opl-doctor-native",
        "opl-state-indexer",
        "opl-artifact-indexer",
        "opl-runtime-watch"
      ]
    },
    "candidate_helpers": [
      "opl-sysprobe",
      "opl-doctor-native",
      "opl-runtime-watch",
      "opl-artifact-indexer",
      "opl-state-indexer"
    ]
  },
  "state_index_target": {
    "status": "rust_helper_backed_contract_first",
    "source_of_truth_rule": "indexes project runtime surfaces but never replace domain-owned durable truth",
    "persistence": {
      "status_surface": "state_index_target.persistence",
      "default_index_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index.json",
      "persisted_surface_kind": "opl_runtime_manager_native_state_projection",
      "lifecycle_files": {
        "history_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-history.jsonl",
        "failure_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-failures.jsonl",
        "last_success_file": "${OPL_STATE_DIR}/runtime-manager/native-state-index-last-success.json"
      },
      "freshness_statuses": [
        "fresh",
        "expired_current_index",
        "stale_last_success_available",
        "expired_last_success",
        "unavailable_no_success"
      ],
      "execution_policy": {
        "default_mode": "auto",
        "auto_mode": "reuse_a_fresh_index_when_the_helper_binary_is_resolved",
        "refresh_mode": "explicit_refresh_native_indexes_executes_all_index_helpers",
        "read_only_mode": "read_existing_native_index_without_persisting"
      },
      "execution_fields": [
        "mode",
        "helper_execution",
        "cache_hit",
        "cache_reason",
        "reused_index_keys"
      ],
      "diff_summary": {
        "compared_fields": [
          "index_key",
          "helper_id",
          "result_surface_kind",
          "status"
        ],
        "count_fields": [
          "previous_index_count",
          "current_index_count",
          "added_count",
          "removed_count",
          "changed_count",
          "unchanged_count",
          "helper_changed_count",
          "result_surface_changed_count",
          "status_changed_count"
        ]
      },
      "failure_record": {
        "required_fields": [
          "generated_at",
          "status",
          "category",
          "errors",
          "details"
        ],
        "categories": [
          "helper_unavailable",
          "helper_error",
          "write_failed"
        ]
      },
      "history_gc": {
        "max_history_entries": 50,
        "reporting_fields": [
          "retained_history_count",
          "preserved_count",
          "removed_count",
          "history_count_before_gc",
          "history_count_after_gc"
        ]
      }
    },
    "candidate_indexes": [
      "workspace_registry_index",
      "managed_session_ledger_index",
      "artifact_projection_index",
      "attention_queue_index",
      "runtime_health_snapshot_index"
    ]
  },
  "family_runtime_stage_attempt_index": {
    "surface_kind": "opl_family_runtime_stage_attempt_index",
    "contract_ref": "contracts/opl-framework/family-runtime-online-substrate-contract.json",
    "command": "opl family-runtime status",
    "state_path": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
    "provider_model": "provider_backed_stage_attempt_runtime",
    "stage_attempt_ledger": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_attempts",
    "stage_run_launch_registry": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_run_launches",
    "stage_quality_cycle_ledger": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_quality_cycles",
    "stage_quality_cycle_contract_ref": "contracts/opl-framework/stage-quality-cycle-contract.json",
    "wakeup_bridge": "Temporal schedule/workflow history -> provider SLO and stage-attempt projection readback",
    "webhook_bridge": "provider signal/webhook -> Temporal signal/update",
    "domain_route_projection": {
      "surface_kind": "opl_domain_route_support_projection",
      "schema_version": 1,
      "owner_route_handoff_ref": "domain_runtime_owner_route_handoff",
      "accepted_runtime_owner_route_ref": "opl_runtime_owner_route",
      "supported_task_kind_prefix": "domain_route/",
      "canonical_task_kinds": [
        "domain_route/stage-route",
        "domain_route/reconcile-apply"
      ],
      "action_ref_source": "domain_route_runtime_request.command_kind_or_action_ref",
      "profile_source": "domain_owned_profile_ref",
      "accepted_runtime_responsibilities": [
        "stage_attempt_index",
        "stage_attempt_ledger",
        "liveness_projection",
        "provider_wakeup",
        "typed_blocker_or_temporal_failure_projection"
      ],
      "authority_boundary": {
        "writes_domain_truth": false,
        "writes_domain_quality_verdict": false,
        "writes_domain_owner_receipt": false,
        "writes_domain_typed_blocker": false,
        "writes_domain_human_gate": false,
        "writes_domain_current_package": false,
        "writes_domain_artifact_body": false,
        "provider_completion_is_domain_progress": false,
        "provider_completion_is_domain_ready": false
      }
    }
  },
  "family_scheduler_replacement": {
    "surface_kind": "opl_family_scheduler_replacement",
    "version": "v1",
    "owner": "one-person-lab",
    "scheduler_owner": "opl_provider_runtime_manager",
    "cadence_owner": "provider_backed_family_runtime",
    "replacement_status": "replacement_contract_available",
    "allowed_opl_targets": [
      "provider_slo_tick",
      "scheduler_cadence",
      "runtime_manager_projection"
    ],
    "command_set": {
      "status": "opl runtime manager",
      "provider_slo_tick": "opl family-runtime provider-slo tick --provider temporal",
      "scheduler_status": "opl family-runtime scheduler status --provider temporal",
      "scheduler_trigger": "opl family-runtime scheduler trigger --provider temporal"
    },
    "state_refs": {
      "provider_slo_receipts": "${OPL_STATE_DIR}/family-runtime/provider-slo",
      "stage_attempt_index": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
      "stage_attempt_ledger": "${OPL_STATE_DIR}/family-runtime/queue.sqlite#stage_attempts",
      "events_ledger": "${OPL_STATE_DIR}/family-runtime/events.jsonl"
    },
    "managed_domains_projection": {
      "source_of_truth_ref": "src/kernel/standard-agent-registry.ts#family_runtime_profile.runtime_manager_registration",
      "runtime_projection": "runtimeManagerDomainProfiles",
      "entry_fields": [
        "domain_id",
        "domain_owner",
        "migration_priority",
        "legacy_scheduler_owner",
        "legacy_scheduler_residue_policy",
        "replacement_role",
        "required_domain_refs"
      ]
    },
    "authority_boundary": {
      "can_write_domain_truth": false,
      "can_write_domain_memory_body": false,
      "can_authorize_domain_quality": false,
      "can_authorize_domain_export": false,
      "can_install_domain_daemon": false,
      "can_execute_domain_repair_command_directly": false,
      "can_enqueue_provider_stage_attempts": false,
      "can_record_opl_provider_receipts": true,
      "can_project_operator_workbench": true
    },
    "migration_gate": {
      "active_domain_callers_must_use_replacement_owner": true,
      "legacy_domain_scheduler_must_be_explicit_diagnostic_or_tombstone": true,
      "no_active_launchagent_install_from_domain_default": true
    }
  },
  "daemon_policy": {
    "surface_kind": "opl_runtime_manager_daemon_policy",
    "local_daemon_added": false,
    "opl_domain_daemon_installation_allowed": false,
    "cadence_owner": "provider_backed_family_runtime",
    "runtime_kernel_owner": "provider_backed_family_runtime",
    "provider_backed_cadence_surface": "opl family-runtime provider-slo tick --provider temporal",
    "domain_launchagent_policy_projection": {
      "source_of_truth_ref": "src/kernel/standard-agent-registry.ts#family_runtime_profile.runtime_manager_registration.scheduler.daemon_policy",
      "runtime_projection": "runtimeManagerDomainProfiles"
    },
    "allowed_domain_daemon_role": "legacy_diagnostic_cleanup_only",
    "authority_boundary": {
      "can_install_opl_daemon": false,
      "can_install_domain_daemon": false,
      "can_maintain_domain_daemon": false,
      "can_start_legacy_domain_launchagent": false,
      "can_record_provider_cadence_receipt": true
    }
  },
  "tray_snapshot_projection": {
    "surface_kind": "opl_runtime_tray_snapshot",
    "schema_version": "runtime_tray_snapshot.v1",
    "command": "opl runtime snapshot",
    "consumer": "One Person Lab desktop tray",
    "source_of_truth_rule": "OPL projects active domain-owned manifest and progress surfaces into tray lanes; cached or indexed values are not authoritative.",
    "required_fields": [
      "schema_version",
      "runtime_health",
      "last_updated",
      "running_items",
      "attention_items",
      "recent_items",
      "source_refs"
    ],
    "lanes": [
      "attention_items",
      "running_items",
      "recent_items"
    ],
    "daemon_policy": {
      "local_daemon_added": false,
      "runtime_kernel_owner": "provider_backed_family_runtime",
      "sidecar_promotion_gate": "Only promote beyond provider adapters if supported providers cannot express required task, wakeup, approval, audit, or product isolation contracts."
    }
  },
  "future_sidecar_promotion_gate": "Only promote beyond provider adapters if supported providers cannot express required task, wakeup, approval, audit, or product isolation contracts."
}
