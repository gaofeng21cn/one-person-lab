    "input": "domain_environment_intent",
    "ordinary_user_commands": [
      "opl env doctor",
      "opl env prepare",
      "opl env run"
    ],
    "advanced_operator_surface": "opl runtime env inspect|lock|build|prepare|materialize|verify|cache|doctor|run-context|contract",
    "steps": [
      "runtime_environment_descriptor",
      "runtime_lock",
      "content_addressed_layers",
      "runtime_bundle_manifest",
      "materialized_runtime_root",
      "receipt_cleanup_rollback"
    ],
    "default_mode": "materialize_only_with_explicit_apply_and_receipt",
    "default_provider_kind": "fast_local_env",
    "ordinary_entrypoint_policy": "ordinary_users_use_opl_env_doctor_prepare_run_advanced_operators_may_use_opl_runtime_env",
    "domain_agents_declare_dependency_intent_only": true
  },
  "module_mapping": {
    "runway": {
      "role": "runtime_materialization_and_run_consumption",
      "owner": "OPL Framework"
    },
    "pack": {
      "role": "descriptor_lock_layer_manifest_and_distribution_refs",
      "owner": "OPL Framework"
    },
    "connect": {
