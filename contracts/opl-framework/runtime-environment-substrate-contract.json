      "owner": "OPL Framework"
    },
    "ledger": {
      "role": "refs_only_evidence_and_receipt_refs",
      "owner": "OPL Framework"
    },
    "workspace": {
      "role": "managed_runtime_root_and_workspace_state_separation",
      "owner": "OPL Framework"
    },
    "atlas": {
      "role": "package_module_registry",
      "owner": "OPL Framework"
    },
    "stagecraft": {
      "role": "stage_runtime_consumption_refs",
      "owner": "OPL Framework"
    },
    "foundry": {
      "role": "foundry_kernel_evaluation_environment_consumption",
      "owner": "OPL Framework"
    },
    "charter": {
      "role": "policy_and_false_ready_boundary",
      "owner": "OPL Framework"
    }
  },
