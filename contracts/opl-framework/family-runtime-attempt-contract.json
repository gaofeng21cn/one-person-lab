{
  "contract_kind": "opl_family_runtime_attempt_contract.v1",
  "owner": "one-person-lab",
  "scope": "family-level provider-backed stage attempt ledger and projection vocabulary for domain-owned runtime attempts",
  "provider_model": "provider_backed_stage_attempt_runtime",
  "allowed_providers": [
    "local_sqlite",
    "temporal"
  ],
  "observability_only": true,
  "opl_runtime_manager_role": [
    "read domain-owned durable surfaces",
    "index attempt freshness",
    "project operator status",
    "report reconciliation gaps"
  ],
  "opl_runtime_manager_non_goals": [
    "scheduler kernel owner",
    "session kernel owner",
    "memory kernel owner",
    "domain runtime truth owner",
    "domain quality judgment owner"
  ],
  "attempt_states": [
    "unclaimed",
    "claimed",
    "queued",
    "running",
    "checkpointed",
    "retry_queued",
    "human_gate",
    "released",
    "completed",
    "succeeded",
    "failed",
    "blocked",
    "dead_lettered"
  ],
  "required_ledger_fields": [
    "stage_attempt_id",
    "provider_kind",
    "idempotency_key",
    "workflow_id",
    "domain_id",
    "stage_id",
    "workspace_locator",
    "source_fingerprint",
    "executor_kind",
    "status",
    "checkpoint_refs",
    "closeout_refs",
    "human_gate_refs",
    "retry_budget",
    "attempt_count",
    "task_id",
    "blocked_reason",
    "provider_receipt",
    "provider_run",
    "activity_events",
    "user_instruction_refs",
    "resume_refs",
    "consumed_memory_refs",
    "writeback_receipt_refs",
    "route_impact",
    "usage_projection",
    "closeout_receipt_status",
    "authority_boundary"
  ],
  "required_projection_fields": [
    "attempt_state",
    "attempt_count",
    "retry_policy",
    "workspace_boundary",
    "owner_repo",
    "failure_reason",
    "reconciliation_status",
    "last_observed_projection",
    "operator_visibility",
    "completion_boundary",
    "control_loop_summary",
    "usage_projection",
    "resource_pressure",
    "observability_export"
  ],
  "provider_lifecycle_contract": {
    "temporal": {
      "workflow_name": "StageAttemptWorkflow",
      "activity_names": [
        "CodexStageActivity",
        "DomainSidecarDispatchActivity"
      ],
      "signals": [
        "HumanGateSignal",
        "UserInstructionSignal",
        "ResumeSignal"
      ],
      "queries": [
        "StageAttemptQuery"
      ],
      "fixture_mode_allowed_without_temporal_server": true
    },
    "local_sqlite": {
      "role": "development_and_offline_provider",
      "stores": [
        "attempt_ledger",
        "signals",
        "provider_run_receipts",
        "activity_events",
        "typed_closeout_receipts"
      ]
    }
  },
  "typed_closeout_contract": {
    "accepted_surface_kinds": [
      "stage_attempt_closeout_packet",
      "stage_memory_closeout_packet",
      "domain_stage_closeout_packet"
    ],
    "required_for_completed_status": true,
    "free_text_closeout_accepted": false,
    "tracked_refs": [
      "closeout_refs",
      "consumed_refs",
      "consumed_memory_refs",
      "writeback_receipt_refs",
      "rejected_writes",
      "route_impact",
      "next_owner",
      "domain_ready_verdict"
    ]
  },
  "operator_visibility_fields": [
    "provider_kind",
    "attempt_id",
    "stage_id",
    "status",
    "provider_run",
    "activity_events",
    "user_instructions",
    "resume_signals",
    "heartbeat",
    "consumed_refs",
    "consumed_memory_refs",
    "writeback_receipt_refs",
    "closeout_refs",
    "closeout_receipt_status",
    "route_impact",
    "usage_projection",
    "rejected_writes",
    "next_owner",
    "human_gate_refs",
    "dead_letter"
  ],
  "stability_projection_fields": [
    "control_loop_summary",
    "usage_projection",
    "resource_pressure",
    "runtime_observability_export"
  ],
  "stability_projection_authority_boundary": {
    "projection_role": "read_only_operator_stability_projection",
    "can_execute_domain_action": false,
    "can_change_executor": false,
    "can_auto_degrade": false,
    "can_write_domain_truth": false,
    "can_write_domain_memory_body": false,
    "can_authorize_domain_ready": false,
    "can_authorize_quality_verdict": false,
    "provider_completion_is_domain_ready": false
  },
  "reconciliation_statuses": [
    "fresh",
    "stale",
    "conflict",
    "needs_domain_refresh"
  ],
  "unsupported_required_entries": [
    "Linear",
    "Symphony scheduler",
    "external issue tracker",
    "generic persona router"
  ],
  "domain_truth_owners": [
    "med-autoscience",
    "med-autogrant",
    "redcube-ai"
  ]
}
