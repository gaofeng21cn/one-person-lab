{
  "surface_kind": "opl_source_material_ingest_contract",
  "version": "source-material-ingest.v3",
  "owner": "OPL Workspace",
  "purpose": "Provide a domain-neutral source material intake surface for user-supplied files such as PDFs, documents, datasets, and reference designs.",
  "cli_surface": {
    "command": "opl workspace source ingest",
    "usage": "opl workspace source ingest --workspace <path> --file <path> [--project-id <id>] [--role <role>] [--title <title>] [--note <text>] [--dry-run|--apply]",
    "output_surface_kind": "opl_workspace_source_ingest",
    "receipt_surface_kind": "opl_workspace_source_material_receipt"
  },
  "stored_refs": {
    "source_copy_root": "shared/sources/source_materials/<role>/",
    "receipt_root": "control/opl/source_materials/",
    "content_address": "sha256"
  },
  "handoff_policy": {
    "canonical_reference_design_path": [
      "SourceMaterialReceipt",
      "extraction_receipt_refs",
      "ReferenceDesignPatternPacket",
      "OMA ReferenceDesignPacket"
    ],
    "consumers": [
      "domain_stage",
      "Codex CLI attempt",
      "OPL Meta Agent reference-design distillation",
      "MAS or BookForge source intake"
    ],
    "handoff_refs": [
      "source_material_ref",
      "source_fingerprint_ref",
      "receipt_ref",
      "stored_file.ref"
    ],
    "body_reader": "stage_or_domain_agent",
    "reference_design_pattern_handoff": {
      "applicable_role": "reference_design",
      "receipt_field": "reference_design_pattern_handoff",
      "contract_ref": "contracts/opl-framework/source-material-ingest-contract.json#/handoff_policy/reference_design_pattern_handoff",
      "schema_ref": "contracts/opl-framework/reference-design-pattern-packet.schema.json",
      "input_ref_fields": [
        "source_material_ref",
        "source_material_receipt_ref",
        "source_fingerprint_ref",
        "stored_file_ref"
      ],
      "required_return_shape": "ReferenceDesignPatternPacket",
      "required_return_fields_ref": "contracts/opl-framework/reference-design-pattern-packet.schema.json#/required",
      "next_owner": "stage_or_domain_agent",
      "next_owner_action": "extract_reference_design_patterns_and_return_typed_packet",
      "packet_consumer": "oma",
      "consumer_return_shape": "ReferenceDesignPacket",
      "consumer_return_contract_ref": "oma-contract:reference-design-packet.v1",
      "consumer_return_fields_ref": "oma-contract:reference-design-packet.v1#/required_fields",
      "semantic_extraction_executed_by_ingest": false,
      "pattern_packet_created_by_ingest": false
    }
  },
  "authority_boundary": {
    "source_ingest_is_refs_only": true,
    "opl_can_copy_source_file": true,
    "opl_can_hash_source_file": true,
    "opl_can_extract_source_semantics": false,
    "opl_can_write_domain_truth": false,
    "opl_can_copy_source_body_into_contract": false,
    "opl_can_write_pattern_body": false,
    "opl_can_mutate_artifact_body": false,
    "opl_can_create_owner_receipt": false,
    "opl_can_sign_owner_receipt": false,
    "opl_can_create_typed_blocker": false,
    "opl_can_claim_pattern_quality_ready": false,
    "opl_can_claim_target_ready": false,
    "opl_can_claim_domain_ready": false,
    "opl_can_claim_production_ready": false,
    "receipt_is_not_domain_acceptance": true,
    "receipt_is_not_extraction_quality_verdict": true
  }
}
