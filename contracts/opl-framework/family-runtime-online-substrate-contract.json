{
  "version": "v2",
  "contract_id": "opl_family_runtime_online_substrate_contract",
  "contract_ref": "contracts/opl-framework/family-runtime-online-substrate-contract.json",
  "provider_model": "provider_backed_stage_attempt_runtime",
  "scope": "OPL family Temporal-backed runtime substrate, stage attempt ledger/index, notification, signal, and recovery projection",
  "standard_agent_default_runtime_policy": {
    "surface_kind": "opl_standard_agent_default_runtime_policy",
    "default_runtime_path": "opl_temporal_hosted_autonomous",
    "temporal_hosted_autonomy_default_enabled": true,
    "provider_kind_required_for_production": "temporal",
    "default_executor_kind": "codex_cli",
    "codex_app_drives_long_running_tasks": false,
    "codex_app_role": "start_observe_intervene_project_only",
    "domain_agent_internal_daemon_allowed": false,
    "domain_agent_internal_scheduler_allowed": false,
    "domain_agent_internal_attempt_loop_allowed": false
  },
  "owner_split": {
    "family_runtime_provider_owner": "one-person-lab",
    "product_control_plane_owner": "one-person-lab",
    "domain_truth_owners": [
      "med-autoscience",
      "med-autogrant",
      "redcube-ai"
    ],
    "concrete_executor_owner": "codex_cli_or_domain_selected_executor"
  },
  "allowed_providers": [
    "temporal"
  ],
  "provider_semantics": {
    "temporal": {
      "role": "required production durable stage-attempt workflow provider",
      "durable_online_wakeup": true,
      "external_runtime_required": true,
      "production_required": true,
      "workflow_mapping": {
        "contract_ref": "contracts/opl-framework/family-runtime-temporal-first-contract.json",
        "stage_run_workflow": "StageRunWorkflow",
        "stage_attempt_child_workflow": "StageAttemptWorkflow",
        "stage_run_workflow_is_stage_attempt_alias": false,
        "stage_attempt_activity": "StageAttemptActivity",
        "current_stage_attempt_activity_adapters": [
          "CodexStageActivity",
          "DomainHandlerDispatchActivity"
        ],
        "reconcile_workflow": "ReconcileWorkflow",
        "current_reconcile_workflow_adapter": "SchedulerTickWorkflow",
        "human_gate_signal": "HumanGateSignal",
        "owner_receipt_signal": "OwnerReceiptSignal",
        "query": "operator_progress_projection",
        "history": "durable_replay_and_audit"
      },
      "required_configuration": [
        "OPL_TEMPORAL_ADDRESS or OPL-managed local Temporal service supervisor address",
        "Temporal worker implementing OPL stage attempt contract"
      ],
      "local_service_supervision": {
        "dependency_role": "required_local_durable_workflow_service",
        "desktop_macos": {
          "supervisor_kind": "launchd_user_agent",
          "label": "ai.opl.family-runtime.temporal-service",
          "run_at_load": true,
          "keep_alive": true,
          "throttle_interval_seconds": 15,
          "launchctl_timeout_ms": 5000,
          "launcher_policy": "direct_realpath_temporal_cli_only_no_framework_checkout_or_shell_command",
          "configuration_currentness": "exact_plist_sha256_and_launcher_sha256_plus_executable_realpath_x_ok_readback",
          "database_path": "${OPL_STATE_DIR}/family-runtime/temporal-server/temporal.sqlite",
          "database_argument": "--db-filename",
          "commands": {
            "status": "opl family-runtime service supervisor status --provider temporal",
            "install": "opl family-runtime service supervisor install --provider temporal",
            "trigger": "opl family-runtime service supervisor trigger --provider temporal",
            "remove": "opl family-runtime service supervisor remove --provider temporal"
          },
          "app_actions": {
            "status": "provider_service_status",
            "start_or_install": "provider_service_start",
            "restart": "provider_service_restart",
            "stop": "provider_service_stop"
          }
        },
        "non_darwin": {
          "launchd_supervisor_supported": false,
          "supervisor_status": "not_applicable",
          "supervisor_error": null,
          "ordinary_service_start_policy": "retain_external_container_or_explicit_foreground_detached_service_lifecycle",
          "managed_detached_restart_policy": "bounded_stop_then_start_with_fresh_service_readback",
          "webui_policy": "container_or_external_temporal_service_not_launchd"
        },
        "readiness_contract": {
          "ready_requires": [
            "installed",
            "configuration_current",
            "loaded",
            "supervisor_process_running",
            "fresh_tcp_probe_reachable",
            "error_null"
          ],
          "required_projection_fields": [
            "installed",
            "loaded",
            "ready",
            "observed_at",
            "error",
            "supported",
            "applicable",
            "required"
          ],
          "fast_projection_path": "app_state.provider.temporal.details.worker_readiness.temporal_service_lifecycle.supervisor",
          "full_projection_path": "family_runtime.provider_runtime.providers.temporal.details.worker_readiness.temporal_service_lifecycle.supervisor"
        },
        "restart_lifecycle": {
          "command": "opl family-runtime service restart --provider temporal",
          "app_action_id": "provider_service_restart",
          "darwin_local_managed_route": "launchctl_kickstart_k_existing_opl_supervisor",
          "non_darwin_managed_detached_route": "bounded_stop_then_start",
          "external_service_route": "typed_not_applicable_no_mutation",
          "success_requires": [
            "fresh_service_readback_ready",
            "fresh_supervisor_readback_ready_or_not_applicable",
            "darwin_managed_supervisor_pid_changed",
            "error_null"
          ],
          "start_is_not_restart": true
        },
        "maintenance_order": [
          "temporal_service_supervisor",
          "provider_worker_supervisor",
          "temporal_scheduler_cadence"
        ],
        "startup_maintenance_reconcile": {
          "receipt_path": "system_action.details.temporal_runtime_reconcile",
          "surface_kind": "opl_temporal_runtime_startup_reconcile.v1",
          "applicability": {
            "platform": "darwin",
            "host_kind": "desktop",
            "private_host_hint": "OPL_APP_HOST_KIND=desktop",
            "packaged_local_default_address": "127.0.0.1:7233",
            "packaged_local_default_address_source": "OPL_TEMPORAL_ADDRESS_SOURCE=packaged_local_default",
            "provider_kind": "temporal",
            "service_owner": "opl_local_managed",
            "process_instance_hint_is_insufficient": true
          },
          "strict_dependency_order": [
            "fresh_server_supervisor_ready",
            "fresh_worker_supervisor_and_worker_runtime_ready",
            "fresh_scheduler_cadence_ready"
          ],
          "dependency_failure_policy": "stop_before_next_step_and_return_blocked_manual_required",
          "worker_root_drift_policy": "loaded_supervisor_for_different_runtime_root_is_blocked_without_remove_or_reinstall",
          "non_applicable_policy": "external_custom_non_darwin_and_non_desktop_hosts_return_ready_null_without_opening_runtime_or_mutating_services",
          "address_provenance_policy": "only the exact packaged loopback default plus packaged_local_default provenance may cross the environment-address boundary into managed reconcile; missing, unknown, remote, or mismatched provenance stays mutation-free not_applicable",
          "system_action_status": "blocked_reconcile_maps_to_manual_required",
          "private_host_hint_is_mutation_authority": false,
          "mutation_requires_explicit_startup_maintenance_execution": true
        },
        "scheduler_independence": "service_process_supervision_never_installs_triggers_or_inferrs_scheduler_cadence",
        "detached_service_adoption": {
          "required_order": [
            "bounded_stop_existing_detached_process",
            "confirm_address_released",
            "bootstrap_supervisor",
            "confirm_fresh_readiness"
          ],
          "failure_policy": "rollback_supervisor_files_and_restore_detached_service_when_safe",
          "old_in_memory_history_migration": "not_available_and_never_claimed"
        },
        "rollback_policy": "bootstrap_or_write_failure_restores_exact_prior_plist_and_config; failed_bootout_preserves_current_files",
        "authority_boundary": {
          "service_supervisor_owner": "one-person-lab",
          "domain_daemon_install_allowed": false,
          "provider_ready_authorizes_domain_ready": false
        }
      }
    }
  },
  "opl_owned_capabilities": [
    "provider_selection",
    "stage_attempt_ledger",
    "local_inbox_notification_copy",
    "family_runtime_events_export",
    "provider_slo_cadence_action_projection",
    "repair_doctor_surface",
    "runtime_manager_projection"
  ],
  "provider_slo_cadence_action": {
    "surface_kind": "opl_temporal_provider_slo_execution_receipt",
    "action_id": "temporal-provider-production-proof-cadence",
    "action_kind": "provider_slo_cadence_execution",
    "command": "opl family-runtime residency proof --provider temporal --production",
    "execution_owner": "operator_or_infrastructure",
    "execution_policy": "provider_scheduler_default_for_standard_agents",
    "expected_event_type": "temporal_provider_slo_execution_receipt",
    "expected_receipt_kind": "opl_temporal_provider_slo_execution_receipt",
    "max_proof_age_seconds": 86400,
    "authority_boundary": {
      "can_auto_execute": false,
      "can_authorize_domain_ready": false,
      "can_authorize_quality_verdict": false,
      "can_authorize_artifact_export": false,
      "can_write_domain_truth": false
    }
  },
  "domain_owned_capabilities": [
    "runtime_truth",
    "quality_judgment",
    "artifact_authority",
    "publication_or_package_gate",
    "worker_launch_decision"
  ],
  "state": {
    "stage_attempt_index_database": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
    "stage_attempts_table": "stage_attempts",
    "stage_quality_cycles_table": "stage_quality_cycles",
    "local_inbox_table": "notifications",
    "events_table": "events"
  },
  "stage_attempt_fields": [
    "stage_attempt_id",
    "provider_kind",
    "workflow_id",
    "domain_id",
    "stage_id",
    "stage_run_id",
    "quality_cycle_id",
    "attempt_role",
    "quality_round_index",
    "parent_attempt_ref",
    "workspace_locator",
    "source_fingerprint",
    "input_artifact_refs",
    "reviewed_artifact_hashes",
    "quality_source_refs",
    "quality_rubric_refs",
    "prior_finding_refs",
    "repair_map_refs",
    "quality_role_prompt_ref",
    "execution_session_ref",
    "context_manifest_ref",
    "no_context_inheritance",
    "executor_kind",
    "status",
    "checkpoint_refs",
    "closeout_refs",
    "human_gate_refs",
    "retry_budget",
    "attempt_count",
    "task_id",
    "blocked_reason",
    "provider_receipt",
    "authority_boundary"
  ],
  "degraded_diagnostic_mode": {
    "selected_provider_when_unconfigured": "temporal",
    "retired_local_provider": "local_sqlite",
    "sqlite_sidecar_role": "projection_and_readback_index_only",
    "temporal_unready_policy": "fail_closed_blocked",
    "full_online_ready": false,
    "allowed_surfaces": [
      "local status",
      "manifest",
      "doctor diagnostics",
      "stage attempt create",
      "stage attempt inspect"
    ]
  },
  "forbidden_authority": [
    "OPL cannot write domain truth",
    "OPL cannot clear domain quality gates",
    "OPL cannot override artifact or publication authority",
    "Provider receipt cannot become MAS/MAG/RCA truth owner",
    "Hermes cannot be described as a family-runtime provider or default production substrate",
    "Local sqlite cannot be described as a family-runtime provider or production online ready",
    "SQLite sidecar rows cannot drive scheduling, queue mutation, redrive, or provider readiness",
    "Temporal unavailable must be reported as a required dependency blocker for Full online readiness"
  ]
}
