{
  "version": "v2",
  "contract_id": "opl_family_runtime_online_substrate_contract",
  "contract_ref": "contracts/opl-framework/family-runtime-online-substrate-contract.json",
  "provider_model": "provider_backed_stage_attempt_runtime",
  "scope": "OPL family provider-backed runtime substrate, typed queue, stage attempt ledger, dispatch, notification, approval, signal, and recovery bridge",
  "owner_split": {
    "family_runtime_provider_owner": "one-person-lab",
    "product_control_plane_owner": "one-person-lab",
    "domain_truth_owners": [
      "med-autoscience",
      "med-autogrant",
      "redcube-ai"
    ],
    "concrete_executor_owner": "codex_cli_or_domain_selected_executor"
  },
  "allowed_providers": [
    "local_sqlite",
    "hermes_legacy",
    "temporal"
  ],
  "provider_semantics": {
    "local_sqlite": {
      "role": "local queue, receipt, and stage attempt ledger provider for development, direct skill calls, and guarded local operation",
      "durable_online_wakeup": false,
      "external_runtime_required": false
    },
    "hermes_legacy": {
      "role": "migration-period legacy wakeup and webhook bridge",
      "durable_online_wakeup": true,
      "external_runtime_required": true,
      "legacy_bridge": {
        "cron_job_name": "opl-family-runtime-tick",
        "cron_cadence": "every 1m",
        "cron_script": "opl family-runtime tick --source hermes-cron --hydrate",
        "webhook_subscription": "opl-family-runtime-webhook"
      }
    },
    "temporal": {
      "role": "production durable stage-attempt workflow provider candidate",
      "durable_online_wakeup": true,
      "external_runtime_required": true,
      "workflow_mapping": {
        "workflow": "stage_attempt",
        "activity": "codex_cli_stage_execution_or_domain_sidecar_dispatch",
        "signal": "human_gate_user_modification_intake_or_resume",
        "query": "operator_progress_projection",
        "history": "durable_replay_and_audit"
      },
      "required_configuration": [
        "OPL_TEMPORAL_ADDRESS",
        "Temporal worker implementing OPL stage attempt contract"
      ]
    }
  },
  "opl_owned_capabilities": [
    "provider_selection",
    "typed_family_queue",
    "stage_attempt_ledger",
    "domain_adapter_dispatch",
    "local_inbox_notification_copy",
    "family_runtime_events_export",
    "repair_doctor_surface",
    "runtime_manager_projection"
  ],
  "domain_owned_capabilities": [
    "runtime_truth",
    "quality_judgment",
    "artifact_authority",
    "publication_or_package_gate",
    "worker_launch_decision"
  ],
  "state": {
    "queue_database": "${OPL_STATE_DIR}/family-runtime/queue.sqlite",
    "stage_attempts_table": "stage_attempts",
    "dispatch_task_dir": "${OPL_STATE_DIR}/family-runtime/dispatch",
    "local_inbox_table": "notifications",
    "events_table": "events"
  },
  "stage_attempt_fields": [
    "stage_attempt_id",
    "provider_kind",
    "workflow_id",
    "domain_id",
    "stage_id",
    "workspace_locator",
    "source_fingerprint",
    "executor_kind",
    "status",
    "checkpoint_refs",
    "closeout_refs",
    "human_gate_refs",
    "retry_budget",
    "attempt_count",
    "task_id",
    "blocked_reason",
    "provider_receipt",
    "authority_boundary"
  ],
  "degraded_diagnostic_mode": {
    "env": "OPL_DISABLE_HERMES_ONLINE=1",
    "selected_provider_when_unconfigured": "local_sqlite",
    "full_online_ready": false,
    "allowed_surfaces": [
      "local status",
      "manifest",
      "doctor diagnostics",
      "queue read",
      "stage attempt create",
      "stage attempt inspect"
    ]
  },
  "forbidden_authority": [
    "OPL cannot write domain truth",
    "OPL cannot clear domain quality gates",
    "OPL cannot override artifact or publication authority",
    "Provider receipt cannot become MAS/MAG/RCA truth owner",
    "Hermes legacy bridge cannot be described as the default production substrate"
  ]
}
