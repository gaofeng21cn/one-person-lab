{
  "contract_id": "opl-domain-runtime-surfaces",
  "version": "1.0.0",
  "state": "active",
  "owner": "one-person-lab",
  "public_exports": {
    "domain_task_runtime": "opl-framework/domain-task-runtime",
    "domain_artifact_runtime": "opl-framework/domain-artifact-runtime",
    "domain_helper_runtime": "opl-framework/domain-helper-runtime",
    "domain_source_runtime": "opl-framework/domain-source-runtime"
  },
  "responsibilities": {
    "domain_task_runtime": ["generic run record and event lifecycle", "agent executor invocation", "action handler dispatch"],
    "domain_artifact_runtime": ["Stage Artifact Unit byte read and write", "refs-only artifact indexing"],
    "domain_helper_runtime": ["OPL-managed Python resolution", "native helper process execution"],
    "domain_source_runtime": ["source byte materialization", "content fingerprint and material refs"]
  },
  "authority_boundary": {
    "framework_can_define_domain_workflow": false,
    "framework_can_decide_source_readiness": false,
    "framework_can_mutate_artifact_without_domain_authorization": false,
    "framework_can_claim_domain_quality": false,
    "framework_can_sign_owner_receipt": false,
    "framework_can_create_typed_blocker": false,
    "domain_repo_can_install_private_runtime_substrate": false
  }
}
