{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/foundry-evolution-proposal.schema.json",
  "title": "OPL Foundry EvolutionProposal",
  "type": "object",
  "required": [
    "surface_kind", "version", "proposal_id", "target_agent_id", "target_domain_id", "target_version_ref",
    "blueprint_digest", "evidence_digest", "root_causes", "next_blueprint", "semantic_diff", "expected_benefits",
    "new_tests", "trade_offs", "risk_hints"
  ],
  "properties": {
    "surface_kind": { "const": "opl_foundry_evolution_proposal" },
    "version": { "const": "opl-foundry-protocol.v1" },
    "proposal_id": { "$ref": "#/$defs/non_empty" },
    "target_agent_id": { "$ref": "#/$defs/non_empty" },
    "target_domain_id": { "$ref": "#/$defs/non_empty" },
    "target_version_ref": { "type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$" },
    "blueprint_digest": { "$ref": "#/$defs/digest" },
    "evidence_digest": { "$ref": "#/$defs/digest" },
    "root_causes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/root_cause" } },
    "next_blueprint": { "$ref": "https://one-person-lab.local/contracts/opl-framework/foundry-agent-blueprint.schema.json" },
    "semantic_diff": { "type": "array", "items": { "$ref": "#/$defs/semantic_change" } },
    "expected_benefits": { "$ref": "#/$defs/string_list" },
    "new_tests": { "type": "array", "items": { "$ref": "#/$defs/new_test" } },
    "trade_offs": { "$ref": "#/$defs/string_list" },
    "risk_hints": { "type": "array", "items": { "enum": ["low", "medium", "high"] }, "uniqueItems": true }
  },
  "additionalProperties": false,
  "$defs": {
    "non_empty": { "type": "string", "minLength": 1 },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "string_list": { "type": "array", "items": { "$ref": "#/$defs/non_empty" }, "uniqueItems": true },
    "root_cause": {
      "type": "object",
      "required": ["failure_class", "explanation", "evidence_refs"],
      "properties": {
        "failure_class": { "$ref": "#/$defs/non_empty" },
        "explanation": { "$ref": "#/$defs/non_empty" },
        "evidence_refs": { "$ref": "#/$defs/string_list" }
      },
      "additionalProperties": false
    },
    "semantic_change": {
      "type": "object",
      "required": ["operation", "semantic_path", "rationale"],
      "properties": {
        "operation": { "enum": ["add", "replace", "remove"] },
        "semantic_path": { "type": "string", "pattern": "^/" },
        "rationale": { "$ref": "#/$defs/non_empty" }
      },
      "additionalProperties": false
    },
    "new_test": {
      "type": "object",
      "required": ["case_id", "test_ref", "rationale"],
      "properties": {
        "case_id": { "$ref": "#/$defs/non_empty" },
        "test_ref": { "$ref": "#/$defs/non_empty" },
        "rationale": { "$ref": "#/$defs/non_empty" }
      },
      "additionalProperties": false
    }
  }
}
