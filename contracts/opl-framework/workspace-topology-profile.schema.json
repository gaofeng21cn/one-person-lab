{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/workspace-topology-profile.schema.json",
  "schema_id": "opl.workspace_topology_profile.v1",
  "surface_kind": "opl_workspace_topology_profile_schema",
  "owner": "one-person-lab",
  "purpose": "Define the OPL-owned workspace topology template shared by standard domain agents: Workspace Group -> Project Unit -> Stage Artifact Unit -> owner receipt or typed blocker, with runtime-state kept as backing/provenance.",
  "state": "active_contract",
  "machine_boundary": "OPL owns the topology envelope, workspace modes, default profile templates, generated projection boundary, and runtime-state boundary. Domain repositories own domain truth, workspace instances, product views, artifact bodies, owner receipts, typed blockers, quality verdicts, and export verdicts.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "surface_kind",
    "version",
    "profile_id",
    "topology_model",
    "workspace_modes",
    "default_project_stage_outputs_root",
    "default_profiles",
    "domain_profile_defaults",
    "default_user_inspection_surface",
    "runtime_state_boundary",
    "authority_boundary",
    "workspace_initialization_policy",
    "example_project_layouts"
  ],
  "properties": {
    "surface_kind": {
      "const": "opl_workspace_topology_profile"
    },
    "version": {
      "const": "workspace-topology-profile.v1"
    },
    "profile_id": {
      "const": "opl.workspace_topology_profile.v1"
    },
    "topology_model": {
      "type": "array",
      "prefixItems": [
        {
          "const": "workspace_group"
        },
        {
          "const": "project_unit"
        },
        {
          "const": "stage_artifact_unit"
        },
        {
          "const": "owner_receipt_or_typed_blocker"
        }
      ],
      "minItems": 4
    },
    "workspace_modes": {
      "type": "array",
      "items": {
        "enum": [
          "one_off",
          "series",
          "portfolio"
        ]
      },
      "contains": {
        "const": "one_off"
      }
    },
    "default_project_stage_outputs_root": {
      "const": "artifacts/stage_outputs"
    },
    "default_profiles": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "one_off",
        "rca_series",
        "mas_portfolio"
      ],
      "properties": {
        "one_off": {
          "$ref": "#/$defs/one_off_profile"
        },
        "rca_series": {
          "$ref": "#/$defs/rca_series_profile"
        },
        "mas_portfolio": {
          "$ref": "#/$defs/mas_portfolio_profile"
        }
      }
    },
    "domain_profile_defaults": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mas",
        "mag",
        "rca",
        "oma"
      ],
      "properties": {
        "mas": {
          "const": "mas_portfolio"
        },
        "mag": {
          "const": "one_off"
        },
        "rca": {
          "const": "rca_series"
        },
        "oma": {
          "const": "one_off"
        }
      }
    },
    "default_user_inspection_surface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ordinary_user_default_surface",
        "project_stage_outputs_pattern",
        "runtime_state_is_default_user_surface",
        "product_views_are_stage_outputs"
      ],
      "properties": {
        "ordinary_user_default_surface": {
          "const": "workspace_local_project_stage_outputs"
        },
        "project_stage_outputs_pattern": {
          "const": "<project-root>/artifacts/stage_outputs/<stage-id>/"
        },
        "runtime_state_is_default_user_surface": {
          "const": false
        },
        "product_views_are_stage_outputs": {
          "const": false
        }
      }
    },
    "runtime_state_boundary": {
      "$ref": "#/$defs/runtime_state_boundary"
    },
    "authority_boundary": {
      "$ref": "#/$defs/authority_boundary"
    },
    "workspace_initialization_policy": {
      "$ref": "#/$defs/workspace_initialization_policy"
    },
    "example_project_layouts": {
      "$ref": "#/$defs/example_project_layouts"
    }
  },
  "$defs": {
    "one_off_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workspace_mode",
        "project_collection_path",
        "series_capable_skeleton",
        "shared_resource_roots",
        "project_stage_outputs_root"
      ],
      "properties": {
        "workspace_mode": {
          "const": "one_off"
        },
        "project_collection_path": {
          "const": "projects"
        },
        "series_capable_skeleton": {
          "const": true
        },
        "shared_resource_roots": {
          "type": "array",
          "contains": {
            "const": "shared/sources"
          }
        },
        "project_stage_outputs_root": {
          "const": "artifacts/stage_outputs"
        }
      }
    },
    "rca_series_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workspace_mode",
        "project_collection_path",
        "shared_resource_roots",
        "project_stage_outputs_root"
      ],
      "properties": {
        "workspace_mode": {
          "const": "series"
        },
        "project_collection_path": {
          "const": "projects"
        },
        "shared_resource_roots": {
          "type": "array",
          "contains": {
            "const": "shared/brand"
          }
        },
        "project_stage_outputs_root": {
          "const": "artifacts/stage_outputs"
        }
      }
    },
    "mas_portfolio_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workspace_mode",
        "project_collection_path",
        "shared_resource_roots",
        "project_stage_outputs_root"
      ],
      "properties": {
        "workspace_mode": {
          "const": "portfolio"
        },
        "project_collection_path": {
          "const": "projects"
        },
        "shared_resource_roots": {
          "type": "array",
          "contains": {
            "const": "data"
          }
        },
        "project_stage_outputs_root": {
          "const": "artifacts/stage_outputs"
        }
      }
    },
    "runtime_state_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "role",
        "runtime_state_can_be_canonical_project_root",
        "runtime_state_can_close_stage",
        "runtime_state_can_replace_owner_receipt_or_typed_blocker"
      ],
      "properties": {
        "role": {
          "const": "provider_backing_provenance_restore_audit"
        },
        "runtime_state_can_be_canonical_project_root": {
          "const": false
        },
        "runtime_state_can_close_stage": {
          "const": false
        },
        "runtime_state_can_replace_owner_receipt_or_typed_blocker": {
          "const": false
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "opl_can_define_topology_contract",
        "opl_can_project_workspace_refs",
        "opl_can_write_domain_truth",
        "opl_can_mutate_artifact_body",
        "opl_can_create_owner_receipt",
        "opl_can_create_typed_blocker",
        "runtime_state_counts_as_user_default_surface"
      ],
      "properties": {
        "opl_can_define_topology_contract": {
          "const": true
        },
        "opl_can_project_workspace_refs": {
          "const": true
        },
        "opl_can_write_domain_truth": {
          "const": false
        },
        "opl_can_mutate_artifact_body": {
          "const": false
        },
        "opl_can_create_owner_receipt": {
          "const": false
        },
        "opl_can_create_typed_blocker": {
          "const": false
        },
        "runtime_state_counts_as_user_default_surface": {
          "const": false
        }
      }
    },
    "workspace_initialization_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "default_workspace_mode",
        "default_project_collection_path",
        "legacy_project_collection_aliases",
        "infer_series_when_user_requests_multiple_related_deliverables",
        "infer_portfolio_when_user_requests_shared_research_workspace_with_multiple_studies",
        "upgrading_one_off_to_series_must_not_move_existing_project_roots",
        "explicit_workspace_mode_declaration_preferred"
      ],
      "properties": {
        "default_workspace_mode": {
          "const": "one_off"
        },
        "infer_series_when_user_requests_multiple_related_deliverables": {
          "const": true
        },
        "infer_portfolio_when_user_requests_shared_research_workspace_with_multiple_studies": {
          "const": true
        },
        "upgrading_one_off_to_series_must_not_move_existing_project_roots": {
          "const": true
        },
        "explicit_workspace_mode_declaration_preferred": {
          "const": true
        },
        "default_project_collection_path": {
          "const": "projects"
        },
        "legacy_project_collection_aliases": {
          "type": "array",
          "prefixItems": [
            {
              "const": "deliverables"
            },
            {
              "const": "studies"
            }
          ],
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "example_project_layouts": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "one_off",
        "rca_series",
        "mas_portfolio"
      ],
      "properties": {
        "one_off": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "project_collection_path",
            "project_root_pattern",
            "project_stage_outputs_pattern",
            "legacy_project_collection_aliases"
          ],
          "properties": {
            "project_collection_path": {
              "const": "projects"
            },
            "project_root_pattern": {
              "const": "projects/<project-id>"
            },
            "project_stage_outputs_pattern": {
              "const": "projects/<project-id>/artifacts/stage_outputs/<stage-id>/"
            },
            "legacy_project_collection_aliases": {
              "type": "array",
              "contains": {
                "const": "deliverables"
              }
            }
          }
        },
        "rca_series": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "shared_roots",
            "project_collection_path",
            "project_root_pattern",
            "project_stage_outputs_pattern",
            "legacy_project_collection_aliases"
          ],
          "properties": {
            "shared_roots": {
              "type": "array",
              "contains": {
                "const": "shared/brand"
              }
            },
            "project_collection_path": {
              "const": "projects"
            },
            "project_root_pattern": {
              "const": "projects/<deck-id>"
            },
            "project_stage_outputs_pattern": {
              "const": "projects/<deck-id>/artifacts/stage_outputs/<stage-id>/"
            },
            "legacy_project_collection_aliases": {
              "type": "array",
              "contains": {
                "const": "deliverables"
              }
            }
          }
        },
        "mas_portfolio": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "shared_roots",
            "project_collection_path",
            "project_root_pattern",
            "project_stage_outputs_pattern",
            "legacy_project_collection_aliases"
          ],
          "properties": {
            "shared_roots": {
              "type": "array",
              "contains": {
                "const": "data"
              }
            },
            "project_collection_path": {
              "const": "projects"
            },
            "project_root_pattern": {
              "const": "projects/<study-id>"
            },
            "project_stage_outputs_pattern": {
              "const": "projects/<study-id>/artifacts/stage_outputs/<stage-id>/"
            },
            "legacy_project_collection_aliases": {
              "type": "array",
              "contains": {
                "const": "studies"
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "surface_kind": "opl_workspace_topology_profile",
      "version": "workspace-topology-profile.v1",
      "profile_id": "opl.workspace_topology_profile.v1",
      "topology_model": [
        "workspace_group",
        "project_unit",
        "stage_artifact_unit",
        "owner_receipt_or_typed_blocker"
      ],
      "workspace_modes": [
        "one_off",
        "series",
        "portfolio"
      ],
      "default_project_stage_outputs_root": "artifacts/stage_outputs",
      "default_profiles": {
        "one_off": {
          "workspace_mode": "one_off",
          "project_collection_path": "projects",
          "series_capable_skeleton": true,
          "shared_resource_roots": [
            "shared/sources",
            "shared/memory",
            "shared/style_system"
          ],
          "project_stage_outputs_root": "artifacts/stage_outputs"
        },
        "rca_series": {
          "workspace_mode": "series",
          "project_collection_path": "projects",
          "shared_resource_roots": [
            "shared/sources",
            "shared/brand",
            "shared/visual_memory",
            "shared/style_system",
            "shared/material_inventory"
          ],
          "project_stage_outputs_root": "artifacts/stage_outputs"
        },
        "mas_portfolio": {
          "workspace_mode": "portfolio",
          "project_collection_path": "projects",
          "shared_resource_roots": [
            "data",
            "literature",
            "memory",
            "shared/sources"
          ],
          "project_stage_outputs_root": "artifacts/stage_outputs"
        }
      },
      "domain_profile_defaults": {
        "mas": "mas_portfolio",
        "mag": "one_off",
        "rca": "rca_series",
        "oma": "one_off"
      },
      "default_user_inspection_surface": {
        "ordinary_user_default_surface": "workspace_local_project_stage_outputs",
        "project_stage_outputs_pattern": "<project-root>/artifacts/stage_outputs/<stage-id>/",
        "runtime_state_is_default_user_surface": false,
        "product_views_are_stage_outputs": false
      },
      "runtime_state_boundary": {
        "role": "provider_backing_provenance_restore_audit",
        "runtime_state_can_be_canonical_project_root": false,
        "runtime_state_can_close_stage": false,
        "runtime_state_can_replace_owner_receipt_or_typed_blocker": false
      },
      "authority_boundary": {
        "opl_can_define_topology_contract": true,
        "opl_can_project_workspace_refs": true,
        "opl_can_write_domain_truth": false,
        "opl_can_mutate_artifact_body": false,
        "opl_can_create_owner_receipt": false,
        "opl_can_create_typed_blocker": false,
        "runtime_state_counts_as_user_default_surface": false
      },
      "workspace_initialization_policy": {
        "default_workspace_mode": "one_off",
        "infer_series_when_user_requests_multiple_related_deliverables": true,
        "infer_portfolio_when_user_requests_shared_research_workspace_with_multiple_studies": true,
        "upgrading_one_off_to_series_must_not_move_existing_project_roots": true,
        "explicit_workspace_mode_declaration_preferred": true,
        "default_project_collection_path": "projects",
        "legacy_project_collection_aliases": [
          "deliverables",
          "studies"
        ]
      },
      "example_project_layouts": {
        "one_off": {
          "project_collection_path": "projects",
          "project_root_pattern": "projects/<project-id>",
          "project_stage_outputs_pattern": "projects/<project-id>/artifacts/stage_outputs/<stage-id>/",
          "legacy_project_collection_aliases": [
            "deliverables"
          ]
        },
        "rca_series": {
          "shared_roots": [
            "shared/sources",
            "shared/brand",
            "shared/visual_memory",
            "shared/style_system",
            "shared/material_inventory"
          ],
          "project_collection_path": "projects",
          "project_root_pattern": "projects/<deck-id>",
          "project_stage_outputs_pattern": "projects/<deck-id>/artifacts/stage_outputs/<stage-id>/",
          "legacy_project_collection_aliases": [
            "deliverables"
          ]
        },
        "mas_portfolio": {
          "shared_roots": [
            "data",
            "literature",
            "memory"
          ],
          "project_collection_path": "projects",
          "project_root_pattern": "projects/<study-id>",
          "project_stage_outputs_pattern": "projects/<study-id>/artifacts/stage_outputs/<stage-id>/",
          "legacy_project_collection_aliases": [
            "studies"
          ]
        }
      }
    }
  ]
}
