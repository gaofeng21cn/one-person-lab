{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://one-person-lab.local/contracts/opl-framework/epistemic-review-scope-v2.schema.json",
  "title": "OPL Epistemic Review Scope V2",
  "type": "object",
  "required": [
    "surface_kind",
    "version",
    "scope_id",
    "scope_kind",
    "evidence_profile",
    "trust_model",
    "reviewed_node_refs",
    "nodes",
    "dependency_edges",
    "authority_boundary"
  ],
  "properties": {
    "surface_kind": { "const": "opl_epistemic_review_scope" },
    "version": { "const": "opl-epistemic-review-scope.v2" },
    "scope_id": { "type": "string", "minLength": 1 },
    "scope_kind": { "enum": ["content", "reference", "display", "package"] },
    "evidence_profile": { "const": "epistemic_provenance" },
    "trust_model": { "const": "trusted_local_workspace" },
    "reviewed_node_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "dependency_edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "hash_is_locator_or_stale_hint_only",
        "hash_is_content_authority",
        "release_integrity_is_separate",
        "framework_can_issue_domain_verdict"
      ],
      "properties": {
        "hash_is_locator_or_stale_hint_only": { "const": true },
        "hash_is_content_authority": { "const": false },
        "release_integrity_is_separate": { "const": true },
        "framework_can_issue_domain_verdict": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "node": {
      "type": "object",
      "required": ["node_ref", "node_kind", "role"],
      "properties": {
        "node_ref": { "type": "string", "minLength": 1 },
        "node_kind": { "enum": ["artifact", "claim", "provenance"] },
        "role": {
          "enum": [
            "source_data",
            "context",
            "analysis_code",
            "analysis_parameters",
            "analysis_result",
            "claim",
            "reference_source",
            "citation_linkage",
            "limitation",
            "reproduction_instruction",
            "visual_content",
            "layout",
            "render_template",
            "package_content",
            "package_wrapper",
            "governance_metadata",
            "review_receipt"
          ]
        },
        "locator": {
          "type": ["object", "null"],
          "required": ["ref"],
          "properties": {
            "ref": { "type": "string", "minLength": 1 },
            "sha256": {
              "anyOf": [
                { "$ref": "#/$defs/sha256" },
                { "type": "null" }
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["source_ref", "dependent_ref", "relation"],
      "properties": {
        "source_ref": { "type": "string", "minLength": 1 },
        "dependent_ref": { "type": "string", "minLength": 1 },
        "relation": {
          "enum": ["derived_from", "interprets", "supports", "cites", "renders", "packages", "reproduces"]
        }
      },
      "additionalProperties": false
    }
  }
}
