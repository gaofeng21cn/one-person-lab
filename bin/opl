#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$SOURCE_DIR/$LINK_TARGET"
  fi
done
ROOT_DIR="$(cd "$(dirname "$SOURCE_PATH")/.." && pwd)"

run_opl() {
  if [[ -f "$ROOT_DIR/src/entrypoints/cli.ts" ]]; then
    exec node --experimental-strip-types "$ROOT_DIR/src/entrypoints/cli.ts" "$@"
  fi

  exec node "$ROOT_DIR/dist/entrypoints/cli.js" "$@"
}

invoke_opl() {
  if [[ -f "$ROOT_DIR/src/entrypoints/cli.ts" ]]; then
    node --experimental-strip-types "$ROOT_DIR/src/entrypoints/cli.ts" "$@"
    return
  fi

  node "$ROOT_DIR/dist/entrypoints/cli.js" "$@"
}

print_framework_version() {
  node -e '
const fs = require("node:fs");
const packageJson = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
const version = typeof packageJson.version === "string" ? packageJson.version.trim() : "";
if (!version) {
  process.stderr.write("OPL Framework package.json is missing version.\n");
  process.exit(1);
}
process.stdout.write(`${version}\n`);
' "$ROOT_DIR/package.json"
}

run_codex() {
  if [[ -n "${OPL_CODEX_BIN:-}" ]]; then
    exec "$OPL_CODEX_BIN" "$@"
  fi

  exec codex "$@"
}

maybe_sync_family_skills() {
  if [[ "${OPL_SKIP_SKILL_SYNC:-}" == "1" ]]; then
    return
  fi

  invoke_opl connect sync-skills --quiet >/dev/null
}

if [[ "$#" -eq 0 ]]; then
  maybe_sync_family_skills
  run_codex
fi

case "$1" in
  --version|-V)
    print_framework_version
    ;;
  --help|-h)
    run_opl --help --text
    ;;
  exec)
    shift
    maybe_sync_family_skills
    if [[ -n "${OPL_EXECUTOR_KIND:-}" ]]; then
      run_opl exec "$@"
    fi
    for arg in "$@"; do
      if [[ "$arg" == "--executor" ]]; then
        run_opl exec "$@"
      fi
    done
    run_codex exec "$@"
    ;;
  resume)
    maybe_sync_family_skills
    run_codex "$@"
    ;;
  ask)
    shift
    run_opl ask "$@"
    ;;
  chat)
    shift
    run_opl chat "$@"
    ;;
  shell)
    shift
    run_opl shell "$@"
    ;;
  session)
    run_opl "$@"
    ;;
  okf)
    run_opl "$@"
    ;;
  help|doctor|install|start|web|mcp-stdio|app|status|update|workspace|domain|actions|agents|agent-lab|foundry-lab|feedback|work-order|domain-memory|stages|stage|stage-artifact|index|packages|contract|system|modules|module|engine|service|runtime|env|family-runtime|executor|skill|quality|framework|substrate|brand-modules|capability-pack|scholar-skills|charter|atlas|pack|stagecraft|runway|ledger|vault|console|foundry|connect|profiles|release)
    run_opl "$@"
    ;;
  *)
    if [[ "$1" == @* ]]; then
      run_opl "$@"
    fi
    maybe_sync_family_skills
    run_codex "$@"
    ;;
esac
