#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

OPL_OPTION_TOKENS=(
  --dry-run
  --goal
  --intent
  --target
  --preferred-family
  --request-kind
  --workspace-path
  --skills
  --executor
  --provider
)

run_opl() {
  if [[ -f "$ROOT_DIR/src/cli.ts" ]]; then
    exec node --experimental-strip-types "$ROOT_DIR/src/cli.ts" "$@"
  fi

  exec node "$ROOT_DIR/dist/cli.js" "$@"
}

run_codex() {
  if [[ -n "${OPL_CODEX_BIN:-}" ]]; then
    exec "$OPL_CODEX_BIN" "$@"
  fi

  exec codex "$@"
}

is_opl_option() {
  local token="$1"
  local option
  for option in "${OPL_OPTION_TOKENS[@]}"; do
    if [[ "$option" == "$token" ]]; then
      return 0
    fi
  done

  return 1
}

has_explicit_hermes_executor() {
  local args=("$@")
  local index
  for ((index = 0; index < ${#args[@]}; index += 1)); do
    if [[ "${args[index]}" == "--executor" && "${args[index + 1]:-}" == "hermes" ]]; then
      return 0
    fi
  done

  return 1
}

strip_explicit_codex_executor() {
  local args=("$@")
  local output=()
  local index

  for ((index = 0; index < ${#args[@]}; index += 1)); do
    if [[ "${args[index]}" == "--executor" && "${args[index + 1]:-}" == "codex" ]]; then
      index=$((index + 1))
      continue
    fi

    output+=("${args[index]}")
  done

  printf '%s\0' "${output[@]}"
}

first_positional_arg() {
  local args=("$@")
  local index

  for ((index = 0; index < ${#args[@]}; index += 1)); do
    if [[ "${args[index]}" != --* ]]; then
      printf '%s\n' "${args[index]}"
      return 0
    fi

    if is_opl_option "${args[index]}"; then
      index=$((index + 1))
    fi
  done

  return 1
}

should_use_opl_product_entry() {
  local args=("$@")
  local token
  for token in "${args[@]}"; do
    if is_opl_option "$token"; then
      return 0
    fi
  done

  local first_positional=""
  if first_positional="$(first_positional_arg "${args[@]}" 2>/dev/null)"; then
    [[ "$first_positional" == @* ]]
    return
  fi

  return 1
}

read_null_terminated_args() {
  local -n target_ref=$1
  shift

  target_ref=()
  while IFS= read -r -d '' entry; do
    target_ref+=("$entry")
  done < <("$@")
}

if [[ "$#" -eq 0 ]]; then
  run_codex
fi

case "$1" in
  exec)
    shift
    run_codex exec "$@"
    ;;
  resume)
    if has_explicit_hermes_executor "$@"; then
      run_opl "$@"
    fi
    stripped_args=()
    read_null_terminated_args stripped_args strip_explicit_codex_executor "$@"
    run_codex "${stripped_args[@]}"
    ;;
  ask)
    shift
    if should_use_opl_product_entry "$@"; then
      run_opl ask "$@"
    fi
    run_codex exec "$@"
    ;;
  chat)
    shift
    if should_use_opl_product_entry "$@"; then
      run_opl chat "$@"
    fi
    run_codex "$@"
    ;;
  shell)
    shift
    if [[ "$#" -eq 0 ]]; then
      run_codex
    fi
    if [[ "${1:-}" == "--resume" ]]; then
      if has_explicit_hermes_executor "$@"; then
        run_opl shell "$@"
      fi

      shift
      stripped_args=()
      read_null_terminated_args stripped_args strip_explicit_codex_executor "$@"
      run_codex resume "${stripped_args[@]}"
    fi
    if [[ "${1:-}" != "--resume" ]] && ! should_use_opl_product_entry "$@"; then
      run_codex "$@"
    fi
    run_opl shell "$@"
    ;;
  session)
    if [[ "${2:-}" == "resume" ]] && ! has_explicit_hermes_executor "${@:3}"; then
      stripped_args=()
      read_null_terminated_args stripped_args strip_explicit_codex_executor "${@:3}"
      run_codex resume "${stripped_args[@]}"
    fi
    run_opl "$@"
    ;;
  help|doctor|start|web|mcp-stdio|status|workspace|domain|contract|system|modules|module|engine|service|runtime)
    run_opl "$@"
    ;;
  *)
    if [[ "$1" == @* ]]; then
      run_opl "$@"
    fi
    run_codex "$@"
    ;;
esac
